{
    "$schema": "/resources/schemas/theme.schema.json",
    "name": "Tests Options Fixture",
    "slug": "tests-options-fixture",
    "version": "1.0.0",
    "author": "bx-Blogger Test Suite",
    "description": "Test-only theme. Exists solely so ThemeOptionsServiceSpec can exercise color / int / bool option normalization without coupling to user-facing themes. Do NOT ship — lives under tests/fixtures/ and is registered + torn down by the spec.",
    "minBxblogerVersion": "0.1.0",
    "bootstrap": "5.3",
    "supports": [],
    "options": [
        { "key": "primary_color",   "type": "color", "default": "#0d6efd", "label": "Primary Color" },
        { "key": "posts_per_page",  "type": "int",   "default": 10,        "label": "Posts Per Page" },
        { "key": "show_author_box", "type": "bool",  "default": true,      "label": "Show Author Box" },
        {
            "key":     "header_layout",
            "type":    "select",
            "default": "centered",
            "label":   "Header Layout",
            "enum": [
                { "value": "centered", "label": "Centered" },
                { "value": "left",     "label": "Left-aligned" },
                { "value": "split",    "label": "Split (logo + nav)" }
            ]
        },
        { "key": "tagline",       "type": "text",   "default": "Just another bx-Blogger site", "label": "Tagline (text canonical)" },
        { "key": "footer_credit", "type": "string", "default": "© bx-Blogger",                 "label": "Footer Credit (string alias)" },
        { "key": "hero_image",    "type": "image",  "default": 0,                              "label": "Hero Image" },
        { "key": "intro_page",    "type": "page",   "default": 0,                              "label": "Intro Page (page-type fixture)" }
    ]
}
