/**
 * Phase 1 Chunk 1.D — PasswordService smoke tests.
 *
 * Covers:
 *   - hash() produces a bcrypt-format hash
 *   - verify() round-trips the hash
 *   - verify() rejects wrong passwords and malformed hashes
 *   - needsRehash() detects lower work factors
 *   - validate() B17 policy checks (length, complexity, common-blocklist,
 *     email-prefix rejection)
 *   - generateRandom() produces passwords that pass validate()
 */
class extends="coldbox.system.testing.BaseTestCase" {

    this.appMapping = "/root";

    function beforeAll() {
        super.beforeAll();
        setup();
        variables.passwordService = getInstance( "PasswordService" );
    }

    function run() {
        describe( "PasswordService", function() {

            describe( "hash() + verify()", function() {
                it( "produces a bcrypt-format hash and verifies against it", function() {
                    var pw = "CorrectHorseBattery42!";
                    var h  = variables.passwordService.hash( pw );

                    expect( h ).toStartWith( "$2" );    // bcrypt prefix
                    expect( len( h ) ).toBe( 60 );
                    expect( variables.passwordService.verify( pw, h ) ).toBeTrue();
                } );

                it( "rejects a wrong password", function() {
                    var h = variables.passwordService.hash( "CorrectHorseBattery42!" );
                    expect( variables.passwordService.verify( "WrongHorse42!", h ) ).toBeFalse();
                } );

                it( "fails closed on a malformed hash", function() {
                    expect( variables.passwordService.verify( "whatever", "not-a-hash" ) ).toBeFalse();
                    expect( variables.passwordService.verify( "whatever", "" ) ).toBeFalse();
                } );

                it( "produces distinct hashes for the same password (unique salt)", function() {
                    var pw  = "CorrectHorseBattery42!";
                    var h1  = variables.passwordService.hash( pw );
                    var h2  = variables.passwordService.hash( pw );
                    expect( h1 ).notToBe( h2 );
                    expect( variables.passwordService.verify( pw, h1 ) ).toBeTrue();
                    expect( variables.passwordService.verify( pw, h2 ) ).toBeTrue();
                } );
            } );

            describe( "needsRehash()", function() {
                it( "returns false for current-work-factor hashes", function() {
                    var h = variables.passwordService.hash( "AnyGoodPassword42!", 12 );
                    expect( variables.passwordService.needsRehash( h, 12 ) ).toBeFalse();
                } );

                it( "returns true when stored cost is below target", function() {
                    var h = variables.passwordService.hash( "AnyGoodPassword42!", 10 );
                    expect( variables.passwordService.needsRehash( h, 12 ) ).toBeTrue();
                } );
            } );

            describe( "validate() B17 policy", function() {
                it( "accepts a strong password", function() {
                    var r = variables.passwordService.validate( "Tr0ub4dor-42!!" );
                    expect( r.valid ).toBeTrue();
                    expect( r.errors ).toBeEmpty();
                } );

                it( "rejects too-short passwords", function() {
                    var r = variables.passwordService.validate( "Sh0rt!" );
                    expect( r.valid ).toBeFalse();
                    expect( r.errors.len() ).toBeGT( 0 );
                    // At least one error should mention the length requirement
                    var hasLengthMsg = r.errors.some( function( msg ) {
                        return findNoCase( "characters", msg ) > 0;
                    } );
                    expect( hasLengthMsg ).toBeTrue();
                } );

                it( "rejects all-letters (no digit)", function() {
                    var r = variables.passwordService.validate( "LetterOnlyPasswordYes" );
                    expect( r.valid ).toBeFalse();
                } );

                it( "rejects all-digits (no letter)", function() {
                    var r = variables.passwordService.validate( "1234567890123" );
                    expect( r.valid ).toBeFalse();
                } );

                it( "rejects common-blocklist entries", function() {
                    var r = variables.passwordService.validate( "password123" );
                    expect( r.valid ).toBeFalse();
                } );

                it( "rejects passwords containing the email local-part", function() {
                    var r = variables.passwordService.validate(
                        "michaelrigsby-Password42",
                        { email: "michaelrigsby@example.com" }
                    );
                    expect( r.valid ).toBeFalse();
                } );

                it( "accepts passwords that don't contain the email local-part", function() {
                    var r = variables.passwordService.validate(
                        "AnotherGoodOne42!",
                        { email: "michaelrigsby@example.com" }
                    );
                    expect( r.valid ).toBeTrue();
                } );
            } );

            describe( "generateRandom()", function() {
                it( "produces a password of requested length", function() {
                    var pw = variables.passwordService.generateRandom( 20 );
                    expect( len( pw ) ).toBe( 20 );
                } );

                it( "always passes the policy checks", function() {
                    // Run many iterations to catch any re-roll edge cases
                    for ( var i = 1; i <= 25; i++ ) {
                        var pw = variables.passwordService.generateRandom( 16 );
                        var r  = variables.passwordService.validate( pw );
                        expect( r.valid ).toBeTrue( "generated password #pw# failed policy: #r.errors.toList()#" );
                    }
                } );
            } );

        } );
    }

}
