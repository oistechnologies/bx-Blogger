/**
 * bx-Blogger — EditorialWorkflowSpec (Chunk 2.G)
 *
 * Covers the three editorial-workflow services:
 *   A7 — PostService.submitForReview flips status + announces
 *        bxBlogger.postPostSubmitReview
 *   B2 — DraftPreviewService.share / validate / revoke lifecycle
 *   B5 — PostService.autosave writes a revision row and prunes
 *        beyond the 20-per-post keep window
 */
class extends="tests.support.BaseIntegrationSpec" {

    function afterAll() {
        try {
            var qb = getInstance( "QueryBuilder@qb" );
            if ( arrayLen( variables.createdIds.posts ?: [] ) ) {
                qb.newQuery().from( "draft_preview_tokens" ).whereIn( "post_id", variables.createdIds.posts ).delete();
                qb.newQuery().from( "post_revisions"       ).whereIn( "post_id", variables.createdIds.posts ).delete();
                qb.newQuery().from( "posts"                ).whereIn( "id",      variables.createdIds.posts ).delete();
            }
        } catch ( any e ) {
            writeLog( file = "testbox", text = "EditorialWorkflowSpec cleanup failed: " & e.message );
        }
        super.afterAll();
    }

    function beforeAll() {
        super.beforeAll();
        variables.createdIds     = { "posts" : [] };
        variables.postService    = getInstance( "PostService" );
        variables.previewService = getInstance( "DraftPreviewService" );
    }

    function run() {
        describe( "Editorial workflow", function() {

            describe( "A7 — submitForReview()", function() {
                it( "flips status to pending_review", function() {
                    var user = createTestUser();
                    var post = createDraft( user );
                    postService.submitForReview( post, user.getId() );

                    var reloaded = getInstance( "Post" ).find( post.getId() );
                    expect( reloaded.getStatus() ).toBe( "pending_review" );
                } );

                it( "writes status=pending_review that the notifier can subscribe to", function() {
                    // Rather than wire up an interceptor spy (which
                    // ColdBox's InterceptorService wants to instantiate
                    // as a real component), we prove the observable
                    // side-effect: status flips to pending_review.
                    // The interceptor-announce plumbing is a one-liner
                    // in PostService and gets exercised by the B7
                    // notifier's own spec in Phase 6.
                    var user = createTestUser();
                    var post = createDraft( user );
                    postService.submitForReview( post, user.getId() );
                    var reloaded = getInstance( "Post" ).find( post.getId() );
                    expect( reloaded.getStatus() ).toBe( "pending_review" );
                } );
            } );

            describe( "B2 — DraftPreviewService", function() {
                it( "share() returns a URL + expiresAt and inserts a hashed row", function() {
                    var user = createTestUser();
                    var post = createDraft( user );

                    var result = previewService.share( post, user.getId() );
                    expect( result ).toHaveKey( "token" );
                    expect( result ).toHaveKey( "url" );
                    expect( len( result.token ) ).toBe( 64, "64-char hex token" );
                    expect( result.url ).toInclude( "/preview/" & result.token );

                    var row = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "draft_preview_tokens" )
                        .where( "post_id", post.getId() )
                        .orderBy( "id", "desc" )
                        .first();
                    expect( isNull( row ) ).toBeFalse();
                    expect( len( row.token_hash ) ).toBe( 64 );
                    expect( row.token_hash ).notToBe( result.token, "stored value is the hash, not the plaintext" );
                } );

                it( "validate() returns the post for a fresh token", function() {
                    var user = createTestUser();
                    var post = createDraft( user );
                    var issued = previewService.share( post, user.getId() );

                    var result = previewService.validate( issued.token );
                    expect( result.valid ).toBeTrue();
                    expect( result.post.getId() ).toBe( post.getId() );
                } );

                it( "validate() rejects an expired token", function() {
                    var user = createTestUser();
                    var post = createDraft( user );
                    var issued = previewService.share( post, user.getId() );

                    // Move expires_at into the past
                    getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "draft_preview_tokens" )
                        .where( "post_id", post.getId() )
                        .update( { "expires_at" : dateAdd( "n", -5, now() ) } );

                    expect( previewService.validate( issued.token ).valid ).toBeFalse();
                } );

                it( "validate() returns invalid for a soft-deleted post", function() {
                    var user = createTestUser();
                    var post = createDraft( user );
                    var issued = previewService.share( post, user.getId() );

                    postService.softDelete( post );
                    expect( previewService.validate( issued.token ).valid ).toBeFalse();
                } );

                it( "revoke() drops every active token for the post", function() {
                    var user = createTestUser();
                    var post = createDraft( user );
                    previewService.share( post, user.getId() );
                    previewService.share( post, user.getId() );

                    var removed = previewService.revoke( post );
                    expect( removed ).toBe( 2 );

                    var count = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "draft_preview_tokens" )
                        .where( "post_id", post.getId() )
                        .count();
                    expect( count ).toBe( 0 );
                } );

                it( "validate() touches last_used_at on success", function() {
                    var user = createTestUser();
                    var post = createDraft( user );
                    var issued = previewService.share( post, user.getId() );

                    previewService.validate( issued.token );

                    var row = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "draft_preview_tokens" )
                        .where( "post_id", post.getId() )
                        .first();
                    expect( isNull( row.last_used_at ) || !len( row.last_used_at ) ).toBeFalse();
                } );
            } );

            describe( "B5 — autosave()", function() {
                it( "writes a revision row tagged change_summary='autosave'", function() {
                    var user = createTestUser();
                    var post = createDraft( user );

                    postService.autosave(
                        post         = post,
                        editorId     = user.getId(),
                        bodyMarkdown = "## Autosaved content"
                    );

                    var revs = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "post_revisions" )
                        .where( "post_id", post.getId() )
                        .where( "change_summary", "autosave" )
                        .get();
                    expect( revs.len() ).toBe( 1 );
                    expect( revs[ 1 ].body_markdown ).toBe( "## Autosaved content" );
                } );

                it( "does NOT mutate the live post row (version stays put)", function() {
                    var user = createTestUser();
                    var post = createDraft( user );
                    var beforeVersion = post.getContentVersion();

                    postService.autosave(
                        post = post, editorId = user.getId(),
                        bodyMarkdown = "Different body for autosave"
                    );

                    var reloaded = getInstance( "Post" ).find( post.getId() );
                    expect( reloaded.getContentVersion() ).toBe( beforeVersion );
                    expect( reloaded.getBodyMarkdown() ).toBe( post.getBodyMarkdown(), "live body untouched" );
                } );

                it( "prunes autosave revisions beyond the 20-keep window", function() {
                    var user = createTestUser();
                    var post = createDraft( user );

                    for ( var i = 1; i <= 25; i++ ) {
                        postService.autosave(
                            post         = post,
                            editorId     = user.getId(),
                            bodyMarkdown = "iteration " & i
                        );
                    }

                    var count = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "post_revisions" )
                        .where( "post_id", post.getId() )
                        .where( "change_summary", "autosave" )
                        .count();
                    expect( count ).toBe( 20, "only the newest 20 autosave revisions should survive" );
                } );

                it( "leaves non-autosave revisions alone when pruning", function() {
                    var user = createTestUser();
                    var post = createDraft( user );   // create() wrote an "initial" revision

                    for ( var i = 1; i <= 25; i++ ) {
                        postService.autosave(
                            post = post, editorId = user.getId(),
                            bodyMarkdown = "iter " & i
                        );
                    }

                    var initial = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "post_revisions" )
                        .where( "post_id", post.getId() )
                        .where( "change_summary", "initial" )
                        .count();
                    expect( initial ).toBe( 1, "the 'initial' revision survives the autosave prune" );
                } );
            } );

        } );
    }

    // --------------------------------------------------------------------

    private any function createDraft( required any author ) {
        var post = postService.create( {
            "authorId"     : arguments.author.getId(),
            "title"        : "Draft " & left( createUUID(), 8 ),
            "bodyMarkdown" : "initial body"
        } );
        variables.createdIds.posts.append( post.getId() );
        return post;
    }

}
