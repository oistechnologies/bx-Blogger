/**
 * bx-Blogger — OgImageServiceSpec
 *
 * End-to-end exercise of the eager OG-card generator:
 *
 *   - `urlFor(post)` renders + writes + returns a URL on first call
 *   - second call at the same `og_version` is a cache hit (no rewrite)
 *   - `regenerate(post)` bumps og_version → new disk key → fresh PNG
 *   - PNG bytes start with the PNG magic signature
 *   - Disk path encodes `{post_id}-v{og_version}.png`
 *   - SeoService integration: published post still falls through to
 *     a generated og:image absolute URL
 *
 * Files are written under the real `og` cbfs disk (Local provider
 * pointing at `/includes/public/og/`). Cleanup removes only files
 * this spec produced + sweeps any orphaned `{postId}-v*.png` whose
 * postId is no longer in `posts` (catches transients from failed
 * runs without hand-tracking every path).
 */
class extends="tests.support.BaseIntegrationSpec" {

    function beforeAll() {
        super.beforeAll();
        variables.ogSvc          = getInstance( "OgImageService" );
        variables.seoSvc         = getInstance( "SeoService" );
        variables.postSvc        = getInstance( "PostService" );
        variables.cbfs           = getInstance( "DiskService@cbfs" );
        variables.settingSvc     = getInstance( "SettingService" );
        variables.createdOgPaths = [];

        // Snapshot the current `og.*` settings so each test can flip
        // a value and the afterAll() restore writes the originals
        // back. Keys match the seed migration; absent keys read as
        // their defaults from buildRenderContext().
        variables.ogSettingKeys = [
            "og.qr_enabled",
            "og.author_photo_enabled",
            "og.logo_media_id",
            "og.color_background",
            "og.color_highlight",
            "og.color_title",
            "og.color_synopsis"
        ];
        variables.ogSettingsBackup = {};
        for ( var k in variables.ogSettingKeys ) {
            variables.ogSettingsBackup[ k ] = variables.settingSvc.get( k, "" );
        }
    }

    function afterAll() {
        try {
            var disk = variables.cbfs.get( "og" );
            for ( var p in variables.createdOgPaths ) {
                try { if ( disk.exists( p ) ) disk.delete( p ); } catch ( any e ) {}
            }
        }
        catch ( any e ) {
            writeLog( file = "testbox", text = "OgImageServiceSpec tracked cleanup failed: " & e.message );
        }

        // Restore the OG settings to whatever was there before the
        // spec started touching them. Empty value means "not seeded
        // yet"; SettingService has no "delete if not present"
        // helper but `set` with the empty string round-trips
        // safely through coerceWrite for the string-typed colors.
        try {
            for ( var k in variables.ogSettingKeys ) {
                var orig = variables.ogSettingsBackup[ k ];
                if ( !len( orig ) ) continue;
                var t = ( reFind( "^og\.color_", k ) ) ? "string"
                      : ( k == "og.logo_media_id"   ) ? "int"
                      :                                  "bool";
                variables.settingSvc.set( key = k, value = orig, type = t );
            }
        }
        catch ( any e ) {
            writeLog( file = "testbox", text = "OgImageServiceSpec settings restore failed: " & e.message );
        }

        super.afterAll();

        // Self-heal: drop any `{postId}-v*.png` whose postId is no
        // longer in posts. Catches files left behind by a failing
        // test that didn't track its path.
        try {
            var disk     = variables.cbfs.get( "og" );
            var qb       = getInstance( "QueryBuilder@qb" );
            var livePids = qb.newQuery().from( "posts" ).select( "id" ).get()
                .map( function( r ) { return r.id; } );
            var livePidSet = {};
            for ( var pid in livePids ) livePidSet[ pid ] = true;
            for ( var file in disk.files( "" ) ) {
                var m = reFind( "^([0-9]+)-v[0-9]+\.png$", file, 1, true );
                if ( m.len[ 1 ] == 0 ) continue;
                var pid = val( mid( file, m.pos[ 2 ], m.len[ 2 ] ) );
                if ( !structKeyExists( livePidSet, pid ) ) {
                    try { disk.delete( file ); } catch ( any e ) {}
                }
            }
        }
        catch ( any e ) {
            writeLog( file = "testbox", text = "OgImageServiceSpec orphan sweep failed: " & e.message );
        }
    }

    function run() {
        describe( "OgImageService", function() {

            it( "pathFor() encodes postId + og_version", function() {
                var post = makePost();
                expect( ogSvc.pathFor( post ) ).toBe( post.getId() & "-v" & val( post.getOgVersion() ?: 0 ) & ".png" );
            } );

            it( "urlFor() renders a PNG to the `og` disk on first call", function() {
                var post = makePost();
                var path = ogSvc.pathFor( post );
                trackPath( path );

                var disk = variables.cbfs.get( "og" );

                var ogUrl = ogSvc.urlFor( post );
                expect( len( ogUrl ) ).toBeGT( 0, "url non-empty" );
                expect( ogUrl contains path ).toBeTrue( "url includes cache path" );
                expect( disk.exists( path ) ).toBeTrue( "file was written" );
            } );

            it( "produces bytes that begin with the PNG magic signature", function() {
                var post = makePost();
                ogSvc.urlFor( post );
                trackPath( ogSvc.pathFor( post ) );

                var bytes = variables.cbfs.get( "og" ).getAsBinary( ogSvc.pathFor( post ) );
                expect( arrayLen( bytes ) ).toBeGTE( 8 );
                expect( bytes[ 1 ] ).toBe( -119 );  // 0x89 as signed byte
                expect( bytes[ 2 ] ).toBe( 80 );    // 'P'
                expect( bytes[ 3 ] ).toBe( 78 );    // 'N'
                expect( bytes[ 4 ] ).toBe( 71 );    // 'G'
            } );

            it( "is idempotent — a second urlFor at the same og_version is a cache hit", function() {
                var post = makePost();
                ogSvc.urlFor( post );
                trackPath( ogSvc.pathFor( post ) );

                var disk    = variables.cbfs.get( "og" );
                var path    = ogSvc.pathFor( post );
                var firstMt = disk.lastModified( path );

                sleep( 1100 );  // lastModified has ~second resolution

                ogSvc.urlFor( post );
                expect( disk.lastModified( path ) ).toBe( firstMt, "no rewrite on cache hit" );
            } );

            it( "regenerate() bumps og_version + writes a new file at the new key", function() {
                var post = makePost();
                ogSvc.urlFor( post );
                var v1Path = ogSvc.pathFor( post );
                trackPath( v1Path );

                ogSvc.regenerate( post );

                var v2Path = ogSvc.pathFor( post );
                trackPath( v2Path );
                expect( v2Path ).notToBe( v1Path, "regen produces a new key" );
                expect( variables.cbfs.get( "og" ).exists( v2Path ) ).toBeTrue( "fresh PNG at new key" );
            } );

            it( "honors `og.qr_enabled = false` — author with QR opt-in still gets a card without QR", function() {
                // Force the per-author opt-in on so this is a true
                // global-master-switch test. Then turn the global
                // off; the spec passes if the regenerate succeeds
                // (no exception, valid PNG) which proves the new
                // gating wiring doesn't crash when the master flag
                // suppresses QR draw.
                variables.settingSvc.set( "og.qr_enabled", false, "bool" );

                var post = makePost();
                post.getAuthor().setOgIncludeSocialsAndUrl( true ).save();
                ogSvc.regenerate( post );
                trackPath( ogSvc.pathFor( post ) );

                var bytes = variables.cbfs.get( "og" ).getAsBinary( ogSvc.pathFor( post ) );
                expect( arrayLen( bytes ) ).toBeGTE( 8 );
                expect( bytes[ 1 ] ).toBe( -119 );
                expect( bytes[ 2 ] ).toBe( 80 );

                // Restore for subsequent tests within this describe.
                variables.settingSvc.set( "og.qr_enabled", true, "bool" );
            } );

            it( "honors custom color settings — fully overridden palette renders without crash", function() {
                variables.settingSvc.set( "og.color_background", "##2A0033", "string" );
                variables.settingSvc.set( "og.color_highlight",  "##FF00AA", "string" );
                variables.settingSvc.set( "og.color_title",      "##FFFF00", "string" );
                variables.settingSvc.set( "og.color_synopsis",   "##CCCCCC", "string" );

                var post = makePost();
                ogSvc.regenerate( post );
                trackPath( ogSvc.pathFor( post ) );

                var bytes = variables.cbfs.get( "og" ).getAsBinary( ogSvc.pathFor( post ) );
                expect( arrayLen( bytes ) ).toBeGTE( 8 );
                expect( bytes[ 1 ] ).toBe( -119 );

                // Restore so subsequent tests render against the
                // bundled defaults (visual baseline expectations).
                variables.settingSvc.set( "og.color_background", "##1B1E2C", "string" );
                variables.settingSvc.set( "og.color_highlight",  "##00DBFF", "string" );
                variables.settingSvc.set( "og.color_title",      "##FFFFFF", "string" );
                variables.settingSvc.set( "og.color_synopsis",   "##B0B6C8", "string" );
            } );

            it( "falls back to the bundled logo when og.logo_media_id is 0 (default)", function() {
                variables.settingSvc.set( "og.logo_media_id", 0, "int" );

                var post = makePost();
                ogSvc.regenerate( post );
                trackPath( ogSvc.pathFor( post ) );

                var bytes = variables.cbfs.get( "og" ).getAsBinary( ogSvc.pathFor( post ) );
                expect( arrayLen( bytes ) ).toBeGTE( 8 );
                expect( bytes[ 1 ] ).toBe( -119 );
            } );

            it( "falls back to the bundled logo when og.logo_media_id points at a missing media row", function() {
                // 9999999 chosen so it's well outside any seeded id.
                // The drawLogo path catches the empty-result query
                // and routes to the bundled mark.
                variables.settingSvc.set( "og.logo_media_id", 9999999, "int" );

                var post = makePost();
                ogSvc.regenerate( post );
                trackPath( ogSvc.pathFor( post ) );

                var bytes = variables.cbfs.get( "og" ).getAsBinary( ogSvc.pathFor( post ) );
                expect( arrayLen( bytes ) ).toBeGTE( 8 );
                expect( bytes[ 1 ] ).toBe( -119 );

                variables.settingSvc.set( "og.logo_media_id", 0, "int" );
            } );

            it( "SeoService falls through to OgImageService.urlFor when no other og:image candidate exists", function() {
                var post = makePost();
                trackPath( ogSvc.pathFor( post ) );

                var meta = variables.seoSvc.buildForPost(
                    post       = post,
                    authorName = "Layer 5",
                    baseUrl    = "https://example.com",
                    siteName   = "Example"
                );

                expect( structKeyExists( meta.og, "image" ) ).toBeTrue();
                expect( left( meta.og.image, 8 ) ).toBe( "https://", "absolute URL" );
                expect( meta.og.image contains "/includes/public/og/" ).toBeTrue();
                expect( meta.og.image contains ogSvc.pathFor( post ) ).toBeTrue();
                expect( meta.twitter.card ).toBe( "summary_large_image" );
            } );

        } );
    }

    // --------------------------------------------------------------------
    // Fixtures
    // --------------------------------------------------------------------

    private any function makePost() {
        var author = createTestUser();
        var post   = variables.postSvc.create( {
            "authorId"     : author.getId(),
            "title"        : "OG card spec " & createUUID(),
            "slug"         : "ogsvc-" & lCase( replace( createUUID(), "-", "", "all" ) ),
            "bodyMarkdown" : "Body."
        } );
        variables.postSvc.publish( post );
        return post;
    }

    private void function trackPath( required string path ) {
        variables.createdOgPaths.append( arguments.path );
    }

}
