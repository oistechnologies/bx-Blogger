/**
 * bx-Blogger — SeoOutboundLinksSpec (SEO Phase 12)
 *
 * Validates the outbound-link health checker without firing
 * real HTTP traffic. Specifically:
 *
 *   - extractFromPost dedupes + normalizes external URLs out
 *     of an HTML body, ignoring anchors / mailto / relative paths.
 *   - recordResults UPSERTs, garbage-collects rows whose URLs
 *     are no longer in the body, and bumps last_status_change_at
 *     only when the status bucket flips.
 *   - brokenCountForPost counts 4xx/5xx/0 but not 2xx or 3xx.
 *   - OutboundLinkAuditJob.handle() with `{postId: 0}` is a
 *     valid no-op (post not found path), and the no-payload
 *     site sweep iterates the published-post set.
 *
 * `checkUrl` is exercised via a single localhost probe expected
 * to fail with status 0 — proves the network failure path
 * doesn't throw and bucketing is correct, without depending on
 * any external host being up.
 */
class extends="tests.support.BaseIntegrationSpec" {

    function beforeAll() {
        super.beforeAll();
        variables.svc        = getInstance( "OutboundLinkService" );
        variables.qb         = getInstance( "QueryBuilder@qb" );
        variables.testAuthor = createTestUser( {}, "", "author" );
    }

    function run() {
        describe( "SEO Phase 12 — outbound link health", function() {

            describe( "extractFromPost", function() {

                it( "pulls external HTML hrefs and skips internal/anchors/mailto", function() {
                    var post = makePost( bodyHtml = '
                        <p>External: <a href="https://example.com/a">A</a></p>
                        <p>Internal: <a href="/blog/foo">foo</a></p>
                        <p>Anchor:   <a href="##section">Top</a></p>
                        <p>Mailto:   <a href="mailto:hi@example.com">mail</a></p>
                        <p>Schemeless: <a href="example.org">x</a></p>
                    ' );
                    var urls = variables.svc.extractFromPost( post );
                    expect( urls.len() ).toBe( 1 );
                    expect( urls[ 1 ] ).toBe( "https://example.com/a" );
                } );

                it( "deduplicates and normalizes case + fragment", function() {
                    var post = makePost( bodyHtml = '
                        <a href="HTTPS://Example.com/path">x</a>
                        <a href="https://example.com/path##frag">y</a>
                        <a href="https://example.com/other">z</a>
                    ' );
                    var urls = variables.svc.extractFromPost( post );
                    expect( urls.len() ).toBe( 2 );
                    // Order preserved (first-seen wins).
                    expect( urls[ 1 ] ).toBe( "https://Example.com/path" );
                    expect( urls[ 2 ] ).toBe( "https://example.com/other" );
                } );

                it( "returns an empty array when the body has no external links", function() {
                    var post = makePost( bodyHtml = "<p>Just text. <a href='/internal'>internal</a></p>" );
                    expect( variables.svc.extractFromPost( post ).len() ).toBe( 0 );
                } );

            } );

            describe( "recordResults + brokenCountForPost", function() {

                it( "inserts new rows for unseen URLs and counts only 4xx/5xx/0 as broken", function() {
                    var post = makePost();
                    variables.svc.recordResults( post.getId(), [
                        { "url" : "https://ok.example.com/",   "statusCode" : 200, "errorMessage" : "", "redirectTarget" : "" },
                        { "url" : "https://gone.example.com/", "statusCode" : 404, "errorMessage" : "", "redirectTarget" : "" },
                        { "url" : "https://oops.example.com/", "statusCode" : 500, "errorMessage" : "Internal Server Error", "redirectTarget" : "" },
                        { "url" : "https://moved.example.com/","statusCode" : 301, "errorMessage" : "", "redirectTarget" : "https://new.example.com/" },
                        { "url" : "https://dead.example.com/", "statusCode" : 0,   "errorMessage" : "Connection refused", "redirectTarget" : "" }
                    ] );

                    var rows = variables.qb.newQuery().from( "outbound_links" )
                        .where( "post_id", post.getId() ).get();
                    expect( rows.len() ).toBe( 5 );

                    expect( variables.svc.brokenCountForPost( post.getId() ) ).toBe( 3 );  // 404 + 500 + 0
                } );

                it( "garbage-collects rows whose URLs no longer appear in the recorded set", function() {
                    var post = makePost();
                    variables.svc.recordResults( post.getId(), [
                        { "url" : "https://a.example/", "statusCode" : 200, "errorMessage" : "", "redirectTarget" : "" },
                        { "url" : "https://b.example/", "statusCode" : 200, "errorMessage" : "", "redirectTarget" : "" }
                    ] );
                    expect( countRows( post.getId() ) ).toBe( 2 );

                    // Re-record without 'b' — it should be dropped.
                    variables.svc.recordResults( post.getId(), [
                        { "url" : "https://a.example/", "statusCode" : 200, "errorMessage" : "", "redirectTarget" : "" }
                    ] );
                    expect( countRows( post.getId() ) ).toBe( 1 );

                    // And an empty pass wipes the row entirely.
                    variables.svc.recordResults( post.getId(), [] );
                    expect( countRows( post.getId() ) ).toBe( 0 );
                } );

                it( "bumps last_status_change_at only when the bucket flips", function() {
                    var post = makePost();
                    variables.svc.recordResults( post.getId(), [
                        { "url" : "https://x.example/", "statusCode" : 200, "errorMessage" : "", "redirectTarget" : "" }
                    ] );
                    var initial = variables.qb.newQuery().from( "outbound_links" )
                        .where( "post_id", post.getId() )
                        .first();
                    var firstChangeAt = initial.last_status_change_at;
                    expect( isDate( firstChangeAt ) ).toBeTrue();

                    // Same bucket (200 → 204 both 2xx). Should NOT bump.
                    sleep( 1100 );  // ensure the 1-sec timestamp granularity registers IF a write happens
                    variables.svc.recordResults( post.getId(), [
                        { "url" : "https://x.example/", "statusCode" : 204, "errorMessage" : "", "redirectTarget" : "" }
                    ] );
                    var same = variables.qb.newQuery().from( "outbound_links" )
                        .where( "post_id", post.getId() ).first();
                    expect( same.last_status_change_at ).toBe( firstChangeAt );

                    // Bucket change (2xx → 4xx). Should bump.
                    sleep( 1100 );
                    variables.svc.recordResults( post.getId(), [
                        { "url" : "https://x.example/", "statusCode" : 404, "errorMessage" : "", "redirectTarget" : "" }
                    ] );
                    var flipped = variables.qb.newQuery().from( "outbound_links" )
                        .where( "post_id", post.getId() ).first();
                    expect( flipped.last_status_change_at ).notToBe( firstChangeAt );
                } );

            } );

            describe( "OutboundLinkAuditJob.handle()", function() {

                it( "no-ops gracefully when postId points to a missing post", function() {
                    var job = getInstance( "OutboundLinkAuditJob" );
                    job.setProperties( { "postId" : 9999999 } );
                    var threw = false;
                    try { job.handle(); }
                    catch ( any e ) { threw = true; }
                    expect( threw ).toBeFalse();
                } );

            } );

            describe( "checkUrl network-failure bucketing (no external host)", function() {

                it( "records statusCode=0 with a non-empty errorMessage on connection failure", function() {
                    // Port 1 on localhost is reserved tcpmux + virtually
                    // nothing listens there, so this is a deterministic
                    // "connection refused" probe without depending on
                    // any external host.
                    var probe = variables.svc.checkUrl( "http://127.0.0.1:1/" );
                    expect( probe.statusCode ).toBe( 0 );
                    expect( len( probe.errorMessage ) gt 0 ).toBeTrue();
                } );

            } );

        } );
    }

    // ------------------------------------------------------------------------
    // helpers
    // ------------------------------------------------------------------------

    private numeric function countRows( required numeric postId ) {
        return val( variables.qb.newQuery().from( "outbound_links" )
            .where( "post_id", arguments.postId )
            .selectRaw( "COUNT(*) AS n" )
            .first().n ?: 0 );
    }

    private any function makePost( string bodyHtml = "" ) {
        var post = getInstance( "PostService" ).create( {
            "authorId"     : variables.testAuthor.getId(),
            "title"        : "Phase 12 post " & createUUID(),
            "bodyMarkdown" : "body"
        } );
        if ( len( arguments.bodyHtml ) ) {
            // PostService.create only stores markdown + auto-renders body_html
            // on save; we want a controlled fixture for the URL extraction
            // tests, so write directly.
            variables.qb.newQuery().from( "posts" )
                .where( "id", post.getId() )
                .update( { "body_html" : arguments.bodyHtml } );
            post.refresh();
        }
        return post;
    }

}
