/**
 * bx-Blogger — OgImageJobSpec
 *
 * Verifies the per-post OG render job that PostService dispatches
 * after every save:
 *
 *   - dispatched synchronously (`onConnection("sync")`) it bumps
 *     og_version + leaves a PNG on the `og` disk
 *   - second dispatch produces a new file at the next og_version key
 *   - dispatch with a missing post id is a clean no-op (warns and
 *     returns) — covers the race where a post is deleted between
 *     dispatch + run
 *   - dispatch with a malformed payload throws so cbq can retry
 */
class extends="tests.support.BaseIntegrationSpec" {

    function beforeAll() {
        super.beforeAll();
        variables.ogSvc          = getInstance( "OgImageService" );
        variables.postSvc        = getInstance( "PostService" );
        variables.cbfs           = getInstance( "DiskService@cbfs" );
        variables.createdOgPaths = [];
    }

    function afterAll() {
        try {
            var disk = variables.cbfs.get( "og" );
            for ( var p in variables.createdOgPaths ) {
                try { if ( disk.exists( p ) ) disk.delete( p ); } catch ( any e ) {}
            }
            getInstance( "QueryBuilder@qb" ).newQuery()
                .from( "cbq_jobs" ).where( "queue", "default" ).delete();
        }
        catch ( any e ) {}

        super.afterAll();

        // Self-heal: drop any orphaned `{postId}-v*.png` whose postId
        // is no longer in posts. Catches transients from earlier
        // failed runs without hand-tracking every key.
        try {
            var disk     = variables.cbfs.get( "og" );
            var qb       = getInstance( "QueryBuilder@qb" );
            var livePids = qb.newQuery().from( "posts" ).select( "id" ).get()
                .map( function( r ) { return r.id; } );
            var livePidSet = {};
            for ( var pid in livePids ) livePidSet[ pid ] = true;
            for ( var file in disk.files( "" ) ) {
                var m = reFind( "^([0-9]+)-v[0-9]+\.png$", file, 1, true );
                if ( m.len[ 1 ] == 0 ) continue;
                var pid = val( mid( file, m.pos[ 2 ], m.len[ 2 ] ) );
                if ( !structKeyExists( livePidSet, pid ) ) {
                    try { disk.delete( file ); } catch ( any e ) {}
                }
            }
        }
        catch ( any e ) {}
    }

    function run() {
        describe( "OgImageJob", function() {

            it( "synchronous dispatch bumps og_version + writes the PNG", function() {
                var post = makePost();
                var startVersion = val( post.getOgVersion() ?: 0 );

                getInstance( "OgImageJob" )
                    .onConnection( "sync" )
                    .setProperties( { "postId" : int( post.getId() ) } )
                    .dispatch();

                var refetched = getInstance( "Post" ).findOrFail( post.getId() );
                expect( val( refetched.getOgVersion() ?: 0 ) ).toBe( startVersion + 1 );

                var path = variables.ogSvc.pathFor( refetched );
                trackPath( path );
                expect( variables.cbfs.get( "og" ).exists( path ) ).toBeTrue();
            } );

            it( "second sync dispatch lands at a new og_version key", function() {
                var post = makePost();

                getInstance( "OgImageJob" ).onConnection( "sync" )
                    .setProperties( { "postId" : int( post.getId() ) } ).dispatch();

                var first = getInstance( "Post" ).findOrFail( post.getId() );
                var firstPath = variables.ogSvc.pathFor( first );
                trackPath( firstPath );

                getInstance( "OgImageJob" ).onConnection( "sync" )
                    .setProperties( { "postId" : int( post.getId() ) } ).dispatch();

                var second = getInstance( "Post" ).findOrFail( post.getId() );
                var secondPath = variables.ogSvc.pathFor( second );
                trackPath( secondPath );

                expect( secondPath ).notToBe( firstPath );
                expect( variables.cbfs.get( "og" ).exists( secondPath ) ).toBeTrue();
            } );

            it( "no-ops when the post no longer exists", function() {
                // Pick an id we KNOW isn't in the table.
                var ghostId = 999999999;
                getInstance( "OgImageJob" ).onConnection( "sync" )
                    .setProperties( { "postId" : ghostId } ).dispatch();
                // Reaching this assertion = no exception thrown.
                expect( true ).toBeTrue();
            } );

            it( "throws on malformed payload (missing/zero postId)", function() {
                expect( function() {
                    getInstance( "OgImageJob" ).onConnection( "sync" )
                        .setProperties( { "postId" : 0 } ).dispatch();
                } ).toThrow( "bxBlogger.OgImageJob.MalformedPayload" );
            } );

        } );
    }

    private any function makePost() {
        var author = createTestUser();
        var post   = variables.postSvc.create( {
            "authorId"     : author.getId(),
            "title"        : "OG job spec " & createUUID(),
            "slug"         : "ogjob-" & lCase( replace( createUUID(), "-", "", "all" ) ),
            "bodyMarkdown" : "Body."
        } );

        // PostService.create() dispatches an OgImageJob to the default
        // (async) cbq queue. Drain it before we snapshot og_version,
        // otherwise the async bump can land BETWEEN our reset and the
        // spec's own sync dispatch — pushing og_version from 0 → 1 → 2
        // and tripping the "Expected 1, received 2" assertion. Cheap
        // poll on cbq_jobs is fine here (test-only path, low volume).
        drainCbqJobs();

        // Now reset og_version + re-fetch so the returned entity
        // reflects what's actually in the DB.
        post.setOgVersion( 0 );
        post.save();
        return getInstance( "Post" ).findOrFail( post.getId() );
    }

    /**
     * Wait for the cbq queue to drain (no pending or in-flight jobs).
     * Returns when the queue is empty, or after 5s — whichever comes
     * first. The 5s ceiling guards against a wedged worker hanging
     * the spec; in practice a single OgImageJob completes in <500ms.
     */
    private void function drainCbqJobs() {
        var qb       = getInstance( "QueryBuilder@qb" );
        var deadline = getTickCount() + 5000;
        while ( getTickCount() < deadline ) {
            var pending = qb.newQuery().from( "cbq_jobs" )
                .whereNull( "completedDate" )
                .whereNull( "failedDate" )
                .count();
            if ( pending == 0 ) return;
            sleep( 50 );
        }
    }

    private void function trackPath( required string path ) {
        variables.createdOgPaths.append( arguments.path );
    }

}
