/**
 * bx-Blogger — WebpConvertJobSpec (Phase 6.F)
 *
 * Covers the cwebp-backed WebP conversion path. Reuses the JPG
 * fixture committed for the thumbnail spec (same
 * tests/fixtures/media/landscape-1600x1000.jpg) so no new
 * binary fixtures land.
 *
 * What's asserted:
 *   - MalformedPayload on missing mediaId.
 *   - Non-image rows no-op without touching the disk.
 *   - Image rows: a `.webp` sibling lands on the cbfs disk for
 *     the original AND each pre-existing thumbnail; the updated
 *     `thumbnails_json` carries `original_webp.path` + a `webp`
 *     sub-key on every existing sized entry.
 *   - `media/webp` mime rows are detected as already-webp and
 *     short-circuit.
 */
class extends="tests.support.BaseIntegrationSpec" {

    variables.fixtureRel = "tests/fixtures/media/landscape-1600x1000.jpg";

    function beforeAll() {
        super.beforeAll();
        variables.cbfs     = getInstance( "DiskService@cbfs" );
        variables.disk     = cbfs.get( "media" );
        variables.srcImage = expandPath( "/" & variables.fixtureRel );
    }

    function afterAll() {
        try {
            getInstance( "QueryBuilder@qb" ).newQuery()
                .from( "cbq_jobs" ).where( "queue", "default" ).delete();
        }
        catch ( any e ) {}
        super.afterAll();
    }

    function run() {
        describe( "WebpConvertJob", function() {

            it( "throws MalformedPayload when mediaId is missing", function() {
                var job = getInstance( "WebpConvertJob" );
                job.setProperties( {} );

                var threw = false;
                try { job.handle(); }
                catch ( bxBlogger.WebpConvertJob.MalformedPayload e ) { threw = true; }
                expect( threw ).toBeTrue();
            } );

            it( "no-ops on a non-image mime type", function() {
                var user = createTestUser();
                var media = getInstance( "Media" ).create( {
                    "uploaderId"       : user.getId(),
                    "disk"             : "media",
                    "path"             : "test/notes-" & createUUID() & ".txt",
                    "filename"         : "notes.txt",
                    "originalFilename" : "notes.txt",
                    "mimeType"         : "text/plain",
                    "sizeBytes"        : 42,
                    "hash"             : lCase( hash( "notes" & createUUID(), "SHA-256" ) )
                } );

                getInstance( "WebpConvertJob" )
                    .onConnection( "sync" )
                    .setProperties( { "mediaId" : media.getId() } )
                    .dispatch();

                var row = getInstance( "QueryBuilder@qb" ).newQuery()
                    .from( "media" ).where( "id", media.getId() ).first();
                expect( len( row.thumbnails_json ?: "" ) ).toBe( 0 );
            } );

            it( "no-ops on a row that's already image/webp", function() {
                var user = createTestUser();
                var media = getInstance( "Media" ).create( {
                    "uploaderId"       : user.getId(),
                    "disk"             : "media",
                    "path"             : "test/already-" & createUUID() & ".webp",
                    "filename"         : "already.webp",
                    "originalFilename" : "already.webp",
                    "mimeType"         : "image/webp",
                    "altText"          : "already webp",
                    "sizeBytes"        : 42,
                    "hash"             : lCase( hash( "webp" & createUUID(), "SHA-256" ) )
                } );

                getInstance( "WebpConvertJob" )
                    .onConnection( "sync" )
                    .setProperties( { "mediaId" : media.getId() } )
                    .dispatch();

                // No thumbnails_json changes, no side-effects.
                var row = getInstance( "QueryBuilder@qb" ).newQuery()
                    .from( "media" ).where( "id", media.getId() ).first();
                expect( len( row.thumbnails_json ?: "" ) ).toBe( 0 );
            } );

            it( "produces .webp siblings for original + every existing thumbnail", function() {
                // Upload a real image. upload() dispatches both
                // GenerateThumbnails (async via DBProvider) and —
                // through the postThumbnailGenerate interceptor — the
                // WebpConvertJob. For test determinism we re-dispatch
                // each job on the sync connection so the assertions
                // land without polling.
                var user = createTestUser();
                var media = getInstance( "MediaService" ).upload(
                    tmpPath          = variables.srcImage,
                    originalFilename = "webp-spec.jpg",
                    mimeType         = "image/jpeg",
                    sizeBytes        = getFileInfo( variables.srcImage ).size,
                    uploaderId       = user.getId(),
                    altText          = "webp spec image"
                );

                // Run thumbnails inline so thumbnails_json is populated
                // before the WebP job reads it.
                getInstance( "GenerateThumbnailsJob" )
                    .onConnection( "sync" )
                    .setProperties( { "mediaId" : media.getId() } )
                    .dispatch();

                getInstance( "WebpConvertJob" )
                    .onConnection( "sync" )
                    .setProperties( { "mediaId" : media.getId() } )
                    .dispatch();

                var row = getInstance( "QueryBuilder@qb" ).newQuery()
                    .from( "media" ).where( "id", media.getId() ).first();
                var thumbs = jsonDeserialize( row.thumbnails_json );

                expect( thumbs ).toHaveKey( "original_webp" );
                expect( variables.disk.exists( thumbs.original_webp.path ) ).toBeTrue(
                    "original .webp present on disk"
                );

                // Every declared size should have a .webp sibling
                // present both in thumbnails_json and on disk.
                for ( var sizeName in [ "thumb", "small", "medium", "large" ] ) {
                    expect( thumbs ).toHaveKey( sizeName );
                    expect( thumbs[ sizeName ] ).toHaveKey( "webp" );
                    expect( variables.disk.exists( thumbs[ sizeName ].webp ) ).toBeTrue(
                        "webp variant of '" & sizeName & "' present on disk"
                    );
                }
            } );

        } );
    }

}
