/**
 * bx-Blogger — FeedServiceSpec (Chunk 3.E)
 *
 * Validates the RSS 2.0 output for all four feed scopes:
 *   - site       (latest published posts)
 *   - category   (posts in a category)
 *   - tag        (posts with a tag)
 *   - author     (posts by an author)
 *
 * We don't parse the XML end-to-end — the hand-rolled generator is
 * simple enough that string-contains assertions give us confidence
 * without pulling in a heavier XML-diff dependency.
 */
class extends="tests.support.BaseIntegrationSpec" {

    function afterAll() {
        try {
            var qb = getInstance( "QueryBuilder@qb" );
            if ( arrayLen( variables.createdIds.posts ?: [] ) ) {
                qb.newQuery().from( "post_revisions"  ).whereIn( "post_id", variables.createdIds.posts ).delete();
                qb.newQuery().from( "post_categories" ).whereIn( "post_id", variables.createdIds.posts ).delete();
                qb.newQuery().from( "post_tags"       ).whereIn( "post_id", variables.createdIds.posts ).delete();
                qb.newQuery().from( "posts"           ).whereIn( "id", variables.createdIds.posts ).delete();
            }
            if ( arrayLen( variables.createdIds.categories ?: [] ) ) {
                qb.newQuery().from( "post_categories" ).whereIn( "category_id", variables.createdIds.categories ).delete();
                qb.newQuery().from( "categories"      ).whereIn( "id", variables.createdIds.categories ).delete();
            }
            if ( arrayLen( variables.createdIds.tags ?: [] ) ) {
                qb.newQuery().from( "post_tags" ).whereIn( "tag_id", variables.createdIds.tags ).delete();
                qb.newQuery().from( "tags"      ).whereIn( "id", variables.createdIds.tags ).delete();
            }
        }
        catch ( any e ) {
            writeLog( file = "testbox", text = "FeedServiceSpec cleanup failed: " & e.message );
        }
        super.afterAll();
    }

    function beforeAll() {
        super.beforeAll();
        variables.createdIds = { "posts" : [], "categories" : [], "tags" : [] };
        variables.svc        = getInstance( "FeedService" );
        variables.postSvc    = getInstance( "PostService" );
    }

    function run() {
        describe( "FeedService", function() {

            describe( "siteFeed()", function() {
                it( "emits a valid RSS 2.0 envelope with channel metadata", function() {
                    var xml = svc.siteFeed( baseUrl = "https://example.test" );
                    expect( xml ).toInclude( '<?xml version="1.0" encoding="UTF-8"?>' );
                    expect( xml ).toInclude( '<rss version="2.0"' );
                    expect( xml ).toInclude( "<channel>" );
                    expect( xml ).toInclude( "<link>https://example.test</link>" );
                    expect( xml ).toInclude( 'rel="self"' );
                    expect( xml ).toInclude( "<lastBuildDate>" );
                } );

                it( "includes published posts as <item> entries with absolute links", function() {
                    var author = createTestUser();
                    var p      = publishNew( author, "Feed item post" );

                    var xml = svc.siteFeed( baseUrl = "https://example.test" );
                    expect( xml ).toInclude( "<title>Feed item post</title>" );
                    expect( xml ).toInclude( "https://example.test/blog/" & p.getSlug() );
                } );

                it( "caps at the configured limit", function() {
                    var author = createTestUser();
                    for ( var i = 1; i <= 3; i++ ) publishNew( author, "Cap post " & i );

                    var xml   = svc.siteFeed( baseUrl = "https://example.test", limit = 2 );
                    var count = arrayLen( reMatch( "<item>", xml ) );
                    expect( count ).toBe( 2 );
                } );
            } );

            describe( "categoryFeed()", function() {
                it( "only returns posts in the category + titles the channel after it", function() {
                    var author = createTestUser();
                    var cat    = createCategory( "fc-" & left( createUUID(), 6 ) );

                    var inside  = publishNew( author, "In cat" );
                    attachCategory( inside, cat );
                    var outside = publishNew( author, "Out of cat" );

                    var xml = svc.categoryFeed( category = cat, baseUrl = "https://example.test" );
                    expect( xml ).toInclude( "In cat" );
                    expect( xml ).notToInclude( "Out of cat" );
                    expect( xml ).toInclude( "/category/" & cat.getSlug() & "/feed.xml" );
                } );
            } );

            describe( "tagFeed()", function() {
                it( "only returns posts with the tag", function() {
                    var author = createTestUser();
                    var tag    = createTag( "ft-" & left( createUUID(), 6 ) );

                    var tagged = publishNew( author, "Tagged" );
                    attachTag( tagged, tag );
                    var untagged = publishNew( author, "Untagged" );

                    var xml = svc.tagFeed( tag = tag, baseUrl = "https://example.test" );
                    expect( xml ).toInclude( "Tagged" );
                    expect( xml ).notToInclude( "Untagged" );
                } );
            } );

            describe( "authorFeed()", function() {
                it( "only returns posts by that author", function() {
                    var mine   = createTestUser();
                    var theirs = createTestUser();
                    var myP    = publishNew( mine,   "Mine feed" );
                    var theirP = publishNew( theirs, "Theirs feed" );

                    var xml = svc.authorFeed( author = mine, baseUrl = "https://example.test" );
                    expect( xml ).toInclude( "Mine feed" );
                    expect( xml ).notToInclude( "Theirs feed" );
                } );
            } );

        } );
    }

    // --------------------------------------------------------------------

    private any function publishNew( required any author, required string title, any publishedAt = now() ) {
        var post = postSvc.create( {
            "authorId"    : arguments.author.getId(),
            "title"       : arguments.title,
            "slug"        : "feed-" & left( createUUID(), 12 ),
            "bodyMarkdown": "body for " & arguments.title
        } );
        trackPost( post );

        getInstance( "QueryBuilder@qb" ).newQuery()
            .from( "posts" )
            .where( "id", post.getId() )
            .update( {
                "status"       : "published",
                "published_at" : dateTimeFormat( arguments.publishedAt, "yyyy-mm-dd HH:nn:ss" )
            } );

        return getInstance( "Post" ).find( post.getId() );
    }

    private any function trackPost( required any post ) {
        variables.createdIds.posts.append( arguments.post.getId() );
        return arguments.post;
    }

    private any function createCategory( required string slug ) {
        var now = dateTimeFormat( now(), "yyyy-mm-dd HH:nn:ss" );
        getInstance( "QueryBuilder@qb" ).newQuery().from( "categories" ).insert( {
            "slug"       : arguments.slug,
            "name"       : arguments.slug,
            "path"       : arguments.slug,
            "created_at" : now,
            "updated_at" : now
        } );
        var cat = getInstance( "Category" ).where( "slug", arguments.slug ).first();
        variables.createdIds.categories.append( cat.getId() );
        return cat;
    }

    private void function attachCategory( required any post, required any cat ) {
        getInstance( "QueryBuilder@qb" ).newQuery().from( "post_categories" ).insert( {
            "post_id"     : arguments.post.getId(),
            "category_id" : arguments.cat.getId()
        } );
    }

    private any function createTag( required string slug ) {
        var now = dateTimeFormat( now(), "yyyy-mm-dd HH:nn:ss" );
        getInstance( "QueryBuilder@qb" ).newQuery().from( "tags" ).insert( {
            "slug"       : arguments.slug,
            "name"       : arguments.slug,
            "created_at" : now,
            "updated_at" : now
        } );
        var tag = getInstance( "Tag" ).where( "slug", arguments.slug ).first();
        variables.createdIds.tags.append( tag.getId() );
        return tag;
    }

    private void function attachTag( required any post, required any tag ) {
        getInstance( "QueryBuilder@qb" ).newQuery().from( "post_tags" ).insert( {
            "post_id" : arguments.post.getId(),
            "tag_id"  : arguments.tag.getId()
        } );
    }

}
