/**
 * bx-Blogger — NotificationServiceSpec (Phase 6.C)
 *
 * Covers the core write + read + cache-invalidation paths:
 *   - notify() writes a row with the expected shape and announces
 *     `bxBlogger.notificationCreated`
 *   - notifyAllAdmins() fans out one row per active admin-role user
 *   - unreadCountFor() reflects recent writes + is busted on write
 *   - listFor() returns newest-first + respects includeRead flag
 *   - markRead / markAllReadFor clear rows from the unread count
 *   - delete ownership — markRead() on someone else's row is a
 *     silent no-op
 */
class extends="tests.support.BaseIntegrationSpec" {

    function beforeAll() {
        super.beforeAll();
        variables.svc = getInstance( "NotificationService" );
    }

    function afterAll() {
        // Notification rows that might have survived a failing test.
        // FK cascade wipes them when the user drops, but the user may
        // have been created in a prior spec and the boundary sweep
        // can run in a race we don't want to chase.
        try {
            getInstance( "QueryBuilder@qb" ).newQuery()
                .from( "notifications" )
                .where( "type", "like", "test.%" )
                .delete();
        }
        catch ( any e ) {
            writeLog( file = "testbox", text = "NotificationServiceSpec cleanup failed: " & e.message );
        }
        super.afterAll();
    }

    function run() {
        describe( "NotificationService", function() {

            describe( "notify()", function() {
                it( "writes a row and returns its id", function() {
                    var user = createTestUser();
                    var id = svc.notify(
                        userId   = user.getId(),
                        type     = "test.basic",
                        title    = "Hello",
                        body     = "Body text",
                        link     = "/admin/somewhere",
                        severity = "info"
                    );
                    expect( id ).toBeNumeric();
                    expect( id ).toBeGT( 0 );

                    var row = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "notifications" )
                        .where( "id", id )
                        .first();
                    expect( row.title ).toBe( "Hello" );
                    expect( row.body  ).toBe( "Body text" );
                    expect( row.link  ).toBe( "/admin/somewhere" );
                    expect( row.severity ).toBe( "info" );
                    expect( row.user_id ).toBe( user.getId() );
                    expect( row.read_at ?: "" ).toBe( "", "new rows are unread" );
                } );

                it( "coerces unknown severity to 'info'", function() {
                    var user = createTestUser();
                    var id = svc.notify(
                        userId   = user.getId(),
                        type     = "test.badsev",
                        title    = "Nope",
                        severity = "critical"
                    );
                    var row = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "notifications" ).where( "id", id ).first();
                    expect( row.severity ).toBe( "info" );
                } );

                it( "PostService.publish() fires a 'post_published' row for the author", function() {
                    // End-to-end proof that PostService's direct call
                    // to NotificationService is wired: publish a post
                    // via the real service and verify a notification
                    // row appears for its author with the expected
                    // type + link. (Direct-call rather than interceptor
                    // — see the comment in PostService.publish for the
                    // ColdBox auto-wire / dot-prefix constraint that
                    // forced this.)
                    var author = createTestUser();
                    var postService = getInstance( "PostService" );
                    var post = postService.create( {
                        "authorId"     : author.getId(),
                        "title"        : "Hello cbq notifications",
                        "slug"         : "hello-cbq-notifications-" & lCase( replace( createUUID(), "-", "", "all" ) ),
                        "bodyMarkdown" : "Hello world."
                    } );
                    postService.publish( post );

                    var row = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "notifications" )
                        .where( "user_id", author.getId() )
                        .where( "type", "post_published" )
                        .orderBy( "id", "desc" )
                        .first();
                    expect( isNull( row ) ).toBeFalse( "publish triggered a notification row" );
                    expect( row.title ).toBe( "Your post is live" );
                    expect( row.link contains "id=" & post.getId() ).toBeTrue();
                    expect( row.severity ).toBe( "info" );
                } );
            } );

            describe( "notifyAllAdmins()", function() {
                it( "writes one row per active admin-role user", function() {
                    // The seeded super_admin from onAppInit counts; add
                    // another admin so we can assert >1.
                    var extraAdmin = createTestUser( roleSlug = "admin" );

                    var ids = svc.notifyAllAdmins(
                        type  = "test.fanout",
                        title = "Alert for every admin"
                    );
                    expect( ids.len() ).toBeGTE( 2, "at least super_admin seed + our test admin" );

                    var rows = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "notifications" )
                        .where( "type", "test.fanout" )
                        .get();
                    expect( rows.len() ).toBe( ids.len() );
                } );
            } );

            describe( "unreadCountFor() + markRead()", function() {
                it( "counts only unread rows, drops on markRead", function() {
                    var user = createTestUser();
                    var idA = svc.notify( userId = user.getId(), type = "test.count.a", title = "A" );
                    var idB = svc.notify( userId = user.getId(), type = "test.count.b", title = "B" );

                    expect( svc.unreadCountFor( user.getId() ) ).toBe( 2 );

                    svc.markRead( notificationId = idA, userId = user.getId() );
                    expect( svc.unreadCountFor( user.getId() ) ).toBe( 1 );

                    svc.markAllReadFor( user.getId() );
                    expect( svc.unreadCountFor( user.getId() ) ).toBe( 0 );
                } );

                it( "markRead silently no-ops when the row belongs to someone else", function() {
                    var owner   = createTestUser();
                    var intruder = createTestUser();
                    var id = svc.notify( userId = owner.getId(), type = "test.owner", title = "Mine" );

                    svc.markRead( notificationId = id, userId = intruder.getId() );

                    // The owner's unread count should not have changed.
                    expect( svc.unreadCountFor( owner.getId() ) ).toBe( 1 );
                    expect( svc.unreadCountFor( intruder.getId() ) ).toBe( 0 );
                } );
            } );

            describe( "listFor()", function() {
                it( "returns newest-first, unread-only by default, limit honored", function() {
                    var user = createTestUser();
                    svc.notify( userId = user.getId(), type = "test.list.1", title = "first" );
                    svc.notify( userId = user.getId(), type = "test.list.2", title = "second" );
                    var idThird = svc.notify( userId = user.getId(), type = "test.list.3", title = "third" );

                    // Mark one read — it should disappear from the default list.
                    svc.markRead( notificationId = idThird, userId = user.getId() );

                    var list = svc.listFor( userId = user.getId(), limit = 5 );
                    expect( list.len() ).toBe( 2 );
                    expect( list[ 1 ].title ).toBe( "second", "newest unread first" );

                    var withRead = svc.listFor( userId = user.getId(), limit = 5, includeRead = true );
                    expect( withRead.len() ).toBe( 3 );
                } );
            } );

            describe( "searchFor() — admin manager queries", function() {
                it( "paginates results and reports totals", function() {
                    var user = createTestUser();
                    for ( var i = 1; i lte 7; i++ ) {
                        svc.notify( userId = user.getId(), type = "test.page", title = "Item " & i );
                    }
                    var p1 = svc.searchFor( userId = user.getId(), perPage = 3, page = 1 );
                    expect( p1.total ).toBe( 7 );
                    expect( p1.totalPages ).toBe( 3 );
                    expect( p1.rows.len() ).toBe( 3 );
                    expect( p1.page ).toBe( 1 );

                    var p3 = svc.searchFor( userId = user.getId(), perPage = 3, page = 3 );
                    expect( p3.rows.len() ).toBe( 1 );
                } );

                it( "filters by status (read vs unread)", function() {
                    var user = createTestUser();
                    var a = svc.notify( userId = user.getId(), type = "test.f", title = "alpha" );
                    var b = svc.notify( userId = user.getId(), type = "test.f", title = "beta" );
                    svc.markRead( notificationId = a, userId = user.getId() );

                    var unreadOnly = svc.searchFor( userId = user.getId(), status = "unread" );
                    expect( unreadOnly.total ).toBe( 1 );
                    expect( unreadOnly.rows[ 1 ].title ).toBe( "beta" );

                    var readOnly = svc.searchFor( userId = user.getId(), status = "read" );
                    expect( readOnly.total ).toBe( 1 );
                    expect( readOnly.rows[ 1 ].title ).toBe( "alpha" );
                } );

                it( "filters by severity + searches title/body substring", function() {
                    var user = createTestUser();
                    svc.notify( userId = user.getId(), type = "test.s", title = "Login warning",
                                body = "an unknown device", severity = "warning" );
                    svc.notify( userId = user.getId(), type = "test.s", title = "Routine info",
                                body = "nothing to see here", severity = "info" );

                    var warns = svc.searchFor( userId = user.getId(), severity = "warning" );
                    expect( warns.total ).toBe( 1 );
                    expect( warns.rows[ 1 ].title ).toBe( "Login warning" );

                    var bySearch = svc.searchFor( userId = user.getId(), search = "unknown device" );
                    expect( bySearch.total ).toBe( 1 );
                    expect( bySearch.rows[ 1 ].title ).toBe( "Login warning" );
                } );

                it( "respects sort order (oldest / newest / unread_first)", function() {
                    var user = createTestUser();
                    var a = svc.notify( userId = user.getId(), type = "test.o", title = "first" );
                    var b = svc.notify( userId = user.getId(), type = "test.o", title = "second" );
                    var c = svc.notify( userId = user.getId(), type = "test.o", title = "third" );
                    svc.markRead( notificationId = a, userId = user.getId() );

                    var oldest = svc.searchFor( userId = user.getId(), sortBy = "oldest" );
                    expect( oldest.rows[ 1 ].title ).toBe( "first" );

                    var newest = svc.searchFor( userId = user.getId(), sortBy = "newest" );
                    expect( newest.rows[ 1 ].title ).toBe( "third" );

                    var unreadFirst = svc.searchFor( userId = user.getId(), sortBy = "unread_first" );
                    // The two unread (third, second) must come before the read one (first).
                    expect( unreadFirst.rows[ 1 ].title ).toBe( "third" );
                    expect( unreadFirst.rows[ 2 ].title ).toBe( "second" );
                    expect( unreadFirst.rows[ 3 ].title ).toBe( "first" );
                } );
            } );

            describe( "bulk operations", function() {
                it( "markMultipleReadFor marks only listed ids and only for the owner", function() {
                    var owner    = createTestUser();
                    var intruder = createTestUser();
                    var a = svc.notify( userId = owner.getId(),    type = "test.b", title = "a" );
                    var b = svc.notify( userId = owner.getId(),    type = "test.b", title = "b" );
                    var c = svc.notify( userId = owner.getId(),    type = "test.b", title = "c" );
                    var x = svc.notify( userId = intruder.getId(), type = "test.b", title = "x" );

                    // Try to mark the intruder's row alongside the owner's:
                    // the user_id filter inside the service should drop x silently.
                    svc.markMultipleReadFor( owner.getId(), [ a, b, x ] );
                    expect( svc.unreadCountFor( owner.getId() ) ).toBe( 1, "c stays unread" );
                    expect( svc.unreadCountFor( intruder.getId() ) ).toBe( 1, "x untouched" );
                } );

                it( "deleteMultipleFor wipes only listed ids for the owner", function() {
                    var owner    = createTestUser();
                    var intruder = createTestUser();
                    var a = svc.notify( userId = owner.getId(),    type = "test.d", title = "a" );
                    var b = svc.notify( userId = owner.getId(),    type = "test.d", title = "b" );
                    var x = svc.notify( userId = intruder.getId(), type = "test.d", title = "x" );

                    svc.deleteMultipleFor( owner.getId(), [ a, x ] );
                    var ownerAfter = svc.searchFor( userId = owner.getId() );
                    expect( ownerAfter.total ).toBe( 1, "only b remains for owner" );
                    expect( ownerAfter.rows[ 1 ].title ).toBe( "b" );
                    var intruderAfter = svc.searchFor( userId = intruder.getId() );
                    expect( intruderAfter.total ).toBe( 1, "intruder's x untouched" );
                } );

                it( "deleteAllFor empties only the caller's inbox", function() {
                    var owner    = createTestUser();
                    var intruder = createTestUser();
                    svc.notify( userId = owner.getId(),    type = "test.da", title = "o1" );
                    svc.notify( userId = owner.getId(),    type = "test.da", title = "o2" );
                    svc.notify( userId = intruder.getId(), type = "test.da", title = "i1" );

                    svc.deleteAllFor( owner.getId() );
                    expect( svc.searchFor( userId = owner.getId() ).total ).toBe( 0 );
                    expect( svc.searchFor( userId = intruder.getId() ).total ).toBe( 1 );
                } );
            } );

        } );
    }

}
