/**
 * bx-Blogger — ThemeOptionsServiceSpec (Chunk 4.D)
 *
 * Covers per-theme options storage + retrieval:
 *   - getEffectiveOptions merges manifest defaults with stored rows
 *   - getOption returns stored value; falls back to manifest default
 *   - setOption normalizes per declared type (bool / int / color)
 *   - setMany ignores keys the manifest doesn't declare
 *   - reset() wipes all stored rows for a theme
 *   - Theme.option() wires through the VO's lookup closure
 *
 * Tests run against a **synthetic** `tests-options-fixture` theme that
 * lives under `tests/fixtures/themes/` and declares a color / int / bool
 * option each. The user-facing themes (bx-blogger-default / -magazine)
 * don't declare options today — their manifests will re-acquire options
 * only when the public-render consumers land (see PLAN Post-UX item
 * "Wire theme options into public render"). Keeping the spec off the
 * shipped themes avoids churn when those manifests change later.
 */
class extends="tests.support.BaseIntegrationSpec" {

    variables.FIXTURE_SLUG = "tests-options-fixture";
    variables.FIXTURE_DIR  = "tests/fixtures/themes/tests-options-fixture";

    function beforeAll() {
        super.beforeAll();
        variables.svc      = getInstance( "ThemeOptionsService" );
        variables.themeSvc = getInstance( "ThemeService" );

        // Seed a throwaway themes row for the fixture. `resolveActive()`
        // only accepts rows whose `directory` exists on disk — the JSON
        // at tests/fixtures/themes/tests-options-fixture/theme.json is
        // what makes that check pass.
        var manifestPath = expandPath( "/" & variables.FIXTURE_DIR & "/theme.json" );
        var manifestJson = fileRead( manifestPath );

        var qb = getInstance( "QueryBuilder@qb" );
        qb.newQuery().from( "themes" ).where( "slug", variables.FIXTURE_SLUG ).delete();
        qb.newQuery().from( "themes" ).insert( {
            "slug"          : variables.FIXTURE_SLUG,
            "name"          : "Tests Options Fixture",
            "version"       : "1.0.0",
            "author"        : "bx-Blogger Test Suite",
            "description"   : "Test-only theme — see spec header.",
            "manifest_json" : manifestJson,
            "is_active"     : 0,
            "is_system"     : 0,
            "directory"     : variables.FIXTURE_DIR
        } );
    }

    function afterAll() {
        try {
            var qb = getInstance( "QueryBuilder@qb" );
            qb.newQuery().from( "theme_options" )
                .where( "theme_slug", variables.FIXTURE_SLUG ).delete();
            qb.newQuery().from( "themes" )
                .where( "slug", variables.FIXTURE_SLUG ).delete();

            // Restore canonical active-theme state — the Theme.option()
            // test flips is_active via ThemeService.activate().
            qb.newQuery().from( "themes" ).update( { "is_active" : 0 } );
            qb.newQuery().from( "themes" )
                .where( "slug", "bx-blogger-default" )
                .update( { "is_active" : 1 } );
        }
        catch ( any e ) {
            writeLog( file = "testbox", text = "ThemeOptionsServiceSpec cleanup failed: " & e.message );
        }
        super.afterAll();
    }

    function run() {
        describe( "ThemeOptionsService", function() {

            beforeEach( function() {
                // Clean slate for each test so writes in one don't
                // bleed into the next.
                var qb = getInstance( "QueryBuilder@qb" );
                qb.newQuery().from( "theme_options" )
                    .where( "theme_slug", variables.FIXTURE_SLUG ).delete();
                svc.invalidate( variables.FIXTURE_SLUG );
            } );

            describe( "getEffectiveOptions()", function() {
                it( "returns every manifest-declared option with the declared default", function() {
                    var list = svc.getEffectiveOptions( variables.FIXTURE_SLUG );
                    expect( list.len() ).toBeGTE( 3 );

                    var keys = list.map( function( o ) { return o.key; } );
                    expect( keys ).toInclude( "primary_color" );
                    expect( keys ).toInclude( "posts_per_page" );
                    expect( keys ).toInclude( "show_author_box" );

                    for ( var entry in list ) {
                        if ( entry.key == "primary_color" ) {
                            expect( entry.value ).toBe( "##0d6efd" );
                            expect( entry.default ).toBe( "##0d6efd" );
                            expect( entry.type ).toBe( "color" );
                        }
                    }
                } );

                it( "returns the declared option set for the fallback theme (header + footer + menu toggles)", function() {
                    var list = svc.getEffectiveOptions( "bx-blogger-fallback" );
                    expect( list ).toBeArray();
                    expect( list.len() ).toBeGTE(
                        10,
                        "fallback now declares logo + site_title + 2 colors + 2 menu toggles + 4 footer toggles/text"
                    );
                    var keys = list.map( function( o ) { return o.key; } );
                    expect( keys ).toInclude( "logo_image" );
                    expect( keys ).toInclude( "site_title" );
                    expect( keys ).toInclude( "title_color_light" );
                    expect( keys ).toInclude( "title_color_dark" );
                    expect( keys ).toInclude( "show_blog_categories_in_menu" );
                    expect( keys ).toInclude( "show_blog_tags_in_menu" );
                    expect( keys ).toInclude( "show_default_footer_brand" );
                    expect( keys ).toInclude( "custom_footer_text" );
                    expect( keys ).toInclude( "show_authors_in_footer" );
                    expect( keys ).toInclude( "show_footer_rss" );
                } );

                it( "overlays a stored override onto the default", function() {
                    svc.setOption( variables.FIXTURE_SLUG, "posts_per_page", 25 );
                    var list = svc.getEffectiveOptions( variables.FIXTURE_SLUG );
                    for ( var entry in list ) {
                        if ( entry.key == "posts_per_page" ) {
                            expect( entry.value ).toBe( 25 );
                            expect( entry.default ).toBe( 10 );
                        }
                    }
                } );
            } );

            describe( "getOption() / setOption()", function() {
                it( "returns the manifest default when nothing is stored", function() {
                    expect( svc.getOption( variables.FIXTURE_SLUG, "primary_color" ) ).toBe( "##0d6efd" );
                } );

                it( "returns an empty string for an unknown option", function() {
                    expect( svc.getOption( variables.FIXTURE_SLUG, "no-such-key" ) ).toBe( "" );
                } );

                it( "normalizes a bool value (string 'true' -> true)", function() {
                    svc.setOption( variables.FIXTURE_SLUG, "show_author_box", true );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "show_author_box" ) ).toBeTrue();
                    svc.setOption( variables.FIXTURE_SLUG, "show_author_box", false );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "show_author_box" ) ).toBeFalse();
                } );

                it( "normalizes an int value", function() {
                    svc.setOption( variables.FIXTURE_SLUG, "posts_per_page", "15" );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "posts_per_page" ) ).toBe( 15 );
                } );

                it( "validates a color hex and falls back to the manifest default on malformed input", function() {
                    svc.setOption( variables.FIXTURE_SLUG, "primary_color", "##ff0000" );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "primary_color" ) ).toBe( "##ff0000" );

                    // Anything not matching #RRGGBB reverts to default
                    svc.setOption( variables.FIXTURE_SLUG, "primary_color", "not-a-color" );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "primary_color" ) ).toBe( "##0d6efd" );
                } );

                it( "stores a select value when it matches the manifest enum", function() {
                    svc.setOption( variables.FIXTURE_SLUG, "header_layout", "left" );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "header_layout" ) ).toBe( "left" );

                    svc.setOption( variables.FIXTURE_SLUG, "header_layout", "split" );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "header_layout" ) ).toBe( "split" );
                } );

                it( "rejects a select value that isn't in the manifest enum (falls back to default)", function() {
                    svc.setOption( variables.FIXTURE_SLUG, "header_layout", "bogus-not-in-enum" );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "header_layout" ) ).toBe( "centered" );
                } );

                it( "exposes the enum on the entry returned by getEffectiveOptions for the admin form", function() {
                    var list = svc.getEffectiveOptions( variables.FIXTURE_SLUG );
                    var headerEntry = "";
                    for ( var entry in list ) {
                        if ( entry.key == "header_layout" ) headerEntry = entry;
                    }
                    expect( headerEntry ).toBeStruct( "header_layout entry must be present" );
                    expect( headerEntry ).toHaveKey( "enum" );
                    expect( headerEntry.enum ).toBeArray();
                    expect( headerEntry.enum.len() ).toBe( 3 );
                    expect( headerEntry.enum[ 1 ].value ).toBe( "centered" );
                } );

                it( "stores a text-type value as a string and falls back to the manifest default when unset", function() {
                    expect( svc.getOption( variables.FIXTURE_SLUG, "tagline" ) ).toBe( "Just another bx-Blogger site" );
                    svc.setOption( variables.FIXTURE_SLUG, "tagline", "Edited tagline" );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "tagline" ) ).toBe( "Edited tagline" );
                } );

                it( "treats string-type identically to text-type (legacy alias)", function() {
                    expect( svc.getOption( variables.FIXTURE_SLUG, "footer_credit" ) ).toBe( "© bx-Blogger" );
                    svc.setOption( variables.FIXTURE_SLUG, "footer_credit", "© 2026 Example, Inc." );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "footer_credit" ) ).toBe( "© 2026 Example, Inc." );
                } );

                it( "stores an image-type media ID when the row exists; rejects missing IDs", function() {
                    // Seed a throwaway user + media row to point at.
                    var user = createTestUser();
                    var media = getInstance( "Media" ).create( {
                        "uploaderId"       : user.getId(),
                        "disk"             : "media",
                        "path"             : "specs/spec-hero.png",
                        "filename"         : "spec-hero.png",
                        "originalFilename" : "spec-hero.png",
                        "mimeType"         : "image/png",
                        "sizeBytes"        : 1024,
                        "title"            : "Spec Hero",
                        "altText"          : "spec hero"
                    } );
                    var mediaId = media.getId();
                    var qb      = getInstance( "QueryBuilder@qb" );

                    try {
                        svc.setOption( variables.FIXTURE_SLUG, "hero_image", mediaId );
                        expect( svc.getOption( variables.FIXTURE_SLUG, "hero_image" ) ).toBe( mediaId );

                        // Stale ID (a media row that doesn't exist) → falls back to 0
                        svc.setOption( variables.FIXTURE_SLUG, "hero_image", 999999 );
                        expect( svc.getOption( variables.FIXTURE_SLUG, "hero_image" ) ).toBe( 0 );

                        // Non-numeric → 0
                        svc.setOption( variables.FIXTURE_SLUG, "hero_image", "not-a-number" );
                        expect( svc.getOption( variables.FIXTURE_SLUG, "hero_image" ) ).toBe( 0 );

                        // Negative / zero → 0
                        svc.setOption( variables.FIXTURE_SLUG, "hero_image", -5 );
                        expect( svc.getOption( variables.FIXTURE_SLUG, "hero_image" ) ).toBe( 0 );
                    }
                    finally {
                        qb.newQuery().from( "media" ).where( "id", mediaId ).delete();
                    }
                } );

                it( "Theme.imageUrl() resolves a stored media ID to a public URL; empty string when unset", function() {
                    var user = createTestUser();
                    var media = getInstance( "Media" ).create( {
                        "uploaderId"       : user.getId(),
                        "disk"             : "media",
                        "path"             : "specs/spec-hero-2.png",
                        "filename"         : "spec-hero-2.png",
                        "originalFilename" : "spec-hero-2.png",
                        "mimeType"         : "image/png",
                        "sizeBytes"        : 2048,
                        "title"            : "Spec Hero 2",
                        "altText"          : "spec hero 2"
                    } );
                    var mediaId = media.getId();
                    var qb      = getInstance( "QueryBuilder@qb" );
                    try {
                        themeSvc.activate( variables.FIXTURE_SLUG );
                        var theme = themeSvc.resolveActive();

                        // Unset → empty string
                        expect( theme.imageUrl( "hero_image" ) ).toBe( "" );

                        // Set → some non-empty URL string ending in our filename.
                        // (`url` is a reserved scope name in CFML/BoxLang —
                        // local would silently resolve to the URL scope on
                        // the next read; use `resolved` instead.)
                        svc.setOption( variables.FIXTURE_SLUG, "hero_image", mediaId );
                        var resolved = theme.imageUrl( "hero_image" );
                        expect( len( resolved ) ).toBeGT( 0, "expected a resolved URL, got empty" );
                        expect( resolved ).toInclude( "spec-hero-2.png" );
                    }
                    finally {
                        qb.newQuery().from( "media" ).where( "id", mediaId ).delete();
                    }
                } );

                it( "isolates values by theme_slug", function() {
                    // Write a value under the fixture slug, read back
                    // an unrelated slug — they must not bleed.
                    svc.setOption( variables.FIXTURE_SLUG, "posts_per_page", 7 );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "posts_per_page" ) ).toBe( 7 );
                    // A theme with no `posts_per_page` in its manifest
                    // returns "" (unknown-option rule).
                    expect( svc.getOption( "bx-blogger-fallback", "posts_per_page" ) ).toBe( "" );
                } );
            } );

            describe( "setMany() + reset()", function() {
                it( "writes every manifest-declared key and ignores undeclared keys", function() {
                    svc.setMany(
                        slug   = variables.FIXTURE_SLUG,
                        values = {
                            "posts_per_page"  : 12,
                            "show_author_box" : false,
                            "no-such-key"     : "smuggled"
                        }
                    );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "posts_per_page" ) ).toBe( 12 );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "show_author_box" ) ).toBeFalse();
                    expect( svc.getOption( variables.FIXTURE_SLUG, "no-such-key" ) ).toBe( "" );

                    var count = getInstance( "QueryBuilder@qb" ).newQuery()
                        .from( "theme_options" )
                        .where( "theme_slug", variables.FIXTURE_SLUG )
                        .where( "option_key", "no-such-key" )
                        .count();
                    expect( count ).toBe( 0 );
                } );

                it( "reset() wipes every row for the theme", function() {
                    svc.setOption( variables.FIXTURE_SLUG, "posts_per_page", 99 );
                    svc.setOption( variables.FIXTURE_SLUG, "show_author_box", false );

                    svc.reset( variables.FIXTURE_SLUG );

                    expect( svc.getOption( variables.FIXTURE_SLUG, "posts_per_page" ) ).toBe( 10 );
                    expect( svc.getOption( variables.FIXTURE_SLUG, "show_author_box" ) ).toBeTrue();
                } );
            } );

            describe( "Theme.option()", function() {
                it( "returns the effective value via the VO's lookup closure", function() {
                    themeSvc.activate( variables.FIXTURE_SLUG );
                    svc.setOption( variables.FIXTURE_SLUG, "primary_color", "##123456" );

                    var theme = themeSvc.resolveActive();
                    expect( theme.getSlug() ).toBe( variables.FIXTURE_SLUG );
                    expect( theme.option( "primary_color" ) ).toBe( "##123456" );
                } );
            } );

            describe( "Theme.siteTitle()", function() {
                it( "prefers the theme-option site_title when set", function() {
                    themeSvc.activate( "bx-blogger-default" );
                    var settingSvc = getInstance( "SettingService" );
                    var prior      = settingSvc.get( "site.name", "" );
                    try {
                        settingSvc.set( "site.name", "Site-Wide Name" );
                        getInstance( "ThemeOptionsService" ).setOption( "bx-blogger-default", "site_title", "Theme-Override Title" );

                        var theme = themeSvc.resolveActive();
                        expect( theme.siteTitle() ).toBe( "Theme-Override Title" );
                    }
                    finally {
                        getInstance( "ThemeOptionsService" ).reset( "bx-blogger-default" );
                        settingSvc.set( "site.name", prior );
                    }
                } );

                it( "falls back to SettingService site.name when site_title is empty", function() {
                    themeSvc.activate( "bx-blogger-default" );
                    var settingSvc = getInstance( "SettingService" );
                    var prior      = settingSvc.get( "site.name", "" );
                    try {
                        settingSvc.set( "site.name", "Just The Site Name" );
                        getInstance( "ThemeOptionsService" ).reset( "bx-blogger-default" );

                        var theme = themeSvc.resolveActive();
                        expect( theme.siteTitle() ).toBe( "Just The Site Name" );
                    }
                    finally {
                        settingSvc.set( "site.name", prior );
                    }
                } );

                it( "falls back to literal 'bx-Blogger' when both option and setting are blank", function() {
                    themeSvc.activate( "bx-blogger-default" );
                    var settingSvc = getInstance( "SettingService" );
                    var prior      = settingSvc.get( "site.name", "" );
                    try {
                        settingSvc.set( "site.name", "" );
                        getInstance( "ThemeOptionsService" ).reset( "bx-blogger-default" );

                        var theme = themeSvc.resolveActive();
                        expect( theme.siteTitle() ).toBe( "bx-Blogger" );
                    }
                    finally {
                        settingSvc.set( "site.name", prior );
                    }
                } );
            } );

        } );
    }

}
