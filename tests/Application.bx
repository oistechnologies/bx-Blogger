/**
 * bx-Blogger — Test Suite Application Bootstrap (flat layout)
 *
 * Spins a ColdBox Virtual Application for every test request, pointing at the
 * project root where the real app lives. Short timeouts + page-pool clearing
 * ensure test freshness.
 */
class {

	this.name               = "bx-Blogger-TestingSuite";
	this.sessionManagement  = true;
	this.setClientCookies   = true;
	this.sessionTimeout     = createTimespan( 0, 0, 15, 0 );
	this.applicationTimeout = createTimespan( 0, 0, 15, 0 );

	// Mirror the main Application.bx — pull in /lib/*.jar so specs
	// that exercise OgImageService's QR code generation can resolve
	// `io.nayuki.qrcodegen.QrCode`.
	this.javaSettings = {
		loadPaths      : [ "../lib/" ],
		reloadOnChange : false
	};

	// Datasource — mirrors /Application.bx so tests hit the same MySQL instance
	this.datasources = {
		"coldbox": {
			"dbdriver" : "MySQL",
			"database" : getSystemSetting( "DB_DATABASE", "bx_blogger" ),
			"host"     : getSystemSetting( "DB_HOST", "mysql" ),
			"port"     : getSystemSetting( "DB_PORT", "3306" ),
			"username" : getSystemSetting( "DB_USERNAME", "bx_blogger" ),
			"password" : getSystemSetting( "DB_PASSWORD", "bxblog-dev-pass" ),
			// See /Application.bx — serverTimezone omitted intentionally
			// so the MySQL JDBC driver uses JVM local (America/New_York
			// via TZ env) for both writes and comparisons.
			"custom"   : "useUnicode=true&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&useSSL=false&useLegacyDatetimeCode=true"
		}
	};
	this.datasource = "coldbox";

	// Tests-tree mapping + /root mapping pointing at the project root.
	// The flat layout puts config/Coldbox.bx at the project root, one level
	// up from /tests. ColdBox's VirtualApp uses appMapping="/root" to find it.
	_testsRoot = getDirectoryFromPath( getCurrentTemplatePath() );
	_appRoot   = reReplaceNoCase( _testsRoot, "tests(\\|/)$", "" );
	this.mappings[ "/tests" ] = _testsRoot;
	this.mappings[ "/root" ]  = _appRoot;

	/**
	 * Fires on every test request. Builds a ColdBox Virtual Application.
	 */
	public boolean function onRequestStart( targetPage ) output="true" {
		// Plenty of time for slow integration / E2E runs
		bx:setting requestTimeout="9999";
		pagePoolClear();

		// In flat layout, the app root IS the project root — tests/ sits one level down.
		request.coldBoxVirtualApp = new coldbox.system.testing.VirtualApp( appMapping = "/root" );

		// Boot the virtual app only for runner + specs requests
		if ( getBaseTemplatePath().replace( expandPath( "/tests" ), "" ).reFindNoCase( "(runner|specs)" ) ) {
			request.coldBoxVirtualApp.startup( true );
		}

		// Reload for fresh results
		if ( structKeyExists( url, "fwreinit" ) ) {
			request.coldBoxVirtualApp.restart();
		}

		return true;
	}

	/**
	 * Shutdown the virtual app at end of request.
	 */
	public void function onRequestEnd( required targetPage ) {
		request.coldBoxVirtualApp.shutdown();
	}

}
