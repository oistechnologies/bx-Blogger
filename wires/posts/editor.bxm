<bx:script>
// @startWire
/**
 * posts.editor — title/slug/excerpt/body editor + sidebar controls.
 *
 * Seeded with `postId` via wire() params. When `postId > 0` the wire
 * loads the existing post; otherwise it starts a new draft.
 *
 * Actions:
 *   save()    — writes through PostService.update (draft stays draft)
 *   publish() — save, then PostService.publish
 *   trash()   — soft-move to trashed status
 *   preview() — compiles markdown → html for the preview pane
 *   regenerateSlug() — re-derives the slug from the current title
 *
 * Permissions are enforced per-action: contributors can save drafts
 * they own + Submit for Review (A7 — lands Chunk 2.G); editors + admins
 * can publish anyone's content. A user lacking a permission sees a
 * flash error rather than a hidden control — keeps the UI predictable
 * while Phase 3 theme work lays down field-level conditionals.
 */

property name="postService"         inject="PostService";
property name="draftPreviewService"  inject="DraftPreviewService";
property name="aiService"            inject="AiAssistantService";
property name="auditService"         inject="SeoAuditService";
property name="auditAgentService"    inject="SeoAuditAgentService";
property name="outboundLinkService"  inject="OutboundLinkService";
property name="gscService"           inject="GscService";
property name="settingService"       inject="SettingService";
property name="aiImageService"       inject="AiImageService";
property name="themeService"         inject="ThemeService";
property name="cbauth"               inject="AuthenticationService@cbauth";

data = {
    "postId"         : 0,
    "title"          : "",
    "slug"           : "",
    "excerpt"        : "",
    "bodyMarkdown"   : "",
    "bodyPreview"    : "",
    "status"         : "draft",
    "postType"       : "post",
    "visibility"     : "public",
    "seoTitle"       : "",
    "seoDescription" : "",
    "focusKeyword"   : "",
    "schemaType"     : "",      // SEO Phase 7 — empty = default Article
    "schemaDataJson" : "{}",    // SEO Phase 7 — type-specific data, edited as JSON
    "allowIndexing"  : true,
    "templateOverride" : "",
    "scheduledAt"    : "",
    "showPreview"    : false,
    "flashOk"        : "",
    "flashError"     : "",
    "validationErrors" : [],
    // B2 draft-preview share state
    "previewShareUrl" : "",
    "previewExpires"  : "",
    // B5 autosave ticker
    "lastAutosaveAt"  : "",
    // B4 media picker modal state. `pickerTarget` = "body" inserts a
    // markdown `![alt](url)` snippet at EasyMDE's cursor; "featured"
    // sets `featuredMediaId` so the Featured image card updates.
    "showMediaPicker" : false,
    "pickerSearch"    : "",
    "pickerTarget"    : "body",
    // 2.H AI authoring state
    "showAiModal"     : false,    // Create-from-Idea
    "aiIdea"          : "",
    "aiBusy"          : false,
    "aiError"         : "",
    "showAiReview"    : false,    // Review-and-Suggest panel
    "aiSuggestions"   : [],
    // SEO Phase 4 — CTR-variants modal state
    "showCtrModal"    : false,
    "ctrVariants"     : [],
    // SEO Phase 5.2 — AI audit panel state
    "showAuditPanel"  : false,
    "currentAuditId"  : 0,
    "auditMarkdown"   : "",
    "auditTokens"     : 0,
    "auditError"      : "",
    "auditFollowUpQ"  : "",
    // SEO Phase 6 — SERP/social preview modal state
    "showPreviewPanel" : false,
    // SEO Phase 10 — internal-link suggester state
    "showInternalLinks"  : false,
    "internalLinks"      : [],
    "internalLinksError" : "",
    // SEO Phase 12 — outbound link health modal state
    "showLinkHealth"     : false,
    "linkHealthBusy"     : false,
    "linkHealthError"    : "",
    // SEO Phase 14 — GSC performance modal state
    "showPerformance"    : false,
    // 2.I AI image-gen state
    "showImageModal"  : false,
    "imagePrompt"     : "",
    "imageStyle"      : "",       // "" | Realistic | Illustration | Watercolor | Minimalist
    "imagePreviews"   : [],
    "imageBusy"       : false,
    "imageError"      : "",
    "imageTarget"     : "inline", // "inline" appends ![alt](url); "featured" sets featured_media_id
    "featuredMediaId" : 0,        // updated from loadFromDb + by "Use as featured"
    // Phase UX — taxonomy assignment
    "categoryIds"     : [],       // array of numeric category ids currently attached
    "tagsText"        : "",       // comma-separated tag names; resolved via find-or-create on save
    // OG image widget — hydrated on mount, refreshed after a regen
    "ogVersion"          : 0,
    "ogGeneratedAt"      : "",
    "ogAsFeaturedImage"  : 0,     // checkbox: substitute OG image wherever featured renders
    // Featured pin — admin checkbox in the sidebar publishes-this-post-
    // to-the-home-page-featured-section toggle. PostService.normalize
    // stamps featured_at when this flips true.
    "featured"           : 0
};

/**
 * Mount hook — runs once on first render. CBWIRE calls it as
 * `onMount(event, rc, prc, params)`; when `onMount` is defined the
 * framework SKIPS auto-copying wire() params into `data`, so we
 * pull postId out of the params struct ourselves. Without this the
 * editor mounts with data.postId=0 and the Share-Preview /
 * Autosave / Trash sidebar buttons (all guarded on `postId > 0`)
 * stay hidden even for existing posts.
 */
function onMount( event, rc, prc, params ) {
    if ( structKeyExists( arguments.params, "postId" ) ) {
        data.postId = arguments.params.postId;
    }
    if ( ( data.postId ?: 0 ) > 0 ) {
        loadFromDb( data.postId );
    }
}

private function loadFromDb( required id ) {
    var post = getInstance( "Post" ).find( id );
    if ( isNull( post ) ) {
        data.flashError = "Post ##" & id & " not found.";
        data.postId = 0;
        return;
    }
    data.postId         = post.getId();
    data.title          = post.getTitle() ?: "";
    data.slug           = post.getSlug() ?: "";
    data.excerpt        = post.getExcerpt() ?: "";
    data.bodyMarkdown   = post.getBodyMarkdown() ?: "";
    data.status         = post.getStatus() ?: "draft";
    data.postType       = post.getPostType() ?: "post";
    data.visibility     = post.getVisibility() ?: "public";
    data.seoTitle       = post.getSeoTitle() ?: "";
    data.seoDescription = post.getSeoDescription() ?: "";
    data.focusKeyword   = post.getFocusKeyword() ?: "";
    data.schemaType     = post.getSchemaType() ?: "";
    var rawSchemaData   = post.getSchemaData() ?: "";
    data.schemaDataJson = len( rawSchemaData ) ? rawSchemaData : "{}";
    data.allowIndexing  = !!( post.getAllowIndexing() ?: 1 );
    data.templateOverride = post.getTemplateOverride() ?: "";
    data.scheduledAt    = len( post.getScheduledAt() ?: "" )
        ? dateTimeFormat( post.getScheduledAt(), "yyyy-mm-dd'T'HH:nn" )
        : "";
    data.featuredMediaId = val( post.getFeaturedMediaId() ?: 0 );

    // OG state for the editor's OG widget. ogGeneratedAt is best-
    // effort: derive from the disk file's mtime when present so the
    // editor shows a meaningful "Generated X minutes ago" stamp.
    data.ogVersion         = val( post.getOgVersion() ?: 0 );
    data.ogAsFeaturedImage = !!( post.getOgAsFeaturedImage() ?: 0 ) ? 1 : 0;
    data.ogGeneratedAt     = ogGeneratedAtFor( post );
    data.featured          = !!( post.getFeatured() ?: 0 ) ? 1 : 0;

    // Phase UX — hydrate category + tag assignments from the pivots.
    // qb is cheaper + simpler than Quick's `.categories().get()` for
    // a read-only id pull, and it avoids lazy-load surprises during
    // the wire render cycle.
    var qb = getInstance( "QueryBuilder@qb" );
    data.categoryIds = qb.newQuery()
        .from( "post_categories" )
        .where( "post_id", post.getId() )
        .select( "category_id" )
        .get()
        .map( ( r ) => r.category_id );

    var tagRows = qb.newQuery()
        .from( "post_tags" )
        .join( "tags", "tags.id", "post_tags.tag_id" )
        .where( "post_tags.post_id", post.getId() )
        .orderBy( "tags.name", "asc" )
        .select( "tags.name AS name" )
        .get();
    data.tagsText = tagRows.map( ( r ) => r.name ).toList( ", " );
}

// --------------------------------------------------------------------
// Actions
// --------------------------------------------------------------------

function save() {
    clearFlashes();
    if ( !canSave() ) {
        data.flashError = "You don't have permission to save this post.";
        return;
    }
    var errors = validate();
    if ( errors.len() ) {
        data.validationErrors = errors;
        return;
    }

    var attrs = collectAttrs();
    var editorId = cbauth.getUser().getId();

    if ( ( data.postId ?: 0 ) == 0 ) {
        attrs.authorId = editorId;
        var post = postService.create( attrs );
        data.postId = post.getId();
        data.flashOk = "Draft created.";
    } else {
        var post = getInstance( "Post" ).find( data.postId );
        postService.update(
            post          = post,
            attrs         = attrs,
            editorId      = editorId,
            changeSummary = "manual"
        );
        data.flashOk = "Saved.";
    }

    // Phase UX — taxonomy sync happens AFTER the post save so we
    // always have a valid postId, including on first-save. Pulls the
    // freshly-saved Post out of Quick to keep the Post variable in
    // this scope consistent with the DB row after the initial insert.
    var saved = getInstance( "Post" ).find( data.postId );
    postService.syncCategories( saved, data.categoryIds ?: [] );
    postService.syncTags( saved, parseTagsText( data.tagsText ?: "" ) );

    // Reload to reflect normalised slug, bumped version, etc.
    loadFromDb( data.postId );
}

function publish() {
    clearFlashes();
    if ( !canPublish() ) {
        data.flashError = "You don't have permission to publish this post.";
        return;
    }
    save();   // persist current form state first
    if ( len( data.flashError ) || data.validationErrors.len() ) return;

    var post = getInstance( "Post" ).find( data.postId );
    if ( len( data.scheduledAt ) && dateCompare( data.scheduledAt, now() ) == 1 ) {
        postService.schedule( post, data.scheduledAt );
        // Inline the long-format mask rather than calling the
        // `fmtDateTimeLong` application helper — those helpers
        // resolve in view/template scope but not inside a wire
        // class's action methods. Matches the mask documented in
        // includes/helpers/ApplicationHelper.bxm.
        data.flashOk = "Scheduled for " & dateTimeFormat( data.scheduledAt, "mmm. d, yyyy h:nn tt" ) & ".";
    } else {
        postService.publish( post = post, actorId = cbauth.getUser().getId() );
        data.flashOk = "Published.";
    }
    loadFromDb( data.postId );
}

function trash() {
    clearFlashes();
    if ( ( data.postId ?: 0 ) == 0 ) return;

    var post = getInstance( "Post" ).find( data.postId );
    var user = cbauth.getUser();
    var isMine = post.getAuthorId() == user.getId();
    var ok = isMine
        ? user.hasPermission( "posts.delete.own" )
        : user.hasPermission( "posts.delete.others" );
    if ( !ok ) {
        data.flashError = "You don't have permission to trash this post.";
        return;
    }
    postService.trash( post );
    data.flashOk = "Moved to trash.";
    data.status = "trashed";
}

function preview() {
    data.bodyPreview = postService.renderPreview( data.bodyMarkdown ?: "" );
    data.showPreview = true;
}

function hidePreview() {
    data.showPreview = false;
}

function regenerateSlug() {
    if ( !len( trim( data.title ) ) ) return;
    data.slug = postService.slugify( data.title );
}

// --------------------------------------------------------------------
// A7 — Submit for Review
// --------------------------------------------------------------------

function submitForReview() {
    clearFlashes();
    var user = cbauth.getUser();
    if ( !user.hasPermission( "posts.submit_for_review" ) ) {
        data.flashError = "You don't have permission to submit posts for review.";
        return;
    }

    // Persist current buffer state first so reviewers see the right draft
    save();
    if ( len( data.flashError ) || data.validationErrors.len() ) return;

    var post = getInstance( "Post" ).find( data.postId );
    postService.submitForReview( post, user.getId() );
    data.flashOk = "Submitted for editor review. You'll be notified when it's published or needs changes.";
    loadFromDb( data.postId );
}

// --------------------------------------------------------------------
// B2 — Share Preview
// --------------------------------------------------------------------

function sharePreview() {
    clearFlashes();
    if ( ( data.postId ?: 0 ) == 0 ) {
        data.flashError = "Save the post first — preview links attach to saved drafts.";
        return;
    }
    var user = cbauth.getUser();
    if ( !user.hasPermission( "posts.preview.share" ) ) {
        data.flashError = "You don't have permission to share preview links.";
        return;
    }

    var post   = getInstance( "Post" ).find( data.postId );
    var result = draftPreviewService.share( post, user.getId() );
    data.previewShareUrl = result.url;
    // Same mask as fmtDateTimeLong (see note in `publish()`); inlined
    // because the helper is template-scope only.
    data.previewExpires  = dateTimeFormat( result.expiresAt, "mmm. d, yyyy h:nn tt" );
}

function dismissShareLink() {
    data.previewShareUrl = "";
    data.previewExpires  = "";
}

// --------------------------------------------------------------------
// B5 — Autosave
// --------------------------------------------------------------------

/**
 * Wire-triggered autosave. The template's JS timer posts to this
 * action every 30s; it silently no-ops when we don't have a saved
 * post yet (no postId → nothing to attach a revision to), and
 * swallows ownership failures rather than flashing, since autosave
 * is a background action.
 */
function autosave() {
    if ( ( data.postId ?: 0 ) == 0 ) return;
    var user = cbauth.getUser();
    var post = getInstance( "Post" ).find( data.postId );
    if ( isNull( post ) ) return;
    if ( !canSave() ) return;

    postService.autosave(
        post         = post,
        editorId     = user.getId(),
        bodyMarkdown = data.bodyMarkdown ?: "",
        title        = data.title ?: ""
    );
    data.lastAutosaveAt = dateTimeFormat( now(), "h:nn:ss tt" );
}

// --------------------------------------------------------------------
// B4 — Media picker
// --------------------------------------------------------------------

function openMediaPicker( string target = "body" ) {
    data.showMediaPicker = true;
    data.pickerSearch    = "";
    data.pickerTarget    = arguments.target;
}
function closeMediaPicker() { data.showMediaPicker = false; }

/**
 * Body-insert path kept for backward compatibility. The new flow
 * inserts the markdown client-side via EasyMDE's codemirror so the
 * snippet lands at cursor instead of appended to end, and the wire-
 * ignore'd EasyMDE DOM picks up the change instantly. This server-
 * side action remains as a fallback for non-JS contexts + a paper
 * trail in case we add a "last inserted media" feature later.
 */
function insertMedia( required id ) {
    var m = getInstance( "Media" ).find( arguments.id );
    if ( isNull( m ) ) return;
    // `mediaUrl` not `url` — CFML reserved scope name.
    var mediaUrl = getInstance( "MediaService" ).urlFor( m );
    var alt      = m.getAltText() ?: m.getOriginalFilename();
    var snippet  = "

![" & alt & "](" & mediaUrl & ")
";
    data.bodyMarkdown = ( data.bodyMarkdown ?: "" ) & snippet;
    closeMediaPicker();
}

/**
 * Featured-image path — picker in `featured` mode routes here on
 * item click. Sets the sidebar's Featured image card; no markdown
 * snippet.
 */
function setAsFeatured( required id ) {
    data.featuredMediaId = arguments.id;
    closeMediaPicker();
}

function pickerRows() {
    var qb = getInstance( "QueryBuilder@qb" ).newQuery()
        .from( "media" )
        .whereNull( "deleted_at" )
        .where( "mime_type", "like", "image/%" );
    if ( len( trim( data.pickerSearch ) ) ) {
        var q = "%" & trim( data.pickerSearch ) & "%";
        qb.where( function( w ) {
            w.where( "original_filename", "like", q )
             .orWhere( "alt_text", "like", q )
             .orWhere( "title",    "like", q );
        } );
    }
    return qb.orderBy( "created_at", "desc" ).limit( 12 ).get();
}

function pickerUrl( required any row ) {
    return getInstance( "DiskService@cbfs" ).get( "media" ).url( arguments.row.path );
}

// --------------------------------------------------------------------
// 2.H — AI authoring
// --------------------------------------------------------------------

function aiEnabled() {
    var user = cbauth.getUser();
    return aiService.isEnabled() && user.hasPermission( "posts.ai.assist" );
}

function openAiModal() {
    if ( !aiEnabled() ) { data.aiError = "AI authoring is disabled on this site."; return; }
    data.showAiModal = true;
    data.aiIdea      = "";
    data.aiError     = "";
}
function closeAiModal() { data.showAiModal = false; data.aiBusy = false; data.aiError = ""; }

function aiGenerateDraft() {
    if ( !aiEnabled() ) { data.aiError = "AI authoring is disabled on this site."; return; }
    data.aiError = "";
    data.aiBusy  = true;
    try {
        var result = aiService.draftFromIdea(
            idea   = data.aiIdea,
            userId = cbauth.getUser().getId()
        );
        // Append the generated markdown to the body buffer — if the
        // user already typed a draft we keep it and add the AI shell
        // below. Cursor-position insertion is a JS follow-up.
        if ( len( trim( data.bodyMarkdown ?: "" ) ) ) {
            data.bodyMarkdown = data.bodyMarkdown & char( 10 ) & char( 10 ) & result.markdown;
        } else {
            data.bodyMarkdown = result.markdown;
        }
        // If no title yet, crib one from the AI draft's first H1 line
        if ( !len( trim( data.title ?: "" ) ) ) {
            var firstHeading = reMatchNoCase( "^##\s+[^\r\n]+", result.markdown );
            if ( firstHeading.len() ) {
                data.title = trim( reReplace( firstHeading[ 1 ], "^##\s+", "", "one" ) );
            }
        }
        data.flashOk = "AI draft dropped into the editor. Edit or discard freely.";
        // Push the new body into EasyMDE — the textarea is wire:ignore'd
        // so a bare data.bodyMarkdown mutation is invisible until save.
        dispatch( "bx-blogger:body-replaced", { "value" : data.bodyMarkdown } );
        closeAiModal();
    }
    catch ( bxBlogger.AiBudgetExceeded e ) { data.aiError = e.message; }
    catch ( bxBlogger.AiInvalidInput e )   { data.aiError = e.message; }
    catch ( bxBlogger.AiProviderError e )  { data.aiError = "The AI provider failed: " & e.message; }
    catch ( bxBlogger.AiDisabled e )       { data.aiError = e.message; }
    catch ( any e )                         { data.aiError = "Unexpected failure: " & e.message; }
    finally { data.aiBusy = false; }
}

function aiRequestReview() {
    if ( !aiEnabled() ) { data.aiError = "AI authoring is disabled on this site."; return; }
    // Open the modal IMMEDIATELY so the user sees something happen.
    // Empty-body / provider-error states render their messages inside.
    data.aiError       = "";
    data.aiSuggestions = [];
    data.showAiReview  = true;

    if ( !len( trim( data.bodyMarkdown ?: "" ) ) ) {
        data.aiError = "Write some content first — nothing to review yet.";
        return;
    }
    data.aiBusy = true;
    try {
        var result = aiService.reviewPost(
            postBody = data.bodyMarkdown,
            userId   = cbauth.getUser().getId()
        );
        data.aiSuggestions = result.suggestions;
    }
    catch ( bxBlogger.AiBudgetExceeded e ) { data.aiError = e.message; }
    catch ( bxBlogger.AiInvalidInput e )   { data.aiError = e.message; }
    catch ( bxBlogger.AiProviderError e )  { data.aiError = "The AI provider failed: " & e.message; }
    catch ( bxBlogger.AiDisabled e )       { data.aiError = e.message; }
    catch ( any e )                         { data.aiError = "Unexpected failure: " & e.message; }
    finally { data.aiBusy = false; }
}

function closeAiReview() { data.showAiReview = false; data.aiSuggestions = []; }

function acceptSuggestion( required id ) {
    var remaining = [];
    var didChange = false;
    for ( var s in data.aiSuggestions ) {
        if ( ( s.id ?: "" ) == arguments.id ) {
            // Apply before→after to the body buffer if `before` is present + found
            if ( len( s.before ?: "" ) && findNoCase( s.before, data.bodyMarkdown ) ) {
                data.bodyMarkdown = replaceNoCase( data.bodyMarkdown, s.before, s.after ?: "", "one" );
                didChange = true;
            }
            continue;   // drop this suggestion from the pending list
        }
        remaining.append( s );
    }
    data.aiSuggestions = remaining;
    // EasyMDE owns the textarea DOM (wire:ignore), so a server-side
    // mutation to data.bodyMarkdown isn't visible until we tell the
    // editor instance directly. The browser listener in the init
    // script calls easymde.value(...) on this event.
    if ( didChange ) dispatch( "bx-blogger:body-replaced", { "value" : data.bodyMarkdown } );
}

function dismissSuggestion( required id ) {
    var remaining = [];
    for ( var s in data.aiSuggestions ) {
        if ( ( s.id ?: "" ) != arguments.id ) remaining.append( s );
    }
    data.aiSuggestions = remaining;
}

/**
 * One-shot excerpt generator. Reads data.bodyMarkdown, asks the
 * model for a 1-2 sentence synopsis, drops the result into
 * data.excerpt. No modal — the user clicks the button next to the
 * Excerpt label and sees the value appear directly in the textarea.
 *
 * Errors land in data.aiError so the existing AI alert above the
 * editor surfaces them; we don't have a dedicated "excerpt error"
 * field because there's no excerpt-specific UI to render it into.
 */
function aiGenerateExcerpt() {
    if ( !aiEnabled() ) { data.aiError = "AI authoring is disabled on this site."; return; }
    if ( !len( trim( data.bodyMarkdown ?: "" ) ) ) {
        data.aiError = "Write some content first - nothing to summarize yet.";
        return;
    }
    data.aiError = "";
    try {
        var result = aiService.excerptFromBody(
            postBody = data.bodyMarkdown,
            userId   = cbauth.getUser().getId()
        );
        data.excerpt = result.text;
        data.flashOk = "AI excerpt generated.";
    }
    catch ( bxBlogger.AiBudgetExceeded e ) { data.aiError = e.message; }
    catch ( bxBlogger.AiInvalidInput e )   { data.aiError = e.message; }
    catch ( bxBlogger.AiProviderError e )  { data.aiError = "The AI provider failed: " & e.message; }
    catch ( bxBlogger.AiDisabled e )       { data.aiError = e.message; }
    catch ( any e )                         { data.aiError = "Unexpected failure: " & e.message; }
}

// --------------------------------------------------------------------
// SEO Phase 4 — AI SEO meta generation
// --------------------------------------------------------------------

/**
 * Centralized gate. Wraps AiAssistantService.isSeoAiAvailable so
 * the template `<bx:if>` checks stay one-liners and the four
 * generate* wire actions don't each duplicate the same checks.
 */
function seoAiAvailable() {
    return aiService.isSeoAiAvailable( cbauth.getUser().getId() );
}

function seoAiUnavailableReason() {
    return aiService.availabilityReason( cbauth.getUser().getId() );
}

function aiGenerateSeoTitle() {
    data.aiError = "";
    try {
        var result = aiService.generateSeoTitle(
            title        = data.title ?: "",
            body         = data.bodyMarkdown ?: "",
            userId       = cbauth.getUser().getId(),
            focusKeyword = ""
        );
        data.seoTitle = result.text;
        data.flashOk  = "AI SEO title generated.";
    }
    catch ( bxBlogger.AiUnavailable e )    { data.aiError = e.message; }
    catch ( bxBlogger.AiBudgetExceeded e ) { data.aiError = e.message; }
    catch ( bxBlogger.AiInvalidInput e )   { data.aiError = e.message; }
    catch ( bxBlogger.AiProviderError e )  { data.aiError = "The AI provider failed: " & e.message; }
    catch ( any e )                         { data.aiError = "Unexpected failure: " & e.message; }
}

function aiGenerateSeoDescription() {
    data.aiError = "";
    try {
        var result = aiService.generateSeoDescription(
            title        = data.title ?: "",
            body         = data.bodyMarkdown ?: "",
            userId       = cbauth.getUser().getId(),
            focusKeyword = ""
        );
        data.seoDescription = result.text;
        data.flashOk        = "AI SEO description generated.";
    }
    catch ( bxBlogger.AiUnavailable e )    { data.aiError = e.message; }
    catch ( bxBlogger.AiBudgetExceeded e ) { data.aiError = e.message; }
    catch ( bxBlogger.AiInvalidInput e )   { data.aiError = e.message; }
    catch ( bxBlogger.AiProviderError e )  { data.aiError = "The AI provider failed: " & e.message; }
    catch ( any e )                         { data.aiError = "Unexpected failure: " & e.message; }
}

function aiSuggestCtrTitleVariants() {
    data.aiError       = "";
    data.ctrVariants   = [];
    data.showCtrModal  = false;
    try {
        var result = aiService.generateTitleCtrVariations(
            title        = data.title ?: "",
            body         = data.bodyMarkdown ?: "",
            userId       = cbauth.getUser().getId(),
            focusKeyword = ""
        );
        data.ctrVariants  = result.variants;
        data.showCtrModal = true;
    }
    catch ( bxBlogger.AiUnavailable e )    { data.aiError = e.message; }
    catch ( bxBlogger.AiBudgetExceeded e ) { data.aiError = e.message; }
    catch ( bxBlogger.AiInvalidInput e )   { data.aiError = e.message; }
    catch ( bxBlogger.AiProviderError e )  { data.aiError = "The AI provider failed: " & e.message; }
    catch ( any e )                         { data.aiError = "Unexpected failure: " & e.message; }
}

/**
 * SEO Phase 5.1 — live audit helper for the sidebar panel. Pure
 * function of the wire's data — no DB hit, no cache. The template
 * calls this on every render so the panel reacts to wire:model.blur
 * on title / body / seoTitle / seoDescription / focusKeyword.
 */
struct function liveAudit() {
    return auditService.auditDraft(
        title          = data.title          ?: "",
        slug           = data.slug           ?: "",
        seoTitle       = data.seoTitle       ?: "",
        seoDescription = data.seoDescription ?: "",
        focusKeyword   = data.focusKeyword   ?: "",
        bodyMarkdown   = data.bodyMarkdown   ?: ""
    );
}

/**
 * Humanize a camelCase audit check key for the live panel labels.
 * "focusKeywordInTitle" → "Focus Keyword In Title"
 */
string function humanizeCheckKey( required string key ) {
    var spaced = reReplace( arguments.key, "([a-z])([A-Z])", "\1 \2", "all" );
    return uCase( left( spaced, 1 ) ) & right( spaced, len( spaced ) - 1 );
}

function applyCtrVariant( required numeric index ) {
    var idx     = int( arguments.index ?: 0 );
    var variants = data.ctrVariants ?: [];
    if ( idx < 1 || idx > variants.len() ) return;
    var picked = variants[ idx ];
    if ( !len( trim( picked ?: "" ) ) ) return;
    data.seoTitle     = picked;
    data.showCtrModal = false;
    data.flashOk      = "Applied SEO title variant.";
}

function closeCtrModal() {
    data.showCtrModal = false;
    data.ctrVariants  = [];
}

// --------------------------------------------------------------------
// SEO Phase 5.2 — AI Audit Agent
// --------------------------------------------------------------------

function openAuditPanel() {
    data.showAuditPanel = true;
    data.auditError     = "";
    data.auditFollowUpQ = "";
    // Surface the most-recent saved audit on first open so the user
    // doesn't have to re-run if one already exists.
    if ( ( data.postId ?: 0 ) > 0 ) {
        var prior = auditAgentService.listReports( postId = data.postId, limit = 1 );
        if ( prior.len() && structKeyExists( prior[ 1 ], "id" ) ) {
            data.currentAuditId = val( prior[ 1 ].id );
            data.auditMarkdown  = prior[ 1 ].report_markdown ?: "";
            data.auditTokens    = val( prior[ 1 ].tokens_used ?: 0 );
        }
    }
}

function closeAuditPanel() {
    data.showAuditPanel = false;
    data.auditError     = "";
}

function runAiAudit() {
    data.auditError = "";
    if ( ( data.postId ?: 0 ) <= 0 ) {
        data.auditError = "Save the post first — the AI audit needs a persisted post.";
        return;
    }
    try {
        // Pull a fresh entity (the wire's data may have unsaved
        // edits — the audit reflects the saved state).
        var post = getInstance( "Post" ).find( data.postId );
        if ( isNull( post ) ) {
            data.auditError = "Post not found.";
            return;
        }
        var result = auditAgentService.runAudit( post = post, userId = cbauth.getUser().getId() );
        data.currentAuditId = val( result.reportId );
        data.auditMarkdown  = result.reportMarkdown;
        data.auditTokens    = val( result.tokensUsed );
        data.flashOk        = "AI audit complete.";
    }
    catch ( bxBlogger.AiUnavailable e )    { data.auditError = e.message; }
    catch ( bxBlogger.AiBudgetExceeded e ) { data.auditError = e.message; }
    catch ( bxBlogger.SeoAuditFailed e )   { data.auditError = e.message; }
    catch ( any e )                         { data.auditError = "Unexpected failure: " & e.message; }
}

function askAuditFollowUp() {
    data.auditError = "";
    if ( ( data.currentAuditId ?: 0 ) <= 0 ) {
        data.auditError = "Run an audit first before asking a follow-up.";
        return;
    }
    var q = trim( data.auditFollowUpQ ?: "" );
    if ( !len( q ) ) {
        data.auditError = "Type a follow-up question first.";
        return;
    }
    try {
        var result = auditAgentService.askFollowUp(
            reportId = data.currentAuditId,
            question = q,
            userId   = cbauth.getUser().getId()
        );
        data.auditMarkdown  = result.reportMarkdown;
        data.auditTokens    = val( data.auditTokens ) + val( result.tokensUsed );
        data.auditFollowUpQ = "";
    }
    catch ( bxBlogger.AiUnavailable e )    { data.auditError = e.message; }
    catch ( bxBlogger.AiBudgetExceeded e ) { data.auditError = e.message; }
    catch ( bxBlogger.SeoAuditFailed e )   { data.auditError = e.message; }
    catch ( any e )                         { data.auditError = "Unexpected failure: " & e.message; }
}

function loadAuditReport( required numeric reportId ) {
    var rid = val( arguments.reportId ?: 0 );
    if ( rid <= 0 ) return;
    var row = auditAgentService.getReport( rid );
    if ( !row.len() ) return;
    data.currentAuditId = rid;
    data.auditMarkdown  = row.report_markdown ?: "";
    data.auditTokens    = val( row.tokens_used ?: 0 );
    data.auditError     = "";
}

/**
 * Markdown → sanitized HTML for the report panel. bx-markdown's
 * markdown() BIF + cbantisamy's clean() — same chain PostService
 * uses for body compilation.
 */
string function renderAuditMarkdown() {
    var md = data.auditMarkdown ?: "";
    if ( !len( md ) ) return "";
    try {
        var html = markdown( md );
        return html;
    }
    catch ( any e ) {
        return "<pre>" & encodeForHTML( md ) & "</pre>";
    }
}

// --------------------------------------------------------------------
// SEO Phase 6 — SERP + social card preview
// --------------------------------------------------------------------

function openPreviewPanel()  { data.showPreviewPanel = true;  }
function closePreviewPanel() { data.showPreviewPanel = false; }

// --------------------------------------------------------------------
// SEO Phase 10 — AI internal-link suggestions
// --------------------------------------------------------------------

function openInternalLinks() {
    data.showInternalLinks  = true;
    data.internalLinksError = "";
}

function closeInternalLinks() {
    data.showInternalLinks = false;
}

function suggestInternalLinks() {
    data.internalLinksError = "";
    data.internalLinks      = [];
    if ( !len( trim( data.bodyMarkdown ?: "" ) ) ) {
        data.internalLinksError = "Write some content first — the suggester needs context.";
        return;
    }
    try {
        var result = aiService.suggestInternalLinks(
            body          = data.bodyMarkdown ?: "",
            currentPostId = val( data.postId ?: 0 ),
            userId        = cbauth.getUser().getId()
        );
        data.internalLinks = result.suggestions;
        if ( !data.internalLinks.len() ) {
            data.internalLinksError = "No suggestions came back — either the catalog is thin or the model couldn't find a relevant match.";
        }
    }
    catch ( bxBlogger.AiUnavailable e )    { data.internalLinksError = e.message; }
    catch ( bxBlogger.AiBudgetExceeded e ) { data.internalLinksError = e.message; }
    catch ( bxBlogger.AiInvalidInput e )   { data.internalLinksError = e.message; }
    catch ( bxBlogger.AiProviderError e )  { data.internalLinksError = "The AI provider failed: " & e.message; }
    catch ( any e )                         { data.internalLinksError = "Unexpected failure: " & e.message; }
}

/**
 * Append a markdown link to the body at the end. The editor's
 * Markdown textarea is wire:ignore'd while the user types, so a
 * mid-cursor insert isn't reliably synced — we append at the
 * bottom and let the user move it. Pulled from the suggestion
 * list by 1-based index.
 */
function insertInternalLink( required numeric index ) {
    var idx = int( arguments.index ?: 0 );
    var list = data.internalLinks ?: [];
    if ( idx < 1 || idx > list.len() ) return;
    var link = list[ idx ];
    var nl = char( 10 );
    var snippet = nl & nl & "[" & link.title & "](" & link.url & ")";
    data.bodyMarkdown = ( data.bodyMarkdown ?: "" ) & snippet;
    data.flashOk = "Inserted internal link to " & link.title & ".";
}

// --------------------------------------------------------------------
// SEO Phase 12 — outbound link health
// --------------------------------------------------------------------

/**
 * How many broken outbound links does the audit currently
 * have on file for this post? Drives the editor badge — a
 * pill on the SEO panel header that turns the operator's
 * eye to a known-broken state without requiring a click.
 *
 * Returns 0 (badge hidden) when the post is unsaved or no
 * outbound_links rows exist for it yet.
 */
numeric function outboundBrokenCount() {
    var pid = val( data.postId ?: 0 );
    if ( pid <= 0 ) return 0;
    try { return outboundLinkService.brokenCountForPost( pid ); }
    catch ( any e ) { return 0; }
}

/**
 * All outbound_links rows for the post (for the modal). Sorted
 * with broken (4xx/5xx/0) first, then 3xx, then 2xx — the
 * operator should see what to fix at the top.
 */
array function outboundLinkRows() {
    var pid = val( data.postId ?: 0 );
    if ( pid <= 0 ) return [];
    try {
        var qb = getInstance( "QueryBuilder@qb" );
        return qb.newQuery().from( "outbound_links" )
            .where( "post_id", pid )
            .selectRaw(
                "id, url, status_code, error_message, redirect_target,
                 last_checked_at, last_status_change_at,
                 CASE
                    WHEN status_code = 0 OR status_code >= 400 THEN 0
                    WHEN status_code >= 300 THEN 1
                    ELSE 2
                 END AS sort_bucket"
            )
            .orderBy( "sort_bucket", "asc" )
            .orderBy( "status_code", "desc" )
            .get();
    }
    catch ( any e ) {
        return [];
    }
}

function openLinkHealth() {
    data.showLinkHealth  = true;
    data.linkHealthError = "";
}

function closeLinkHealth() {
    data.showLinkHealth = false;
}

/**
 * Audit just this post on demand. Permission-gated on
 * `seo.outbound_links.audit`; falls back to a friendly message
 * if the user lacks the perm. Synchronous so the modal can
 * refresh immediately on close.
 */
function auditOutboundLinksNow() {
    var pid = val( data.postId ?: 0 );
    if ( pid <= 0 ) {
        data.linkHealthError = "Save the post first — the audit needs a stored body to scan.";
        return;
    }
    var user = cbauth.getUser();
    if ( !user.hasPermission( "seo.outbound_links.audit" ) ) {
        data.linkHealthError = "You don't have permission to run on-demand link audits.";
        return;
    }
    data.linkHealthBusy  = true;
    data.linkHealthError = "";
    try {
        var post = getInstance( "Post" ).find( pid );
        if ( isNull( post ) ) {
            data.linkHealthError = "Post not found.";
            return;
        }
        var urls    = outboundLinkService.extractFromPost( post );
        var results = [];
        for ( var u in urls ) {
            var probe = outboundLinkService.checkUrl( u );
            results.append( {
                "url"            : u,
                "statusCode"     : probe.statusCode,
                "errorMessage"   : probe.errorMessage,
                "redirectTarget" : probe.redirectTarget
            } );
        }
        outboundLinkService.recordResults( pid, results );
        data.flashOk = "Re-checked " & urls.len() & " outbound link(s).";
    }
    catch ( any e ) {
        data.linkHealthError = "Audit failed: " & e.message;
    }
    finally {
        data.linkHealthBusy = false;
    }
}

// --------------------------------------------------------------------
// SEO Phase 14 — GSC search-performance tab
// --------------------------------------------------------------------

function openPerformance()  { data.showPerformance = true;  }
function closePerformance() { data.showPerformance = false; }

/**
 * Top 10 queries for this post in the last 28 days. Reads
 * from `seo_search_analytics` (populated by GscDailySyncJob);
 * empty when the post has never appeared in GSC data or the
 * sync hasn't run yet.
 */
array function performanceQueries() {
    var pid = val( data.postId ?: 0 );
    if ( pid <= 0 ) return [];
    try { return gscService.topQueriesForPost( postId = pid, days = 28, n = 10 ); }
    catch ( any e ) { return []; }
}

/**
 * 28-day rollup for THIS post — totals shown in the
 * Performance modal header.
 */
struct function performanceRollup() {
    var pid = val( data.postId ?: 0 );
    if ( pid <= 0 ) return { clicks : 0, impressions : 0, ctr : 0, position : 0 };
    try {
        var qb  = getInstance( "QueryBuilder@qb" );
        var row = qb.newQuery().from( "seo_search_analytics" )
            .where( "post_id", pid )
            .where( "date", ">=", dateFormat( dateAdd( "d", -28, now() ), "yyyy-mm-dd" ) )
            .selectRaw( "
                COALESCE( SUM( clicks ),      0 ) AS clicks,
                COALESCE( SUM( impressions ), 0 ) AS impressions,
                COALESCE( AVG( ctr ),         0 ) AS ctr,
                COALESCE( AVG( position ),    0 ) AS position
            " )
            .first();
        return {
            "clicks"      : val( row.clicks      ?: 0 ),
            "impressions" : val( row.impressions ?: 0 ),
            "ctr"         : val( row.ctr         ?: 0 ),
            "position"    : val( row.position    ?: 0 )
        };
    }
    catch ( any e ) {
        return { clicks : 0, impressions : 0, ctr : 0, position : 0 };
    }
}

// --------------------------------------------------------------------
// SEO Phase 7 — schema.org type picker + AI suggest
// --------------------------------------------------------------------

/**
 * Whitelist of schema types the picker offers. Anything else stored
 * in posts.schema_type is preserved on save (no destructive sync)
 * but the picker will display "(custom)" so the admin can change it
 * via direct DB tooling without the wire reverting.
 */
array function schemaTypeOptions() {
    return [
        { "value" : "",            "label" : "Article (default)" },
        { "value" : "BlogPosting", "label" : "BlogPosting" },
        { "value" : "NewsArticle", "label" : "NewsArticle" },
        { "value" : "FAQPage",     "label" : "FAQ" },
        { "value" : "HowTo",       "label" : "HowTo" },
        { "value" : "Recipe",      "label" : "Recipe" },
        { "value" : "Product",     "label" : "Product" },
        { "value" : "VideoObject", "label" : "VideoObject" }
    ];
}

function aiSuggestSchemaType() {
    data.aiError = "";
    if ( !len( trim( data.title ?: "" ) ) && !len( trim( data.bodyMarkdown ?: "" ) ) ) {
        data.aiError = "Add a title or body before asking for a schema-type suggestion.";
        return;
    }
    try {
        var result = aiService.suggestSchemaType(
            title  = data.title ?: "",
            body   = data.bodyMarkdown ?: "",
            userId = cbauth.getUser().getId()
        );
        // Apply the suggestion; the user can change via the picker.
        data.schemaType = result.schemaType;
        // Default-fill schemaData with an empty type-specific shape
        // so the JSON editor doesn't sit on `{}` after a switch.
        data.schemaDataJson = defaultSchemaDataFor( result.schemaType );
        data.flashOk = "Schema suggested: " & result.schemaType;
    }
    catch ( bxBlogger.AiUnavailable e )    { data.aiError = e.message; }
    catch ( bxBlogger.AiBudgetExceeded e ) { data.aiError = e.message; }
    catch ( bxBlogger.AiInvalidInput e )   { data.aiError = e.message; }
    catch ( bxBlogger.AiProviderError e )  { data.aiError = "The AI provider failed: " & e.message; }
    catch ( any e )                         { data.aiError = "Unexpected failure: " & e.message; }
}

/**
 * Whenever the picker changes type, swap the JSON editor's
 * placeholder so the user has a working starting struct.
 */
function onSchemaTypeChange() {
    var current = trim( data.schemaDataJson ?: "" );
    if ( !len( current ) || current == "{}" || current == "" ) {
        data.schemaDataJson = defaultSchemaDataFor( data.schemaType );
    }
}

/**
 * Default empty shape for each schema type — gives the admin a
 * starting struct to fill out instead of an empty `{}`.
 */
private string function defaultSchemaDataFor( required string sType ) {
    switch ( arguments.sType ) {
        case "FAQPage":     return jsonSerialize( { "items" : [ { "question" : "", "answer" : "" } ] } );
        case "HowTo":       return jsonSerialize( { "totalTime" : "", "steps" : [ { "name" : "", "text" : "" } ] } );
        case "Recipe":      return jsonSerialize( { "prepTime" : "", "cookTime" : "", "recipeYield" : "", "ingredients" : [ "" ], "instructions" : [ "" ] } );
        case "Product":     return jsonSerialize( { "sku" : "", "brand" : "", "price" : "", "priceCurrency" : "USD", "availability" : "InStock" } );
        case "VideoObject": return jsonSerialize( { "contentUrl" : "", "embedUrl" : "", "duration" : "PT0M0S", "uploadDate" : "", "thumbnailUrl" : "" } );
        default: return "{}";
    }
}

/**
 * Build the data struct the preview cards render — same fallback
 * chain SeoService.buildForPost uses (seo_title || title;
 * seo_description || excerpt) and the same 60/160 truncation. Pure
 * function of wire data + a single OgImageService lookup; runs on
 * every modal render so the previews update as the user types.
 */
struct function previewData() {
    var titleRaw = len( trim( data.seoTitle ?: "" ) ) ? data.seoTitle : ( data.title ?: "Untitled" );
    var descRaw  = len( trim( data.seoDescription ?: "" ) ) ? data.seoDescription : ( data.excerpt ?: "" );

    var siteHost = cgi.http_host ?: ( cgi.server_name ?: "localhost" );
    var slug     = data.slug ?: "";
    var url      = "https://" & siteHost & "/blog/" & slug;

    return {
        "title"     : truncateForSerp( titleRaw, 60 ),
        "titleFull" : titleRaw,
        "desc"      : truncateForSerp( descRaw, 160 ),
        "descFull"  : descRaw,
        "url"       : url,
        "host"      : siteHost,
        "slug"      : slug,
        "image"     : ogImageUrl(),
        "twitter"   : settingService.get( "social.twitter_handle", "" )
    };
}

private string function truncateForSerp( required string raw, required numeric max ) {
    var t = trim( arguments.raw );
    if ( len( t ) <= arguments.max ) return t;
    return left( t, arguments.max - 1 ) & "…";
}

/**
 * Reports list for the History dropdown. Only returns rows that
 * actually have a saved report to load — pending / failed rows
 * would render as empty when picked.
 */
array function auditHistory() {
    if ( ( data.postId ?: 0 ) <= 0 ) return [];
    var rows = auditAgentService.listReports( postId = data.postId, limit = 20 );
    var out = [];
    for ( var r in rows ) {
        if ( ( r.status ?: "" ) == "complete" && len( r.report_markdown ?: "" ) ) {
            out.append( r );
        }
        if ( out.len() >= 10 ) break;
    }
    return out;
}

// --------------------------------------------------------------------
// 2.I — AI image generation
// --------------------------------------------------------------------

function aiImageEnabled() {
    var user = cbauth.getUser();
    return aiImageService.isEnabled() && user.hasPermission( "posts.ai.image_generate" );
}

/**
 * Render-time helper for the preview <img src="...">. Looks the URL up
 * from the provider's in-memory cache so the wire never serializes
 * the raw URL into its data snapshot — see generateImagePreviews
 * for the why (multi-MB data: URLs would 400 the next click).
 */
string function previewSrc( required string previewId ) {
    return aiImageService.getPreviewUrl( arguments.previewId );
}

/**
 * Open the image modal. `target` is "inline" (insert into body at end)
 * or "featured" (set featured_media_id on save). Resetting previews
 * here means every click starts with an empty grid — authors don't
 * see stale previews from the last attempt.
 */
function openImageModal( string target = "inline" ) {
    if ( !aiImageEnabled() ) { data.imageError = "AI image generation is disabled."; return; }
    data.showImageModal = true;
    data.imagePrompt    = "";
    data.imageStyle     = "";
    data.imagePreviews  = [];
    data.imageError     = "";
    data.imageTarget    = arguments.target;
}

function closeImageModal() {
    data.showImageModal = false;
    data.imageBusy      = false;
    data.imagePreviews  = [];
    data.imageError     = "";
}

function generateImagePreviews() {
    if ( !aiImageEnabled() ) { data.imageError = "AI image generation is disabled."; return; }
    data.imageBusy    = true;
    data.imageError   = "";
    data.imagePreviews = [];
    try {
        var result = aiImageService.generateImages(
            prompt    = data.imagePrompt,
            styleHint = data.imageStyle,
            userId    = cbauth.getUser().getId(),
            context   = data.imageTarget
        );
        // Strip provider URLs from the serialized wire data — Gemini
        // Flash and similar inline-image providers return data: URLs
        // that can be multi-MB each. CBWIRE round-trips the entire
        // wire `data` struct on every action; with a couple of
        // previews the snapshot easily exceeds Undertow's max POST
        // body and the next click returns 400. The provider keeps
        // the URL in its in-memory cache and the template helper
        // `previewSrc(previewId)` looks it up on render.
        var lightweight = [];
        for ( var p in result.previews ) {
            lightweight.append( {
                "previewId" : p.previewId,
                "expiresAt" : p.expiresAt,
                "width"     : p.width  ?: 0,
                "height"    : p.height ?: 0,
                "mime"      : p.mime   ?: "image/png"
            } );
        }
        data.imagePreviews = lightweight;
    }
    catch ( bxBlogger.AiImageRateLimited e )    { data.imageError = e.message; }
    catch ( bxBlogger.AiImageBudgetExceeded e ) { data.imageError = e.message; }
    catch ( bxBlogger.AiInvalidInput e )        { data.imageError = e.message; }
    catch ( bxBlogger.AiImageDisabled e )       { data.imageError = e.message; }
    catch ( bxBlogger.AiProviderError e )       { data.imageError = "Provider: " & e.message; }
    catch ( any e )                              { data.imageError = "Unexpected: " & e.message; }
    finally { data.imageBusy = false; }
}

/**
 * Save the chosen preview into the media library and insert/attach.
 * For "inline" we append a markdown `![alt](url)` to the body buffer;
 * for "featured" we set featuredMediaId on the post buffer (next
 * save() persists it).
 */
function useImagePreview( required previewId ) {
    if ( !aiImageEnabled() ) { data.imageError = "AI image generation is disabled."; return; }
    try {
        var media = aiImageService.saveGeneratedImage(
            previewId = arguments.previewId,
            userId    = cbauth.getUser().getId(),
            role      = data.imageTarget
        );

        // `mediaUrl` not `url` — CFML reserved scope name.
        var mediaUrl = getInstance( "MediaService" ).urlFor( media );
        var alt      = media.getAltText() ?: "Generated image";

        if ( data.imageTarget == "featured" ) {
            data.featuredMediaId = media.getId();
            data.flashOk = "Featured image set.";
        } else {
            var snippet = char( 10 ) & char( 10 ) & "![" & alt & "](" & mediaUrl & ")" & char( 10 );
            data.bodyMarkdown = ( data.bodyMarkdown ?: "" ) & snippet;
            data.flashOk = "Image inserted into the post body.";
        }
        closeImageModal();
    }
    catch ( bxBlogger.AiPreviewExpired e ) { data.imageError = e.message; }
    catch ( any e )                         { data.imageError = "Could not save image: " & e.message; }
}

// --------------------------------------------------------------------
// Helpers
// --------------------------------------------------------------------

private struct function collectAttrs() {
    var attrs = {
        "title"          : trim( data.title ),
        "slug"           : len( trim( data.slug ) ) ? data.slug : postService.slugify( data.title ),
        "excerpt"        : data.excerpt,
        "bodyMarkdown"   : data.bodyMarkdown,
        "postType"       : data.postType,
        "visibility"     : data.visibility,
        "seoTitle"       : data.seoTitle,
        "seoDescription" : data.seoDescription,
        "focusKeyword"   : trim( data.focusKeyword ?: "" ),
        "schemaType"     : trim( data.schemaType ?: "" ),
        "schemaData"     : trim( data.schemaDataJson ?: "" ) == "{}" ? "" : trim( data.schemaDataJson ?: "" ),
        "allowIndexing"  : data.allowIndexing ? 1 : 0,
        // 4.C — Theme.templateView() treats empty and the literal
        // "default" interchangeably as "render the base view", so we
        // persist whichever the user picks without routing through
        // a qb null-clear (Quick drops null-assigns silently; the
        // clean-to-null variant is a Phase 4.D follow-up).
        "templateOverride" : trim( data.templateOverride ?: "" )
    };
    // Always include featuredMediaId — 0 is the sentinel value the
    // "Remove" button sets (wire:click="$set('featuredMediaId', 0)"),
    // and PostService.update translates 0 into a qb-side NULL on the
    // posts.featured_media_id column. Previous `> 0` guard silently
    // dropped the attribute on remove, so the DB kept whatever image
    // was attached before.
    attrs.featuredMediaId = val( data.featuredMediaId ?: 0 );
    // Featured pin — sidebar checkbox. PostService.normalize stamps
    // featured_at on transitions to true; the timestamp is what
    // PublicPostService.listFeatured() sorts by, so re-pinning bumps
    // the post back to the top of the home featured section.
    attrs.featured = !!data.featured;
    return attrs;
}

private array function validate() {
    var errors = [];
    if ( !len( trim( data.title ) ) )        errors.append( "Title is required." );
    if ( !len( trim( data.bodyMarkdown ) ) ) errors.append( "Body is required." );
    if ( len( data.title ) > 300 )           errors.append( "Title cannot exceed 300 characters." );
    return errors;
}

private boolean function canSave() {
    var user = cbauth.getUser();
    if ( ( data.postId ?: 0 ) == 0 ) return user.hasPermission( "posts.create" );
    var post = getInstance( "Post" ).find( data.postId );
    if ( isNull( post ) ) return false;
    return post.getAuthorId() == user.getId()
        ? user.hasPermission( "posts.edit.own" )
        : user.hasPermission( "posts.edit.others" );
}

private boolean function canPublish() {
    var user = cbauth.getUser();
    if ( ( data.postId ?: 0 ) == 0 ) return user.hasPermission( "posts.publish.own" );
    var post = getInstance( "Post" ).find( data.postId );
    if ( isNull( post ) ) return false;
    return post.getAuthorId() == user.getId()
        ? user.hasPermission( "posts.publish.own" )
        : user.hasPermission( "posts.publish.others" );
}

private function clearFlashes() {
    data.flashOk = "";
    data.flashError = "";
    data.validationErrors = [];
}

/**
 * 4.C — build dropdown options for the Template sidebar control.
 * Reads the active theme's manifest via ThemeService; always leads
 * with a `{ slug: "default", label: "Default" }` entry.
 */
array function availableTemplates() {
    return themeService.templatesForPostType( data.postType ?: "post" );
}

// --------------------------------------------------------------------
// Phase UX — Taxonomy (categories + tags)
// --------------------------------------------------------------------

/**
 * Flat tree of every category, annotated with depth for the template
 * indent. Uses CategoryService.listAll() (path-sorted) so parents
 * always come before their children.
 */
array function allCategoriesFlat() {
    var rows = getInstance( "CategoryService" ).listAll();
    var out  = [];
    for ( var c in rows ) {
        out.append( {
            "id"    : c.getId(),
            "name"  : c.getName(),
            "depth" : listLen( c.getPath(), "/" ) - 1
        } );
    }
    return out;
}

/**
 * Array of existing tag names for the `<datalist>` autocomplete.
 * Ordered alphabetically, capped — if someone has thousands of tags
 * we'll want a live search, but the cap keeps the initial payload
 * reasonable without that work.
 */
array function allTagNames() {
    return getInstance( "QueryBuilder@qb" ).newQuery()
        .from( "tags" )
        .orderBy( "name", "asc" )
        .limit( 500 )
        .select( "name" )
        .get()
        .map( ( r ) => r.name );
}

/**
 * Toggle membership of a category id in data.categoryIds. Called by
 * each row's wire:click on the checkbox; we handle it server-side so
 * the tree renders its own state from the authoritative wire data
 * (no `wire:model` array binding that can drift from the checkbox
 * visual state on re-render).
 */
function toggleCategory( required id ) {
    var cur = data.categoryIds ?: [];
    var idx = cur.findNoCase( arguments.id );
    if ( idx ) {
        cur.deleteAt( idx );
    } else {
        cur.append( arguments.id );
    }
    data.categoryIds = cur;
}

/**
 * Split the free-text tags field on commas, strip blanks. Used by
 * save() to feed PostService.syncTags.
 */
private array function parseTagsText( required string text ) {
    var out = [];
    for ( var part in listToArray( arguments.text, "," ) ) {
        var n = trim( part );
        if ( len( n ) ) out.append( n );
    }
    return out;
}

// --------------------------------------------------------------------
// OG image widget (Step 5)
// --------------------------------------------------------------------

/**
 * URL of the rendered OG image for the current post, including a
 * cache-busting `?v=<og_version>` so the editor always shows the
 * latest render even when the browser holds the prior version. Empty
 * when the post hasn't been saved yet — the widget surfaces a "Save
 * to generate" hint instead.
 */
function ogImageUrl() {
    if ( ( data.postId ?: 0 ) <= 0 ) return "";
    var post = getInstance( "Post" ).find( data.postId );
    if ( isNull( post ) ) return "";
    var disk    = getInstance( "DiskService@cbfs" ).get( "og" );
    var keyPath = getInstance( "OgImageService" ).pathFor( post );
    if ( !disk.exists( keyPath ) ) return "";
    var base = disk.url( keyPath );
    return base & ( base contains "?" ? "&" : "?" ) & "v=" & val( post.getOgVersion() ?: 0 );
}

/**
 * Manual regenerate from the editor button. Bumps og_version + writes
 * a new file on the spot via OgImageService.regenerate so the new
 * thumbnail shows up the moment the wire re-renders. Bypasses the
 * job queue intentionally — the user clicked Regenerate; they want
 * the result NOW, not when the worker gets to it.
 */
function regenerateOgImage() {
    if ( ( data.postId ?: 0 ) <= 0 ) {
        data.flashError = "Save the post before regenerating its OG image.";
        return;
    }
    var post = getInstance( "Post" ).find( data.postId );
    if ( isNull( post ) ) return;
    getInstance( "OgImageService" ).regenerate( post );

    var fresh = getInstance( "Post" ).find( data.postId );
    data.ogVersion     = val( fresh.getOgVersion() ?: 0 );
    data.ogGeneratedAt = ogGeneratedAtFor( fresh );
    data.flashOk       = "OG image regenerated.";
}

/**
 * Toggle the "use OG image as featured image everywhere" flag —
 * persisted onto the post the moment it changes so theme renders
 * pick it up without needing a Save click.
 */
function toggleOgAsFeatured() {
    if ( ( data.postId ?: 0 ) <= 0 ) return;
    var post = getInstance( "Post" ).find( data.postId );
    if ( isNull( post ) ) return;
    var newVal = data.ogAsFeaturedImage ? 1 : 0;
    post.setOgAsFeaturedImage( newVal );
    post.save();
}

private string function ogGeneratedAtFor( required any post ) {
    try {
        var disk = getInstance( "DiskService@cbfs" ).get( "og" );
        var key  = getInstance( "OgImageService" ).pathFor( arguments.post );
        if ( !disk.exists( key ) ) return "";
        return dateTimeFormat( disk.lastModified( key ), "yyyy-mm-dd HH:nn" );
    }
    catch ( any e ) {
        return "";
    }
}
// @endWire
</bx:script>

<bx:output>
<div>
	<!---
	  Persistent wrapper for the flash + validation alerts. Keep this
	  div ALWAYS present (even when every alert inside is empty) so the
	  positional morphdom diff never sees the editor row shift from
	  child[0] to child[1] when an alert appears after a save. Without
	  this wrapper the wire:ignore'd EasyMDE container two siblings
	  away gets nuked because morphdom treats the position-0 mismatch
	  as a "replace from here forward" cue and walks past wire:ignore.
	--->
	<div class="post-editor-alerts">
		<bx:if len( args.flashOk )>
			<div class="alert alert-success alert-dismissible fade show"
			     role="alert"
			     x-data
			     x-init="setTimeout( () => window._postEditor &amp;&amp; window._postEditor.set( 'flashOk', '' ), 20000 )">
				#encodeForHTML( args.flashOk )#
				<button type="button" class="btn-close" wire:click="$set('flashOk','')"></button>
			</div>
		</bx:if>
		<bx:if len( args.flashError )>
			<div class="alert alert-danger alert-dismissible fade show"
			     role="alert"
			     x-data
			     x-init="setTimeout( () => window._postEditor &amp;&amp; window._postEditor.set( 'flashError', '' ), 20000 )">
				#encodeForHTML( args.flashError )#
				<button type="button" class="btn-close" wire:click="$set('flashError','')"></button>
			</div>
		</bx:if>
		<bx:if args.validationErrors.len()>
			<div class="alert alert-warning">
				<strong>Fix these before saving:</strong>
				<ul class="mb-0">
					<bx:loop array="#args.validationErrors#" item="err">
						<li>#encodeForHTML( err )#</li>
					</bx:loop>
				</ul>
			</div>
		</bx:if>
	</div>

	<div class="row g-3">
		<!--- Main editor column --->
		<div class="col-lg-8">
			<div class="card stat-card stat-card-primary">
				<div class="card-header card-header-soft card-header-soft-primary">
					<span class="h6 mb-0">Post content</span>
				</div>
				<div class="card-body">
					<div class="mb-3">
						<label for="postTitle" class="form-label">Title</label>
						<input type="text"
						       id="postTitle"
						       class="form-control form-control-lg"
						       wire:model.blur="title"
						       placeholder="Your post title"
						       maxlength="300">
					</div>
					<div class="mb-3">
						<label for="postSlug" class="form-label d-flex justify-content-between align-items-center">
							<span>Slug</span>
							<button type="button" class="btn btn-sm btn-outline-secondary"
							        wire:click="regenerateSlug"
							        data-bs-toggle="tooltip" title="Regenerate slug from title"
							        aria-label="Regenerate slug from the current title">
								<i class="bi bi-arrow-repeat" aria-hidden="true"></i>
							</button>
						</label>
						<input type="text"
						       id="postSlug"
						       class="form-control"
						       wire:model.blur="slug">
						<small class="text-muted">Public URL: <code>/#args.slug#</code></small>
					</div>
					<div class="mb-3">
						<label for="postExcerpt" class="form-label d-flex justify-content-between align-items-center">
							<span>Excerpt</span>
							<bx:if aiEnabled()>
								<button type="button" class="btn btn-sm btn-outline-secondary"
								        wire:click="aiGenerateExcerpt"
								        wire:loading.attr="disabled"
								        wire:target="aiGenerateExcerpt"
								        data-bs-toggle="tooltip" title="Generate excerpt from body with AI"
								        aria-label="Generate excerpt from body with AI">
									<i class="bi bi-magic" aria-hidden="true"
									   wire:loading.remove wire:target="aiGenerateExcerpt"></i>
									<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"
									      wire:loading wire:target="aiGenerateExcerpt"></span>
								</button>
							</bx:if>
						</label>
						<textarea id="postExcerpt"
						          class="form-control"
						          rows="2"
						          maxlength="500"
						          wire:model.blur="excerpt"
						          placeholder="Short summary shown on archive pages and OG cards"></textarea>
					</div>
					<div class="mb-3">
						<label for="postBody" class="form-label d-flex justify-content-between align-items-center">
							<span>Body (markdown)</span>
							<div class="btn-group btn-group-sm" role="group" aria-label="Editor actions">
								<bx:if aiEnabled()>
									<button type="button" class="btn btn-outline-secondary"
									        wire:click="openAiModal"
									        wire:loading.attr="disabled"
									        wire:target="openAiModal,aiGenerateDraft,aiRequestReview"
									        data-bs-toggle="tooltip" title="Create from idea"
									        aria-label="Create body from an idea with AI">
										<i class="bi bi-stars" aria-hidden="true"
										   wire:loading.remove wire:target="openAiModal,aiGenerateDraft"></i>
										<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"
										      wire:loading wire:target="openAiModal,aiGenerateDraft"></span>
									</button>
									<button type="button" class="btn btn-outline-secondary"
									        wire:click="aiRequestReview"
									        wire:loading.attr="disabled"
									        wire:target="aiRequestReview,aiGenerateDraft"
									        data-bs-toggle="tooltip" title="Review & suggest edits"
									        aria-label="Ask AI to review the body and suggest edits">
										<i class="bi bi-chat-square-text" aria-hidden="true"
										   wire:loading.remove wire:target="aiRequestReview"></i>
										<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"
										      wire:loading wire:target="aiRequestReview"></span>
									</button>
								</bx:if>
								<bx:if aiImageEnabled()>
									<button type="button" class="btn btn-outline-secondary"
									        wire:click="openImageModal('inline')"
									        wire:loading.attr="disabled"
									        wire:target="openImageModal,generateImagePreviews"
									        data-bs-toggle="tooltip" title="Generate image"
									        aria-label="Generate an image with AI and insert inline">
										<i class="bi bi-image" aria-hidden="true"
										   wire:loading.remove wire:target="openImageModal,generateImagePreviews"></i>
										<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"
										      wire:loading wire:target="openImageModal,generateImagePreviews"></span>
									</button>
								</bx:if>
								<bx:if args.showPreview>
									<button type="button" class="btn btn-outline-secondary"
									        wire:click="hidePreview"
									        data-bs-toggle="tooltip" title="Hide preview"
									        aria-label="Hide the rendered preview">
										<i class="bi bi-eye-slash" aria-hidden="true"></i>
									</button>
								<bx:else>
									<!---
										Preview is an inline toggle, not a full
										save — skipping the full-page overlay
										would be overkill. Swapping the eye
										icon for a spinner during the request
										gives enough "working on it" feedback.
									--->
									<button type="button" class="btn btn-outline-secondary"
									        wire:click="preview"
									        wire:loading.attr="disabled"
									        wire:target="preview"
									        data-bs-toggle="tooltip" title="Preview"
									        aria-label="Render a preview of the post body">
										<i class="bi bi-eye" aria-hidden="true"
										   wire:loading.remove wire:target="preview"></i>
										<span class="spinner-border spinner-border-sm" role="status"
										      aria-hidden="true"
										      wire:loading wire:target="preview"></span>
									</button>
								</bx:if>
							</div>
						</label>
						<!---
						  wire:ignore — keeps CBWIRE from replacing the DOM
						  under the EasyMDE instance during wire re-renders.
						  EasyMDE owns this subtree after init; we sync back to
						  the `bodyMarkdown` wire prop on CodeMirror change
						  (see the init script at the bottom of this template).
						--->
						<div wire:ignore>
						<textarea id="postBody"
						          class="form-control font-monospace"
						          rows="18"
						          placeholder="## Hello world

Write in markdown. Headings, lists, **bold**, [links](https://example.com), and fenced code blocks all work.
">#encodeForHTML( args.bodyMarkdown ?: "" )#</textarea>
						</div>
					</div>

					<bx:if args.showPreview>
						<div class="mt-3 p-3 border rounded bg-light">
							<div class="small text-muted mb-2">Preview</div>
							<div class="post-preview">#args.bodyPreview#</div>
						</div>
					</bx:if>
				</div>
			</div>
		</div>

		<!--- Sidebar --->
		<div class="col-lg-4">
			<div class="card stat-card stat-card-info mb-3">
				<div class="card-header card-header-soft card-header-soft-info">
					<span class="h6 mb-0">Publish settings</span>
				</div>
				<div class="card-body">
					<div class="mb-2">
						<label for="postType" class="form-label small">Type</label>
						<select id="postType" class="form-select form-select-sm" wire:model.live="postType">
							<option value="post">Post</option>
							<option value="page">Page</option>
						</select>
					</div>
					<hr class="my-3">
					<p class="small mb-2">
						Current: <span class="badge bg-secondary text-uppercase">#encodeForHTML( args.status )#</span>
					</p>
					<div class="mb-2">
						<label for="postVisibility" class="form-label small">Visibility</label>
						<select id="postVisibility" class="form-select form-select-sm" wire:model.live="visibility">
							<option value="public">Public</option>
							<option value="private">Private</option>
							<option value="password">Password-protected</option>
						</select>
					</div>

					<!---
						4.C — Template override. Options come from the active
						theme's manifest `templates.{postType}[]`. Theme.templateView()
						treats an empty pick as "default", so "Default" here is
						really a sentinel for "render post.bxm unchanged".
					--->
					<bx:set templateOptions = availableTemplates()>
					<bx:if templateOptions.len() gt 1>
						<div class="mb-2">
							<label for="postTemplate" class="form-label small">Template</label>
							<select id="postTemplate" class="form-select form-select-sm"
							        wire:model.blur="templateOverride">
								<bx:loop array="#templateOptions#" item="opt">
									<option value="#encodeForHTMLAttribute( opt.slug )#">
										#encodeForHTML( opt.label )#
									</option>
								</bx:loop>
							</select>
						</div>
					</bx:if>

					<div class="mb-3">
						<label for="postSchedule" class="form-label small">Publish at (leave blank for now)</label>
						<input type="datetime-local"
						       id="postSchedule"
						       class="form-control form-control-sm"
						       wire:model.blur="scheduledAt">
					</div>

					<!---
						Featured pin — surfaces the post in the active theme's
						home-page featured section (when show_featured_section
						is on in /admin/themes/{slug}/options). PostService
						stamps featured_at on transitions to true so re-pinning
						bumps the post to the top.
					--->
					<bx:if args.postType == "post">
						<div class="form-check small mb-3">
							<input type="checkbox"
							       class="form-check-input"
							       id="postFeatured"
							       wire:model.live="featured"
							       value="1"
							       <bx:if val( args.featured ?: 0 )>checked</bx:if>>
							<label class="form-check-label" for="postFeatured">
								Pin to home as featured
							</label>
						</div>
					</bx:if>
					<div class="d-grid gap-2">
						<!---
							Each action button:
							- `onclick` shows the shared Bootstrap overlay
							  immediately (before the wire request leaves the
							  browser) so slow operations get instant feedback.
							- `wire:loading.attr="disabled"` greys the button
							  during the in-flight request so accidental
							  double-clicks don't stack.
							- `wire:target` scopes the spinner + disabled state
							  to this specific action — Save draft spinning
							  while you click Publish would be wrong.
							The layout's morph.updated hook hides the overlay
							on response, livewire:failed hook hides on error.
						--->
						<button class="btn btn-outline-primary"
						        wire:click="save"
						        wire:loading.attr="disabled"
						        wire:target="save"
						        onclick="WireOverlay.show( 'Saving…' );">
							<span class="spinner-border spinner-border-sm me-1"
							      role="status" aria-hidden="true"
							      wire:loading wire:target="save"></span>
							Save draft
						</button>
						<!---
							A7 — Submit for Review shows up for contributors
							who lack publish rights. For authors + editors the
							regular Publish button is the primary path; this
							button still works for them (it's a valid state
							transition) but we de-emphasize it.
						--->
						<button class="btn btn-outline-secondary btn-sm"
						        wire:click="submitForReview"
						        wire:loading.attr="disabled"
						        wire:target="submitForReview"
						        onclick="WireOverlay.show( 'Submitting…' );"
						        title="Flag as ready for an editor to review and publish">
							<span class="spinner-border spinner-border-sm me-1"
							      role="status" aria-hidden="true"
							      wire:loading wire:target="submitForReview"></span>
							Submit for review
						</button>
						<button class="btn btn-primary"
						        wire:click="publish"
						        wire:loading.attr="disabled"
						        wire:target="publish"
						        onclick="WireOverlay.show( <bx:if len( args.scheduledAt )>'Scheduling…'<bx:else>'Publishing…'</bx:if> );">
							<span class="spinner-border spinner-border-sm me-1"
							      role="status" aria-hidden="true"
							      wire:loading wire:target="publish"></span>
							<bx:if len( args.scheduledAt )>Schedule<bx:else>Publish</bx:if>
						</button>
						<bx:if ( args.postId ?: 0 ) gt 0 && args.status != "trashed">
							<!---
								No `onclick` overlay here — `wire:confirm` owns
								the confirmation dialog, and if we also called
								WireOverlay.show() in onclick the overlay would
								stick open when the user cancels (confirm
								aborts the wire request so morph.updated never
								fires to hide it). Button-level spinner + the
								disabled state is enough feedback for a fast op.
							--->
							<button class="btn btn-outline-danger btn-sm"
							        wire:click="trash"
							        wire:loading.attr="disabled"
							        wire:target="trash"
							        wire:confirm="Move this post to trash?">
								<span class="spinner-border spinner-border-sm me-1"
								      role="status" aria-hidden="true"
								      wire:loading wire:target="trash"></span>
								Move to trash
							</button>
						</bx:if>
						<!--- Phase 8.A — revision history link. Plain anchor
						      (not a wire action) because we want a full page
						      nav to the compare UI; the editor state stays
						      where the user left it on return. The route
						      `/admin/posts/:id/revisions` takes the id as a
						      path segment, so we build the URL directly
						      rather than go through `event.buildLink` with
						      a query string. --->
						<bx:if ( args.postId ?: 0 ) gt 0>
							<a class="btn btn-outline-secondary btn-sm"
							   href="/admin/posts/#args.postId#/revisions"
							   title="Compare and restore prior revisions">
								Revisions
							</a>
						</bx:if>
					</div>

					<!--- B2 — Share Preview --->
					<bx:if ( args.postId ?: 0 ) gt 0>
						<hr class="my-3">
						<bx:if len( args.previewShareUrl )>
							<label class="form-label small">Preview link (expires #encodeForHTML( args.previewExpires )#)</label>
							<div class="input-group input-group-sm mb-1">
								<input type="text" class="form-control" readonly value="#encodeForHTMLAttribute( args.previewShareUrl )#">
								<button type="button" class="btn btn-outline-secondary"
								        onclick="navigator.clipboard.writeText(this.previousElementSibling.value)">Copy</button>
							</div>
							<button type="button" class="btn btn-sm btn-link p-0"
							        wire:click="dismissShareLink">Dismiss</button>
						<bx:else>
							<button class="btn btn-sm btn-outline-secondary w-100" wire:click="sharePreview">
								Share preview link
							</button>
						</bx:if>
					</bx:if>

					<!--- B5 — Autosave indicator + client timer --->
					<bx:if ( args.postId ?: 0 ) gt 0 && args.status != "trashed">
						<hr class="my-3">
						<div class="small text-muted" data-autosave-indicator>
							<bx:if len( args.lastAutosaveAt )>
								Autosaved at #encodeForHTML( args.lastAutosaveAt )#
							<bx:else>
								Autosave enabled (every 30s)
							</bx:if>
						</div>
					</bx:if>
				</div>
			</div>

			<!--- Featured image panel — collapsible ---------------- --->
			<div class="card stat-card stat-card-success mb-3 sidebar-collapsible">
				<div class="card-header card-header-soft card-header-soft-success d-flex align-items-center justify-content-between"
				     role="button"
				     data-bs-toggle="collapse"
				     data-bs-target="##sidebarFeaturedImageBody"
				     aria-expanded="false"
				     wire:ignore.self
				     aria-controls="sidebarFeaturedImageBody">
					<span class="h6 mb-0">Featured image</span>
					<i class="bi bi-chevron-up sidebar-chevron text-muted" aria-hidden="true"></i>
				</div>
				<div class="collapse" id="sidebarFeaturedImageBody" wire:ignore.self>
					<div class="card-body">
						<bx:if val( args.featuredMediaId ?: 0 ) gt 0>
							<bx:script>
								fm = getInstance( "Media" ).find( args.featuredMediaId );
							</bx:script>
							<bx:if !isNull( fm )>
								<img src="#getInstance( 'MediaService' ).urlFor( fm )#"
								     class="img-fluid rounded mb-2"
								     alt="#encodeForHTMLAttribute( fm.getAltText() ?: '' )#">
								<p class="small text-muted mb-2 text-truncate">#encodeForHTML( fm.getOriginalFilename() )#</p>
							</bx:if>
						<bx:else>
							<p class="small text-muted mb-2">No featured image yet.</p>
						</bx:if>
						<div class="d-grid gap-2">
							<button type="button" class="btn btn-sm btn-primary"
							        wire:click="openMediaPicker('featured')">
								<i class="bi bi-images" aria-hidden="true"></i>
								<bx:if val( args.featuredMediaId ?: 0 ) gt 0>Replace featured image<bx:else>Select from media library</bx:if>
							</button>
							<bx:if aiImageEnabled()>
								<button type="button" class="btn btn-sm btn-outline-primary"
								        wire:click="openImageModal('featured')">
									<i class="bi bi-stars" aria-hidden="true"></i> Generate with AI
								</button>
							</bx:if>
							<bx:if val( args.featuredMediaId ?: 0 ) gt 0>
								<button type="button" class="btn btn-sm btn-outline-secondary"
								        wire:click="$set('featuredMediaId', 0)">
									<i class="bi bi-x-circle" aria-hidden="true"></i> Remove
								</button>
							</bx:if>
						</div>
					</div>
				</div>
			</div>

			<!--- OG image widget — collapsible ----------------------
			      Renders a thumbnail of the auto-generated share card,
			      a version + timestamp stamp, and three actions:
			        Preview     — full-size modal preview
			        Copy link   — clipboard copy of the public PNG URL
			        Regenerate  — bumps og_version + writes a fresh PNG
			      When the post has a featured image AND an OG render
			      exists, an extra checkbox lets the author flip
			      `og_as_featured_image` so theme surfaces (home cards,
			      post header, related posts) substitute the OG card
			      for the featured image. Step 6 wires that into the
			      theme renderer.
			--------------------------------------------------------- --->
			<bx:script>
				ogUrl       = ogImageUrl();
				hasOgRender = len( ogUrl ) > 0;
			</bx:script>
			<div class="card stat-card stat-card-primary mb-3 sidebar-collapsible">
				<div class="card-header card-header-soft card-header-soft-primary d-flex align-items-center justify-content-between"
				     role="button"
				     data-bs-toggle="collapse"
				     data-bs-target="##sidebarOgImageBody"
				     aria-expanded="false"
				     wire:ignore.self
				     aria-controls="sidebarOgImageBody">
					<span class="h6 mb-0">OG image</span>
					<i class="bi bi-chevron-up sidebar-chevron text-muted" aria-hidden="true"></i>
				</div>
				<div class="collapse" id="sidebarOgImageBody" wire:ignore.self>
					<div class="card-body">
						<bx:if ( args.postId ?: 0 ) lte 0>
							<p class="small text-muted mb-0">
								Save the post to generate its OG share card.
							</p>
						<bx:else>
							<bx:if hasOgRender>
								<img src="#encodeForHTMLAttribute( ogUrl )#"
								     class="img-fluid rounded border mb-2"
								     alt="OG image preview"
								     style="max-height: 180px; cursor: zoom-in;"
								     data-bs-toggle="modal"
								     data-bs-target="##ogImagePreviewModal">
								<div class="small text-muted mb-3">
									v#encodeForHTML( args.ogVersion )#
									<bx:if len( args.ogGeneratedAt ?: "" )>
										&middot; generated #encodeForHTML( args.ogGeneratedAt )#
									</bx:if>
								</div>
							<bx:else>
								<p class="small text-muted mb-3">
									Not generated yet — click Regenerate to create one.
								</p>
							</bx:if>

							<div class="d-grid gap-2 mb-3">
								<bx:if hasOgRender>
									<div class="btn-group btn-group-sm" role="group">
										<button type="button"
										        class="btn btn-outline-primary"
										        data-bs-toggle="modal"
										        data-bs-target="##ogImagePreviewModal">
											<i class="bi bi-eye" aria-hidden="true"></i> Preview
										</button>
										<button type="button"
										        class="btn btn-outline-primary"
										        data-og-copy-link
										        data-og-url="#encodeForHTMLAttribute( ogUrl )#">
											<i class="bi bi-clipboard" aria-hidden="true"></i> Copy link
										</button>
										<button type="button"
										        class="btn btn-outline-primary"
										        wire:click="regenerateOgImage"
										        wire:loading.attr="disabled"
										        wire:target="regenerateOgImage"
										        onclick="WireOverlay.show( 'Regenerating OG image…' );">
											<i class="bi bi-arrow-clockwise" aria-hidden="true"></i> Regenerate
										</button>
									</div>
								<bx:else>
									<button type="button"
									        class="btn btn-sm btn-primary"
									        wire:click="regenerateOgImage"
									        wire:loading.attr="disabled"
									        wire:target="regenerateOgImage"
									        onclick="WireOverlay.show( 'Generating OG image…' );">
										<i class="bi bi-arrow-clockwise" aria-hidden="true"></i> Regenerate
									</button>
								</bx:if>
							</div>

							<bx:if val( args.featuredMediaId ?: 0 ) gt 0 && hasOgRender>
								<div class="form-check small">
									<input class="form-check-input"
									       type="checkbox"
									       id="ogAsFeaturedImage"
									       wire:model.live="ogAsFeaturedImage"
									       wire:change="toggleOgAsFeatured"
									       <bx:if val( args.ogAsFeaturedImage ?: 0 )>checked</bx:if>>
									<label class="form-check-label" for="ogAsFeaturedImage">
										Use OG image as featured image everywhere
									</label>
									<div class="form-text small">
										Replaces the featured image on home cards, post header,
										and related posts. Social previews always use the OG image.
									</div>
								</div>
							</bx:if>
						</bx:if>
					</div>
				</div>
			</div>

			<!--- OG image preview modal — full-size --->
			<bx:if hasOgRender>
				<div class="modal fade"
				     id="ogImagePreviewModal"
				     tabindex="-1"
				     aria-hidden="true"
				     wire:ignore.self>
					<div class="modal-dialog modal-xl modal-dialog-centered">
						<div class="modal-content">
							<div class="modal-header">
								<h5 class="modal-title">OG image preview</h5>
								<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
							</div>
							<div class="modal-body text-center">
								<img src="#encodeForHTMLAttribute( ogUrl )#"
								     class="img-fluid rounded"
								     alt="OG image full preview">
							</div>
							<div class="modal-footer">
								<a class="btn btn-outline-primary"
								   href="#encodeForHTMLAttribute( ogUrl )#"
								   target="_blank"
								   rel="noopener">
									<i class="bi bi-box-arrow-up-right" aria-hidden="true"></i> Open in new tab
								</a>
								<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
							</div>
						</div>
					</div>
				</div>
			</bx:if>

			<!--- Categories sidebar — collapsible --------------- --->
			<bx:script>
				catTree = allCategoriesFlat();
			</bx:script>
			<div class="card stat-card stat-card-info mb-3 sidebar-collapsible">
				<div class="card-header card-header-soft card-header-soft-info d-flex align-items-center justify-content-between"
				     role="button"
				     data-bs-toggle="collapse"
				     data-bs-target="##sidebarCategoriesBody"
				     aria-expanded="false"
				     wire:ignore.self
				     aria-controls="sidebarCategoriesBody">
					<span class="h6 mb-0">Categories</span>
					<i class="bi bi-chevron-up sidebar-chevron text-muted" aria-hidden="true"></i>
				</div>
				<div class="collapse" id="sidebarCategoriesBody" wire:ignore.self>
					<div class="card-body">
						<bx:if !catTree.len()>
							<p class="small text-muted mb-0">
								No categories yet. Add some at
								<a href="#event.buildLink( 'admin:Categories.index' )#">Categories</a>.
							</p>
						<bx:else>
							<div class="small" style="max-height: 16rem; overflow-y: auto;">
								<bx:loop array="#catTree#" item="c">
									<bx:set checked = args.categoryIds.findNoCase( c.id ) gt 0>
									<div class="form-check" style="padding-left: #( 1.5 + ( c.depth * 1.25 ) )#rem;">
										<input type="checkbox"
										       class="form-check-input"
										       id="cat-#c.id#"
										       #( checked ? 'checked' : '' )#
										       wire:click="toggleCategory(#c.id#)">
										<label class="form-check-label" for="cat-#c.id#">
											#encodeForHTML( c.name )#
										</label>
									</div>
								</bx:loop>
							</div>
						</bx:if>
					</div>
				</div>
			</div>

			<!--- Tags sidebar — collapsible -------------------------- --->
			<bx:script>
				existingTags = allTagNames();
			</bx:script>
			<div class="card stat-card stat-card-secondary mb-3 sidebar-collapsible">
				<div class="card-header card-header-soft card-header-soft-secondary d-flex align-items-center justify-content-between"
				     role="button"
				     data-bs-toggle="collapse"
				     data-bs-target="##sidebarTagsBody"
				     aria-expanded="false"
				     wire:ignore.self
				     aria-controls="sidebarTagsBody">
					<span class="h6 mb-0">Tags</span>
					<i class="bi bi-chevron-up sidebar-chevron text-muted" aria-hidden="true"></i>
				</div>
				<div class="collapse" id="sidebarTagsBody" wire:ignore.self>
					<div class="card-body">
						<label for="postTags" class="form-label small d-block mb-1">
							Comma-separated. New tags are created on save.
						</label>
						<input type="text"
						       id="postTags"
						       class="form-control form-control-sm"
						       list="postTagsList"
						       wire:model.blur="tagsText"
						       placeholder="e.g. boxlang, release-notes, 1.0">
						<datalist id="postTagsList">
							<bx:loop array="#existingTags#" item="t">
								<option value="#encodeForHTMLAttribute( t )#"></option>
							</bx:loop>
						</datalist>
					</div>
				</div>
			</div>

			<!--- SEO sidebar — collapsible --------------------------- --->
			<div class="card stat-card stat-card-warning sidebar-collapsible">
				<div class="card-header card-header-soft card-header-soft-warning d-flex align-items-center justify-content-between"
				     role="button"
				     data-bs-toggle="collapse"
				     data-bs-target="##sidebarSeoBody"
				     aria-expanded="false"
				     wire:ignore.self
				     aria-controls="sidebarSeoBody">
					<span class="h6 mb-0">SEO</span>
					<i class="bi bi-chevron-up sidebar-chevron text-muted" aria-hidden="true"></i>
				</div>
				<div class="collapse" id="sidebarSeoBody" wire:ignore.self>
					<div class="card-body">
						<bx:set seoAiOn = seoAiAvailable()>
						<bx:set seoAiTooltip = seoAiOn ? "" : seoAiUnavailableReason()>

						<div class="mb-2">
							<label for="postSeoTitle" class="form-label small d-flex justify-content-between align-items-center">
								<span>SEO title</span>
								<span class="d-flex gap-1">
									<button type="button"
									        class="btn btn-sm btn-link p-0 small text-decoration-none"
									        wire:click="aiGenerateSeoTitle"
									        wire:target="aiGenerateSeoTitle"
									        wire:loading.attr="disabled"
									        title="#encodeForHTMLAttribute( seoAiOn ? "Generate an SEO-optimized title from the post body" : seoAiTooltip )#"
									        <bx:if !seoAiOn>disabled</bx:if>>
										<i class="bi bi-magic"
										   wire:loading.remove wire:target="aiGenerateSeoTitle"></i>
										<span class="spinner-border spinner-border-sm"
										      wire:loading wire:target="aiGenerateSeoTitle"></span>
										AI title
									</button>
									<button type="button"
									        class="btn btn-sm btn-link p-0 small text-decoration-none"
									        wire:click="aiSuggestCtrTitleVariants"
									        wire:target="aiSuggestCtrTitleVariants"
									        wire:loading.attr="disabled"
									        title="#encodeForHTMLAttribute( seoAiOn ? "Suggest 5 CTR-optimized title variants" : seoAiTooltip )#"
									        <bx:if !seoAiOn>disabled</bx:if>>
										<i class="bi bi-list-ol"
										   wire:loading.remove wire:target="aiSuggestCtrTitleVariants"></i>
										<span class="spinner-border spinner-border-sm"
										      wire:loading wire:target="aiSuggestCtrTitleVariants"></span>
										5 variants
									</button>
								</span>
							</label>
							<input type="text" id="postSeoTitle" class="form-control form-control-sm"
							       wire:model.blur="seoTitle" maxlength="255">
						</div>

						<div class="mb-2">
							<label for="postSeoDescription" class="form-label small d-flex justify-content-between align-items-center">
								<span>SEO description</span>
								<button type="button"
								        class="btn btn-sm btn-link p-0 small text-decoration-none"
								        wire:click="aiGenerateSeoDescription"
								        wire:target="aiGenerateSeoDescription"
								        wire:loading.attr="disabled"
								        title="#encodeForHTMLAttribute( seoAiOn ? "Generate an SEO meta description from the post body" : seoAiTooltip )#"
								        <bx:if !seoAiOn>disabled</bx:if>>
									<i class="bi bi-magic"
									   wire:loading.remove wire:target="aiGenerateSeoDescription"></i>
									<span class="spinner-border spinner-border-sm"
									      wire:loading wire:target="aiGenerateSeoDescription"></span>
									AI description
								</button>
							</label>
							<textarea id="postSeoDescription" class="form-control form-control-sm" rows="2"
							          maxlength="320" wire:model.blur="seoDescription"></textarea>
						</div>

						<div class="mb-2">
							<label for="postFocusKeyword" class="form-label small">Focus keyword</label>
							<input type="text" id="postFocusKeyword" class="form-control form-control-sm"
							       wire:model.blur="focusKeyword" maxlength="120"
							       placeholder="e.g. BoxLang adoption">
							<div class="form-text small">Drives the keyword-specific audit checks below + AI generators.</div>
						</div>

						<div class="mb-2">
							<label for="postSchemaType" class="form-label small d-flex justify-content-between align-items-center">
								<span>Schema.org type</span>
								<button type="button"
								        class="btn btn-sm btn-link p-0 small text-decoration-none"
								        wire:click="aiSuggestSchemaType"
								        wire:target="aiSuggestSchemaType"
								        wire:loading.attr="disabled"
								        title="Use AI to classify this post">
									<i class="bi bi-magic"
									   wire:loading.remove wire:target="aiSuggestSchemaType"></i>
									<span class="spinner-border spinner-border-sm"
									      wire:loading wire:target="aiSuggestSchemaType"></span>
									Suggest
								</button>
							</label>
							<select id="postSchemaType"
							        class="form-select form-select-sm"
							        wire:model.live="schemaType"
							        wire:change="onSchemaTypeChange">
								<bx:loop array="#schemaTypeOptions()#" item="opt">
									<option value="#encodeForHTMLAttribute( opt.value )#"
									        <bx:if args.schemaType == opt.value>selected</bx:if>>
										#encodeForHTML( opt.label )#
									</option>
								</bx:loop>
							</select>
							<bx:if len( args.schemaType )>
								<div class="mt-2">
									<label for="postSchemaData" class="form-label small mb-1">Schema data (JSON)</label>
									<textarea id="postSchemaData"
									          class="form-control form-control-sm font-monospace"
									          rows="6"
									          wire:model.blur="schemaDataJson"
									          spellcheck="false"></textarea>
									<div class="form-text small">Type-specific fields. Picker resets the shape on type change; edit in place to fill the values.</div>
								</div>
							</bx:if>
						</div>

						<div class="form-check">
							<input class="form-check-input" type="checkbox" id="postAllowIndexing"
							       wire:model.live="allowIndexing">
							<label class="form-check-label small" for="postAllowIndexing">
								Allow search indexing
							</label>
						</div>

						<!--- SEO Phase 5.1 - Live Audit Panel --->
						<bx:set audit = liveAudit()>
						<hr class="my-3">
						<div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-1">
							<span class="h6 mb-0">SEO audit</span>
							<span class="d-flex gap-1 flex-wrap">
								<button type="button"
								        class="btn btn-sm btn-outline-secondary"
								        wire:click="openPreviewPanel"
								        title="Preview how this post will appear in Google, Twitter, and Facebook">
									<i class="bi bi-eye me-1"></i> Preview
								</button>
								<button type="button"
								        class="btn btn-sm btn-outline-secondary"
								        wire:click="openInternalLinks"
								        title="Suggest internal links from existing posts">
									<i class="bi bi-link-45deg me-1"></i> Internal links
								</button>
								<bx:set obc = outboundBrokenCount()>
								<button type="button"
								        class="btn btn-sm <bx:if obc gt 0>btn-outline-danger<bx:else>btn-outline-secondary</bx:if>"
								        wire:click="openLinkHealth"
								        title="Outbound link health (broken external URLs)">
									<i class="bi bi-broadcast-pin me-1"></i>
									<bx:if obc gt 0>
										#obc# broken
									<bx:else>
										Link health
									</bx:if>
								</button>
								<button type="button"
								        class="btn btn-sm btn-outline-secondary"
								        wire:click="openPerformance"
								        title="Search-engine performance — top queries, clicks, impressions">
									<i class="bi bi-graph-up me-1"></i> Performance
								</button>
								<button type="button"
								        class="btn btn-sm btn-outline-primary"
								        wire:click="openAuditPanel"
								        title="Open the AI SEO Audit panel">
									<i class="bi bi-robot me-1"></i> AI Audit
								</button>
							</span>
						</div>
						<div class="d-flex justify-content-between align-items-center mb-2">
							<span class="text-muted small">Live deterministic score</span>
							<bx:set scoreClass = audit.score gte 80 ? "bg-success" : ( audit.score gte 60 ? "bg-warning text-dark" : "bg-danger" )>
							<span class="badge #scoreClass#" title="Live SEO audit score (0-100)">
								#audit.score#/100
							</span>
						</div>
						<div class="small text-muted mb-2">
							<i class="bi bi-circle-fill text-success"></i> #audit.summary.pass# pass
							&nbsp;<i class="bi bi-circle-fill text-warning"></i> #audit.summary.warn# warn
							&nbsp;<i class="bi bi-circle-fill text-danger"></i> #audit.summary.fail# fail
						</div>
						<div class="seo-audit-list small" style="max-height: 320px; overflow-y: auto;">
							<bx:loop array="#structKeyArray( audit.checks )#" item="checkKey">
								<bx:set ck = audit.checks[ checkKey ]>
								<bx:set dotClass = ck.status == "pass" ? "text-success" : ( ck.status == "warn" ? "text-warning" : "text-danger" )>
								<details class="mb-1">
									<summary class="d-flex align-items-start gap-2" style="cursor: pointer;">
										<i class="bi bi-circle-fill #dotClass# mt-1" style="font-size: .55rem;"></i>
										<span class="flex-grow-1">
											<strong>#humanizeCheckKey( checkKey )#:</strong>
											#encodeForHTML( ck.message )#
										</span>
									</summary>
									<bx:if len( ck.suggestion ?: "" )>
										<div class="ps-3 ms-1 mt-1 text-muted">
											#encodeForHTML( ck.suggestion )#
										</div>
									</bx:if>
								</details>
							</bx:loop>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!--- 2.H — inline AI error (modal-agnostic) ---------------------- --->
	<bx:if len( args.aiError )>
		<div class="alert alert-warning alert-dismissible mt-3">
			<strong>AI:</strong> #encodeForHTML( args.aiError )#
			<button type="button" class="btn-close" wire:click="$set('aiError','')"></button>
		</div>
	</bx:if>

	<!--- 2.H — Create-from-Idea modal ------------------------------- --->
	<bx:if args.showAiModal>
		<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.35);">
			<div class="modal-dialog">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">Create from idea</h5>
						<button type="button" class="btn-close" wire:click="closeAiModal"
						        wire:loading.attr="disabled" wire:target="aiGenerateDraft"></button>
					</div>
					<div class="modal-body">
						<bx:if len( args.aiError )>
							<div class="alert alert-warning small mb-3">
								<i class="bi bi-exclamation-triangle me-1"></i>#encodeForHTML( args.aiError )#
							</div>
						</bx:if>
						<label class="form-label small">Your idea (up to 1000 characters)</label>
						<textarea class="form-control" rows="5" maxlength="1000"
						          wire:model="aiIdea"
						          wire:loading.attr="disabled" wire:target="aiGenerateDraft"
						          placeholder="e.g. How to adopt BoxLang incrementally in a team that already ships ColdFusion."></textarea>
						<small class="text-muted d-block mt-2">
							Your idea is sent to the configured AI provider. See your privacy policy for details.
						</small>
						<div wire:loading wire:target="aiGenerateDraft" class="mt-3 text-muted">
							<span class="spinner-border spinner-border-sm me-2 align-middle" role="status" aria-hidden="true"></span>
							<span class="small align-middle">Generating draft &mdash; this can take 5&ndash;30 seconds depending on the model.</span>
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-outline-secondary"
						        wire:click="closeAiModal"
						        wire:loading.attr="disabled" wire:target="aiGenerateDraft">Cancel</button>
						<button type="button" class="btn btn-primary"
						        wire:click="aiGenerateDraft"
						        wire:loading.attr="disabled"
						        wire:loading.class="disabled">
							<span wire:loading.remove wire:target="aiGenerateDraft">Generate draft</span>
							<span wire:loading wire:target="aiGenerateDraft">
								<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
								Generating&hellip;
							</span>
						</button>
					</div>
				</div>
			</div>
		</div>
	</bx:if>

	<!--- 2.H — Review & Suggest panel ------------------------------- --->
	<bx:if args.showAiReview>
		<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.25);">
			<div class="modal-dialog modal-lg modal-dialog-scrollable">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">
							<bx:if args.aiBusy>
								Reviewing your post&hellip;
							<bx:else>
								Review suggestions (#args.aiSuggestions.len()#)
							</bx:if>
						</h5>
						<button type="button" class="btn-close" wire:click="closeAiReview"
						        wire:loading.attr="disabled" wire:target="aiRequestReview"></button>
					</div>
					<div class="modal-body">
						<bx:if len( args.aiError )>
							<div class="alert alert-warning small">
								<i class="bi bi-exclamation-triangle me-1"></i>#encodeForHTML( args.aiError )#
							</div>
						</bx:if>

						<div wire:loading wire:target="aiRequestReview" class="text-muted py-4">
							<span class="spinner-border spinner-border-sm me-2 align-middle" role="status" aria-hidden="true"></span>
							<span class="small align-middle">Asking the model to review your post &mdash; this can take 5&ndash;30 seconds.</span>
						</div>

						<div wire:loading.remove wire:target="aiRequestReview">
							<bx:if !len( args.aiError ) && args.aiSuggestions.len() == 0>
								<p class="text-muted small mb-0">No suggestions &mdash; either the post looks clean, or you&rsquo;ve handled them all.</p>
							</bx:if>
							<bx:loop array="#args.aiSuggestions#" item="s">
								<div class="card mb-2">
									<div class="card-body p-3">
										<div class="d-flex justify-content-between align-items-start mb-2">
											<span class="badge bg-secondary text-uppercase">#encodeForHTML( s.type ?: "general" )#</span>
											<small class="text-muted">#encodeForHTML( s.locationHint ?: "" )#</small>
										</div>
										<p class="small mb-2">#encodeForHTML( s.rationale ?: "" )#</p>
										<bx:if len( s.before ?: "" )>
											<div class="small">
												<div class="text-muted">Before:</div>
												<pre class="bg-light p-2 rounded small mb-2">#encodeForHTML( s.before )#</pre>
												<div class="text-muted">After:</div>
												<pre class="bg-light p-2 rounded small mb-0">#encodeForHTML( s.after ?: "" )#</pre>
											</div>
										</bx:if>
										<div class="d-flex gap-2 mt-2">
											<bx:if len( s.before ?: "" )>
												<button class="btn btn-sm btn-primary"
												        wire:click="acceptSuggestion('#encodeForHTMLAttribute( s.id ?: "" )#')">Accept</button>
											</bx:if>
											<button class="btn btn-sm btn-outline-secondary"
											        wire:click="dismissSuggestion('#encodeForHTMLAttribute( s.id ?: "" )#')">Dismiss</button>
										</div>
									</div>
								</div>
							</bx:loop>
						</div>
					</div>
					<div class="modal-footer">
						<small class="text-muted me-auto">
							Your content was sent to the configured AI provider.
						</small>
						<button type="button" class="btn btn-outline-secondary" wire:click="closeAiReview">Close</button>
					</div>
				</div>
			</div>
		</div>
	</bx:if>

	<!--- SEO Phase 4 — CTR title variants picker modal --------------- --->
	<bx:if args.showCtrModal>
		<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.25);">
			<div class="modal-dialog modal-lg">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">Pick an SEO title variant</h5>
						<button type="button" class="btn-close" wire:click="closeCtrModal"></button>
					</div>
					<div class="modal-body">
						<p class="text-muted small mb-3">
							Five title variants optimized for search-result click-through.
							Each uses a different angle (curiosity gap, listicle, year, brackets, question).
							Pick one to populate the SEO title field.
						</p>
						<div class="list-group">
							<bx:loop from="1" to="#args.ctrVariants.len()#" index="i">
								<button type="button"
								        class="list-group-item list-group-item-action"
								        wire:click="applyCtrVariant(#i#)">
									#encodeForHTML( args.ctrVariants[ i ] )#
								</button>
							</bx:loop>
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-outline-secondary" wire:click="closeCtrModal">Cancel</button>
					</div>
				</div>
			</div>
		</div>
	</bx:if>

	<!--- SEO Phase 5.2 — AI SEO Audit panel (modal) ------------------ --->
	<bx:if args.showAuditPanel>
		<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.35);">
			<div class="modal-dialog modal-xl modal-dialog-scrollable">
				<div class="modal-content" style="min-height: 70vh;">
					<div class="modal-header">
						<h5 class="modal-title">
							<i class="bi bi-robot me-1"></i> AI SEO Audit
						</h5>
						<button type="button" class="btn-close" wire:click="closeAuditPanel"></button>
					</div>
					<div class="modal-body" style="min-height: 60vh;">
						<bx:if len( args.auditError )>
							<div class="alert alert-warning small">
								<i class="bi bi-exclamation-triangle me-1"></i>#encodeForHTML( args.auditError )#
							</div>
						</bx:if>

						<div class="d-flex justify-content-between align-items-center mb-3">
							<div>
								<button type="button"
								        class="btn btn-primary btn-sm"
								        wire:click="runAiAudit"
								        wire:target="runAiAudit"
								        wire:loading.attr="disabled"
								        title="Run a fresh AI audit against the saved post">
									<i class="bi bi-magic me-1" wire:loading.remove wire:target="runAiAudit"></i>
									<span class="spinner-border spinner-border-sm me-1" wire:loading wire:target="runAiAudit"></span>
									#( ( args.currentAuditId ?: 0 ) > 0 ) ? "Re-run audit" : "Run audit"#
								</button>
								<bx:if val( args.auditTokens ) gt 0>
									<span class="ms-2 text-muted small">
										#numberFormat( args.auditTokens )# tokens
									</span>
								</bx:if>
							</div>

							<bx:set history = auditHistory()>
							<bx:if history.len() gt 1>
								<div class="dropdown">
									<button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
										History (#history.len()#)
									</button>
									<ul class="dropdown-menu dropdown-menu-end">
										<bx:loop array="#history#" item="h">
											<li>
												<button type="button"
												        class="dropdown-item small"
												        wire:click="loadAuditReport(#h.id#)">
													<bx:if h.id == args.currentAuditId><strong></bx:if>
													#dateTimeFormat( h.generated_at, "yyyy-mm-dd HH:nn" )#
													— score #h.deterministic_score#
													<bx:if h.id == args.currentAuditId></strong></bx:if>
												</button>
											</li>
										</bx:loop>
									</ul>
								</div>
							</bx:if>
						</div>

						<div wire:loading wire:target="runAiAudit" class="text-muted py-4 text-center">
							<span class="spinner-border spinner-border-sm me-2 align-middle"></span>
							<span class="small align-middle">Running tools and producing the audit &mdash; this can take 10&ndash;60 seconds.</span>
						</div>

						<div wire:loading.remove wire:target="runAiAudit">
							<bx:if len( args.auditMarkdown )>
								<div class="audit-report-body">
									#renderAuditMarkdown()#
								</div>

								<hr class="my-4">

								<form wire:submit.prevent="askAuditFollowUp">
									<label for="auditFollowUpQ" class="form-label small">Ask a follow-up</label>
									<div class="input-group">
										<input id="auditFollowUpQ"
										       type="text"
										       class="form-control"
										       wire:model.blur="auditFollowUpQ"
										       placeholder="e.g. Expand on the keyword density issue">
										<button type="submit"
										        class="btn btn-outline-primary"
										        wire:target="askAuditFollowUp"
										        wire:loading.attr="disabled">
											<i class="bi bi-send"
											   wire:loading.remove wire:target="askAuditFollowUp"></i>
											<span class="spinner-border spinner-border-sm"
											      wire:loading wire:target="askAuditFollowUp"></span>
											Ask
										</button>
									</div>
									<div class="form-text small">The agent retains the original audit in memory so the follow-up is contextual.</div>
								</form>
							<bx:else>
								<p class="text-muted small mb-0">No audit yet. Click <strong>Run audit</strong> to generate one.</p>
							</bx:if>
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-outline-secondary" wire:click="closeAuditPanel">Close</button>
					</div>
				</div>
			</div>
		</div>
	</bx:if>

	<!--- SEO Phase 6 — SERP + social card preview modal -------------- --->
	<bx:if args.showPreviewPanel>
		<bx:set pv = previewData()>
		<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.35);">
			<div class="modal-dialog modal-xl modal-dialog-scrollable">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">
							<i class="bi bi-eye me-1"></i> SERP &amp; Social Preview
						</h5>
						<button type="button" class="btn-close" wire:click="closePreviewPanel"></button>
					</div>
					<div class="modal-body">
						<p class="text-muted small mb-4">
							Live previews of how this post appears in Google, Twitter / X, and Facebook / LinkedIn.
							Values reflect the current editor state with the same fallbacks <code>SeoService</code> applies
							(seo title falls back to title; seo description falls back to excerpt) and the same 60 / 160 character truncation.
							Edit fields and reopen this panel to refresh.
						</p>

						<!--- Google SERP --->
						<h6 class="text-muted text-uppercase small mb-2">
							<i class="bi bi-google me-1"></i> Google search result
						</h6>
						<div class="card mb-4">
							<div class="card-body">
								<div class="small text-muted mb-1">
									<i class="bi bi-globe2 me-1"></i> #encodeForHTML( pv.host )#
									<span class="text-muted"> &rsaquo; </span>
									blog
									<span class="text-muted"> &rsaquo; </span>
									#encodeForHTML( pv.slug )#
								</div>
								<a href="##" class="d-block fs-5 fw-normal text-decoration-none" style="color:##1a0dab;" onclick="return false;">
									#encodeForHTML( pv.title )#
								</a>
								<div class="text-secondary small">
									#encodeForHTML( pv.desc )#
								</div>
							</div>
						</div>

						<!--- Twitter / X --->
						<h6 class="text-muted text-uppercase small mb-2">
							<i class="bi bi-twitter-x me-1"></i> Twitter / X card
						</h6>
						<div class="card mb-4" style="max-width: 540px;">
							<bx:if len( pv.image )>
								<img src="#encodeForHTMLAttribute( pv.image )#"
								     alt="#encodeForHTMLAttribute( pv.title )#"
								     class="card-img-top"
								     style="aspect-ratio: 1.91/1; object-fit: cover; background:##eee;">
							<bx:else>
								<div class="card-img-top d-flex align-items-center justify-content-center text-muted small bg-light"
								     style="aspect-ratio: 1.91/1;">
									(no OG image &mdash; will use text-only summary card)
								</div>
							</bx:if>
							<div class="card-body">
								<div class="small text-muted">#encodeForHTML( pv.host )#</div>
								<div class="fw-semibold">#encodeForHTML( pv.title )#</div>
								<div class="small text-secondary">#encodeForHTML( pv.desc )#</div>
								<bx:if len( pv.twitter )>
									<div class="small text-muted mt-1">via #encodeForHTML( pv.twitter )#</div>
								</bx:if>
							</div>
						</div>

						<!--- Facebook / LinkedIn --->
						<h6 class="text-muted text-uppercase small mb-2">
							<i class="bi bi-facebook me-1"></i> Facebook / LinkedIn share
						</h6>
						<div class="card" style="max-width: 600px;">
							<bx:if len( pv.image )>
								<img src="#encodeForHTMLAttribute( pv.image )#"
								     alt="#encodeForHTMLAttribute( pv.title )#"
								     class="card-img-top"
								     style="aspect-ratio: 1.91/1; object-fit: cover; background:##eee;">
							<bx:else>
								<div class="card-img-top d-flex align-items-center justify-content-center text-muted small bg-light"
								     style="aspect-ratio: 1.91/1;">
									(no OG image)
								</div>
							</bx:if>
							<div class="card-body" style="background:##f0f2f5;">
								<div class="small text-uppercase text-muted">#encodeForHTML( pv.host )#</div>
								<div class="fs-5 fw-semibold">#encodeForHTML( pv.title )#</div>
								<div class="small text-secondary">#encodeForHTML( pv.desc )#</div>
							</div>
						</div>

						<!--- Truncation hint --->
						<div class="alert alert-info small mt-4 mb-0">
							<strong>Truncation:</strong>
							title is shown at #len( pv.title )# / 60 chars,
							description at #len( pv.desc )# / 160 chars
							(full title #len( pv.titleFull )# chars, full description #len( pv.descFull )# chars).
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-outline-secondary" wire:click="closePreviewPanel">Close</button>
					</div>
				</div>
			</div>
		</div>
	</bx:if>

	<!--- SEO Phase 10 - internal-link suggestions modal --->
	<bx:if args.showInternalLinks>
		<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.35);">
			<div class="modal-dialog modal-lg modal-dialog-scrollable">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title"><i class="bi bi-link-45deg me-1"></i> Suggested internal links</h5>
						<button type="button" class="btn-close" wire:click="closeInternalLinks"></button>
					</div>
					<div class="modal-body">
						<bx:if len( args.internalLinksError )>
							<div class="alert alert-warning small">
								<i class="bi bi-exclamation-triangle me-1"></i>#encodeForHTML( args.internalLinksError )#
							</div>
						</bx:if>

						<div class="d-flex justify-content-between align-items-center mb-3 gap-3">
							<p class="text-muted small mb-0">
								The model picks 3-5 existing posts that semantically match this draft, then explains why
								each is a useful link. Click <strong>Insert</strong> to append a markdown link to the body.
							</p>
							<button type="button"
								        class="btn btn-sm btn-primary flex-shrink-0"
								        wire:click="suggestInternalLinks"
								        wire:target="suggestInternalLinks"
								        wire:loading.attr="disabled">
								<i class="bi bi-magic me-1" wire:loading.remove wire:target="suggestInternalLinks"></i>
								<span class="spinner-border spinner-border-sm me-1" wire:loading wire:target="suggestInternalLinks"></span>
								Suggest links
							</button>
						</div>

						<div wire:loading wire:target="suggestInternalLinks" class="text-muted py-4 text-center">
							<span class="spinner-border spinner-border-sm me-2 align-middle"></span>
							<span class="small align-middle">Analyzing your draft against the post catalog&hellip;</span>
						</div>

						<div wire:loading.remove wire:target="suggestInternalLinks">
							<bx:if args.internalLinks.len()>
								<div class="list-group">
									<bx:loop from="1" to="#args.internalLinks.len()#" index="i">
										<bx:set link = args.internalLinks[ i ]>
										<div class="list-group-item">
											<div class="d-flex justify-content-between align-items-start gap-3">
												<div class="flex-grow-1">
													<div class="fw-semibold">#encodeForHTML( link.title )#</div>
													<div class="small text-muted mb-1"><code>#encodeForHTML( link.url )#</code></div>
													<bx:if len( link.reason ?: "" )>
														<div class="small">#encodeForHTML( link.reason )#</div>
													</bx:if>
												</div>
												<button type="button"
												        class="btn btn-sm btn-outline-primary flex-shrink-0"
												        wire:click="insertInternalLink(#i#)">
													Insert
												</button>
											</div>
										</div>
									</bx:loop>
								</div>
							<bx:elseif !len( args.internalLinksError )>
								<p class="text-muted small mb-0">No suggestions yet. Click <strong>Suggest links</strong> to generate.</p>
							</bx:if>
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-outline-secondary" wire:click="closeInternalLinks">Close</button>
					</div>
				</div>
			</div>
		</div>
	</bx:if>

	<!--- SEO Phase 12 — outbound link health modal -------------------- --->
	<bx:if args.showLinkHealth>
		<bx:set rows = outboundLinkRows()>
		<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.35);">
			<div class="modal-dialog modal-lg modal-dialog-scrollable">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title"><i class="bi bi-broadcast-pin me-1"></i> Outbound link health</h5>
						<button type="button" class="btn-close" wire:click="closeLinkHealth"></button>
					</div>
					<div class="modal-body">
						<bx:if len( args.linkHealthError )>
							<div class="alert alert-warning small">
								<i class="bi bi-exclamation-triangle me-1"></i>#encodeForHTML( args.linkHealthError )#
							</div>
						</bx:if>

						<div class="d-flex justify-content-between align-items-center mb-3 gap-3">
							<p class="text-muted small mb-0">
								Status of every external URL referenced from the post body. Audited
								weekly + on demand. <strong>Re-check now</strong> probes each URL
								synchronously (slow if the post has many — per-host throttle is 1 rps).
							</p>
							<button type="button"
							        class="btn btn-sm btn-primary flex-shrink-0"
							        wire:click="auditOutboundLinksNow"
							        wire:target="auditOutboundLinksNow"
							        wire:loading.attr="disabled">
								<i class="bi bi-arrow-clockwise me-1" wire:loading.remove wire:target="auditOutboundLinksNow"></i>
								<span class="spinner-border spinner-border-sm me-1" wire:loading wire:target="auditOutboundLinksNow"></span>
								Re-check now
							</button>
						</div>

						<div wire:loading wire:target="auditOutboundLinksNow" class="text-muted py-4 text-center">
							<span class="spinner-border spinner-border-sm me-2 align-middle"></span>
							<span class="small align-middle">Probing each external URL&hellip;</span>
						</div>

						<div wire:loading.remove wire:target="auditOutboundLinksNow">
							<bx:if rows.len()>
								<div class="table-responsive">
									<table class="table table-sm align-middle">
										<thead class="small text-muted">
											<tr>
												<th>Status</th>
												<th>URL</th>
												<th class="text-nowrap">Last checked</th>
											</tr>
										</thead>
										<tbody>
											<bx:loop array="#rows#" item="r">
												<bx:set sc = val( r.status_code )>
												<bx:set isErr = ( sc == 0 || sc gte 400 )>
												<bx:set isRedir = ( sc gte 300 && sc lt 400 )>
												<bx:set badgeClass = isErr ? "bg-danger" : ( isRedir ? "bg-warning text-dark" : "bg-success" )>
												<bx:set label = ( sc == 0 ) ? "ERR" : sc>
												<tr>
													<td><span class="badge #badgeClass#">#label#</span></td>
													<td class="small">
														<a href="#encodeForHTMLAttribute( r.url )#" target="_blank" rel="noopener noreferrer">
															#encodeForHTML( r.url )#
														</a>
														<bx:if len( r.error_message ?: "" )>
															<div class="text-danger small">#encodeForHTML( r.error_message )#</div>
														</bx:if>
														<bx:if isRedir && len( r.redirect_target ?: "" )>
															<div class="text-muted small">
																→ <code>#encodeForHTML( r.redirect_target )#</code>
															</div>
														</bx:if>
													</td>
													<td class="small text-nowrap">
														<bx:if isDate( r.last_checked_at ?: "" )>
															#dateTimeFormat( r.last_checked_at, "yyyy-mm-dd HH:nn" )#
														<bx:else>
															&mdash;
														</bx:if>
													</td>
												</tr>
											</bx:loop>
										</tbody>
									</table>
								</div>
							<bx:else>
								<p class="text-muted small mb-0">
									No outbound links recorded for this post yet. Click
									<strong>Re-check now</strong> to scan the current body.
								</p>
							</bx:if>
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-outline-secondary" wire:click="closeLinkHealth">Close</button>
					</div>
				</div>
			</div>
		</div>
	</bx:if>

	<!--- SEO Phase 14 — GSC performance modal ----------------------- --->
	<bx:if args.showPerformance>
		<bx:set perfQueries = performanceQueries()>
		<bx:set perfRollup  = performanceRollup()>
		<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.35);">
			<div class="modal-dialog modal-lg modal-dialog-scrollable">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title"><i class="bi bi-graph-up me-1"></i> Search performance — last 28 days</h5>
						<button type="button" class="btn-close" wire:click="closePerformance"></button>
					</div>
					<div class="modal-body">
						<div class="row g-2 mb-3">
							<div class="col-6 col-md-3">
								<div class="border rounded p-2 text-center">
									<div class="text-muted small">Clicks</div>
									<div class="h4 mb-0">#numberFormat( perfRollup.clicks )#</div>
								</div>
							</div>
							<div class="col-6 col-md-3">
								<div class="border rounded p-2 text-center">
									<div class="text-muted small">Impressions</div>
									<div class="h4 mb-0">#numberFormat( perfRollup.impressions )#</div>
								</div>
							</div>
							<div class="col-6 col-md-3">
								<div class="border rounded p-2 text-center">
									<div class="text-muted small">Avg CTR</div>
									<div class="h4 mb-0">#numberFormat( perfRollup.ctr * 100, "0.00" )#%</div>
								</div>
							</div>
							<div class="col-6 col-md-3">
								<div class="border rounded p-2 text-center">
									<div class="text-muted small">Avg position</div>
									<div class="h4 mb-0">#numberFormat( perfRollup.position, "0.0" )#</div>
								</div>
							</div>
						</div>

						<h6 class="mb-2 small text-muted text-uppercase">Top 10 queries</h6>
						<bx:if perfQueries.len() == 0>
							<p class="small text-muted mb-0">
								No GSC data yet for this post.
								Either GSC isn't connected (<a href="/admin/settings/gsc">connect it</a>),
								the sync hasn't run yet, or this URL hasn't appeared in search results in the
								last 28 days.
							</p>
						<bx:else>
							<div class="table-responsive">
								<table class="table table-sm align-middle mb-0">
									<thead class="small text-muted">
										<tr>
											<th>Query</th>
											<th class="text-end">Clicks</th>
											<th class="text-end">Impressions</th>
											<th class="text-end">CTR</th>
											<th class="text-end">Position</th>
										</tr>
									</thead>
									<tbody>
										<bx:loop array="#perfQueries#" item="q">
											<tr>
												<td class="small">#encodeForHTML( q.query )#</td>
												<td class="text-end small">#numberFormat( val( q.clicks ) )#</td>
												<td class="text-end small">#numberFormat( val( q.impressions ) )#</td>
												<td class="text-end small">#numberFormat( val( q.ctr ) * 100, "0.00" )#%</td>
												<td class="text-end small">#numberFormat( val( q.position ), "0.0" )#</td>
											</tr>
										</bx:loop>
									</tbody>
								</table>
							</div>
						</bx:if>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-outline-secondary" wire:click="closePerformance">Close</button>
					</div>
				</div>
			</div>
		</div>
	</bx:if>

	<!--- 2.I — AI image generation modal ---------------------------- --->
	<bx:if args.showImageModal>
		<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.35);">
			<div class="modal-dialog modal-lg modal-dialog-scrollable">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">
							<bx:if args.imageTarget == "featured">Generate featured image<bx:else>Generate image</bx:if>
						</h5>
						<button type="button" class="btn-close" wire:click="closeImageModal"></button>
					</div>
					<div class="modal-body">
						<bx:if len( args.imageError )>
							<div class="alert alert-warning small">
								<i class="bi bi-exclamation-triangle me-1"></i>#encodeForHTML( args.imageError )#
							</div>
						</bx:if>
						<label class="form-label small">Describe the image (up to 500 characters)</label>
						<textarea class="form-control" rows="3" maxlength="500"
						          wire:model="imagePrompt"
						          wire:loading.attr="disabled" wire:target="generateImagePreviews"
						          placeholder="e.g. A quiet coastal town at dusk, soft rain, warm streetlamps reflected on wet cobblestone."></textarea>
						<label class="form-label small mt-3">Style (optional)</label>
						<select class="form-select form-select-sm" wire:model="imageStyle"
						        wire:loading.attr="disabled" wire:target="generateImagePreviews">
							<option value="">None — let the model decide</option>
							<option value="Realistic">Realistic</option>
							<option value="Illustration">Illustration</option>
							<option value="Watercolor">Watercolor</option>
							<option value="Minimalist">Minimalist</option>
						</select>
						<small class="text-muted d-block mt-2">
							Your description is sent to the configured AI image provider.
							Generated images are stored in your media library with the original prompt recorded.
						</small>

						<div wire:loading wire:target="generateImagePreviews" class="mt-3 text-muted">
							<span class="spinner-border spinner-border-sm me-2 align-middle" role="status" aria-hidden="true"></span>
							<span class="small align-middle">Generating image previews &mdash; image models can take 10&ndash;60 seconds.</span>
						</div>

						<bx:if args.imagePreviews.len() gt 0>
							<hr>
							<p class="small text-muted mb-2">
								Click an image to save it to your media library and
								<bx:if args.imageTarget == "featured">set it as featured.<bx:else>insert it into the post body.</bx:if>
							</p>
							<div class="row row-cols-2 row-cols-md-4 g-2 position-relative">
								<bx:loop array="#args.imagePreviews#" item="p">
									<div class="col">
										<button type="button"
										        class="btn p-0 border w-100 position-relative"
										        wire:click="useImagePreview('#encodeForHTMLAttribute( p.previewId )#')"
										        wire:loading.attr="disabled">
											<img src="#encodeForHTMLAttribute( previewSrc( p.previewId ) )#"
											     class="img-fluid rounded"
											     style="object-fit: cover; aspect-ratio: 1/1;"
											     alt="preview">
										</button>
									</div>
								</bx:loop>
							</div>
							<div wire:loading wire:target="useImagePreview" class="mt-2 text-muted">
								<span class="spinner-border spinner-border-sm me-2 align-middle" role="status" aria-hidden="true"></span>
								<span class="small align-middle">Saving to media library&hellip;</span>
							</div>
						</bx:if>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-outline-secondary" wire:click="closeImageModal">Cancel</button>
						<button type="button" class="btn btn-primary"
						        wire:click="generateImagePreviews"
						        wire:loading.attr="disabled">
							<span wire:loading.remove wire:target="generateImagePreviews">
								<bx:if args.imagePreviews.len() gt 0>Regenerate<bx:else>Generate previews</bx:if>
							</span>
							<span wire:loading wire:target="generateImagePreviews">Generating…</span>
						</button>
					</div>
				</div>
			</div>
		</div>
	</bx:if>

	<!--- B4 — Media picker modal ---------------------------------- --->
	<bx:if args.showMediaPicker>
		<bx:set pickerTitle = args.pickerTarget == "featured" ? "Select featured image" : "Insert media">
		<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.35);">
			<div class="modal-dialog modal-lg">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title mb-0 me-auto">#pickerTitle#</h5>
						<div class="d-flex gap-2 align-items-center flex-shrink-0">
							<button type="button" class="btn btn-sm btn-outline-primary"
							        onclick="document.getElementById( 'bxPickerUpload' ).click();">
								<i class="bi bi-upload" aria-hidden="true"></i> Upload new
							</button>
							<input type="file" id="bxPickerUpload" accept="image/*" style="display:none;"
							       onchange="window.bxPickerUpload &amp;&amp; window.bxPickerUpload( this );">
							<button type="button" class="btn-close" wire:click="closeMediaPicker"></button>
						</div>
					</div>
					<div class="modal-body">
						<input type="text" class="form-control form-control-sm mb-3"
						       placeholder="Search filename, alt, or title…"
						       wire:model.live.debounce.400ms="pickerSearch">
						<div id="bxPickerUploadStatus" class="small mb-2" style="display:none;"></div>
						<bx:script>picks = pickerRows();</bx:script>
						<bx:if picks.len() == 0>
							<p class="text-muted small">No images match. Upload one above, or add some from the <a href="#event.buildLink( 'admin:Media.index' )#">Media library</a>.</p>
						<bx:else>
							<div class="row row-cols-3 row-cols-md-4 g-2">
								<bx:loop array="#picks#" item="p">
									<div class="col">
										<button type="button"
										        class="btn p-0 border w-100 text-start"
										        <bx:if args.pickerTarget == "featured">
										        wire:click="setAsFeatured(#p.id#)"
										        <bx:else>
										        data-picker-insert="1"
										        data-media-url="#encodeForHTMLAttribute( pickerUrl( p ) )#"
										        data-media-alt="#encodeForHTMLAttribute( p.alt_text ?: p.original_filename )#"
										        </bx:if>
										        title="#args.pickerTarget == 'featured' ? 'Set as featured image' : 'Insert into post body'#">
											<img src="#pickerUrl( p )#"
											     alt="#encodeForHTMLAttribute( p.alt_text ?: p.original_filename )#"
											     class="img-fluid rounded"
											     style="object-fit: cover; aspect-ratio: 1/1;">
											<div class="small p-1 text-truncate">#encodeForHTML( p.original_filename )#</div>
										</button>
									</div>
								</bx:loop>
							</div>
						</bx:if>
					</div>
				</div>
			</div>
		</div>
	</bx:if>
</div>

<!---
  EasyMDE init — binds a markdown editor to #postBody, syncs plain
  markdown back to the wire's `bodyMarkdown` prop on CodeMirror
  change, and routes the live preview through the same server-side
  render pipeline the publish path uses (admin:Markdown.preview →
  PostService.renderPreview). The module-scoped flag guarantees we
  only register the livewire hook once per page even if the wire
  re-renders.
--->
<script>
( function() {
    if ( window.__bxBloggerEditorHook ) return;
    window.__bxBloggerEditorHook = true;
    var WIRE_ID      = "#_getID()#";
    var PREVIEW_URL  = "#event.buildLink( to = 'admin:Markdown.preview' )#";

    document.addEventListener( "livewire:init", function() {
        Livewire.hook( "component.init", function( payload ) {
            var component = payload.component;
            var cleanup   = payload.cleanup;
            if ( component.id !== WIRE_ID ) return;

            window._postEditor = component.$wire;

            var ta = document.getElementById( "postBody" );
            if ( !ta || ta.dataset.easymdeInit ) return;
            if ( typeof EasyMDE === "undefined" ) {
                console.warn( "EasyMDE not loaded — markdown editor falling back to textarea." );
                return;
            }
            ta.dataset.easymdeInit = "1";

            var easymde = new EasyMDE( {
                element      : ta,
                spellChecker : false,
                autoDownloadFontAwesome : true,
                minHeight    : "420px",
                status       : [ "lines", "words", "cursor" ],
                placeholder  : ta.getAttribute( "placeholder" ) || "",
                toolbar      : [
                    "bold", "italic", "strikethrough", "heading",
                    "|", "quote", "unordered-list", "ordered-list", "code",
                    "|", "link",
                    {
                        name      : "insert-media",
                        title     : "Insert from media library",
                        className : "bi bi-images",
                        action    : function() {
                            // Open our server-side picker in body mode.
                            // Item-click in the picker is handled via
                            // `[data-picker-insert]` delegation below.
                            if ( window._postEditor ) {
                                window._postEditor.openMediaPicker( "body" );
                            }
                        }
                    },
                    "table", "horizontal-rule",
                    "|", "preview", "side-by-side", "fullscreen",
                    "|", "guide"
                ],
                previewRender: function( plainText, preview ) {
                    // EasyMDE expects a synchronous string OR for us to
                    // write into `preview` asynchronously. We render via
                    // the server so the preview matches the publish path
                    // (markdown → sanitized HTML) exactly.
                    setTimeout( function() {
                        fetch( PREVIEW_URL, {
                            method      : "POST",
                            credentials : "same-origin",
                            headers     : { "Content-Type" : "text/plain; charset=utf-8" },
                            body        : plainText
                        } )
                        .then( function( r ) { return r.text(); } )
                        .then( function( html ) { preview.innerHTML = html; } )
                        .catch( function() { preview.innerHTML = "<em>Preview unavailable.</em>"; } );
                    }, 60 );
                    return "Rendering…";
                }
            } );

            window._postEditorInstance = easymde;

            // Sync editor → wire with light debounce so every keystroke
            // doesn't hammer the wire. 300ms matches the autosave cadence
            // well enough for recovery + keeps the DOM snappy.
            var syncTimer = null;
            easymde.codemirror.on( "change", function() {
                clearTimeout( syncTimer );
                syncTimer = setTimeout( function() {
                    // second arg `false` = don't trigger a re-render; the
                    // value is already where the user sees it.
                    window._postEditor.set( "bodyMarkdown", easymde.value(), false );
                }, 300 );
            } );

            // Wire → editor sync, fired by acceptSuggestion + aiGenerateDraft
            // (and any future server-side body mutation). The textarea is
            // wire:ignore'd, so a re-render never reaches it; we have to
            // push into the EasyMDE instance directly.
            var bodyReplacedHandler = function( e ) {
                var detail = ( e && e.detail ) || {};
                var payload = Array.isArray( detail ) ? detail[ 0 ] : detail;
                var newValue = payload && typeof payload.value === "string" ? payload.value : null;
                if ( newValue === null ) return;
                // Cursor preservation is best-effort — accept-suggestion
                // and AI-draft both reset focus to the start. Users
                // expect the editor to surface the new content; clicking
                // back into the body restores the cursor.
                easymde.value( newValue );
            };
            window.addEventListener( "bx-blogger:body-replaced", bodyReplacedHandler );

            cleanup( function() {
                try { easymde.toTextArea(); } catch ( e ) {}
                window.removeEventListener( "bx-blogger:body-replaced", bodyReplacedHandler );
                delete window._postEditor;
                delete window._postEditorInstance;
            } );
        } );
    } );

    // Body-insert from picker: delegation handler for the picker's
    // body-mode item buttons. Fires `easymde.codemirror.replaceSelection`
    // so the snippet lands at cursor and the wire-ignore'd EasyMDE DOM
    // sees the change immediately (no wire round-trip required). Then
    // calls `closeMediaPicker` on the wire so the modal dismisses.
    document.addEventListener( "click", function( evt ) {
        var btn = evt.target.closest( "[data-picker-insert]" );
        if ( !btn ) return;
        var url = btn.getAttribute( "data-media-url" ) || "";
        var alt = btn.getAttribute( "data-media-alt" ) || "";
        if ( !url ) return;
        var snippet = "\n\n![" + alt + "](" + url + ")\n\n";
        try {
            if ( window._postEditorInstance ) {
                window._postEditorInstance.codemirror.replaceSelection( snippet );
            }
        } catch ( e ) { /* ignore — fall back to server insert */ }
        if ( window._postEditor ) {
            window._postEditor.closeMediaPicker();
        }
    } );

    // Upload-new flow inside the picker modal. POSTs the selected
    // file to admin:Media.uploadJson; on success we either insert the
    // new image at cursor (body-mode picker) or set it as the featured
    // image (featured-mode picker) — same target logic the click
    // handler above uses, reflected out of the live wire state.
    window.bxPickerUpload = function( input ) {
        if ( !input.files || !input.files.length ) return;
        var file = input.files[ 0 ];
        var statusEl = document.getElementById( "bxPickerUploadStatus" );
        var showStatus = function( text, variant ) {
            if ( !statusEl ) return;
            statusEl.textContent   = text;
            statusEl.style.display = text ? "" : "none";
            statusEl.className     = "small mb-2 text-" + ( variant || "muted" );
        };
        showStatus( "Uploading " + file.name + "…", "muted" );

        var fd = new FormData();
        fd.append( "file", file );
        // Re-use the filename as an alt-text fallback so MediaService's
        // required-alt check on images passes. Authors can edit it from
        // the media library afterwards.
        fd.append( "altText", file.name.replace( /\.[^.]+$/, "" ) );

        fetch( "/admin/media/uploadJson", {
            method      : "POST",
            body        : fd,
            credentials : "same-origin"
        } )
        .then( function( r ) { return r.json().then( function( j ) { return { status: r.status, body: j }; } ); } )
        .then( function( res ) {
            if ( !res.body || !res.body.ok ) {
                showStatus( "Upload failed: " + ( res.body && res.body.error ? res.body.error : "unknown error" ), "danger" );
                return;
            }
            showStatus( "Uploaded. Inserting…", "success" );
            // Consume via the current picker target without re-querying
            // the server — we have the url + alt in hand.
            var target = ( window._postEditor && window._postEditor.pickerTarget ) || "body";
            if ( target === "featured" ) {
                window._postEditor.set( "featuredMediaId", res.body.id, false );
                window._postEditor.closeMediaPicker();
            } else {
                var snippet = "\n\n![" + ( res.body.altText || res.body.originalFilename ) + "](" + res.body.url + ")\n\n";
                try {
                    if ( window._postEditorInstance ) {
                        window._postEditorInstance.codemirror.replaceSelection( snippet );
                    }
                } catch ( e ) {}
                window._postEditor.closeMediaPicker();
            }
            // Reset the file input so the same file can be re-picked
            // if the author immediately undoes + re-uploads.
            input.value = "";
        } )
        .catch( function( err ) {
            showStatus( "Upload failed: " + ( err && err.message ? err.message : "network error" ), "danger" );
        } );
    };
} )();
</script>

<bx:if ( args.postId ?: 0 ) gt 0 && args.status != "trashed">
<script>
// B5 — autosave ticker. Fires every 30s while the editor page is open;
// Livewire ignores no-ops (wire:click handlers are idempotent, the
// service guards against missing postId). Stops when the user
// navigates away — ordinary script lifecycle.
( function() {
    if ( window.__bxEditorAutosave ) return;   // don't double-bind on re-render
    window.__bxEditorAutosave = setInterval( function() {
		window._postEditor.autosave();
        // Livewire v3 exposes a global `Livewire`; guard in case CBWIRE
        // reshuffles the symbol name.
		/*
        if ( typeof Livewire === "undefined" ) return;
        var component = document.querySelector( "[wire\\:id]" );
        if ( !component ) return;
        var wire = Livewire.find( component.getAttribute( "wire:id" ) );
        if ( wire && typeof wire.call === "function" ) wire.call( "autosave" );
		*/
    }, 30000 );
} )();
</script>
</bx:if>
</bx:output>
