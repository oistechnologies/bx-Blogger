# =============================================================================
# bx-Blogger — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in values for your environment.
# Never commit `.env` to git (it is in .gitignore).
#
# IMPORTANT: Do not put inline comments (# after a value) on the same
# line as a variable — BoxLang's `getSystemSetting()` reads the whole line
# including trailing comments as the value. Comments on their own lines only.
#
# All development runs inside Docker containers — see CLAUDE.md.
# Never run `box` / `commandbox` on the host.
# =============================================================================

# -----------------------------------------------------------------------------
# Application identity
# -----------------------------------------------------------------------------
APPNAME=bx-Blogger
ENVIRONMENT=development
BOXLANG_DEBUG=true
# generate: openssl rand -base64 32
APP_KEY=
# Used by services that build absolute URLs for outbound email links
# (password reset, email verification). No trailing slash.
APP_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Database — containerized MySQL (compose service name `mysql`)
# -----------------------------------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=bx_blogger
DB_USERNAME=bx_blogger
DB_PASSWORD=bxblog-dev-pass
DB_ROOT_PASSWORD=root-dev-pass
DB_DRIVER=MySQL

# -----------------------------------------------------------------------------
# Mail — MailHog in dev; real SMTP in prod
# -----------------------------------------------------------------------------
MAIL_PROTOCOL=smtp
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
# values: tls | ssl | none
SMTP_ENCRYPTION=none
MAIL_FROM_ADDRESS=dev@bx-blogger.local
MAIL_FROM_NAME=bx-Blogger (dev)

# -----------------------------------------------------------------------------
# Object storage — S3-compatible (MinIO in dev)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET_MEDIA=bx-blogger-media-dev
S3_BUCKET_OG=bx-blogger-og-dev
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_USE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000
S3_FORCE_HTTPS=false

# -----------------------------------------------------------------------------
# MinIO bootstrap (dev stack only)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345

# -----------------------------------------------------------------------------
# Backups (A5) — optional off-host DB backup sync target
# -----------------------------------------------------------------------------
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=

# -----------------------------------------------------------------------------
# Trusted proxies (B15) — comma-separated CIDR blocks
# -----------------------------------------------------------------------------
TRUSTED_PROXIES=127.0.0.1/32,172.16.0.0/12

# -----------------------------------------------------------------------------
# Production reverse proxy (docker-compose.prod.yml only — ignored in dev).
# Name of the existing Nginx Proxy Manager (NPM) Docker network that our
# app container attaches to. Set this to match your NPM stack's network.
# Defaults to "npm_default" which is NPM's official compose file default.
# See DEV-NOTES/OPS-NGINX-PROXY-MANAGER.md for full setup.
# -----------------------------------------------------------------------------
PROXY_NETWORK=npm_default

# -----------------------------------------------------------------------------
# Security secrets
# -----------------------------------------------------------------------------
# Phase 11 stub (REST API JWT auth)
JWT_SECRET=

# -----------------------------------------------------------------------------
# Dev super_admin seed — migration 010012 creates this user on first boot.
# PRODUCTION: set to real values BEFORE first deploy; the defaults are
# intentionally weak so they won't survive a bcrypt policy check in prod
# config. For dev, the defaults are fine.
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@bx-blogger.local
ADMIN_PASSWORD=ChangeMe-Admin-4242!

# -----------------------------------------------------------------------------
# AI authoring assistance (Chunk 2.H)
# -----------------------------------------------------------------------------
# Feature is OFF by default. Flip AI_ENABLED=true AND provide a key below
# to expose Create-from-Idea + Review-and-Suggest in the editor.
# -----------------------------------------------------------------------------

# Master kill-switch. Anything other than "true" hides the AI editor buttons.
AI_ENABLED=false

# AI_PROVIDER = mock | openrouter | openai | anthropic | google
# "mock" routes through MockAiProvider — deterministic canned responses,
# no network, works in dev + CI without an API key.
# Anything else routes through bx-ai's aiChat() against a real upstream.
AI_PROVIDER=mock

# API key for the active provider. Only the one matching AI_PROVIDER is read.
# OpenRouter keys start with "sk-or-v1-…".
AI_API_KEY=

# Model slug for the active provider.
# OpenRouter uses vendor/model, e.g. anthropic/claude-3.5-sonnet,
# openai/gpt-4o-mini, openrouter/auto.
# Leave blank to accept the provider's own default.
AI_MODEL=

# Optional attribution headers. OpenRouter surfaces these on its
# leaderboards + request analytics; other providers ignore them silently.
# AI_SITE_URL becomes HTTP-Referer, AI_APP_NAME becomes X-Title.
AI_SITE_URL=
AI_APP_NAME=

# Default monthly token budget per user. 0 = unlimited.
# Individual users override via users.ai_monthly_tokens.
AI_DEFAULT_MONTHLY_TOKENS=50000

# Optional tone/style override appended after the base system prompt.
# The hard security guardrails (jailbreak protection, role-locking, etc.)
# are ALWAYS appended by the service layer — this value only affects tone.
AI_SYSTEM_PROMPT_TONE=

# -----------------------------------------------------------------------------
# AI image generation (Chunk 2.I)
# -----------------------------------------------------------------------------
# Independent from the text-authoring config above — even when both end
# up pointing at the same upstream, ops can revoke image-gen without
# killing text AI. OpenRouter drives image gen through the same chat
# endpoint with modalities: ["image"]; no separate URL to configure.
# -----------------------------------------------------------------------------

AI_IMAGE_ENABLED=false
AI_IMAGE_PROVIDER=mock
AI_IMAGE_API_KEY=

# Image-capable model — e.g. google/gemini-2.5-flash-image (OpenRouter),
# openai/dall-e-3, or any vendor/model supporting image output.
AI_IMAGE_MODEL=

AI_IMAGE_SITE_URL=
AI_IMAGE_APP_NAME=

# Default monthly image-gen count per user. 0 = unlimited.
# Per-call cost is 10-50× text; keep the cap aggressive.
AI_DEFAULT_MONTHLY_IMAGES=20
