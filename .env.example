# =============================================================================
# bx-Blogger — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in values for your environment.
# Never commit `.env` to git (it is in .gitignore).
#
# All development runs inside Docker containers — see CLAUDE.md.
# Never run `box` / `commandbox` on the host.
# =============================================================================

# -----------------------------------------------------------------------------
# Application identity
# -----------------------------------------------------------------------------
APPNAME=bx-Blogger
ENVIRONMENT=development
BOXLANG_DEBUG=true
APP_KEY=                            # generate: openssl rand -base64 32

# -----------------------------------------------------------------------------
# Database — containerized MySQL (both dev and prod; see PLAN §17 Round-10)
# -----------------------------------------------------------------------------
DB_HOST=mysql                       # docker-compose service name
DB_PORT=3306
DB_DATABASE=bx_blogger
DB_USERNAME=bx_blogger
DB_PASSWORD=bxblog-dev-pass         # change in prod
DB_ROOT_PASSWORD=root-dev-pass      # change in prod
DB_DRIVER=MySQL
DB_CONNECTIONSTRING=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_DATABASE}?useSSL=false&useUnicode=true&characterEncoding=UTF-8&serverTimezone=UTC&allowPublicKeyRetrieval=true

# -----------------------------------------------------------------------------
# Mail — MailHog in dev (captures all outbound); real SMTP in prod
# -----------------------------------------------------------------------------
MAIL_PROTOCOL=smtp
SMTP_HOST=mailhog                   # docker-compose service name
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=none                # tls | ssl | none
MAIL_FROM_ADDRESS=dev@bx-blogger.local
MAIL_FROM_NAME=bx-Blogger (dev)

# -----------------------------------------------------------------------------
# Object storage — S3-compatible backend (see OPS-S3-COMPATIBLE-PROVIDERS.md)
# Dev default: MinIO container in compose.
# Prod default: AWS S3 + CloudFront (set S3_ENDPOINT=https://s3.us-east-1.amazonaws.com,
#               S3_USE_PATH_STYLE=false, S3_PUBLIC_URL=<cloudfront-url>).
# Any S3-compatible provider works via endpoint override.
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://minio:9000       # MinIO service in dev compose
S3_REGION=us-east-1
S3_BUCKET_MEDIA=bx-blogger-media-dev
S3_BUCKET_OG=bx-blogger-og-dev
S3_ACCESS_KEY=minio                 # dev only — matches MINIO_ROOT_USER below
S3_SECRET_KEY=minio12345            # dev only — matches MINIO_ROOT_PASSWORD below
S3_USE_PATH_STYLE=true              # true for MinIO + most non-AWS; false for AWS
S3_PUBLIC_URL=http://localhost:9000 # how <img src> renders; prod points at CDN
S3_FORCE_HTTPS=false                # true in prod with TLS

# -----------------------------------------------------------------------------
# MinIO bootstrap — used by the dev compose stack only (no prod meaning)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345

# -----------------------------------------------------------------------------
# Backups (A5) — optional off-host DB backup sync target
# -----------------------------------------------------------------------------
BACKUP_S3_BUCKET=                   # empty = no off-host sync; set to enable
BACKUP_S3_ENDPOINT=                 # defaults to S3_ENDPOINT if unset

# -----------------------------------------------------------------------------
# Trusted proxies (B15) — unwraps X-Forwarded-For only from these hops
# -----------------------------------------------------------------------------
TRUSTED_PROXIES=127.0.0.1/32,172.16.0.0/12  # docker bridge default; add NGINX in prod

# -----------------------------------------------------------------------------
# Security secrets
# -----------------------------------------------------------------------------
JWT_SECRET=                         # Phase 11 stub (REST API JWT auth)

# -----------------------------------------------------------------------------
# AI authoring assistance (Phase 2 — see PLAN §3 Phase 2 + §22 Round-6/7)
# Feature is OFF by default (settings.ai.enabled=false in app Settings).
# Operator enables in admin UI after providing a key below.
# Leave keys empty unless you actually intend to use the corresponding provider.
# -----------------------------------------------------------------------------
AI_OPENAI_API_KEY=
AI_ANTHROPIC_API_KEY=
AI_GOOGLE_API_KEY=
