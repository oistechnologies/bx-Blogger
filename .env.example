# =============================================================================
# bx-Blogger — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in values for your environment.
# Never commit `.env` to git (it is in .gitignore).
#
# IMPORTANT: Do not put inline comments (# after a value) on the same
# line as a variable — BoxLang's `getSystemSetting()` reads the whole line
# including trailing comments as the value. Comments on their own lines only.
#
# All development runs inside Docker containers — see CLAUDE.md.
# Never run `box` / `commandbox` on the host.
# =============================================================================

# -----------------------------------------------------------------------------
# Application identity
# -----------------------------------------------------------------------------
APPNAME=bx-Blogger
ENVIRONMENT=development
BOXLANG_DEBUG=true
# generate: openssl rand -base64 32
APP_KEY=
# Used by services that build absolute URLs for outbound email links
# (password reset, email verification). No trailing slash.
APP_URL=http://localhost:8080

# Timezone — applied across the whole stack (OS clock in every
# container, MySQL's `NOW()`, JVM's `user.timezone`, ColdBox
# `this.timezone` + scheduled-task firing). IANA database name,
# not an abbreviation ("America/New_York", not "EST"). Using a
# named TZ means DST transitions are handled for you.
APP_TIMEZONE=America/New_York

# -----------------------------------------------------------------------------
# Database — containerized MySQL (compose service name `mysql`)
# -----------------------------------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=bx_blogger
DB_USERNAME=bx_blogger
DB_PASSWORD=bxblog-dev-pass
DB_ROOT_PASSWORD=root-dev-pass
DB_DRIVER=MySQL

# -----------------------------------------------------------------------------
# Mail — MailHog in dev; real SMTP in prod
# -----------------------------------------------------------------------------
MAIL_PROTOCOL=smtp
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
# values: tls | ssl | none
SMTP_ENCRYPTION=none
MAIL_FROM_ADDRESS=dev@bx-blogger.local
MAIL_FROM_NAME=bx-Blogger (dev)

# -----------------------------------------------------------------------------
# Object storage — media (S3-compatible)
# -----------------------------------------------------------------------------
# Leave S3_BUCKET_MEDIA blank to use the Local cbfs disk at
# /app/includes/public/media (host-bind-mounted in prod — see
# docker-compose.prod.yml). Uncomment + fill the S3_* block below to
# flip the media disk over to MinIO / B2 / DO Spaces / etc.
#
# The MinIO-pointing values below are ready to go against the dev
# `minio` service but require creating the bucket first:
#   docker compose exec minio sh -c 'mc alias set local http://localhost:9000 $$MINIO_ROOT_USER $$MINIO_ROOT_PASSWORD && mc mb local/bx-blogger-media-dev && mc anonymous set download local/bx-blogger-media-dev'
#
# OG images stay on the Local disk by design; see config/Coldbox.bx.
# A later phase that switches OG to "generate once, keep forever" will
# wire that up to S3 on its own.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET_MEDIA=
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345

# URL style — path = the only style s3sdk builds correctly for non-AWS
# providers (B2, DO Spaces, Wasabi, MinIO). AWS S3 operators who want
# `<bucket>.s3.amazonaws.com/<key>` flip this to `virtual`.
S3_URL_STYLE=path

# Public-facing base URL — what gets written into <img src=...> tags.
# For MinIO in dev, point at the host-exposed port. For B2, use the
# f00X.backblazeb2.com/file URL or a Cloudflare-fronted custom domain.
# When blank, cbfs falls back to <bucket>.<endpoint> which breaks for
# path-style providers — so set it explicitly once you leave dev.
#
# Auto-bucket-append: for path-style providers (S3_URL_STYLE=path) the
# app appends `/<S3_BUCKET_MEDIA>` to this URL when it doesn't already
# contain the bucket name. Covers both bare hosts and B2's `/file`
# pattern. If you use a CDN that rewrites `/<bucket>/<key>` → `/<key>`
# (common with Cloudflare in front of B2), bake the bucket into this
# URL explicitly to opt out: S3_PUBLIC_URL=https://cdn.example.com/<bucket>.
S3_PUBLIC_URL=http://localhost:9000

# Force HTTPS in generated URLs. `true` in prod; MinIO dev runs HTTP only.
S3_FORCE_HTTPS=false

# Object-key prefix for every uploaded media file — same multi-tenant
# namespacing as BACKUP_S3_PREFIX. Multi-instance hosts sharing one
# bucket set this to distinguish sites; single-tenant installs leave
# it blank. docker-compose.prod.yml defaults it to $COMPOSE_PROJECT_NAME
# so adding a second stack on one host just works.
S3_MEDIA_PREFIX=

# -----------------------------------------------------------------------------
# OG share-card images — S3 bucket (CURRENTLY INACTIVE)
# -----------------------------------------------------------------------------
# Reserved for a future revision: setting these will flip the `og`
# cbfs disk to S3-backed storage the same way S3_BUCKET_MEDIA does
# for media. NOT YET WIRED — the conditional registration in
# config/Coldbox.bx is staged but commented out due to an s3sdk
# `buildUrlEndpoint` defect that breaks reads + subsequent writes
# on non-AWS providers (see CbfsEndpointRepairInterceptor for the
# full story). Until a custom S3 provider subclass ships, the `og`
# disk stays Local in both dev + prod (bind-mount at
# ${OG_HOST_PATH:-./og} in production).
#
# These vars are documented now so when the proper fix lands you
# only need to drop in the bucket name + restart.
S3_BUCKET_OG=
S3_OG_PREFIX=

# -----------------------------------------------------------------------------
# MinIO bootstrap (dev stack only)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345

# -----------------------------------------------------------------------------
# Backups (A5) — optional off-host DB backup sync target
# -----------------------------------------------------------------------------
# When BACKUP_S3_BUCKET is blank the nightly BackupDatabaseJob writes
# only to the local /var/backups/bx-blogger volume. Filling in all five
# vars below activates the S3-compatible upload path.
#
# For Backblaze B2, see docs/operators/BACKBLAZE-B2.md §4 for a
# field-by-field example. The ENDPOINT value can include or omit the
# https:// prefix — the app strips it either way before handing the
# hostname to the s3sdk.
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# URL style for signed requests — `path` works with every S3-compatible
# provider we ship a runbook for (Backblaze B2, DigitalOcean Spaces,
# Wasabi, MinIO, AWS S3). Only flip to `virtual` on pure AWS S3 if the
# operator has a specific reason; s3sdk's virtual-style URL builder
# doesn't handle non-AWS domains correctly, so path is the safe default.
BACKUP_S3_URL_STYLE=path

# Object-key prefix for every uploaded backup — lets multiple
# bx-Blogger installs share one bucket. `prod` uploads `site-a/
# bx-blogger-2026-04-24_02-00-00.sql.gz`; `dev` uploads
# `bx-blogger-dev/...`. Leave blank to put files at the bucket root
# (single-tenant).
#
# In docker-compose.prod.yml this variable defaults to
# ${COMPOSE_PROJECT_NAME:-bx-blogger} so multi-instance hosts (see
# docs/operators/MULTI-INSTANCE.md) automatically namespace each
# stack. Override below when you want a specific folder name that
# differs from the compose project name.
BACKUP_S3_PREFIX=

# -----------------------------------------------------------------------------
# Trusted proxies (B15) — comma-separated CIDR blocks
# -----------------------------------------------------------------------------
TRUSTED_PROXIES=127.0.0.1/32,172.16.0.0/12

# -----------------------------------------------------------------------------
# Production reverse proxy (docker-compose.prod.yml only — ignored in dev).
# Name of the existing Nginx Proxy Manager (NPM) Docker network that our
# app container attaches to. Set this to match your NPM stack's network.
# Defaults to "npm_default" which is NPM's official compose file default.
# See docs/operators/NGINX-PROXY-MANAGER.md for full setup.
# -----------------------------------------------------------------------------
PROXY_NETWORK=npm_default

# -----------------------------------------------------------------------------
# Production persistent volumes (docker-compose.prod.yml only)
# -----------------------------------------------------------------------------
# Host paths for the bind-mounts the prod compose creates on the app
# service. Defaults resolve relative to the compose file's directory
# (./media, ./og), so on a fresh install Docker auto-creates them next
# to docker-compose.prod.yml + .env — no setup needed.
#
# Override to absolute paths when you want these on a NAS mount,
# dedicated SSD, shared volume, etc.:
#
#   MEDIA_HOST_PATH=/mnt/storage/bx-blogger/media
#   OG_HOST_PATH=/mnt/storage/bx-blogger/og
#
# Note: /app/includes/public/branding is intentionally NOT bind-mounted.
# Branding logos ship baked into the product image via COPY in the
# Dockerfile — shadowing that path with an empty host dir would 404
# every admin `<img>` pointing at a logo.
#
# Dev ignores these — the dev compose bind-mounts the whole project at
# /app so /app/includes/public/{media,og} already persist via the host
# repo checkout.
# MEDIA_HOST_PATH=
# OG_HOST_PATH=

# -----------------------------------------------------------------------------
# Security secrets
# -----------------------------------------------------------------------------
# Phase 11 stub (REST API JWT auth)
JWT_SECRET=

# -----------------------------------------------------------------------------
# Dev super_admin seed — migration 010012 creates this user on first boot.
# PRODUCTION: set to real values BEFORE first deploy; the defaults are
# intentionally weak so they won't survive a bcrypt policy check in prod
# config. For dev, the defaults are fine.
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@bx-blogger.local
ADMIN_PASSWORD=ChangeMe-Admin-4242!

# -----------------------------------------------------------------------------
# Settings seed (Phase 6 — System Settings primitive)
# -----------------------------------------------------------------------------
# First-boot seed values for the `settings` table. `Main.onAppInit` writes
# these into the DB via SettingService.seedIfMissing on a fresh install.
# Subsequent boots don't clobber whatever the admin has changed via the
# Settings UI — the DB is authoritative after first write.
#
# Leave blank to skip the seed (admin fills it in later).
# -----------------------------------------------------------------------------

# Destination for admin notification emails (failed background jobs,
# security alerts, daily digest of unread notifications). Must parse as
# a valid email address — SettingService rejects malformed values on
# write. 6.C / NotificationService consumes this when the email channel
# is enabled on a notification.
BX_NOTIFICATION_EMAIL=

# Error reporter — who handles uncaught 500s (Main.onException).
# Two shipping values:
#   noop   — default; writeLog only. The error vanishes from view unless
#            an operator tails the bxblogger log. Zero network, safe on
#            fresh installs without SMTP configured.
#   email  — queues a SendEmailJob to BX_NOTIFICATION_EMAIL on every
#            uncaught 500. Rate-limited to 10 emails per exception
#            fingerprint (type + first line of message) per hour so a
#            crash loop can't flood your inbox.
# Future values ("sentry") slot in via the WireBox binding without
# touching the call site in Main.onException.
ERROR_REPORTER=noop

# Log output format — controls how each log line leaves the container.
#   text  — default, dev. Human-readable single-line text to stdout.
#           Easy to skim in `docker compose logs -f app`.
#   json  — production. One JSON object per line to stdout. Indexable
#           by the Docker log driver (journald / fluentd / Loki / ELK)
#           without regex-scraping free-form text. Keys: ts, level,
#           cat, msg, extra (optional), app, ver.
# Either way logs go to stdout only — no file appender, since a
# container's filesystem is ephemeral.
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# AI authoring assistance (Chunk 2.H)
# -----------------------------------------------------------------------------
# Feature is OFF by default. Flip AI_ENABLED=true AND provide a key below
# to expose Create-from-Idea + Review-and-Suggest in the editor.
# -----------------------------------------------------------------------------

# Master kill-switch. Anything other than "true" hides the AI editor buttons.
AI_ENABLED=false

# AI_PROVIDER = mock | openrouter | openai | anthropic | google
# "mock" routes through MockAiProvider — deterministic canned responses,
# no network, works in dev + CI without an API key.
# Anything else routes through bx-ai's aiChat() against a real upstream.
AI_PROVIDER=mock

# API key for the active provider. Only the one matching AI_PROVIDER is read.
# OpenRouter keys start with "sk-or-v1-…".
AI_API_KEY=

# Model slug for the active provider.
# OpenRouter uses vendor/model, e.g. anthropic/claude-3.5-sonnet,
# openai/gpt-4o-mini, openrouter/auto.
# Leave blank to accept the provider's own default.
AI_MODEL=

# Optional attribution headers. OpenRouter surfaces these on its
# leaderboards + request analytics; other providers ignore them silently.
# AI_SITE_URL becomes HTTP-Referer, AI_APP_NAME becomes X-Title.
AI_SITE_URL=
AI_APP_NAME=

# Default monthly token budget per user. 0 = unlimited.
# Individual users override via users.ai_monthly_tokens.
AI_DEFAULT_MONTHLY_TOKENS=50000

# [DEPRECATED] Optional tone override appended after the base system prompt.
# Edit the prompts directly in the admin UI at /admin/ai-prompts instead —
# the table is seeded with the same defaults this env var used to nudge.
# Still honored at runtime for backward compatibility, with a one-time
# deprecation note in the app log on first read. Will be removed in a
# future phase. The hard security guardrails are appended after either
# value and cannot be disabled from .env or admin.
AI_SYSTEM_PROMPT_TONE=

# -----------------------------------------------------------------------------
# AI image generation (Chunk 2.I)
# -----------------------------------------------------------------------------
# Independent from the text-authoring config above — even when both end
# up pointing at the same upstream, ops can revoke image-gen without
# killing text AI. OpenRouter drives image gen through the same chat
# endpoint with modalities: ["image"]; no separate URL to configure.
# -----------------------------------------------------------------------------

AI_IMAGE_ENABLED=false
AI_IMAGE_PROVIDER=mock
AI_IMAGE_API_KEY=

# Image-capable model — e.g. google/gemini-2.5-flash-image (OpenRouter),
# openai/dall-e-3, or any vendor/model supporting image output.
AI_IMAGE_MODEL=

AI_IMAGE_SITE_URL=
AI_IMAGE_APP_NAME=

# Default monthly image-gen count per user. 0 = unlimited.
# Per-call cost is 10-50× text; keep the cap aggressive.
AI_DEFAULT_MONTHLY_IMAGES=20
