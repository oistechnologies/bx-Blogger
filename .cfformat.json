{
    "indent_size": 1,
    "tab_indent": true,
    "max_columns": 140,
    "newline": "auto",
    "strip_cr": true,
    "alignment_depth": 0,
    "alignment_alignment": "right",
    "alignment_override": false,
    "align_consecutive_assignments": true,
    "align_consecutive_params": true,
    "align_consecutive_properties": true,
    "align_consecutive_attributes": true,
    "struct.multiline": "consistent",
    "array.multiline": "consistent",
    "parameters.multiline": "consistent",
    "arguments.multiline": "consistent",
    "brackets.padding": true,
    "metadata.multiline": true,
    "binary_operators.padding": true,
    "comma.padding": true,
    "assignments.padding": "spaced",
    "function_declaration.spacing": "spaced",
    "function_declaration.empty_padding": "empty",
    "function_declaration.padding": "spaced",
    "function_call.spacing": "spaced",
    "function_call.empty_padding": "empty",
    "function_call.padding": "spaced",
    "function_anonymous.group_to_block_spacing": "spaced",
    "function_anonymous.empty_padding": "empty",
    "function_anonymous.padding": "spaced",
    "for_loop.spacing": "spaced",
    "for_loop.padding": "spaced",
    "do_while.spacing": "spaced",
    "do_while.padding": "spaced",
    "while.spacing": "spaced",
    "while.padding": "spaced",
    "if.spacing": "spaced",
    "if.padding": "spaced",
    "if.single_line.allow": false,
    "else.single_line.allow": false,
    "for.single_line.allow": false,
    "while.single_line.allow": false,
    "switch.spacing": "spaced",
    "switch.padding": "spaced",
    "try.spacing": "spaced",
    "try.padding": "spaced",
    "catch.spacing": "spaced",
    "catch.padding": "spaced",
    "keywords.block_to_keyword_spacing": "spaced",
    "keywords.group_to_block_spacing": "spaced",
    "function_declaration.multiline": "consistent",
    "function_call.multiline": "consistent",
    "function_anonymous.multiline": "consistent",
    "property_declaration.multiline": "consistent",
    "comment.asterisks": "align",
    "over_length_behavior": "multiline"
}
