<bx:output>
<div class="d-flex justify-content-between align-items-center mb-4">
	<h1 class="h3 mb-0">#encodeForHTML( prc.pageTitle )#</h1>
	<a class="btn btn-outline-secondary" href="#event.buildLink( 'admin:Posts.index' )#">← Back to posts</a>
</div>

#wire( "posts.editor", { postId : prc.postId } )#
</bx:output>
