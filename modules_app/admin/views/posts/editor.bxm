<bx:output>
<bx:savecontent variable="actions">
	<a class="btn btn-outline-secondary" href="#event.buildLink( 'admin:Posts.index' )#">← Back to posts</a>
</bx:savecontent>
#view( view = "partials/heading", args = { "title" : prc.pageTitle, "actionHtml" : actions } )#

#wire( "posts.editor", { postId : prc.postId } )#
</bx:output>
