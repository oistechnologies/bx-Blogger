<bx:output>
<bx:savecontent variable="actions">
    <a class="btn btn-outline-secondary btn-sm" href="#event.buildLink( 'admin:Themes.index' )#">
        &laquo; Back to themes
    </a>
</bx:savecontent>
#view( view = "partials/heading", args = { "title" : "Theme Options", "actionHtml" : actions } )#

#wire( name = "themes.options", params = { "slug" : prc.themeSlug } )#
</bx:output>
