/**
 * bx-Blogger — BxAiProvider (Chunk 2.H + OpenRouter follow-up)
 *
 * Thin adapter around bx-ai's `aiChat()` BIF. Bound to the `AiProvider`
 * WireBox alias whenever AI_PROVIDER is anything other than "mock".
 * Keeps AiAssistantService provider-agnostic — swap this class out if
 * you ever want to bypass bx-ai entirely.
 *
 * Config, all via env (see .env.example for full commentary):
 *   AI_PROVIDER  — "openrouter" | "openai" | "anthropic" | "google"
 *                  Forwarded to bx-ai's options.provider; bx-ai picks
 *                  the matching service class.
 *   AI_API_KEY   — upstream API key. OpenRouter keys start "sk-or-v1-".
 *   AI_MODEL     — model slug. OpenRouter uses vendor/model
 *                  ("anthropic/claude-3.5-sonnet", "openrouter/auto");
 *                  other providers use their own naming. Blank = provider default.
 *   AI_SITE_URL  — optional HTTP-Referer (OpenRouter leaderboards).
 *   AI_APP_NAME  — optional X-Title (OpenRouter leaderboards).
 *
 * bx-ai's aiChat signature is (messages, params, options, headers):
 *   messages → array of { role, content }
 *   params   → model + temperature + max_tokens (provider-level knobs)
 *   options  → provider + apiKey + returnFormat (aiChat-level knobs)
 *   headers  → raw HTTP headers forwarded by BaseService.sendChat
 *
 * Token/cost accounting is best-effort — OpenAI-shaped providers
 * return usage under .usage.{prompt,completion}_tokens; we guard
 * every read and fall back to zero.
 */
class accessors="true" singleton {

    property name="log" inject="logbox:logger:{this}";

    variables.defaultMaxTokens   = 4000;
    variables.defaultTemperature = 0.7;

    struct function draft( required string systemPrompt, required string userIdea ) {
        return chat(
            systemPrompt = arguments.systemPrompt,
            userContent  = arguments.userIdea
        );
    }

    struct function review( required string systemPrompt, required string postBody ) {
        var result = chat(
            systemPrompt = arguments.systemPrompt,
            userContent  = arguments.postBody
        );
        return {
            "suggestions"      : tryParseSuggestions( result.markdown ),
            "promptTokens"     : result.promptTokens,
            "completionTokens" : result.completionTokens,
            "totalTokens"      : result.totalTokens,
            "costUsdMicro"     : result.costUsdMicro
        };
    }

    // --------------------------------------------------------------------

    private struct function chat( required string systemPrompt, required string userContent ) {
        var messages = [
            { "role" : "system", "content" : arguments.systemPrompt },
            { "role" : "user",   "content" : arguments.userContent }
        ];

        var params  = buildParams();
        var options = buildOptions();
        var headers = buildHeaders();

        var response = aiChat(
            messages = messages,
            params   = params,
            options  = options,
            headers  = headers
        );

        var markdown = extractMessage( response );
        var usage    = isStruct( response ) && structKeyExists( response, "usage" ) ? response.usage : {};
        var pt = val( usage.prompt_tokens     ?: usage.promptTokens     ?: 0 );
        var ct = val( usage.completion_tokens ?: usage.completionTokens ?: 0 );

        return {
            "markdown"         : markdown,
            "promptTokens"     : pt,
            "completionTokens" : ct,
            "totalTokens"      : pt + ct,
            // Rough per-million-token cost estimate using OpenAI
            // gpt-4o-mini-class pricing ($0.15 in / $0.60 out). A
            // future BillingService can swap this for a real lookup
            // against OpenRouter's /api/v1/models endpoint.
            "costUsdMicro"     : int( pt * 0.15 + ct * 0.60 )
        };
    }

    private struct function buildParams() {
        var p = {
            "max_tokens"  : variables.defaultMaxTokens,
            "temperature" : variables.defaultTemperature
        };
        var model = getSystemSetting( "AI_MODEL", "" );
        if ( len( model ) ) p.model = model;
        return p;
    }

    private struct function buildOptions() {
        var o = {
            "provider"     : getSystemSetting( "AI_PROVIDER", "openrouter" ),
            "returnFormat" : "raw"
        };
        var apiKey = getSystemSetting( "AI_API_KEY", "" );
        if ( len( apiKey ) ) o.apiKey = apiKey;
        return o;
    }

    private struct function buildHeaders() {
        var h = {};
        var referer = getSystemSetting( "AI_SITE_URL", "" );
        var title   = getSystemSetting( "AI_APP_NAME", "" );
        if ( len( referer ) ) h[ "HTTP-Referer" ] = referer;
        if ( len( title ) )   h[ "X-Title" ]      = title;
        return h;
    }

    /**
     * Pull the assistant message text out of a provider response.
     * bx-ai's raw format roughly follows OpenAI's — `choices[1].message.content`.
     */
    private string function extractMessage( required any response ) {
        try {
            if ( isStruct( arguments.response ) && structKeyExists( arguments.response, "choices" ) ) {
                var choices = arguments.response.choices;
                if ( isArray( choices ) && choices.len() > 0 ) {
                    var first = choices[ 1 ];
                    return first.message.content ?: ( first.text ?: "" );
                }
            }
        }
        catch ( any e ) { /* fall through */ }
        return "";
    }

    /**
     * Parse a review response into an array of suggestion structs.
     * Expected shape: JSON array of `{ id, type, locationHint, before, after, rationale }`.
     * If the model returns prose instead of JSON we synthesize a
     * single suggestion so the panel isn't empty.
     */
    private array function tryParseSuggestions( required string text ) {
        var t = trim( arguments.text );
        if ( !len( t ) ) return [];
        // Strip a leading/trailing markdown fence if present
        t = reReplace( t, "^```[a-z]*\s*", "", "one" );
        t = reReplace( t, "```\s*$",        "", "one" );
        try {
            var parsed = jsonDeserialize( t );
            if ( isArray( parsed ) ) return parsed;
            if ( isStruct( parsed ) && structKeyExists( parsed, "suggestions" ) ) return parsed.suggestions;
        }
        catch ( any e ) { /* fall through */ }

        return [ {
            "id"           : "prose-1",
            "type"         : "general",
            "locationHint" : "overall",
            "before"       : "",
            "after"        : "",
            "rationale"    : arguments.text
        } ];
    }

}
