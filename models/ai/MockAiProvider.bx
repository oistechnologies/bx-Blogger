/**
 * bx-Blogger — MockAiProvider (Chunk 2.H)
 *
 * Deterministic, no-network AI provider used in dev (when no real
 * API key is configured) and in every spec run. Each method returns
 * a canned response shaped like what a real LLM would emit, plus a
 * token-count estimate based on the input length so budget-
 * enforcement specs can exercise both the under-budget and
 * over-budget branches without patching the service.
 *
 * Provider contract:
 *   draft( systemPrompt, userIdea )   → { markdown, promptTokens, completionTokens, totalTokens, costUsdMicro }
 *   review( systemPrompt, postBody )  → { suggestions[], promptTokens, completionTokens, totalTokens, costUsdMicro }
 *
 * Any real provider (BxAiProvider wrapping aiChat()) implements the
 * same shape — AiAssistantService is provider-agnostic.
 *
 * Spec-friendly knobs (set via setters on a singleton-broken test
 * spec, or injected as a custom WireBox mapping):
 *   simulateFailure = "" | "rate_limit" | "timeout" | "auth" | "server"
 *   fixedTokens     = numeric (overrides the estimate)
 */
class accessors="true" singleton {

    property name="simulateFailure"  default="";
    property name="fixedTokens";
    property name="lastSystemPrompt" default="";

    variables.simulateFailure  = "";
    variables.lastSystemPrompt = "";

    /**
     * Canned draft — echoes the idea back wrapped in a realistic
     * markdown shell. Counting tokens as ~1 per 4 input chars is a
     * decent cross-provider rough estimate (OpenAI's own rule of
     * thumb for English prose).
     */
    struct function draft( required string systemPrompt, required string userIdea ) {
        variables.lastSystemPrompt = arguments.systemPrompt;
        maybeFail();
        var tokens = estimateTokens( arguments.systemPrompt & arguments.userIdea );
        // Note: literal '#' chars in a .bx string literal must be
        // doubled to escape BoxLang's interpolation. "####" → "##"
        // → literal markdown H2 prefix.
        var body = "#### " & summarize( arguments.userIdea ) & char( 10 ) & char( 10 ) &
            "This is a mock draft generated from your idea. A real provider would produce a full article here — the mock returns a deterministic shell so specs can assert shape without burning API budget." & char( 10 ) & char( 10 ) &
            "###### Your idea, repeated" & char( 10 ) & char( 10 ) &
            "> " & arguments.userIdea & char( 10 );

        return {
            "markdown"          : body,
            "promptTokens"      : tokens,
            "completionTokens"  : int( tokens * 2 ),      // completions typically longer than prompts
            "totalTokens"       : int( tokens * 3 ),
            "costUsdMicro"      : int( tokens * 3 ) * 10  // fake 10 micros/token — ≈$0.01/1k tok
        };
    }

    /**
     * Canned review — returns a small, deterministic array of
     * suggestion objects. Real provider would return more diverse,
     * content-aware suggestions.
     */
    /**
     * Canned excerpt — deterministic 1-sentence synopsis that mirrors
     * what a real model would return. Mock never produces variation
     * so specs can assert the wire's "drop into data.excerpt" path
     * without depending on token weather.
     */
    struct function excerpt( required string systemPrompt, required string postBody ) {
        variables.lastSystemPrompt = arguments.systemPrompt;
        maybeFail();
        var tokens = estimateTokens( arguments.systemPrompt & arguments.postBody );
        var text   = "Mock synopsis: " & summarize( arguments.postBody ) & ".";
        return {
            "text"             : text,
            "promptTokens"     : tokens,
            "completionTokens" : 30,
            "totalTokens"      : tokens + 30,
            "costUsdMicro"     : ( tokens + 30 ) * 10
        };
    }

    /**
     * SEO Phase 4 — deterministic single-shot completion. Used by
     * AiAssistantService.generateSeoTitle / SeoDescription /
     * TitleCtrVariations / AltText so specs can assert exact output
     * without hitting a real provider.
     *
     * The mock inspects the system prompt for keywords ("CTR" /
     * "5 alternative" → numbered list, otherwise → single sentence)
     * and tailors output. Token estimates come from the same length
     * heuristic the rest of the mock uses.
     */
    struct function complete( required string systemPrompt, required string userContent ) {
        variables.lastSystemPrompt = arguments.systemPrompt;
        maybeFail();
        var tokens = estimateTokens( arguments.systemPrompt & arguments.userContent );

        var text = "";
        var sp   = arguments.systemPrompt;
        if ( findNoCase( "5 alternative", sp ) || findNoCase( "CTR", sp ) ) {
            // Numbered-list output for the CTR-variants prompt.
            text = "1. Mock CTR Title — Curiosity Hook" & char( 10 )
                & "2. Mock CTR Title — 7 Things to Know" & char( 10 )
                & "3. Mock CTR Title for 2026 Readers" & char( 10 )
                & "4. Mock CTR Title (Quick Guide)" & char( 10 )
                & "5. Why Does Mock CTR Title Matter?";
        }
        else if ( findNoCase( "alt-text", sp ) || findNoCase( "alt text", sp ) ) {
            text = "Mock alt text describing the image";
        }
        else if ( findNoCase( "meta description", sp ) ) {
            text = "Mock meta description summarizing the post in roughly 150 characters of plain prose for the SERP snippet preview.";
        }
        else {
            // Default = single SEO title.
            text = "Mock SEO Title: " & summarize( arguments.userContent );
        }

        return {
            "text"             : text,
            "promptTokens"     : tokens,
            "completionTokens" : 25,
            "totalTokens"      : tokens + 25,
            "costUsdMicro"     : ( tokens + 25 ) * 10
        };
    }

    struct function review( required string systemPrompt, required string postBody ) {
        variables.lastSystemPrompt = arguments.systemPrompt;
        maybeFail();
        var tokens = estimateTokens( arguments.systemPrompt & arguments.postBody );
        var suggestions = [
            {
                "id"            : "mock-1",
                "type"          : "style",
                "locationHint"  : "opening paragraph",
                "before"        : left( arguments.postBody, 60 ),
                "after"         : "[mock: consider a hook that names the problem]",
                "rationale"     : "Lead with what the reader gets."
            },
            {
                "id"            : "mock-2",
                "type"          : "clarity",
                "locationHint"  : "middle section",
                "before"        : "[example passive phrase]",
                "after"         : "[example active phrase]",
                "rationale"     : "Active voice reads faster."
            }
        ];
        return {
            "suggestions"      : suggestions,
            "promptTokens"     : tokens,
            "completionTokens" : 200,
            "totalTokens"      : tokens + 200,
            "costUsdMicro"     : ( tokens + 200 ) * 10
        };
    }

    // --------------------------------------------------------------------

    private numeric function estimateTokens( required string text ) {
        if ( !isNull( variables.fixedTokens ) ) return variables.fixedTokens;
        // ~1 token per 4 characters of English text is a reasonable
        // cross-provider estimate. Enough precision for budget tests
        // without an actual tokenizer.
        return ceiling( len( arguments.text ) / 4 );
    }

    private string function summarize( required string text ) {
        // `\s` covers carriage-returns / newlines / tabs without the
        // backslash-escape headaches `"[\r\n\t]"` triggers in a
        // BoxLang double-quoted string literal.
        var clean = reReplace( trim( arguments.text ), "[\s]+", " ", "all" );
        return len( clean ) > 60 ? left( clean, 60 ) & "…" : clean;
    }

    /**
     * Throw a shaped failure if the spec primed `simulateFailure`.
     * Mirrors the error taxonomy real providers emit so service-layer
     * error handling is exercised without hitting a network.
     */
    private void function maybeFail() {
        if ( !len( variables.simulateFailure ?: "" ) ) return;
        var kind = variables.simulateFailure;
        variables.simulateFailure = "";  // one-shot — don't poison the next call
        switch ( kind ) {
            case "rate_limit": throw( type = "bxBlogger.AiRateLimited",  message = "Mock: provider rate-limited us." );
            case "timeout":    throw( type = "bxBlogger.AiTimeout",       message = "Mock: provider timed out." );
            case "auth":       throw( type = "bxBlogger.AiAuth",          message = "Mock: bad API key." );
            default:           throw( type = "bxBlogger.AiProviderError", message = "Mock: generic upstream error." );
        }
    }

}
