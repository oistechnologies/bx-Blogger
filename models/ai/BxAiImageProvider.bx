/**
 * bx-Blogger — BxAiImageProvider (Chunk 2.I)
 *
 * Thin adapter around bx-ai's `aiChat()` BIF configured for image
 * output. OpenRouter (and other OpenAI-shape providers) drive image
 * generation through the same chat endpoint with
 * `modalities=["image"]` and a picture-capable model
 * (`google/gemini-2.5-flash-image`, `openai/dall-e-3`, etc.).
 *
 * Env config (parallel to BxAiProvider but independent):
 *   AI_IMAGE_PROVIDER   — forwarded to aiChat options.provider
 *   AI_IMAGE_API_KEY    — API key (OpenRouter "sk-or-v1-…")
 *   AI_IMAGE_MODEL      — image-capable model slug
 *   AI_IMAGE_SITE_URL   — HTTP-Referer (OpenRouter attribution)
 *   AI_IMAGE_APP_NAME   — X-Title (OpenRouter attribution)
 *
 * Same provider contract as MockAiImageProvider:
 *   generate( prompt, styleHint, variants ) → { previews[], usage… }
 *   fetchPreview( previewId ) → { bytes, mime, width, height } | null
 *
 * We keep a short-lived in-memory cache of { previewId → providerUrl }
 * so saveGeneratedImage() can fetch the chosen preview by id without
 * the wire having to round-trip the URL. Previews not chosen are
 * never downloaded — they simply age out of the cache.
 */
class accessors="true" singleton {

    property name="log" inject="logbox:logger:{this}";

    variables.defaultMaxTokens = 4000;
    // previewId → { providerUrl, expiresAt }
    variables.previewIndex = {};

    struct function generate(
        required string  prompt,
                 string  styleHint    = "",
                 numeric variants     = 2,
                 string  systemPrompt = ""
    ) {
        var n = clamp( arguments.variants, 1, 8 );
        var styleSuffix = len( arguments.styleHint ) ? ( " Style: " & arguments.styleHint & "." ) : "";
        var userContent = arguments.prompt & styleSuffix;

        var messages = [];
        if ( len( trim( arguments.systemPrompt ) ) ) {
            messages.append( { "role" : "system", "content" : arguments.systemPrompt } );
        }
        messages.append( { "role" : "user", "content" : userContent } );

        var params = {
            "max_tokens" : variables.defaultMaxTokens,
            "n"          : n,
            "modalities" : [ "image" ]
        };
        var model = getSystemSetting( "AI_IMAGE_MODEL", "" );
        if ( len( model ) ) params.model = model;

        var options = {
            "provider"     : getSystemSetting( "AI_IMAGE_PROVIDER", "openrouter" ),
            "returnFormat" : "raw"
        };
        var apiKey = getSystemSetting( "AI_IMAGE_API_KEY", "" );
        if ( len( apiKey ) ) options.apiKey = apiKey;

        var headers = {};
        var referer = getSystemSetting( "AI_IMAGE_SITE_URL", "" );
        var title   = getSystemSetting( "AI_IMAGE_APP_NAME", "" );
        if ( len( referer ) ) headers[ "HTTP-Referer" ] = referer;
        if ( len( title ) )   headers[ "X-Title" ]      = title;

        var response = aiChat(
            messages = messages,
            params   = params,
            options  = options,
            headers  = headers
        );

        return unpackResponse( response, n );
    }

    /**
     * Return the providerUrl for a previewId without fetching bytes.
     * Used by the editor wire to render `<img src=...>` without
     * round-tripping the URL through the wire's serialized state —
     * data: URLs from inline-image providers (Gemini Flash, OpenAI
     * b64_json) are multi-MB and would blow past Undertow's POST body
     * limit on the next wire action. Returns "" when the previewId
     * isn't in the cache (expired / unknown / different process).
     */
    string function getPreviewUrl( required string previewId ) {
        if ( !structKeyExists( variables.previewIndex, arguments.previewId ) ) return "";
        var rec = variables.previewIndex[ arguments.previewId ];
        if ( dateCompare( rec.expiresAt, now() ) != 1 ) return "";
        return rec.providerUrl ?: "";
    }

    /**
     * Fetch the bytes for a previewId that a prior generate() emitted.
     * Returns null if the provider URL has expired or the previewId
     * never existed on this process.
     */
    any function fetchPreview( required string previewId ) {
        if ( !structKeyExists( variables.previewIndex, arguments.previewId ) ) return javaCast( "null", "" );
        var rec = variables.previewIndex[ arguments.previewId ];
        if ( dateCompare( rec.expiresAt, now() ) != 1 ) {
            structDelete( variables.previewIndex, arguments.previewId );
            return javaCast( "null", "" );
        }

        // Some providers (Gemini 2.5 Flash via OpenRouter, OpenAI gpt-image-1
        // when b64_json is requested) return the bytes inline as a data URL
        // instead of a fetchable https URL. cfhttp can't follow data: URIs,
        // so decode the base64 payload directly when we see one.
        if ( left( rec.providerUrl, 5 ) == "data:" ) {
            return decodeDataUrl( rec );
        }

        try {
            cfhttp(
                url      = rec.providerUrl,
                method   = "GET",
                getAsBinary = "yes",
                timeout  = 30,
                result   = "local.fetch"
            );
            if ( local.fetch.statusCode contains "200" && isBinary( local.fetch.fileContent ) ) {
                return {
                    "bytes"     : local.fetch.fileContent,
                    "mime"      : rec.mime ?: "image/png",
                    "width"     : rec.width ?: 0,
                    "height"    : rec.height ?: 0,
                    "expiresAt" : rec.expiresAt
                };
            }
            log.warn( "BxAiImageProvider.fetchPreview non-200 response for " & arguments.previewId &
                     ": status=" & ( local.fetch.statusCode ?: "?" ) &
                     ", binary=" & isBinary( local.fetch.fileContent ?: "" ) );
        }
        catch ( any e ) {
            log.error( "BxAiImageProvider.fetchPreview failed for " & arguments.previewId & ": " & e.message );
        }
        return javaCast( "null", "" );
    }

    /**
     * Decode a `data:image/...;base64,...` URL into the same struct shape
     * the cfhttp path returns. The mime type from the URL header wins
     * over the cached default — providers occasionally return jpeg or
     * webp for prompts they decide deserve it.
     */
    private any function decodeDataUrl( required struct rec ) {
        try {
            var headerEnd = find( ",", arguments.rec.providerUrl );
            if ( !headerEnd ) {
                log.error( "BxAiImageProvider.fetchPreview malformed data URL (no comma)" );
                return javaCast( "null", "" );
            }
            var header = mid( arguments.rec.providerUrl, 6, headerEnd - 6 );   // strip leading "data:"
            var b64    = mid( arguments.rec.providerUrl, headerEnd + 1, len( arguments.rec.providerUrl ) - headerEnd );
            // header is e.g. "image/png;base64" — pull the mime off the front.
            var mime = listFirst( header, ";" );
            if ( !len( mime ) ) mime = arguments.rec.mime ?: "image/png";
            var bytes = binaryDecode( trim( b64 ), "base64" );
            return {
                "bytes"     : bytes,
                "mime"      : mime,
                "width"     : arguments.rec.width  ?: 0,
                "height"    : arguments.rec.height ?: 0,
                "expiresAt" : arguments.rec.expiresAt
            };
        }
        catch ( any e ) {
            log.error( "BxAiImageProvider.fetchPreview data-URL decode failed: " & e.message );
            return javaCast( "null", "" );
        }
    }

    // --------------------------------------------------------------------

    /**
     * Convert an aiChat raw response into our provider contract shape.
     * OpenRouter returns choices[*].message.images[*].image_url.url
     * for image output; we cache each URL against a previewId so the
     * save path can fetch by id.
     */
    private struct function unpackResponse( required any response, required numeric expectedCount ) {
        var previews = [];
        var expiresAt = dateAdd( "n", 55, now() );   // providers usually expire at ~60m; 55m is safe

        if ( isStruct( arguments.response ) && structKeyExists( arguments.response, "choices" ) ) {
            for ( var choice in arguments.response.choices ) {
                var images = choice.message.images ?: [];
                for ( var img in images ) {
                    // `imageUrl` not `url` — CFML reserved scope name.
                    var imageUrl = img.image_url.url ?: ( img.url ?: "" );
                    if ( !len( imageUrl ) ) continue;
                    var previewId = lCase( hash( createUUID(), "SHA-256" ) ).left( 12 );
                    variables.previewIndex[ previewId ] = {
                        "providerUrl" : imageUrl,
                        "expiresAt"   : expiresAt,
                        "mime"        : "image/png",
                        "width"       : img.width  ?: 0,
                        "height"      : img.height ?: 0
                    };
                    previews.append( {
                        "previewId"   : previewId,
                        "providerUrl" : imageUrl,
                        "expiresAt"   : expiresAt,
                        "width"       : img.width  ?: 0,
                        "height"      : img.height ?: 0,
                        "mime"        : "image/png"
                    } );
                }
            }
        }

        var usage = isStruct( arguments.response ) && structKeyExists( arguments.response, "usage" ) ? arguments.response.usage : {};
        var pt = val( usage.prompt_tokens     ?: usage.promptTokens     ?: 0 );
        var ct = val( usage.completion_tokens ?: usage.completionTokens ?: 0 );

        return {
            "previews"         : previews,
            "promptTokens"     : pt,
            "completionTokens" : ct,
            "totalTokens"      : pt + ct,
            "costUsdMicro"     : previews.len() * 40000    // ballpark; swap for lookup later
        };
    }

    private numeric function clamp( required numeric n, required numeric lo, required numeric hi ) {
        if ( arguments.n < arguments.lo ) return arguments.lo;
        if ( arguments.n > arguments.hi ) return arguments.hi;
        return arguments.n;
    }

}
