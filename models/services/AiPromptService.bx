/**
 * bx-Blogger — AiPromptService
 *
 * Read/write access to the `ai_prompts` table. The three rows are
 * seeded on first migrate-up; this service is the only authoritative
 * writer (don't reach for qb or Quick from outside).
 *
 * Hot-path read is `getActiveBody( slug, fallback )` — used by
 * AiAssistantService + AiImageService on every AI call. Cached per-
 * slug in `cachebox:default` under `ai_prompt:{slug}` with a 60-min
 * TTL; writes invalidate the per-slug entry. Same pattern as
 * SettingService, minus the page-cache flush (prompts only affect
 * future LLM calls, not rendered HTML).
 *
 * Method naming: methods avoid CFML/BoxLang BIF collisions
 * (`find`, `hash`, `left`, `right`, etc.) — in-class calls would
 * resolve to the BIF first and produce cryptic argument errors.
 * Use `getBySlug`, not `find`.
 */
class accessors="true" singleton {

    property name="wirebox" inject="wirebox";
    property name="cache"   inject="cachebox:default";
    property name="log"     inject="logbox:logger:{this}";

    variables.cacheTtlMinutes = 60;

    // --------------------------------------------------------------------
    // Read
    // --------------------------------------------------------------------

    /**
     * Hot-path lookup: return the active prompt body for `slug`, or
     * `fallback` when the row is missing or `is_active = 0`. Empty
     * `prompt_text` also falls through so a blank row behaves the
     * same as "no override".
     *
     * Cached. Bust by calling `update()` / `resetToDefault()` /
     * `invalidate()` on this service.
     */
    string function getActiveBody( required string slug, string fallback = "" ) {
        var row = readRow( arguments.slug );
        if ( isNull( row ) ) return arguments.fallback;
        if ( !val( row.is_active ?: 0 ) ) return arguments.fallback;
        var body = row.prompt_text ?: "";
        if ( !len( trim( body ) ) ) return arguments.fallback;
        return body;
    }

    /**
     * Return the full row for `slug` (cached) or null if missing.
     * Useful for the admin UI; hot-path callers should use
     * `getActiveBody` instead.
     */
    any function getBySlug( required string slug ) {
        var row = readRow( arguments.slug );
        if ( isNull( row ) ) return javaCast( "null", "" );
        return row;
    }

    /**
     * Every prompt row, ordered by slug. Used by the admin list view.
     * Doesn't hit the per-slug cache because it's not a hot path.
     */
    array function listAll() {
        return freshQb().from( "ai_prompts" )
            .orderBy( "slug", "asc" )
            .get();
    }

    // --------------------------------------------------------------------
    // Write
    // --------------------------------------------------------------------

    /**
     * Update one or more editable fields on the row identified by
     * `slug`. Supported keys in `attrs`:
     *   - prompt_text  (string)
     *   - is_active    (bool/0|1)
     *   - description  (string)
     *
     * `default_text`, `slug`, `name`, `is_system` are deliberately NOT
     * accepted here — they're seed-time concerns. `updated_by` is
     * stamped from the `editorUserId` arg; pass 0 for "system /
     * unattributed".
     *
     * Throws `bxBlogger.AiPromptService.NotFound` if the slug doesn't
     * exist.
     */
    function update( required string slug, required struct attrs, numeric editorUserId = 0 ) {
        var existing = readRow( arguments.slug );
        if ( isNull( existing ) ) {
            throw(
                type    = "bxBlogger.AiPromptService.NotFound",
                message = "No AI prompt with slug [" & arguments.slug & "]."
            );
        }

        var row = { "updated_at" : nowForDb() };
        if ( arguments.editorUserId > 0 ) row[ "updated_by" ] = arguments.editorUserId;
        if ( structKeyExists( arguments.attrs, "prompt_text" ) ) {
            row[ "prompt_text" ] = arguments.attrs.prompt_text ?: "";
        }
        if ( structKeyExists( arguments.attrs, "description" ) ) {
            row[ "description" ] = arguments.attrs.description ?: "";
        }
        if ( structKeyExists( arguments.attrs, "is_active" ) ) {
            row[ "is_active" ] = coerceBool( arguments.attrs.is_active ) ? 1 : 0;
        }

        freshQb().from( "ai_prompts" )
            .where( "slug", arguments.slug )
            .update( row );

        invalidate( arguments.slug );
    }

    /**
     * Restore `prompt_text` to the seeded `default_text` and flip
     * `is_active = 1`. Description is NOT restored — admins typically
     * tweak descriptions for their own clarity and don't want them
     * blown away.
     */
    function resetToDefault( required string slug, numeric editorUserId = 0 ) {
        var existing = readRow( arguments.slug );
        if ( isNull( existing ) ) {
            throw(
                type    = "bxBlogger.AiPromptService.NotFound",
                message = "No AI prompt with slug [" & arguments.slug & "]."
            );
        }

        var row = {
            "prompt_text" : existing.default_text ?: "",
            "is_active"   : 1,
            "updated_at"  : nowForDb()
        };
        if ( arguments.editorUserId > 0 ) row[ "updated_by" ] = arguments.editorUserId;

        freshQb().from( "ai_prompts" )
            .where( "slug", arguments.slug )
            .update( row );

        invalidate( arguments.slug );
    }

    /**
     * Insert a prompt row only if `slug` doesn't already exist. Used
     * by future programmatic seeding (e.g., a module that ships with
     * its own AI feature wants to register a default prompt without
     * requiring a separate migration). Returns true if a row was
     * inserted, false if the slug was already present.
     */
    boolean function seedIfMissing(
        required string slug,
        required string name,
        required string defaultText,
                 string description = "",
                 boolean isActive   = true,
                 boolean isSystem   = true
    ) {
        if ( !isNull( readRow( arguments.slug ) ) ) return false;
        var now = nowForDb();
        freshQb().from( "ai_prompts" ).insert( {
            "slug"         : arguments.slug,
            "name"         : arguments.name,
            "description"  : arguments.description,
            "prompt_text"  : arguments.defaultText,
            "default_text" : arguments.defaultText,
            "is_active"    : arguments.isActive ? 1 : 0,
            "is_system"    : arguments.isSystem ? 1 : 0,
            "created_at"   : now,
            "updated_at"   : now
        } );
        invalidate( arguments.slug );
        return true;
    }

    /**
     * Bust any cached row for `slug`. Public so external callers
     * (e.g. specs, future warm-cache jobs) can force a refresh.
     */
    function invalidate( required string slug ) {
        variables.cache.clear( cacheKey( arguments.slug ) );
    }

    // --------------------------------------------------------------------
    // Private
    // --------------------------------------------------------------------

    private any function readRow( required string slug ) {
        var key = cacheKey( arguments.slug );
        var cached = variables.cache.get( key );
        if ( !isNull( cached ) ) {
            // Sentinel for "known-missing" so we don't keep round-
            // tripping the DB for a slug that doesn't exist.
            return cached == "__NULL__" ? javaCast( "null", "" ) : cached;
        }

        var row = freshQb().from( "ai_prompts" )
            .where( "slug", arguments.slug )
            .first();

        if ( isNull( row ) || ( isStruct( row ) && structIsEmpty( row ) ) ) {
            variables.cache.set( key, "__NULL__", variables.cacheTtlMinutes, 0 );
            return javaCast( "null", "" );
        }

        variables.cache.set( key, row, variables.cacheTtlMinutes, 0 );
        return row;
    }

    private string function cacheKey( required string slug ) {
        return "ai_prompt:" & arguments.slug;
    }

    private boolean function coerceBool( required any value ) {
        if ( isBoolean( arguments.value ) ) return arguments.value;
        var v = lCase( trim( arguments.value ?: "" ) );
        return ( v == "true" || v == "1" || v == "yes" || v == "on" );
    }

    private any function freshQb() {
        return variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery();
    }

    private string function nowForDb() {
        return dateTimeFormat( now(), "yyyy-mm-dd HH:nn:ss" );
    }

}
