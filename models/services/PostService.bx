/**
 * bx-Blogger — PostService (Chunk 2.C)
 *
 * Business-logic authority for posts. Handlers push user intent in
 * through `create`, `update`, `publish`, `trash`, `restore`, etc.; the
 * service handles slug uniqueness, scheduled→published transitions,
 * reading-time + word-count computation, revision bookkeeping, and
 * content-version bumps. Permission checks stay in the handler layer —
 * a service method that mutates state assumes the caller already has
 * the right permission.
 *
 * Business rules enforced here:
 *   - `slug` is unique per `(post_type, parent_id)` — MySQL's unique
 *     index only catches collisions when parent_id is NOT NULL, so the
 *     service checks before every insert/update.
 *   - `body_html` is regenerated from `body_markdown` on every save,
 *     `body_compiled_at` bumps, and `content_version` increments. Chunk
 *     2.D swaps the placeholder markdown→html pass-through for the real
 *     bx-markdown + cbantisamy pipeline; the seam is `compileBody()`.
 *   - `reading_time_minutes` = `ceil( word_count / 225 )`, clamped to
 *     at least 1 minute when the post has any body at all.
 *   - A new `post_revisions` row is written for every save that
 *     actually changes title or body. Autosave revisions (Chunk 2.G)
 *     will write through the same path with `change_summary='autosave'`
 *     and get pruned separately.
 *
 * Status transitions (see PLAN §9 for the enum):
 *   draft / pending_review / scheduled  →  published  (`publish`)
 *   published                            →  draft      (`unpublish`)
 *   any                                  →  trashed    (`trash`)
 *   trashed                              →  draft      (`restore`)
 *   scheduled-at-or-before-now           →  published  (`promoteScheduledPosts`)
 */
class accessors="true" singleton {

    property name="wirebox"            inject="wirebox";
    property name="antisamy"           inject="AntiSamy@cbantisamy";
    property name="interceptorService" inject="coldbox:InterceptorService";
    property name="pageCacheService"   inject="PageCacheService";
    property name="redirectService"    inject="RedirectService";
    property name="oembedService"      inject="OembedService";
    property name="auditLogService"    inject="AuditLogService";
    property name="log"                inject="logbox:logger:{this}";

    variables.autosaveKeep = 20;   // B5: prune autosave revisions beyond this per post

    variables.readingWordsPerMinute = 225;   // newsroom-average reading pace
    variables.maxSlugLength         = 200;   // matches posts.slug VARCHAR

    // --------------------------------------------------------------------
    // Create / update
    // --------------------------------------------------------------------

    /**
     * Create a new post.
     *
     * @attrs Struct of Quick-compatible fields. Must include `authorId` +
     *        `title` + `bodyMarkdown`. Optional: `slug` (auto-derived
     *        from title if absent), `postType` (default "post"), `status`
     *        (default "draft"), `parentId`, `excerpt`, any SEO fields.
     * @return the created Post entity.
     */
    function create( required struct attrs ) {
        var data = normalizeIncoming( arguments.attrs );
        data.slug = ensureUniqueSlug(
            slug     = data.slug,
            postType = data.postType,
            parentId = structKeyExists( data, "parentId" ) ? data.parentId : javaCast( "null", "" )
        );
        applyComputedFields( data );
        data.contentVersion = 1;

        var post = variables.wirebox.getInstance( "Post" ).create( data );
        writeRevision(
            post          = post,
            editorId      = data.authorId,
            changeSummary = "initial"
        );
        dispatchOgImageRender( post );
        log.info( "PostService: created post=" & post.getId() & " slug=" & post.getSlug() );
        return post;
    }

    /**
     * Apply a struct of changes to an existing post. Recomputes body,
     * reading-time, word-count; bumps `content_version`; writes a
     * revision only if title or body actually changed.
     *
     * @post   Quick Post entity to update
     * @attrs  Struct of fields to change
     * @editorId  Who made the change (for the revision row)
     * @changeSummary  Freeform description (e.g. "autosave", "manual save")
     */
    function update(
        required any    post,
        required struct attrs,
        required numeric editorId,
                 string  changeSummary = ""
    ) {
        // Capture the post's status BEFORE anything mutates it. The
        // normalizeIncoming default + applyAttrsToEntity sequence can
        // reset `status` back to "draft" when a caller omits status
        // from the attrs struct (the admin-save flow does this and
        // relies on a subsequent publish() call to re-promote);
        // Phase 7.C's slug-change redirect hook needs the pre-update
        // reality so a slug rename on a published post still pushes
        // an auto-redirect even when this sequence demotes-then-
        // re-promotes within the same request.
        var priorStatus = dbStatusFor( arguments.post.getId() );

        var data = normalizeIncoming( arguments.attrs );
        var titleOrBodyChanged = false;

        if ( structKeyExists( data, "title" ) && data.title != arguments.post.getTitle() ) {
            titleOrBodyChanged = true;
        }
        if ( structKeyExists( data, "bodyMarkdown" ) && data.bodyMarkdown != arguments.post.getBodyMarkdown() ) {
            titleOrBodyChanged = true;
        }

        // Slug change handling. We remember the old slug so the
        // post-save block can auto-register a 301 into the redirects
        // table when the post was (and remains) public.
        var oldSlug       = arguments.post.getSlug();
        var slugChanged   = false;
        if ( structKeyExists( data, "slug" ) && len( data.slug ) && data.slug != oldSlug ) {
            data.slug = ensureUniqueSlug(
                slug     = data.slug,
                postType = data.postType ?: arguments.post.getPostType(),
                parentId = structKeyExists( data, "parentId" ) ? data.parentId : arguments.post.getParentId(),
                excludeId = arguments.post.getId()
            );
            if ( data.slug != oldSlug ) slugChanged = true;
        }

        applyComputedFields( data, arguments.post );
        if ( titleOrBodyChanged ) {
            data.contentVersion = ( arguments.post.getContentVersion() ?: 1 ) + 1;
        }

        // Featured-image "Remove" signal — the wire sends
        // featuredMediaId=0 as sentinel for "clear the FK". Capture
        // BEFORE normalizeIncoming, which now strips the key entirely
        // (so create() doesn't try to INSERT featured_media_id=0 and
        // trip the FK constraint). For update() we still need the raw
        // UPDATE NULL below — Quick can't null an FK cleanly
        // (setXxx(javaCast("null","")) silently drops the column from
        // the generated UPDATE per the CLAUDE.md gotcha).
        var shouldClearFeaturedMedia = (
            structKeyExists( arguments.attrs, "featuredMediaId" )
            && val( arguments.attrs.featuredMediaId ?: -1 ) == 0
        );

        applyAttrsToEntity( arguments.post, data );
        arguments.post.save();

        if ( shouldClearFeaturedMedia ) {
            queryExecute(
                "UPDATE posts SET featured_media_id = NULL WHERE id = ?",
                [ arguments.post.getId() ]
            );
            arguments.post.setFeaturedMediaId( javaCast( "null", "" ) );
        }

        // Phase 7.C — auto-redirect from old slug to new slug when
        // the post is (still) published. Drafts and scheduled posts
        // never had a live public URL, so crawlers won't be
        // following old paths; skipping them keeps the redirects
        // table free of rows that would never serve a hit.
        if ( slugChanged && priorStatus == "published" ) {
            try {
                variables.redirectService.register(
                    fromPath   = publicPathFor( arguments.post, oldSlug ),
                    toPath     = publicPathFor( arguments.post, arguments.post.getSlug() ),
                    statusCode = 301,
                    createdBy  = arguments.editorId
                );
            }
            catch ( any e ) {
                // Never let a redirect-write failure take down the
                // update itself — the post save already succeeded
                // and is the user-visible operation.
                log.warn( "PostService: auto-redirect register failed for post=" & arguments.post.getId() & ": " & e.message );
            }
        }

        if ( titleOrBodyChanged ) {
            writeRevision(
                post          = arguments.post,
                editorId      = arguments.editorId,
                changeSummary = len( arguments.changeSummary ) ? arguments.changeSummary : "manual"
            );
            // 5.A — edits to a published post could change the rendered
            // output (body, title, excerpt, featured image, etc.);
            // flush so the next GET rebuilds. Non-content edits (SEO
            // fields, template override) still qualify since they
            // affect <head> tags.
            if ( arguments.post.getStatus() == "published" ) {
                variables.pageCacheService.invalidateAll();
            }
        }

        dispatchOgImageRender( arguments.post );

        log.info( "PostService: updated post=" & arguments.post.getId() & " version=" & arguments.post.getContentVersion() );
        return arguments.post;
    }

    // --------------------------------------------------------------------
    // Status transitions
    // --------------------------------------------------------------------

    /**
     * Move a post to `published`. Sets `published_at` to now unless it's
     * already populated (re-publishing a previously-published post
     * preserves the original publish timestamp — `scheduled_at` stays
     * informational). Caller owns the permission check.
     */
    function publish( required any post, any actorId = javaCast( "null", "" ) ) {
        variables.interceptorService.announce(
            state = "prePostPublish",
            data  = { "post" : arguments.post }
        );

        arguments.post.setStatus( "published" );
        if ( isNull( arguments.post.getPublishedAt() ) || !len( arguments.post.getPublishedAt() ?: "" ) ) {
            arguments.post.setPublishedAt( now() );
        }
        arguments.post.save();

        // Phase 8.C.1 — record the publish in the unified audit log.
        // `actorId` is optional so legacy callers (the sample-post
        // seed, scheduled-publish cron) stay working; when absent,
        // user_id lands as NULL which the viewer renders as "system".
        variables.auditLogService.record(
            action     = "post.publish",
            userId     = arguments.actorId,
            entityType = "post",
            entityId   = arguments.post.getId(),
            metadata   = {
                "title" : arguments.post.getTitle() ?: "",
                "slug"  : arguments.post.getSlug() ?: ""
            }
        );
        // 5.A — freshly-published posts should appear on the public
        // site immediately; flush the rendered-HTML cache.
        variables.pageCacheService.invalidateAll();

        // 6.C — notify the author that their post is live. Direct call
        // rather than the `bxBlogger.postPostPublish` interception
        // route: ColdBox's auto-wiring can't match a method name to a
        // dot-prefixed state name (method names can't contain `.`),
        // and rewriting every `bxBlogger.*` point to the unprefixed
        // form is a bigger refactor than this chunk warrants. The
        // `interceptorService.announce` below still fires so future
        // subscribers (email channel, search-engine ping, etc.) that
        // go through a different registration route can listen.
        try {
            var notifications = variables.wirebox.getInstance( "NotificationService" );
            notifications.notify(
                userId   = int( arguments.post.getAuthorId() ),
                type     = "post_published",
                title    = "Your post is live",
                body     = "‘" & arguments.post.getTitle() & "’ was published successfully.",
                link     = "/admin/posts/editor?id=" & arguments.post.getId(),
                severity = "info",
                channels = [ "db" ]
            );
        }
        catch ( any e ) {
            variables.log.warn( "PostService.publish: notify failed: " & e.message, e );
        }

        variables.interceptorService.announce(
            state = "postPostPublish",
            data  = { "post" : arguments.post }
        );

        return arguments.post;
    }

    /**
     * Schedule a post for future publication. `scheduledAt` must be in
     * the future; past timestamps fall through to immediate publish.
     */
    function schedule( required any post, required any scheduledAt ) {
        if ( dateCompare( arguments.scheduledAt, now() ) != 1 ) {
            return publish( arguments.post );
        }
        arguments.post.setStatus( "scheduled" );
        arguments.post.setScheduledAt( arguments.scheduledAt );
        arguments.post.save();
        return arguments.post;
    }

    /**
     * Back to draft. The Phase 5 page cache consults `content_version`,
     * so we also bump that — prevents a stale published-HTML cache from
     * serving the now-private post.
     */
    function unpublish( required any post ) {
        arguments.post.setStatus( "draft" );
        arguments.post.setContentVersion( ( arguments.post.getContentVersion() ?: 1 ) + 1 );
        arguments.post.save();
        variables.pageCacheService.invalidateAll();
        return arguments.post;
    }

    function trash( required any post ) {
        arguments.post.setStatus( "trashed" );
        arguments.post.save();
        variables.pageCacheService.invalidateAll();
        return arguments.post;
    }

    /**
     * A7 — submit a draft for editor review. Flips status to
     * `pending_review` and announces `bxBlogger.postPostSubmitReview`
     * so the Phase 6 notifier can notify users with
     * `posts.publish.others`. Caller owns the permission check
     * (usually `posts.submit_for_review`).
     */
    function submitForReview( required any post, required numeric editorId ) {
        arguments.post.setStatus( "pending_review" );
        arguments.post.save();

        variables.interceptorService.announce(
            state = "postPostSubmitReview",
            data  = {
                "postId"      : arguments.post.getId(),
                "authorId"    : arguments.post.getAuthorId(),
                "submitterId" : arguments.editorId,
                "title"       : arguments.post.getTitle()
            }
        );
        log.info( "PostService: post=" & arguments.post.getId() & " submitted for review by user=" & arguments.editorId );
        return arguments.post;
    }

    /**
     * B5 — autosave the current editor buffer as a revision tagged
     * `change_summary='autosave'`. Does NOT touch the live post row
     * — the draft/published state stays where the author left it
     * until they explicitly save. Prunes to the newest `autosaveKeep`
     * autosaves per post so we don't grow the revisions table
     * unbounded on a long editing session.
     */
    function autosave(
        required any     post,
        required numeric editorId,
        required string  bodyMarkdown,
                 string  title = ""
    ) {
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" );

        qb.newQuery().from( "post_revisions" ).insert( {
            "post_id"        : arguments.post.getId(),
            "editor_id"      : arguments.editorId,
            "title"          : len( arguments.title ) ? arguments.title : ( arguments.post.getTitle() ?: "" ),
            "body_markdown"  : arguments.bodyMarkdown,
            "body_html"      : compileBody( arguments.bodyMarkdown ),
            "change_summary" : "autosave"
        } );

        pruneAutosaves( arguments.post.getId() );
    }

    /**
     * Keep the newest `autosaveKeep` autosave revisions for a post;
     * delete older ones. Runs in one DELETE with a subselect so we
     * don't round-trip every candidate id.
     */
    private void function pruneAutosaves( required numeric postId ) {
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" );

        var keepers = qb.newQuery()
            .from( "post_revisions" )
            .where( "post_id", arguments.postId )
            .where( "change_summary", "autosave" )
            .orderBy( "id", "desc" )
            .limit( variables.autosaveKeep )
            .select( "id" )
            .get();

        if ( keepers.len() < variables.autosaveKeep ) return;  // nothing to prune

        var keeperIds = keepers.map( function( r ) { return r.id; } );
        qb.newQuery()
            .from( "post_revisions" )
            .where( "post_id", arguments.postId )
            .where( "change_summary", "autosave" )
            .whereNotIn( "id", keeperIds )
            .delete();
    }

    function restore( required any post ) {
        arguments.post.setStatus( "draft" );
        arguments.post.save();
        variables.pageCacheService.invalidateAll();
        return arguments.post;
    }

    /**
     * Soft-delete. Sets `deleted_at`; the slug-uniqueness guard keys on
     * this column so the freed slug becomes available for reuse.
     */
    function softDelete( required any post ) {
        arguments.post.setDeletedAt( now() );
        arguments.post.save();
        variables.pageCacheService.invalidateAll();
        return arguments.post;
    }

    /**
     * Promote scheduled posts whose `scheduledAt <= now()` to
     * `published`. Returns the number of rows flipped. A Phase 6
     * scheduler task calls this every minute; for tests, call it
     * directly.
     */
    numeric function promoteScheduledPosts() {
        var due = variables.wirebox.getInstance( "Post" )
            .where( "status", "scheduled" )
            .where( "scheduled_at", "<=", now() )
            .whereNull( "deleted_at" )
            .get();

        var count = 0;
        for ( var p in due ) {
            publish( p );
            count++;
        }
        if ( count > 0 ) {
            log.info( "PostService.promoteScheduledPosts: published " & count & " scheduled posts" );
        }
        return count;
    }

    // --------------------------------------------------------------------
    // Slug helpers
    // --------------------------------------------------------------------

    /**
     * Convert a title (or anything else) to a URL-safe slug.
     *
     *   "Hello, World!"       → "hello-world"
     *   "Multiple   spaces"   → "multiple-spaces"
     *   "Unicôdé tëst"        → "unicode-test"   (after latin-fold)
     *   " leading/trailing "  → "leading-trailing"
     *   ""                    → "untitled"        (stable fallback)
     */
    string function slugify( required string source ) {
        var s = lCase( trim( arguments.source ) );
        // Simple latin-1 diacritic folding. Phase 11 can upgrade to ICU
        // for full Unicode normalization when we add i18n.
        s = replaceList( s,
            "à,á,â,ã,ä,å,ç,è,é,ê,ë,ì,í,î,ï,ñ,ò,ó,ô,õ,ö,ø,ù,ú,û,ü,ý,ÿ",
            "a,a,a,a,a,a,c,e,e,e,e,i,i,i,i,n,o,o,o,o,o,o,u,u,u,u,y,y"
        );
        s = reReplace( s, "[^a-z0-9]+", "-", "all" );
        s = reReplace( s, "^-+|-+$", "", "all" );
        if ( len( s ) > variables.maxSlugLength ) {
            s = left( s, variables.maxSlugLength );
            s = reReplace( s, "-+$", "", "all" );
        }
        return len( s ) ? s : "untitled";
    }

    /**
     * Given a candidate slug + scope, return a unique slug in the same
     * scope. Appends `-2`, `-3`, etc. until no collision. Excludes a
     * specific post id (for updates — a post can keep its own slug).
     */
    string function ensureUniqueSlug(
        required string  slug,
        required string  postType,
                 any     parentId,
                 numeric excludeId = 0
    ) {
        var base = arguments.slug;
        var candidate = base;
        var suffix = 1;

        while ( slugExists( candidate, arguments.postType, arguments.parentId, arguments.excludeId ) ) {
            suffix++;
            candidate = base & "-" & suffix;
        }
        return candidate;
    }

    private boolean function slugExists(
        required string  slug,
        required string  postType,
                 any     parentId,
                 numeric excludeId = 0
    ) {
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery()
            .from( "posts" )
            .where( "slug",      arguments.slug )
            .where( "post_type", arguments.postType )
            .whereNull( "deleted_at" );

        if ( isNull( arguments.parentId ) || !len( arguments.parentId ?: "" ) ) {
            qb.whereNull( "parent_id" );
        } else {
            qb.where( "parent_id", arguments.parentId );
        }
        if ( arguments.excludeId > 0 ) {
            qb.where( "id", "!=", arguments.excludeId );
        }
        return qb.exists();
    }

    // --------------------------------------------------------------------
    // Internals
    // --------------------------------------------------------------------

    /**
     * Fill in defaults for a caller-supplied attrs struct. Always returns
     * a new struct — never mutates the caller's.
     */
    private struct function normalizeIncoming( required struct attrs ) {
        var out = duplicate( arguments.attrs );
        if ( !structKeyExists( out, "postType" ) || !len( out.postType ?: "" ) )       out.postType = "post";
        if ( !structKeyExists( out, "status" )   || !len( out.status ?: "" ) )         out.status   = "draft";

        if ( !structKeyExists( out, "slug" ) || !len( trim( out.slug ?: "" ) ) ) {
            out.slug = slugify( out.title ?: "untitled" );
        } else {
            out.slug = slugify( out.slug );   // normalize user-typed slugs too
        }

        // Defensive FK handling. featured_media_id is a real foreign
        // key into `media.id`, so any value that isn't a live row id
        // will trip MySQL's constraint and take the whole save down
        // with an opaque error. Three cases the wire produces:
        //
        //   featuredMediaId is missing → no-op (Quick won't touch the column)
        //   featuredMediaId == 0       → "no featured image" sentinel from
        //                                 the wire's data init or its
        //                                 Remove button. Drop the key so
        //                                 create() inserts NULL; update()
        //                                 captured the explicit-clear
        //                                 signal before this normalize
        //                                 ran and still triggers a raw
        //                                 UPDATE NULL on the column.
        //   featuredMediaId > 0        → must reference a live (not
        //                                 soft-deleted) media row. Drop
        //                                 the key when it doesn't —
        //                                 create() inserts NULL,
        //                                 update() leaves the existing
        //                                 value alone.
        if ( structKeyExists( out, "featuredMediaId" ) ) {
            var fmid = val( out.featuredMediaId ?: 0 );
            if ( fmid == 0 ) {
                structDelete( out, "featuredMediaId" );
            }
            else {
                var exists = variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery()
                    .from( "media" )
                    .where( "id", fmid )
                    .whereNull( "deleted_at" )
                    .count();
                if ( !exists ) {
                    log.warn( "PostService.normalizeIncoming: dropping stale featuredMediaId=" & fmid & " (no live media row); preventing FK violation." );
                    structDelete( out, "featuredMediaId" );
                }
            }
        }

        // `featured` toggle controls home-page pinning. When the wire
        // sends featured=true, stamp featuredAt with the current time
        // (unless the caller passed an explicit value) so the listing
        // sort key always reflects when the pin happened. When false,
        // the stale featuredAt is left in place — the listFeatured()
        // query filters by featured=1 first so it's never observable.
        if ( structKeyExists( out, "featured" ) ) {
            out.featured = isBoolean( out.featured ) && out.featured;
            if ( out.featured && !structKeyExists( out, "featuredAt" ) ) {
                out.featuredAt = now();
            }
        }
        return out;
    }

    /**
     * Compute body_html / body_compiled_at / word_count / reading_time
     * for the struct, reading from `bodyMarkdown` if present (on
     * updates, fall back to the entity's current body).
     */
    private void function applyComputedFields( required struct data, any existing ) {
        var markdown = "";
        if ( structKeyExists( arguments.data, "bodyMarkdown" ) ) {
            markdown = arguments.data.bodyMarkdown;
        } else if ( structKeyExists( arguments, "existing" ) && !isNull( arguments.existing ) ) {
            markdown = arguments.existing.getBodyMarkdown() ?: "";
        }

        arguments.data.bodyHtml        = compileBody( markdown );
        arguments.data.bodyCompiledAt  = now();

        var words = countWords( markdown );
        arguments.data.wordCount          = words;
        arguments.data.readingTimeMinutes = readingTimeFor( words );
    }

    /**
     * Compile markdown → sanitized HTML.
     *
     * The `markdown()` BIF is provided by the bx-markdown runtime module
     * (registered via server.json's `onServerInitialInstall`). Every
     * rendering is piped through cbantisamy's `clean()` before it can
     * reach a template — the policy strips `<script>`, event handlers,
     * and untrusted URLs. `posts.html.unsafe` (PLAN §10) is a future
     * escape hatch for editors who need raw HTML widgets; the policy
     * swap lives here when that permission is wired in Phase 11.
     */
    string function compileBody( required string markdown ) {
        if ( !len( trim( arguments.markdown ) ) ) return "";

        // Phase 7.E — extract bare-URL-on-their-own-line embeds BEFORE
        // markdown + antisamy run. The preprocessor swaps each
        // embeddable URL for a `{{OEMBED:token}}` marker; markdown
        // treats the marker as plain text and antisamy leaves it
        // alone. After sanitization we swap the markers back in for
        // the real embed HTML (iframe / script / blockquote) — which
        // lets trusted-provider embeds bypass the AntiSamy policy
        // without loosening it for author-authored body HTML.
        var pre = variables.oembedService.preprocessMarkdown( arguments.markdown );
        var rawHtml = markdown( pre.markdown );
        var cleaned = variables.antisamy.clean( rawHtml );
        return variables.oembedService.restoreEmbeds( cleaned, pre.placeholders );
    }

    /**
     * Public entry point for the editor's live-preview button. Thin
     * alias around compileBody — exposes the same markdown→sanitize
     * pipeline the save path uses, so authors see exactly what the
     * public site will render.
     */
    string function renderPreview( required string markdown ) {
        return compileBody( arguments.markdown );
    }

    /**
     * Replace the full set of categories attached to a post. Takes an
     * array of category ids (ints or numeric strings) and wholesale-
     * overwrites the `post_categories` pivot. Simpler than diffing for
     * the typical <10 categories per post; we can swap to diff if the
     * cost ever shows up.
     */
    function syncCategories( required any post, required array categoryIds ) {
        var qb     = variables.wirebox.getInstance( "QueryBuilder@qb" );
        var postId = arguments.post.getId();

        qb.newQuery().from( "post_categories" ).where( "post_id", postId ).delete();
        for ( var catId in arguments.categoryIds ) {
            if ( !val( catId ) ) continue;
            variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery()
                .from( "post_categories" )
                .insert( {
                    "post_id"     : postId,
                    "category_id" : catId,
                    "is_primary"  : 0
                } );
        }
    }

    /**
     * Replace the full set of tags attached to a post. Accepts names
     * (not ids) so the editor form can be a plain text input — each
     * name is find-or-created via TagService (slug generation,
     * uniqueness handling). Blank / duplicate names are squashed.
     */
    function syncTags( required any post, required array tagNames ) {
        var postId     = arguments.post.getId();
        var tagService = variables.wirebox.getInstance( "TagService" );
        var qb         = variables.wirebox.getInstance( "QueryBuilder@qb" );

        // Resolve names → ids. Case-insensitive de-dupe by lowercased name.
        var seen = {};
        var ids  = [];
        for ( var raw in arguments.tagNames ) {
            var name = trim( raw );
            if ( !len( name ) ) continue;
            var key = lCase( name );
            if ( structKeyExists( seen, key ) ) continue;
            seen[ key ] = true;

            var existing = variables.wirebox.getInstance( "Tag" )
                .where( "name", name )
                .first();
            if ( isNull( existing ) ) {
                existing = tagService.create( { "name" : name } );
            }
            ids.append( existing.getId() );
        }

        qb.newQuery().from( "post_tags" ).where( "post_id", postId ).delete();
        for ( var tagId in ids ) {
            variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery()
                .from( "post_tags" )
                .insert( { "post_id" : postId, "tag_id" : tagId } );
        }
    }

    /**
     * Words in a markdown body. Strips common markdown punctuation so
     * `[link](x)` doesn't inflate the count and code fences / images
     * don't count as prose. Accurate enough for reading-time display;
     * ground-truth word count would parse to AST.
     */
    private numeric function countWords( required string markdown ) {
        var stripped = arguments.markdown;
        stripped = reReplace( stripped, "```[\s\S]*?```",    " ", "all" ); // fenced code
        stripped = reReplace( stripped, "`[^`]*`",           " ", "all" ); // inline code
        stripped = reReplace( stripped, "!\[[^\]]*\]\([^)]*\)", " ", "all" ); // images
        stripped = reReplace( stripped, "\[[^\]]*\]\([^)]*\)",  " ", "all" ); // links → label
        stripped = reReplace( stripped, "[##*_>~`\-\+]+", " ", "all" );
        stripped = trim( reReplace( stripped, "\s+", " ", "all" ) );
        if ( !len( stripped ) ) return 0;
        return listLen( stripped, " " );
    }

    private numeric function readingTimeFor( required numeric wordCount ) {
        if ( arguments.wordCount <= 0 ) return 0;
        var minutes = ceiling( arguments.wordCount / variables.readingWordsPerMinute );
        return minutes < 1 ? 1 : minutes;
    }

    /**
     * Persist a snapshot into `post_revisions`. Called from create()
     * and from update() when title or body changed.
     */
    /**
     * Phase 8.A — revision history for a post, newest first.
     * `includeAutosaves=false` (the default) hides rows with
     * `change_summary='autosave'`, matching the admin UI's
     * default view (the autosave firehose is noise when an editor
     * is looking for a deliberate save point).
     *
     * Returns full row structs (not Quick entities) so the wire
     * can render editor-name + body markdown without hitting the
     * ORM once per row. Body columns are included — the wire's
     * compare pane renders them directly.
     */
    array function listRevisions( required numeric postId, boolean includeAutosaves = false ) {
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery();
        var q  = qb.from( "post_revisions" )
            .leftJoin( "users", "users.id", "post_revisions.editor_id" )
            .where( "post_revisions.post_id", arguments.postId )
            .select( [
                "post_revisions.id AS id",
                "post_revisions.title AS title",
                "post_revisions.body_markdown AS body_markdown",
                "post_revisions.body_html AS body_html",
                "post_revisions.change_summary AS change_summary",
                "post_revisions.created_at AS created_at",
                "users.id AS editor_id",
                "users.display_name AS editor_display_name"
            ] )
            .orderBy( "post_revisions.created_at", "desc" )
            .orderBy( "post_revisions.id", "desc" );

        if ( !arguments.includeAutosaves ) {
            // Tight filter — PostService always sets change_summary
            // explicitly (manual / autosave / restored from ## / etc.),
            // so a simple `!= 'autosave'` suffices without the
            // NULL-handling dance. MySQL's ANSI semantics excludes
            // NULL from `!=`, which would be wrong for legitimately-
            // null rows, but we don't produce those.
            q.where( "post_revisions.change_summary", "!=", "autosave" );
        }
        return q.get();
    }

    /**
     * Phase 8.A — restore a post to a prior revision. Copies the
     * revision's `title` + `body_markdown` onto the live post,
     * re-compiles the HTML from current markdown (not the stored
     * body_html — compilation rules may have changed since the
     * revision was written), bumps `content_version`, and writes
     * a fresh revision tagged "restored from ##{rev.id}" so the
     * history retains the full trail.
     *
     * Returns the new revision's id so the caller can surface a
     * flash referencing it.
     */
    numeric function revertToRevision(
        required numeric postId,
        required numeric revisionId,
        required numeric editorId
    ) {
        var qb  = variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery();
        var rev = qb.from( "post_revisions" )
            .where( "id", arguments.revisionId )
            .where( "post_id", arguments.postId )
            .first();
        if ( isNull( rev ) || ( isStruct( rev ) && structIsEmpty( rev ) ) ) {
            throw(
                type    = "bxBlogger.PostService.RevisionNotFound",
                message = "Revision id=" & arguments.revisionId & " not found for post=" & arguments.postId
            );
        }

        var post = variables.wirebox.getInstance( "Post" ).find( arguments.postId );
        if ( isNull( post ) ) {
            throw(
                type    = "bxBlogger.PostService.NotFound",
                message = "Post id=" & arguments.postId & " not found"
            );
        }

        // Route the mutation through `update()` so the
        // slug-change / content-version / page-cache invalidation /
        // redirect-hook chain all fire, exactly as if the editor
        // had typed these values into the form and saved. No
        // explicit transaction — each step is individually
        // atomic + idempotent; a failure between them would leave
        // the post half-restored at worst, recoverable by the
        // admin re-running revert.
        update(
            post          = post,
            attrs         = {
                "title"        : rev.title,
                "bodyMarkdown" : rev.body_markdown
            },
            editorId      = arguments.editorId,
            changeSummary = "restored from ##" & arguments.revisionId
        );

        // `update()` already wrote a revision when title-or-body
        // changed; pull the most recent one back out to return
        // its id so the caller can reference it in a flash msg.
        var fresh = variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery()
            .from( "post_revisions" )
            .where( "post_id", arguments.postId )
            .orderBy( "id", "desc" )
            .first();
        return ( isNull( fresh ) || ( isStruct( fresh ) && structIsEmpty( fresh ) ) )
            ? 0
            : val( fresh.id ?: 0 );
    }

    private void function writeRevision(
        required any    post,
        required numeric editorId,
                 string  changeSummary = "manual"
    ) {
        variables.wirebox.getInstance( "PostRevision" ).create( {
            "postId"        : arguments.post.getId(),
            "editorId"      : arguments.editorId,
            "title"         : arguments.post.getTitle(),
            "bodyMarkdown"  : arguments.post.getBodyMarkdown() ?: "",
            "bodyHtml"      : arguments.post.getBodyHtml() ?: "",
            "changeSummary" : arguments.changeSummary
        } );
    }

    /**
     * Copy a struct onto a Quick entity. Skips keys that the entity
     * doesn't own (ignores typos rather than exploding). The Quick
     * setter names are camelCase matching the property name.
     */
    private void function applyAttrsToEntity( required any entity, required struct data ) {
        for ( var key in arguments.data ) {
            var setter = "set" & uCase( left( key, 1 ) ) & mid( key, 2, 999 );
            if ( structKeyExists( arguments.entity, setter ) ) {
                invoke( arguments.entity, setter, { "1" : arguments.data[ key ] } );
            }
        }
    }

    /**
     * Public-site path for a post given a slug — `/blog/{slug}` for
     * regular posts, `/{slug}` for pages. Used by the slug-change
     * hook to register redirects; single place to encode the route
     * pattern so we don't drift from config/Router.bx. The `slug`
     * argument is explicit (rather than pulled from the entity) so
     * callers can generate the *old* path before the entity was
     * mutated.
     */
    private string function publicPathFor( required any post, required string slug ) {
        var type = arguments.post.getPostType() ?: "post";
        return type == "page" ? ( "/" & arguments.slug ) : ( "/blog/" & arguments.slug );
    }

    /**
     * Read the current status directly from the `posts` table. Quick's
     * in-memory entity state can lag after a cross-service mutation
     * (publish → update call sequence), and this hook runs at a spot
     * where that lag would let a published-post slug change skip the
     * auto-redirect. One indexed SELECT by PK is cheap.
     */
    private string function dbStatusFor( required numeric postId ) {
        try {
            var qb = variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery();
            var row = qb.from( "posts" )
                .select( "status" )
                .where( "id", arguments.postId )
                .first();
            if ( isNull( row ) || ( isStruct( row ) && structIsEmpty( row ) ) ) return "";
            return row.status ?: "";
        }
        catch ( any e ) {
            return "";
        }
    }

    /**
     * Enqueue an OG-image render for the given post. Fired after
     * every create/update so the rendered card always reflects the
     * current title + author + author-preferences state. Failures are
     * swallowed — a queue hiccup mustn't take down a post save.
     */
    private void function dispatchOgImageRender( required any post ) {
        try {
            variables.wirebox.getInstance( "OgImageJob" )
                .setProperties( { "postId" : int( arguments.post.getId() ) } )
                .dispatch();
        }
        catch ( any e ) {
            log.warn( "PostService: OG image dispatch failed for post=" & arguments.post.getId() & ": " & e.message );
        }
    }

}
