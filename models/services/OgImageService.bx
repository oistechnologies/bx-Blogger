/**
 * bx-Blogger — OgImageService
 *
 * Renders a 1200×630 PNG share card for a post, eagerly on every
 * post save and on demand when an author changes a preference that
 * affects OG composition. Cached on the `og` cbfs disk keyed by
 * `{post_id}-v{og_version}.png` — `og_version` is bumped on each
 * regenerate, which gives free cache-busting for browsers + the
 * CDN fronting the og disk.
 *
 * Composition (1200×630):
 *
 *   Top-left   — site logo (when /includes/public/branding/
 *                logo-mark-light.png exists)
 *   Top-right  — site name (text)
 *   Center     — title (bold, wrapped to 2 lines, ellipsized on
 *                overflow)
 *   Bottom-left — author block:
 *                   * profile photo (64×64, only when
 *                     ogIncludeProfilePhoto is on AND the user has
 *                     a photo on file)
 *                   * "by {display_name}"
 *                   * email line (only when ogIncludeEmail is on)
 *   Bottom-right — post URL text + QR code pair (only when
 *                  ogIncludeSocialsAndUrl is on; QR comes in 4b)
 *   Bottom edge  — accent bar (12px, full width)
 *
 * Each "include …" toggle is a per-author preference set on
 * /admin/account; an author with all three off ships a clean
 * title-card render. The toggles ALSO govern what shows on the
 * public author page — same set of switches, two surfaces.
 *
 * Service is a WireBox singleton. Renders happen on the cbq worker
 * thread (via OgImageJob) so HTTP threads never wait on Java2D.
 */
class accessors="true" singleton {

    property name="wirebox" inject="wirebox";
    property name="cbfs"    inject="DiskService@cbfs";
    property name="log"     inject="logbox:logger:{this}";
    property name="settingService" inject="SettingService";

    variables.canvasWidth    = 1200;
    variables.canvasHeight   = 630;
    variables.paddingX       = 72;
    variables.paddingY       = 72;
    variables.logoMaxWidth   = 96;
    variables.logoMaxHeight  = 96;
    variables.titleMaxChars  = 160;
    variables.bgColorHex     = "##1B1E2C";
    variables.fgColorHex     = "##FFFFFF";
    variables.fgMutedHex     = "##B0B6C8";
    variables.accentColorHex = "##00DBFF";
    variables.authorPhotoSize = 64;
    // Vertical gap between the email line and the name line above
    // it when both are drawn. Pure visual breathing room.
    variables.authorLineGap   = 12;

    // QR + URL (bottom-right) — only drawn when the author's
    // ogIncludeSocialsAndUrl preference is on.
    variables.qrModulePixels  = 6;     // pixel width per QR module
    variables.qrQuietZonePx   = 12;    // white border around the QR
    variables.qrSidePadding   = 16;    // gap between URL text + QR

    // --------------------------------------------------------------------
    // Public API
    // --------------------------------------------------------------------

    /**
     * Public URL for the rendered card. Renders on first miss so a
     * post visited before its scheduled render-job has run still
     * gets a valid og:image. Returns "" on failure — callers
     * downgrade to a `summary`-shaped twitter card.
     */
    string function urlFor( required any post ) {
        try {
            var disk = variables.cbfs.get( "og" );
            var path = pathFor( arguments.post );
            if ( !disk.exists( path ) ) generate( arguments.post );
            if ( !disk.exists( path ) ) return "";
            return disk.url( path );
        }
        catch ( any e ) {
            log.warn( "OgImageService.urlFor failed for post=" & arguments.post.getId() & ": " & e.message );
            return "";
        }
    }

    /**
     * Bump og_version + render. The "fresh-image-please" path used by
     * OgImageJob (post save), AuthorOgRegenJob (author preference
     * change fan-out), and the manual Regenerate button in the post
     * editor.
     */
    function regenerate( required any post ) {
        var current = val( arguments.post.getOgVersion() ?: 0 );
        arguments.post.setOgVersion( current + 1 );
        arguments.post.save();
        generate( arguments.post );
        return arguments.post;
    }

    /**
     * Render the card and write it to disk at the current og_version
     * key. Overwrites any existing file at that key — meaningful only
     * after a regenerate(), since the version bumps make the key
     * unique anyway. Fail-quiet: a single render failure logs but
     * does NOT throw, so a transient JVM hiccup doesn't blow up an
     * entire post save.
     */
    function generate( required any post ) {
        try {
            var disk = variables.cbfs.get( "og" );
            var path = pathFor( arguments.post );
            var bytes = renderPngBytes( arguments.post );
            disk.create( path = path, contents = bytes, overwrite = true );
            log.info( "OgImageService: generated " & path & " (" & arrayLen( bytes ) & " bytes)" );
        }
        catch ( any e ) {
            log.warn( "OgImageService.generate failed for post=" & arguments.post.getId() & ": " & e.message & " / " & ( e.detail ?: "" ) );
        }
    }

    /**
     * Disk key — deterministic from post id + og_version. Callers
     * (handler-side preview, page cache invalidation hook) can
     * compute it without touching the disk.
     */
    string function pathFor( required any post ) {
        return arguments.post.getId() & "-v" & val( arguments.post.getOgVersion() ?: 0 ) & ".png";
    }

    // --------------------------------------------------------------------
    // Rendering
    // --------------------------------------------------------------------

    /**
     * Read the post's author + the configured site name, then render
     * the 1200×630 PNG with the per-author preference toggles applied.
     * Returns byte[].
     */
    private any function renderPngBytes( required any post ) {
        var BufferedImage  = createObject( "java", "java.awt.image.BufferedImage" );
        var Color          = createObject( "java", "java.awt.Color" );
        var Font           = createObject( "java", "java.awt.Font" );
        var RenderingHints = createObject( "java", "java.awt.RenderingHints" );
        var ImageIO        = createObject( "java", "javax.imageio.ImageIO" );
        var BAOS           = createObject( "java", "java.io.ByteArrayOutputStream" );

        // Pull the author + site once so the draw block doesn't make
        // round-trips while it's holding the Graphics context.
        var ctx = buildRenderContext( arguments.post );

        var img = BufferedImage.init(
            variables.canvasWidth,
            variables.canvasHeight,
            BufferedImage.TYPE_INT_RGB
        );
        var g = img.createGraphics();

        try {
            g.setRenderingHint( RenderingHints.KEY_ANTIALIASING,      RenderingHints.VALUE_ANTIALIAS_ON      );
            g.setRenderingHint( RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_ON );
            g.setRenderingHint( RenderingHints.KEY_RENDERING,         RenderingHints.VALUE_RENDER_QUALITY    );

            // Background
            g.setColor( decodeColor( Color, variables.bgColorHex ) );
            g.fillRect( 0, 0, variables.canvasWidth, variables.canvasHeight );

            // Bottom accent bar (cyan, 12px)
            g.setColor( decodeColor( Color, variables.accentColorHex ) );
            g.fillRect( 0, variables.canvasHeight - 12, variables.canvasWidth, 12 );

            drawTitle(    g, Font, Color, ctx );
            drawSiteName( g, Font, Color, ctx );
            drawLogo(     g, ImageIO );
            drawAuthorBlock( g, Font, Color, ImageIO, ctx );
            drawUrlAndQr(    g, Font, Color, ctx );

            var baos = BAOS.init();
            ImageIO.write( img, "png", baos );
            return baos.toByteArray();
        }
        finally {
            g.dispose();
        }
    }

    /**
     * Resolve everything renderPngBytes needs about the post + its
     * author + site config into a single struct. Decoupled so spec
     * setup can stub the same struct without exercising the ORM.
     */
    private struct function buildRenderContext( required any post ) {
        var author     = arguments.post.getAuthor();
        var hasAuthor  = !isNull( author );

        var siteName   = trim( settingService.get( "site_name", "" ) );
        if ( !len( siteName ) ) siteName = trim( settingService.get( "AppName", "" ) );

        // Author preferences with safe defaults — a post with a
        // deleted/missing author still renders a clean title card.
        var includePhoto    = hasAuthor && !!author.getOgIncludeProfilePhoto();
        var includeEmail    = hasAuthor && !!author.getOgIncludeEmail();
        var includeSocials  = hasAuthor && !!author.getOgIncludeSocialsAndUrl();

        // Decide whether to attempt a profile-photo read. We don't
        // resolve bytes here — that happens in drawAuthorBlock
        // through the cbfs disk's own getAsBinary() so the path-
        // resolution logic (Local filesystem path vs. S3 GET vs.
        // anything else cbfs supports) stays inside the provider.
        var hasUsablePhoto = includePhoto && hasAuthor && author.hasProfilePhoto();

        return {
            "post"             : arguments.post,
            "title"            : arguments.post.getTitle() ?: "",
            "siteName"         : siteName,
            "author"           : hasAuthor ? author : javaCast( "null", "" ),
            "authorName"       : hasAuthor ? ( author.getDisplayName() ?: "" ) : "",
            "authorEmail"      : hasAuthor ? ( author.getEmail() ?: "" ) : "",
            "includePhoto"     : includePhoto,
            "includeEmail"     : includeEmail,
            "includeSocials"   : includeSocials,
            "hasUsablePhoto"   : hasUsablePhoto,
            "profilePhotoKey"  : hasUsablePhoto ? author.getProfilePhotoPath() : "",
            "postUrl"          : buildPostUrl( arguments.post )
        };
    }

    /**
     * Absolute public URL for a post, derived from APP_URL + the post
     * type's path convention. Mirrors the private `publicPathFor`
     * used inside PostService — kept inline here rather than DRY'd
     * because OgImageService is on the cbq worker thread and we
     * want zero cross-service injection in the render path.
     */
    private string function buildPostUrl( required any post ) {
        var base = trim( getSystemSetting( "APP_URL", "" ) );
        if ( !len( base ) ) base = trim( settingService.get( "site_url", "" ) );
        base = reReplace( base, "/+$", "", "all" );
        if ( !len( base ) ) return "";

        var slug = arguments.post.getSlug() ?: "";
        var type = arguments.post.getPostType() ?: "post";
        if ( !len( slug ) ) return base;
        return type == "page" ? ( base & "/" & slug ) : ( base & "/blog/" & slug );
    }

    private void function drawTitle( required any g, required any Font, required any Color, required struct ctx ) {
        var titleText = left( arguments.ctx.title, variables.titleMaxChars );
        var titleFont = arguments.Font.init( "SansSerif", arguments.Font.BOLD, 64 );
        arguments.g.setFont( titleFont );
        arguments.g.setColor( decodeColor( arguments.Color, variables.fgColorHex ) );

        var maxTextWidth = variables.canvasWidth - ( 2 * variables.paddingX );
        var lines        = wrapText( arguments.g, titleText, maxTextWidth, 2 );
        var fm           = arguments.g.getFontMetrics();
        var lineHeight   = fm.getHeight();

        var titleBlockHeight = arrayLen( lines ) * lineHeight;
        var titleBaseY       = int( ( variables.canvasHeight - titleBlockHeight ) / 2 ) + fm.getAscent();
        for ( var i = 1; i <= arrayLen( lines ); i++ ) {
            arguments.g.drawString(
                lines[ i ],
                variables.paddingX,
                titleBaseY + ( ( i - 1 ) * lineHeight )
            );
        }
    }

    private void function drawSiteName( required any g, required any Font, required any Color, required struct ctx ) {
        if ( !len( arguments.ctx.siteName ) ) return;
        var siteFont = arguments.Font.init( "SansSerif", arguments.Font.PLAIN, 28 );
        arguments.g.setFont( siteFont );
        arguments.g.setColor( decodeColor( arguments.Color, variables.fgColorHex ) );
        var fm = arguments.g.getFontMetrics();
        var w  = fm.stringWidth( arguments.ctx.siteName );
        arguments.g.drawString(
            arguments.ctx.siteName,
            variables.canvasWidth - variables.paddingX - w,
            variables.paddingY + fm.getAscent()
        );
    }

    private void function drawLogo( required any g, required any ImageIO ) {
        try {
            var logoPath = expandPath( "/includes/public/branding/logo-mark-light.png" );
            if ( !fileExists( logoPath ) ) return;
            var logoImg = arguments.ImageIO.read( createObject( "java", "java.io.File" ).init( logoPath ) );
            if ( isNull( logoImg ) ) return;
            var lw = logoImg.getWidth();
            var lh = logoImg.getHeight();
            var scale = min(
                variables.logoMaxWidth  / lw,
                variables.logoMaxHeight / lh
            );
            arguments.g.drawImage(
                logoImg,
                variables.paddingX,
                variables.paddingY,
                int( lw * scale ),
                int( lh * scale ),
                javaCast( "null", "" )
            );
        }
        catch ( any e ) {
            log.debug( "OgImageService: logo draw skipped — " & e.message );
        }
    }

    /**
     * Bottom-left author block. Profile photo (when enabled + on
     * file), display name in cyan, email below name in muted grey
     * (when ogIncludeEmail is on). Skips entirely when the post has
     * no resolvable author.
     */
    private void function drawAuthorBlock( required any g, required any Font, required any Color, required any ImageIO, required struct ctx ) {
        if ( isNull( arguments.ctx.author ) ) return;
        if ( !len( arguments.ctx.authorName ) && !len( arguments.ctx.authorEmail ) ) return;

        var nameFont  = arguments.Font.init( "SansSerif", arguments.Font.PLAIN, 32 );
        var emailFont = arguments.Font.init( "SansSerif", arguments.Font.PLAIN, 22 );

        // Anchor: the baseline of the bottom-most line of text sits at
        // `canvasHeight - paddingY`. With one line that's name-only;
        // with email enabled, name goes up by emailLineHeight.
        var baselineY = variables.canvasHeight - variables.paddingY;
        var nameX     = variables.paddingX;

        // Optional profile photo — sits to the LEFT of the text block,
        // shifts text rightward by photoSize + gap. Photo bytes are
        // fetched via `readPhotoBytes()` rather than cbfs.getAsBinary
        // because the latter routes through s3sdk.getObject(), which
        // calls buildUrlEndpoint() as a side effect and re-introduces
        // the broken double-region hostname for non-AWS providers
        // (B2 / DO Spaces). That mutation persists on the singleton
        // disk instance and breaks every subsequent PUT until the
        // next fwreinit. readPhotoBytes() avoids the trap by going
        // either filesystem-direct (Local cbfs) or HTTP-direct
        // through the disk's public URL (S3-backed cbfs).
        if ( arguments.ctx.hasUsablePhoto && len( arguments.ctx.profilePhotoKey ) ) {
            try {
                var photoBytes = readPhotoBytes( arguments.ctx.profilePhotoKey );
                if ( !isNull( photoBytes ) && isBinary( photoBytes ) ) {
                    var bais = createObject( "java", "java.io.ByteArrayInputStream" ).init( photoBytes );
                    var photoImg = arguments.ImageIO.read( bais );
                    bais.close();
                    if ( !isNull( photoImg ) ) {
                        var photoSize = variables.authorPhotoSize;
                        var photoY    = baselineY - photoSize + 8;
                        arguments.g.drawImage(
                            photoImg,
                            variables.paddingX,
                            photoY,
                            photoSize,
                            photoSize,
                            javaCast( "null", "" )
                        );
                        nameX = variables.paddingX + photoSize + 16;
                    }
                }
            }
            catch ( any e ) {
                log.debug( "OgImageService: profile-photo draw skipped — " & e.message );
            }
        }

        // Email line first when enabled, drawn BELOW the name baseline.
        var nameBaseline = baselineY;
        if ( arguments.ctx.includeEmail && len( arguments.ctx.authorEmail ) ) {
            arguments.g.setFont( emailFont );
            arguments.g.setColor( decodeColor( arguments.Color, variables.fgMutedHex ) );
            var efm = arguments.g.getFontMetrics();
            arguments.g.drawString( arguments.ctx.authorEmail, nameX, baselineY );
            // Push the name baseline up by one full email-line height
            // PLUS the configured gap so the two lines breathe.
            nameBaseline = baselineY - efm.getHeight() - variables.authorLineGap;
        }

        // Name line in cyan accent.
        if ( len( arguments.ctx.authorName ) ) {
            arguments.g.setFont( nameFont );
            arguments.g.setColor( decodeColor( arguments.Color, variables.accentColorHex ) );
            arguments.g.drawString( "by " & arguments.ctx.authorName, nameX, nameBaseline );
        }
    }

    /**
     * Bottom-right URL text + paired QR code. Drawn only when the
     * author has `ogIncludeSocialsAndUrl` enabled AND the post URL
     * resolved to non-empty. Either piece missing skips the entire
     * block — partial render would look broken.
     *
     * Layout: QR in the bottom-right corner with a quiet-zone white
     * background (B2-friendly contrast against the dark canvas);
     * URL text right-aligned to the QR's left edge, vertically
     * centered with the QR. Long URLs are clipped with an ellipsis
     * before they walk over the author block on the left.
     */
    private void function drawUrlAndQr( required any g, required any Font, required any Color, required struct ctx ) {
        if ( !arguments.ctx.includeSocials ) return;
        if ( !len( arguments.ctx.postUrl ) ) return;

        try {
            var QrCode    = createObject( "java", "io.nayuki.qrcodegen.QrCode" );
            var Ecc       = createObject( "java", "io.nayuki.qrcodegen.QrCode$Ecc" );
            var qr        = QrCode.encodeText( arguments.ctx.postUrl, Ecc.MEDIUM );

            // Compute pixel size of the rendered QR + its quiet-zone
            // white border. Nayuki's `qr.size` is the module count
            // (e.g., 25 for v2 with 25×25 modules).
            var modules    = qr.size;
            var modulePx   = variables.qrModulePixels;
            var quiet      = variables.qrQuietZonePx;
            var qrPixels   = modules * modulePx;
            var blockSize  = qrPixels + ( 2 * quiet );

            // Anchor: bottom-right, sitting just above the accent bar.
            var blockRight  = variables.canvasWidth  - variables.paddingX;
            var blockBottom = variables.canvasHeight - variables.paddingY;
            var blockLeft   = blockRight  - blockSize;
            var blockTop    = blockBottom - blockSize;

            // White background rectangle (the quiet zone) so the QR
            // is high-contrast against the dark canvas + scannable.
            arguments.g.setColor( decodeColor( arguments.Color, "##FFFFFF" ) );
            arguments.g.fillRoundRect(
                javaCast( "int", blockLeft ),
                javaCast( "int", blockTop ),
                javaCast( "int", blockSize ),
                javaCast( "int", blockSize ),
                javaCast( "int", 8 ),
                javaCast( "int", 8 )
            );

            // QR modules — solid black squares.
            arguments.g.setColor( decodeColor( arguments.Color, "##000000" ) );
            for ( var y = 0; y < modules; y++ ) {
                for ( var x = 0; x < modules; x++ ) {
                    if ( qr.getModule( javaCast( "int", x ), javaCast( "int", y ) ) ) {
                        arguments.g.fillRect(
                            javaCast( "int", blockLeft + quiet + ( x * modulePx ) ),
                            javaCast( "int", blockTop  + quiet + ( y * modulePx ) ),
                            javaCast( "int", modulePx ),
                            javaCast( "int", modulePx )
                        );
                    }
                }
            }

            // URL text — right-aligned to the QR's left edge,
            // vertically centered with the QR. Trimmed to fit the
            // available width on the left of the QR, with an
            // ellipsis when it would otherwise collide with the
            // author block on the left side of the canvas.
            var urlFont = arguments.Font.init( "SansSerif", arguments.Font.PLAIN, 22 );
            arguments.g.setFont( urlFont );
            arguments.g.setColor( decodeColor( arguments.Color, variables.fgMutedHex ) );
            var fm        = arguments.g.getFontMetrics();
            // Leave the left half of the canvas to the author block —
            // start text no further left than canvasWidth / 2.
            var maxTextLeft  = int( variables.canvasWidth / 2 );
            var maxTextWidth = blockLeft - variables.qrSidePadding - maxTextLeft;
            var displayUrl   = stripUrlScheme( arguments.ctx.postUrl );
            var fitted       = clipToWidth( fm, displayUrl, maxTextWidth );
            // Ellipsize when clipping happened.
            if ( len( fitted ) < len( displayUrl ) ) {
                fitted = clipToWidth( fm, fitted & "...", maxTextWidth );
            }
            var textWidth = fm.stringWidth( fitted );
            var textX     = blockLeft - variables.qrSidePadding - textWidth;
            var textY     = int( ( blockTop + blockBottom ) / 2 ) + int( fm.getAscent() / 2 ) - 2;
            arguments.g.drawString( fitted, javaCast( "int", textX ), javaCast( "int", textY ) );
        }
        catch ( any e ) {
            log.warn( "OgImageService.drawUrlAndQr: skipped — " & e.message );
        }
    }

    /**
     * Trim the leading scheme from a URL (`https://` / `http://`)
     * for compact display next to the QR. The QR itself encodes the
     * full URL; the visible text is just for humans skimming the
     * card.
     */
    private string function stripUrlScheme( required string url ) {
        return reReplaceNoCase( arguments.url, "^https?://", "" );
    }

    /**
     * Read profile-photo bytes from the `media` cbfs disk WITHOUT
     * routing through cbfs.getAsBinary, which calls s3sdk.getObject
     * and overwrites our patched URL via buildUrlEndpoint() as a
     * side effect. Two paths:
     *
     *   - Local cbfs: properties.path holds a real filesystem
     *     directory; concatenate the key + read directly.
     *   - S3 cbfs (MinIO / B2 / DO Spaces): the disk's public URL
     *     resolves to the bucket's public-read endpoint; cfhttp it.
     *
     * Returns binary bytes on success, null on miss/failure. Caller
     * silently degrades to "no profile photo on the OG card" when
     * the photo can't be read — never blocks a render.
     */
    private any function readPhotoBytes( required string profilePhotoKey ) {
        var mediaDisk = variables.cbfs.get( "media" );

        try {
            if ( structKeyExists( mediaDisk, "getProperties" ) ) {
                var props = mediaDisk.getProperties();
                if ( structKeyExists( props, "path" ) && len( props.path ) ) {
                    var localPath = props.path & "/" & arguments.profilePhotoKey;
                    if ( fileExists( localPath ) ) {
                        return fileReadBinary( localPath );
                    }
                }
            }
        }
        catch ( any e ) { /* fall through to HTTP */ }

        try {
            var pubUrl = mediaDisk.url( arguments.profilePhotoKey );
            if ( !len( pubUrl ) || !( pubUrl contains "://" ) ) {
                return javaCast( "null", "" );
            }

            // Use java.net.URL directly rather than `cfhttp(...)` —
            // OG renders run on cbq worker threads, where the BoxLang
            // compat layer for cfhttp isn't always wired up
            // ("Function [cfhttp] not found" on non-request threads,
            // analogous to the LogBox-from-non-request-thread caveat
            // in CLAUDE.md). Java's URLConnection is JDK-core and
            // works from any thread.
            //
            // Local var is `JavaUrl` (not `URL`) because `URL` is a
            // reserved CFML scope name — `var URL = createObject(...)`
            // resolves to `ortus.boxlang.web.scopes.URLScope` instead
            // of the Java class. Same trap as the global CLAUDE.md
            // reserved-scope-collision note.
            var JavaUrl = createObject( "java", "java.net.URL" );
            var u       = JavaUrl.init( pubUrl );
            var conn = u.openConnection();
            conn.setConnectTimeout( javaCast( "int", 5000 )  );
            conn.setReadTimeout(    javaCast( "int", 10000 ) );
            conn.setRequestMethod( "GET" );

            var status = conn.getResponseCode();
            if ( status != 200 ) {
                log.warn( "OgImageService.readPhotoBytes: HTTP " & status & " for " & pubUrl );
                return javaCast( "null", "" );
            }

            var inStream = conn.getInputStream();
            try {
                var BAOS = createObject( "java", "java.io.ByteArrayOutputStream" );
                var baos = BAOS.init();
                // Allocate a 4 KB reusable read buffer. `.getBytes()` on
                // a CFML string yields a Java byte[] — cheaper than
                // routing through java.lang.reflect.Array.newInstance.
                var buf = repeatString( " ", 4096 ).getBytes();
                var n = inStream.read( buf );
                while ( n > -1 ) {
                    baos.write( buf, javaCast( "int", 0 ), javaCast( "int", n ) );
                    n = inStream.read( buf );
                }
                return baos.toByteArray();
            }
            finally {
                inStream.close();
            }
        }
        catch ( any e ) {
            log.warn( "OgImageService.readPhotoBytes: HTTP fetch failed for " & arguments.profilePhotoKey & " — " & e.message );
        }
        return javaCast( "null", "" );
    }

    // --------------------------------------------------------------------
    // Color + text utilities
    // --------------------------------------------------------------------

    /**
     * Hex-string → java.awt.Color. Accepts `#RRGGBB`, `##RRGGBB`
     * (BoxLang doubles `#`), and bare `RRGGBB`. Builds Color(r,g,b)
     * directly because Color.decode("0x...") tripped BoxLang's
     * literal-parser in early development.
     */
    private any function decodeColor( required any ColorClass, required string hex ) {
        var h = arguments.hex;
        if ( left( h, 1 ) == "##" ) h = right( h, len( h ) - 1 );
        var Integer = createObject( "java", "java.lang.Integer" );
        var r = Integer.parseInt( mid( h, 1, 2 ), 16 );
        var g = Integer.parseInt( mid( h, 3, 2 ), 16 );
        var b = Integer.parseInt( mid( h, 5, 2 ), 16 );
        return arguments.ColorClass.init( javaCast( "int", r ), javaCast( "int", g ), javaCast( "int", b ) );
    }

    /**
     * Greedy word-wrap into `maxLines` lines under `maxPx`. Last line
     * gets ellipsized when text overflows; a single oversized word is
     * hard-clipped rather than escaping the canvas.
     */
    private array function wrapText(
        required any     g,
        required string  text,
        required numeric maxPx,
        required numeric maxLines
    ) {
        var fm    = arguments.g.getFontMetrics();
        var lines = [];
        var current = "";

        var words = listToArray( reReplace( arguments.text, "\s+", " ", "all" ), " " );
        for ( var w in words ) {
            var candidate = len( current ) ? ( current & " " & w ) : w;
            if ( fm.stringWidth( candidate ) <= arguments.maxPx ) {
                current = candidate;
                continue;
            }
            if ( len( current ) ) lines.append( current );
            if ( arrayLen( lines ) >= arguments.maxLines ) break;
            current = w;
            if ( fm.stringWidth( current ) > arguments.maxPx ) {
                current = clipToWidth( fm, current, arguments.maxPx );
            }
        }
        if ( len( current ) && arrayLen( lines ) < arguments.maxLines ) lines.append( current );

        if ( arrayLen( lines ) == arguments.maxLines ) {
            var consumed = lines.toList( " " );
            if ( len( consumed ) < len( arguments.text ) && arrayLen( lines ) ) {
                var last = lines[ arrayLen( lines ) ];
                lines[ arrayLen( lines ) ] = clipToWidth( fm, last & "...", arguments.maxPx );
            }
        }
        if ( !arrayLen( lines ) ) lines.append( "" );
        return lines;
    }

    private string function clipToWidth(
        required any     fm,
        required string  text,
        required numeric maxPx
    ) {
        var s = arguments.text;
        while ( len( s ) > 0 && arguments.fm.stringWidth( s ) > arguments.maxPx ) {
            s = left( s, len( s ) - 1 );
        }
        return s;
    }

}
