/**
 * bx-Blogger — SitemapService (Chunk 3.E + Phase 7.F B20)
 *
 * Single-sitemap output is the default — a `<urlset>` document
 * covering home, blog index, published posts, pages, categories,
 * tags, and per-author archives. Once the count of published posts
 * crosses `indexThreshold` (default 40,000), `forBaseUrl()` flips
 * to `<sitemapindex>` mode and references per-year sub-sitemaps:
 *
 *   /sitemap.xml          → sitemapindex (or urlset if under threshold)
 *   /sitemap-static.xml   → home + blog + categories + tags + authors
 *   /sitemap-{year}.xml   → that year's published posts
 *
 * Per-year + static sub-sitemaps are always build-capable; only the
 * top-level dispatch changes at the threshold. That means crawlers
 * following `<sitemap>` links always land on a valid `<urlset>`,
 * even on a small site — the sub-sitemap routes are live from day
 * one; they just aren't referenced until the threshold flips.
 *
 * Cache layout — CacheBox's default cache, 60-minute TTL:
 *   sitemap:{baseUrl}                → top-level (index or single)
 *   sitemap:{baseUrl}:static         → /sitemap-static.xml
 *   sitemap:{baseUrl}:year:{year}    → /sitemap-{year}.xml
 * `invalidate()` clears the whole `sitemap:` keyspace in one call.
 *
 * Interception: `bxBlogger.preSitemapGenerate` fires on top-level
 * + sub-sitemap builds so modules can mutate the URL list. Data
 * struct: `{ baseUrl, urls, scope: "single" | "index" | "static" | "year:{year}" }`.
 * `postSitemapGenerate` fires after the XML is assembled.
 */
class accessors="true" singleton {

    property name="wirebox"            inject="wirebox";
    property name="cache"              inject="cachebox:default";
    property name="interceptorService" inject="coldbox:InterceptorService";
    property name="log"                inject="logbox:logger:{this}";

    variables.cacheTtlMinutes    = 60;
    variables.indexThreshold     = 40000;   // B20 flip point

    // --------------------------------------------------------------------
    // Public — top-level dispatch
    // --------------------------------------------------------------------

    /**
     * Produce the top-level sitemap for `baseUrl`. Below threshold:
     * a single `<urlset>`. At or above threshold: a
     * `<sitemapindex>` pointing at sub-sitemaps. Cached per
     * baseUrl — multi-host setups (staging + prod from the same
     * image) get different output.
     */
    string function forBaseUrl( required string baseUrl ) {
        var key    = cacheKey( arguments.baseUrl );
        var cached = variables.cache.get( key );
        if ( !isNull( cached ) && isSimpleValue( cached ) && len( cached ) ) {
            return cached;
        }

        var xml = publishedPostCount() > variables.indexThreshold
            ? buildIndex( arguments.baseUrl )
            : buildSingle( arguments.baseUrl );

        variables.cache.set( key, xml, variables.cacheTtlMinutes, 0 );
        return xml;
    }

    /**
     * `<urlset>` for the given year's published posts. Year is an
     * integer (e.g. 2026). Empty years — valid in the URL pattern
     * but with no matching posts — render an empty urlset; crawlers
     * handle that cleanly.
     */
    string function forYear( required string baseUrl, required numeric year ) {
        var key    = cacheKey( arguments.baseUrl ) & ":year:" & arguments.year;
        var cached = variables.cache.get( key );
        if ( !isNull( cached ) && isSimpleValue( cached ) && len( cached ) ) {
            return cached;
        }

        var urls = postUrls( arguments.baseUrl, arguments.year );
        var xml  = assembleUrlset( arguments.baseUrl, urls, "year:" & arguments.year );
        variables.cache.set( key, xml, variables.cacheTtlMinutes, 0 );
        return xml;
    }

    /**
     * `<urlset>` for the non-post surfaces — home, blog index,
     * published pages, category archives, tag archives, author
     * archives. Split out in index mode so per-year sub-sitemaps
     * stay focused on post URLs.
     */
    string function forStatic( required string baseUrl ) {
        var key    = cacheKey( arguments.baseUrl ) & ":static";
        var cached = variables.cache.get( key );
        if ( !isNull( cached ) && isSimpleValue( cached ) && len( cached ) ) {
            return cached;
        }

        var urls = staticUrls( arguments.baseUrl );
        var xml  = assembleUrlset( arguments.baseUrl, urls, "static" );
        variables.cache.set( key, xml, variables.cacheTtlMinutes, 0 );
        return xml;
    }

    /**
     * Drop every `sitemap:` cache entry. Called by
     * `cacheInvalidate` on post publish / theme switch /
     * category edit.
     */
    function invalidate() {
        variables.cache.clearByKeySnippet( keySnippet = "sitemap:", regex = false );
    }

    /**
     * Operator-friendly accessor for the threshold. Tests and
     * future admin controls lower this to force-split below 40k.
     */
    function setIndexThreshold( required numeric n ) {
        variables.indexThreshold = int( arguments.n );
        invalidate();  // cached output was built under the old threshold
    }

    numeric function getIndexThreshold() {
        return variables.indexThreshold;
    }

    /**
     * Distinct calendar years that contain ≥1 published post,
     * descending. Used by the index builder to know which
     * per-year sub-sitemaps to reference.
     */
    array function activeYears() {
        var rows = freshQb().from( "posts" )
            .selectRaw( "YEAR(COALESCE(published_at, created_at)) AS y, MAX(updated_at) AS lastmod" )
            .where( "post_type",  "post" )
            .where( "status",     "published" )
            .where( "visibility", "public" )
            .whereNull( "deleted_at" )
            .groupBy( "y" )
            .orderBy( "y", "desc" )
            .get();
        var out = [];
        for ( var r in rows ) {
            if ( isNull( r.y ) || !isNumeric( r.y ) ) continue;
            out.append( { "year" : int( r.y ), "lastmod" : r.lastmod ?: "" } );
        }
        return out;
    }

    // --------------------------------------------------------------------
    // Private — top-level builders
    // --------------------------------------------------------------------

    /**
     * Single-sitemap output: home + blog + posts + pages +
     * taxonomies + authors, all in one `<urlset>`. Used below the
     * index-split threshold.
     */
    private string function buildSingle( required string baseUrl ) {
        var urls = staticUrls( arguments.baseUrl );
        // No year arg → `postUrls` returns all posts (capped by
        // `indexThreshold` so a single sitemap never grows past
        // sitemaps.org's 50k URL limit even if an operator forgets
        // to re-raise the threshold after disabling the split).
        urls.append( postUrls( arguments.baseUrl ), true );
        return assembleUrlset( arguments.baseUrl, urls, "single" );
    }

    /**
     * Sitemap index referencing `/sitemap-static.xml` plus one
     * `/sitemap-{year}.xml` per year with published posts.
     */
    private string function buildIndex( required string baseUrl ) {
        var years = activeYears();
        var data  = {
            "baseUrl" : arguments.baseUrl,
            "scope"   : "index",
            "entries" : [
                {
                    "loc"     : arguments.baseUrl & "/sitemap-static.xml",
                    "lastmod" : w3cDate( now() )
                }
            ]
        };
        for ( var y in years ) {
            data.entries.append( {
                "loc"     : arguments.baseUrl & "/sitemap-" & y.year & ".xml",
                "lastmod" : w3cDate( y.lastmod )
            } );
        }

        variables.interceptorService.announce( state = "preSitemapGenerate", data = data );

        var buf = createObject( "java", "java.lang.StringBuilder" ).init();
        buf.append( '<?xml version="1.0" encoding="UTF-8"?>' );
        buf.append( char( 10 ) );
        buf.append( '<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">' );
        buf.append( char( 10 ) );
        for ( var e in data.entries ) {
            buf.append( "  <sitemap>" & char( 10 ) );
            buf.append( "    <loc>" & xmlSafe( e.loc ) & "</loc>" & char( 10 ) );
            if ( len( e.lastmod ?: "" ) ) {
                buf.append( "    <lastmod>" & xmlSafe( e.lastmod ) & "</lastmod>" & char( 10 ) );
            }
            buf.append( "  </sitemap>" & char( 10 ) );
        }
        buf.append( "</sitemapindex>" & char( 10 ) );

        data.xml = buf.toString();
        variables.interceptorService.announce( state = "postSitemapGenerate", data = data );
        return data.xml;
    }

    // --------------------------------------------------------------------
    // Private — URL-list builders
    // --------------------------------------------------------------------

    /**
     * Published-post URLs, optionally filtered by calendar year.
     * Year coerces via `int()`; a zero / negative / out-of-range
     * value narrows to a guaranteed-empty result (so
     * `/sitemap-abc.xml`'s handler-side fallback to year=0 doesn't
     * end up serving every post as if the split didn't happen).
     * When `year` is absent entirely, every published post is
     * returned — used by `buildSingle`.
     *
     * `published_at` is COALESCEd with `created_at` so a post
     * drafted-and-never-back-dated still lands in the right
     * bucket; matches the same COALESCE in `activeYears()`.
     *
     * A LIMIT is applied in "all posts" mode only so a
     * misconfigured install above-threshold-but-split-disabled
     * still produces a valid (truncated) sitemap rather than
     * OOMing the render.
     */
    private array function postUrls( required string baseUrl, numeric year ) {
        var q = freshQb().from( "posts" )
            .select( [ "slug", "updated_at" ] )
            .where( "post_type",  "post" )
            .where( "status",     "published" )
            .where( "visibility", "public" )
            .whereNull( "deleted_at" )
            .orderBy( "published_at", "desc" );

        if ( structKeyExists( arguments, "year" ) && !isNull( arguments.year ) ) {
            q.whereRaw( "YEAR(COALESCE(published_at, created_at)) = ?", [ int( arguments.year ) ] );
        }
        else {
            q.limit( variables.indexThreshold );
        }

        var rows = q.get();
        var out  = [];
        for ( var p in rows ) {
            out.append( {
                "loc"        : arguments.baseUrl & "/blog/" & p.slug,
                "lastmod"    : w3cDate( p.updated_at ),
                "changefreq" : "weekly",
                "priority"   : "0.8"
            } );
        }
        return out;
    }

    /**
     * Non-post public surfaces. Separated so index mode can serve
     * them from `/sitemap-static.xml` without mixing into per-year
     * buckets.
     */
    private array function staticUrls( required string baseUrl ) {
        var urls = [];

        urls.append( { "loc" : arguments.baseUrl & "/",     "changefreq" : "daily", "priority" : "1.0" } );
        urls.append( { "loc" : arguments.baseUrl & "/blog", "changefreq" : "daily", "priority" : "0.9" } );

        var pageRows = freshQb().from( "posts" )
            .select( [ "slug", "updated_at" ] )
            .where( "post_type",  "page" )
            .where( "status",     "published" )
            .where( "visibility", "public" )
            .whereNull( "deleted_at" )
            .get();
        for ( var pg in pageRows ) {
            urls.append( {
                "loc"        : arguments.baseUrl & "/" & pg.slug,
                "lastmod"    : w3cDate( pg.updated_at ),
                "changefreq" : "monthly",
                "priority"   : "0.6"
            } );
        }

        var catRows = freshQb().from( "categories" )
            .select( [ "slug", "updated_at" ] )
            .get();
        for ( var c in catRows ) {
            urls.append( {
                "loc"        : arguments.baseUrl & "/category/" & c.slug,
                "lastmod"    : w3cDate( c.updated_at ),
                "changefreq" : "weekly",
                "priority"   : "0.5"
            } );
        }

        var tagRows = freshQb().from( "tags" )
            .select( [ "slug", "updated_at" ] )
            .get();
        for ( var t in tagRows ) {
            urls.append( {
                "loc"        : arguments.baseUrl & "/tag/" & t.slug,
                "lastmod"    : w3cDate( t.updated_at ),
                "changefreq" : "weekly",
                "priority"   : "0.4"
            } );
        }

        // Author archives — only users who have at least one
        // published post.
        var authorRows = freshQb().from( "users" )
            .select( [ "users.username", "users.updated_at" ] )
            .distinct()
            .join( "posts", "posts.author_id", "=", "users.id" )
            .where( "posts.post_type",  "post" )
            .where( "posts.status",     "published" )
            .where( "posts.visibility", "public" )
            .whereNull( "posts.deleted_at" )
            .get();
        for ( var a in authorRows ) {
            if ( !len( a.username ?: "" ) ) continue;
            urls.append( {
                "loc"        : arguments.baseUrl & "/author/" & a.username,
                "lastmod"    : w3cDate( a.updated_at ),
                "changefreq" : "weekly",
                "priority"   : "0.4"
            } );
        }

        return urls;
    }

    /**
     * Assemble a `<urlset>` from a URL list. Fires the interception
     * hooks so modules can mutate the list / final XML.
     */
    private string function assembleUrlset(
        required string baseUrl,
        required array  urls,
        required string scope
    ) {
        var data = {
            "baseUrl" : arguments.baseUrl,
            "urls"    : arguments.urls,
            "scope"   : arguments.scope
        };
        variables.interceptorService.announce( state = "preSitemapGenerate", data = data );

        var buf = createObject( "java", "java.lang.StringBuilder" ).init();
        buf.append( '<?xml version="1.0" encoding="UTF-8"?>' );
        buf.append( char( 10 ) );
        buf.append( '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">' );
        buf.append( char( 10 ) );

        for ( var u in data.urls ) {
            buf.append( "  <url>" & char( 10 ) );
            buf.append( "    <loc>" & xmlSafe( u.loc ) & "</loc>" & char( 10 ) );
            if ( structKeyExists( u, "lastmod" ) && len( u.lastmod ) ) {
                buf.append( "    <lastmod>" & xmlSafe( u.lastmod ) & "</lastmod>" & char( 10 ) );
            }
            if ( structKeyExists( u, "changefreq" ) && len( u.changefreq ) ) {
                buf.append( "    <changefreq>" & xmlSafe( u.changefreq ) & "</changefreq>" & char( 10 ) );
            }
            if ( structKeyExists( u, "priority" ) && len( u.priority ) ) {
                buf.append( "    <priority>" & xmlSafe( u.priority ) & "</priority>" & char( 10 ) );
            }
            buf.append( "  </url>" & char( 10 ) );
        }

        buf.append( "</urlset>" & char( 10 ) );
        data.xml = buf.toString();
        variables.interceptorService.announce( state = "postSitemapGenerate", data = data );
        return data.xml;
    }

    // --------------------------------------------------------------------
    // Private — helpers
    // --------------------------------------------------------------------

    private numeric function publishedPostCount() {
        return freshQb().from( "posts" )
            .where( "post_type",  "post" )
            .where( "status",     "published" )
            .where( "visibility", "public" )
            .whereNull( "deleted_at" )
            .count();
    }

    private string function cacheKey( required string baseUrl ) {
        return "sitemap:" & arguments.baseUrl;
    }

    private any function freshQb() {
        return variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery();
    }

    /**
     * W3C Datetime (ISO 8601) — YYYY-MM-DD for `<lastmod>`.
     * sitemap.org accepts either date-only or full timestamp; we
     * keep it date-only so trivial content-version bumps don't
     * cause crawlers to re-fetch an otherwise unchanged URL too
     * aggressively.
     */
    private string function w3cDate( required any dt ) {
        if ( isNull( arguments.dt ) || ( isSimpleValue( arguments.dt ) && !len( arguments.dt ) ) ) return "";
        var d = isDate( arguments.dt ) ? arguments.dt : parseDateTime( arguments.dt );
        return dateFormat( d, "yyyy-mm-dd" );
    }

    /**
     * Minimal XML text-safe escape. bx-esapi's `encodeForXML` is
     * more aggressive — it percent-escapes colons / slashes too,
     * which turns a clean URL into `http&##x3a;&##x2f;&##x2f;...`
     * in the `<loc>`. Crawlers accept both forms, but the tighter
     * five-entity escape matches what every other CMS emits.
     */
    private string function xmlSafe( required string text ) {
        var t = arguments.text;
        t = replace( t, "&",  "&amp;",  "all" );
        t = replace( t, "<",  "&lt;",   "all" );
        t = replace( t, ">",  "&gt;",   "all" );
        t = replace( t, '"',  "&quot;", "all" );
        t = replace( t, "'",  "&##39;",  "all" );
        return t;
    }

}
