/**
 * bx-Blogger — UserService
 *
 * Implements cbauth's IAuthenticationService contract so the module can
 * drive login/logout flows against our Quick User entity. Also owns
 * login-audit writes (success + failure) so the Security handler doesn't
 * need to know the audit-table shape.
 *
 * cbauth contract methods:
 *   isValidCredentials( username, password ) : boolean
 *   retrieveUserByUsername( username )        : User or null
 *   retrieveUserById( id )                    : User or null
 *
 * Additional methods specific to bx-Blogger:
 *   recordSuccessfulLogin( user, ip, userAgent )
 *   recordFailedLogin( email, ip, userAgent, reason )
 *   touchLastLogin( user, ip )
 */
class accessors="true" singleton {

    property name="wirebox"         inject="wirebox";
    property name="passwordService" inject="PasswordService";
    property name="cbfs"            inject="DiskService@cbfs";
    property name="log"             inject="logbox:logger:{this}";

    /**
     * Failed-login lockout knobs (A6 — durable per-user lock complementing
     * the in-memory rate-limit interceptor). Hard-coded Phase 1; a future
     * settings UI can promote these to `settings.auth_*` rows.
     */
    variables.lockoutThreshold      = 5;    // failed attempts before lock
    variables.lockoutDurationMinutes = 15;  // lock length

    /**
     * Profile photo policy.
     *   - Accept JPEG / PNG / WebP; reject anything else at the service
     *     boundary so handlers never need to double-check.
     *   - Max 5 MB on the wire, max 2000×2000 at the pixel level. We
     *     resize-crop down to 512×512 server-side, so the upper bound
     *     is about "reasonable source photo" not "display size."
     *   - Always output PNG (512×512) regardless of source format — a
     *     single output format keeps the render path consistent and
     *     PNG is lossless + universally supported. Profile photos are
     *     small enough that the size delta vs. JPEG doesn't matter.
     */
    variables.profilePhotoMimeAllow = [ "image/jpeg", "image/png", "image/webp" ];
    variables.profilePhotoMaxBytes  = 5 * 1024 * 1024;
    variables.profilePhotoMaxDim    = 2000;
    variables.profilePhotoOutDim    = 512;

    /**
     * cbauth: does the email + plaintext-password combo authenticate?
     * Also records the audit row (success OR failure) so the handler
     * doesn't have to do a second call.
     */
    function isValidCredentials( required string username, required string password ) {
        var user = retrieveUserByUsername( arguments.username );
        if ( isNull( user ) ) return false;
        if ( !user.canLogin() ) return false;  // is_active + email_verified + !deleted
        return variables.passwordService.verify( arguments.password, user.getPasswordHash() );
    }

    /**
     * cbauth: look up a User by the login identifier (email, for us).
     * Returns null if not found or soft-deleted.
     */
    function retrieveUserByUsername( required string username ) {
        var User = variables.wirebox.getInstance( "User" );
        return User.where( "email", arguments.username )
                   .whereNull( "deleted_at" )
                   .first();
    }

    /**
     * cbauth: look up a User by primary key (called when restoring a session).
     */
    function retrieveUserById( required any id ) {
        var User = variables.wirebox.getInstance( "User" );
        return User.where( "id", arguments.id )
                   .whereNull( "deleted_at" )
                   .first();
    }

    /**
     * Record a successful login in the login_audit table, clear the
     * failed-attempts counter, and bump last_login_at / last_login_ip.
     */
    function recordSuccessfulLogin(
        required any    user,
        required string ip,
                 string userAgent = ""
    ) {
        writeAudit( {
            email:      arguments.user.getEmail(),
            user_id:    arguments.user.getId(),
            ip:         arguments.ip,
            user_agent: left( arguments.userAgent, 512 ),
            success:    1
        } );
        // Order matters: touchLastLogin calls entity.save(), which
        // persists every current field on the Quick entity — including
        // a stale failed_login_count. Doing the qb-based resetLockout
        // AFTER the save ensures the zeroed columns are not overwritten.
        touchLastLogin( arguments.user, arguments.ip );
        resetLockout( arguments.user );
    }

    /**
     * Record a failed login. `email` is the string the user typed (may
     * not match any real account). `reason` is one of:
     *   "bad_password", "user_inactive", "user_not_found",
     *   "email_not_verified", "rate_limited", "account_locked"
     *
     * When a real user is involved and the reason is a credential failure
     * (not e.g. "account_locked" — already locked, don't extend), we also
     * bump failed_login_count and potentially set locked_until.
     */
    function recordFailedLogin(
        required string email,
        required string ip,
                 string userAgent = "",
                 string reason    = "bad_password"
    ) {
        // Resolve user_id if we can (for stats; unset if email unknown).
        // We build the audit row conditionally — on BoxLang, assigning
        // a `javaCast("null","")` to a local variable and then putting
        // it in a struct throws "key not located". Omitting the key
        // when there's no user leaves user_id as SQL NULL.
        var user = retrieveUserByUsername( arguments.email );
        var row  = {
            email:          arguments.email,
            ip:             arguments.ip,
            user_agent:     left( arguments.userAgent, 512 ),
            success:        0,
            failure_reason: arguments.reason
        };
        if ( !isNull( user ) ) {
            row.user_id = user.getId();
        }
        writeAudit( row );

        // Only escalate the per-user lockout counter for true credential
        // failures against a known account. Don't bump on "account_locked"
        // (already locked — no need to double-penalize) or "user_not_found"
        // (no account to associate the count with).
        if ( !isNull( user ) && listFindNoCase( "bad_password,email_not_verified,user_inactive", arguments.reason ) ) {
            bumpFailureCount( user );
        }
    }

    /**
     * Increment failed_login_count; once threshold is hit, set locked_until.
     * Uses a qb update rather than Quick so we don't clobber unrelated
     * columns someone else might be mutating in the same request.
     */
    private function bumpFailureCount( required any user ) {
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" );
        var nextCount = ( arguments.user.getFailedLoginCount() ?: 0 ) + 1;
        var update = { "failed_login_count" : nextCount };
        if ( nextCount >= variables.lockoutThreshold ) {
            update[ "locked_until" ] = dateAdd( "n", variables.lockoutDurationMinutes, now() );
        }
        qb.from( "users" ).where( "id", arguments.user.getId() ).update( update );
    }

    /**
     * Reset the per-user lockout state after a successful login (or after
     * an admin manually unlocks). Uses qb so we don't pick up unrelated
     * pending changes on the Quick entity. `locked_until` is set back to
     * NULL via `qb.raw` because qb's update-struct path trips a type
     * mismatch when a value is `javaCast("null", "")`.
     */
    function resetLockout( required any user ) {
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" );
        qb.from( "users" ).where( "id", arguments.user.getId() ).update( {
            "failed_login_count" : 0,
            "locked_until"       : qb.raw( "NULL" )
        } );
    }

    /**
     * Update a user's last-login timestamps. Called from recordSuccessfulLogin.
     */
    function touchLastLogin( required any user, required string ip ) {
        arguments.user.setLastLoginAt( now() );
        arguments.user.setLastLoginIp( arguments.ip );
        arguments.user.save();
    }

    /**
     * Internal — inserts a row into login_audit using qb (not Quick, since
     * there's no entity class for audit rows — append-only log style).
     */
    private function writeAudit( required struct row ) {
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" );
        qb.from( "login_audit" ).insert( arguments.row );
    }

    // --------------------------------------------------------------------
    // Admin-facing CRUD (Phase UX — admin:Users wire)
    // --------------------------------------------------------------------

    /**
     * Create a user from the admin. Hashes the plaintext password,
     * marks email verified (admins can trust their own invites), and
     * attaches the given role slug if supplied. Returns the saved
     * entity. Validation failures raise bxBlogger.* exceptions so the
     * wire can surface them in the flash scope.
     */
    function adminCreate(
        required struct  attrs,
        required string  plainPassword,
                 string  roleSlug = ""
    ) {
        validateAdminAttrs( arguments.attrs, 0 );
        if ( !len( trim( arguments.plainPassword ) ) ) {
            throw( type = "bxBlogger.UserValidation", message = "Password is required." );
        }

        var User = variables.wirebox.getInstance( "User" );
        var user = User.create( {
            "email"              : trim( lCase( arguments.attrs.email ) ),
            "displayName"        : trim( arguments.attrs.displayName ?: arguments.attrs.email ),
            "username"           : trim( arguments.attrs.username    ?: "" ),
            "passwordHash"       : variables.passwordService.hash( arguments.plainPassword ),
            "isActive"           : ( arguments.attrs.isActive ?: 1 ) ? 1 : 0,
            "twoFactorEnabled"   : 0,
            "emailVerifiedAt"    : now(),
            "passwordChangedAt"  : now(),
            "mustChangePassword" : 0
        } );

        if ( len( arguments.roleSlug ) ) {
            var role = variables.wirebox.getInstance( "Role" ).where( "slug", arguments.roleSlug ).first();
            if ( !isNull( role ) ) user.roles().attach( role.getId() );
        }
        return user;
    }

    /**
     * Update basic profile fields + active flag. Role changes live in
     * `syncRoles()` so permission guards can run before the pivot is
     * touched. Returns the updated entity.
     */
    function adminUpdate( required any user, required struct attrs ) {
        validateAdminAttrs( arguments.attrs, arguments.user.getId() );

        if ( structKeyExists( arguments.attrs, "email" ) && len( trim( arguments.attrs.email ) ) ) {
            arguments.user.setEmail( trim( lCase( arguments.attrs.email ) ) );
        }
        if ( structKeyExists( arguments.attrs, "displayName" ) ) {
            arguments.user.setDisplayName( trim( arguments.attrs.displayName ) );
        }
        if ( structKeyExists( arguments.attrs, "username" ) ) {
            arguments.user.setUsername( trim( arguments.attrs.username ) );
        }
        if ( structKeyExists( arguments.attrs, "isActive" ) ) {
            arguments.user.setIsActive( arguments.attrs.isActive ? 1 : 0 );
        }
        arguments.user.save();
        return arguments.user;
    }

    /**
     * Admin-set password. Bumps `password_changed_at`, clears
     * `must_change_password`, resets any active lockout so the user
     * can log in right away with the new password.
     */
    function adminSetPassword( required any user, required string plainPassword ) {
        if ( !len( trim( arguments.plainPassword ) ) ) {
            throw( type = "bxBlogger.UserValidation", message = "Password is required." );
        }
        arguments.user.setPasswordHash( variables.passwordService.hash( arguments.plainPassword ) );
        arguments.user.setPasswordChangedAt( now() );
        arguments.user.setMustChangePassword( 0 );
        arguments.user.save();
        resetLockout( arguments.user );
    }

    /**
     * Replace the user's full role set with the given slug array.
     * Skips slugs that don't resolve to a real role. Runs BEFORE
     * permission guards in the caller — the wire must have already
     * checked that `actor` is allowed to assign each of these roles
     * (e.g. non-super_admin can't grant super_admin).
     */
    function syncRoles( required any user, required array roleSlugs ) {
        var Role = variables.wirebox.getInstance( "Role" );
        var desiredIds = [];
        for ( var slug in arguments.roleSlugs ) {
            var r = Role.where( "slug", slug ).first();
            if ( !isNull( r ) ) desiredIds.append( r.getId() );
        }
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" );
        qb.newQuery().from( "user_roles" ).where( "user_id", arguments.user.getId() ).delete();
        for ( var rid in desiredIds ) {
            qb.newQuery().from( "user_roles" ).insert( {
                "user_id"    : arguments.user.getId(),
                "role_id"    : rid,
                "created_at" : now()
            } );
        }
    }

    /**
     * Soft-delete a user. Preserves login_audit / posts authorship
     * history; cbauth's `canLogin()` short-circuits on `deleted_at`
     * being non-null so the account can't re-authenticate.
     */
    function adminSoftDelete( required any user ) {
        arguments.user.setDeletedAt( now() );
        arguments.user.setIsActive( 0 );
        arguments.user.save();
    }

    /**
     * True if `user` holds the super_admin role. Used by guard rails
     * in the wire to block non-super-admins from editing / demoting
     * / deleting super_admins.
     */
    boolean function isSuperAdmin( required any user ) {
        return arguments.user.hasRole( "super_admin" );
    }

    /**
     * Count of active super_admin accounts (not soft-deleted, not
     * inactive). The wire uses this to block the delete / demote /
     * deactivate of the LAST super_admin — otherwise an operator
     * could lock themselves out of their own site.
     */
    numeric function countActiveSuperAdmins() {
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" );
        var row = qb.newQuery()
            .from( "users" )
            .join( "user_roles", "user_roles.user_id", "users.id" )
            .join( "roles", "roles.id", "user_roles.role_id" )
            .where( "roles.slug", "super_admin" )
            .where( "users.is_active", 1 )
            .whereNull( "users.deleted_at" )
            .selectRaw( "COUNT(DISTINCT users.id) AS n" )
            .first();
        return val( row.n ?: 0 );
    }

    // --------------------------------------------------------------------
    // Author slug — URL segment for /author/{slug}. Generated from
    // display_name on demand (first time the user opts into a public
    // author page, or explicit admin regen). Kept unique site-wide;
    // collisions get a `-2`, `-3` numeric suffix.
    // --------------------------------------------------------------------

    /**
     * Returns a URL-safe lowercased slug from the given source string.
     * Accent-folded so "José" → "jose". Empty / all-punctuation input
     * collapses to `""` so the caller can fall back to `user-{id}`.
     *
     * Kept local to UserService rather than a shared helper because
     * authorSlug is the only cross-entity slug that isn't already
     * handled inside its own service (CategoryService / TagService /
     * PostService each own their slugify). A later refactor can
     * consolidate once patterns align.
     */
    string function slugifyText( required string source ) {
        var s = lCase( trim( arguments.source ) );
        s = replaceList( s,
            "à,á,â,ã,ä,å,ç,è,é,ê,ë,ì,í,î,ï,ñ,ò,ó,ô,õ,ö,ø,ù,ú,û,ü,ý,ÿ",
            "a,a,a,a,a,a,c,e,e,e,e,i,i,i,i,n,o,o,o,o,o,o,u,u,u,u,y,y"
        );
        s = reReplace( s, "[^a-z0-9]+", "-", "all" );
        s = reReplace( s, "^-+|-+$", "", "all" );
        // Cap at the column width (120). Trailing dashes after the
        // cut get stripped so we don't end up with `foo-bar-`.
        if ( len( s ) > 120 ) {
            s = left( s, 120 );
            s = reReplace( s, "-+$", "", "all" );
        }
        return s;
    }

    /**
     * Ensure the given user has an `author_slug`, creating one if
     * missing. Returns the slug. Idempotent — a user who already has
     * a slug gets it back unchanged.
     *
     * Preferred base is the display_name; falls back to `user-{id}`
     * when the display name slugifies to empty (accent-stripped
     * punctuation, CJK, etc.). Uniqueness is enforced by appending
     * `-2`, `-3`, ... until no row collides.
     */
    string function ensureAuthorSlug( required any user ) {
        var existing = trim( arguments.user.getAuthorSlug() ?: "" );
        if ( len( existing ) ) return existing;

        var base = slugifyText( arguments.user.getDisplayName() ?: "" );
        if ( !len( base ) ) base = "user-" & arguments.user.getId();

        var candidate = ensureUniqueAuthorSlug( base, arguments.user.getId() );
        arguments.user.setAuthorSlug( candidate );
        arguments.user.save();
        return candidate;
    }

    /**
     * Set an explicit author slug on `user`, validating shape + global
     * uniqueness. Throws `bxBlogger.UserValidation` when the slug is
     * empty, too long, or taken by another user. Admins use this when
     * editing the slug from the Users editor; self-service via
     * `/admin/account` lands here too once that UI ships in Step 3.
     */
    string function setAuthorSlug( required any user, required string rawSlug ) {
        var normalized = slugifyText( arguments.rawSlug );
        if ( !len( normalized ) ) {
            throw(
                type    = "bxBlogger.UserValidation",
                message = "Author slug must contain at least one alphanumeric character."
            );
        }
        // Uniqueness: only error when another user holds it. Same user
        // re-submitting their own slug is a no-op.
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery()
            .from( "users" )
            .where( "author_slug", normalized )
            .where( "id", "!=", arguments.user.getId() )
            .selectRaw( "COUNT(*) AS n" )
            .first();
        if ( val( qb.n ?: 0 ) > 0 ) {
            throw(
                type    = "bxBlogger.UserValidation",
                message = "Author slug '" & normalized & "' is already taken."
            );
        }
        arguments.user.setAuthorSlug( normalized );
        arguments.user.save();
        return normalized;
    }

    /**
     * Find-or-fail by author_slug — used by the public Author handler.
     * Caller is responsible for the `publicAuthorPageEnabled` check;
     * this method just resolves the slug.
     */
    any function findByAuthorSlug( required string slug ) {
        var User = variables.wirebox.getInstance( "User" );
        return User.where( "author_slug", arguments.slug )
            .whereNull( "deleted_at" )
            .first();
    }

    private string function ensureUniqueAuthorSlug( required string base, required numeric excludeId ) {
        var candidate = arguments.base;
        var suffix    = 1;
        while ( authorSlugTakenBy( candidate, arguments.excludeId ) ) {
            suffix++;
            candidate = arguments.base & "-" & suffix;
        }
        return candidate;
    }

    private boolean function authorSlugTakenBy( required string slug, required numeric excludeId ) {
        var row = variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery()
            .from( "users" )
            .where( "author_slug", arguments.slug )
            .where( "id", "!=", arguments.excludeId )
            .selectRaw( "COUNT(*) AS n" )
            .first();
        return val( row.n ?: 0 ) > 0;
    }

    // --------------------------------------------------------------------
    // Profile photo — upload / replace / remove. Stored on the media
    // cbfs disk under `profile_images/{user_id}/{uuid}.png` so the
    // disk path itself is per-user-namespaced (no user can reach
    // another user's file by guessing the path). Always resize-cropped
    // to a 512×512 square via Java2D so the public author page + OG
    // composition can render a uniform avatar shape without checking
    // source dimensions.
    // --------------------------------------------------------------------

    /**
     * Upload-or-replace the target user's profile photo.
     *
     * @actor        The user performing the action (usually the logged-in
     *               user from cbauth). Required for permission check.
     * @userId       The user whose photo is being set. Owner or a
     *               `users.manage` holder is allowed; everyone else
     *               gets a bxBlogger.Forbidden throw.
     * @upload       A struct from the handler carrying the tmp-file
     *               path + original filename + MIME + byte size:
     *                 { tmpPath, originalFilename, mimeType, sizeBytes }
     *
     * @return       The updated User entity with the new photo columns
     *               populated. Caller typically re-flashes to the account
     *               page where the new photo renders.
     *
     * @throws       bxBlogger.Forbidden — actor can't touch this user
     *               bxBlogger.UserValidation — MIME / size / dims out of policy
     */
    any function setProfilePhoto( required any actor, required numeric userId, required struct upload ) {
        assertCanManageUserPhoto( arguments.actor, arguments.userId );

        validateProfilePhotoUpload( arguments.upload );

        var target = variables.wirebox.getInstance( "User" ).findOrFail( arguments.userId );
        var pngBytes = cropResizeToSquarePng(
            arguments.upload.tmpPath,
            variables.profilePhotoOutDim
        );

        var newKey = "profile_images/" & arguments.userId & "/" & createUUID() & ".png";
        variables.cbfs.get( "media" ).create(
            path      = newKey,
            contents  = pngBytes,
            overwrite = true
        );

        // Remove the previous file only after the new one is written —
        // if create() failed above we'd rather keep the old photo than
        // leave the user with nothing.
        deleteProfilePhotoFileSafe( target.getProfilePhotoPath() ?: "" );

        target.setProfilePhotoPath(  newKey );
        target.setProfilePhotoMime(  "image/png" );
        target.setProfilePhotoWidth(  variables.profilePhotoOutDim );
        target.setProfilePhotoHeight( variables.profilePhotoOutDim );
        target.save();

        // Photo just changed — every post by this author needs a
        // fresh OG render so the new avatar shows on share cards.
        dispatchAuthorOgRegen( arguments.userId );

        log.info( "UserService.setProfilePhoto: user=" & arguments.userId & " key=" & newKey );
        return target;
    }

    /**
     * Drop the target user's profile photo — deletes the file on disk
     * and clears the four profile_photo_* columns. Same permission
     * gate as setProfilePhoto. No-op (returns the user unchanged)
     * when there was no photo to begin with.
     */
    any function removeProfilePhoto( required any actor, required numeric userId ) {
        assertCanManageUserPhoto( arguments.actor, arguments.userId );

        var target = variables.wirebox.getInstance( "User" ).findOrFail( arguments.userId );
        var oldKey = target.getProfilePhotoPath() ?: "";
        if ( !len( oldKey ) ) return target;

        deleteProfilePhotoFileSafe( oldKey );

        target.setProfilePhotoPath(  javaCast( "null", "" ) );
        target.setProfilePhotoMime(  javaCast( "null", "" ) );
        target.setProfilePhotoWidth( javaCast( "null", "" ) );
        target.setProfilePhotoHeight( javaCast( "null", "" ) );
        target.save();

        // Quick silently drops `setXxx( null )` from its UPDATE in some
        // cases, and qb's struct-based `.update()` rejects null values
        // (CLAUDE.md note). Raw SQL is the surest way to actually clear
        // the columns back to NULL.
        queryExecute(
            "UPDATE users
                SET profile_photo_path   = NULL,
                    profile_photo_mime   = NULL,
                    profile_photo_width  = NULL,
                    profile_photo_height = NULL
              WHERE id = ?",
            [ arguments.userId ]
        );

        // Photo gone — same fan-out as upload so OG cards update.
        dispatchAuthorOgRegen( arguments.userId );

        log.info( "UserService.removeProfilePhoto: user=" & arguments.userId & " key=" & oldKey );
        return target;
    }

    /**
     * Public wrapper around the AuthorOgRegenJob dispatch — exposed
     * so handlers (Account.updateProfile / Account.updatePreferences)
     * can request a regen after persisting OG-affecting fields the
     * service layer doesn't directly own (display_name, OG-inclusion
     * toggles, the public-author-page flag, etc.). Callers that
     * already touch the photo via this service get the fan-out
     * for free.
     */
    void function dispatchAuthorOgRegenForUser( required numeric userId ) {
        dispatchAuthorOgRegen( arguments.userId );
    }

    private void function dispatchAuthorOgRegen( required numeric userId ) {
        try {
            variables.wirebox.getInstance( "AuthorOgRegenJob" )
                .setProperties( { "authorId" : int( arguments.userId ) } )
                .dispatch();
        }
        catch ( any e ) {
            log.warn( "UserService: AuthorOgRegenJob dispatch failed for user=" & arguments.userId & ": " & e.message );
        }
    }

    // --------------------------------------------------------------------
    // Profile photo helpers
    // --------------------------------------------------------------------

    private void function assertCanManageUserPhoto( required any actor, required numeric userId ) {
        if ( isNull( arguments.actor ) ) {
            throw( type = "bxBlogger.Forbidden", message = "Authentication required." );
        }
        if ( arguments.actor.getId() == arguments.userId ) return;
        if ( arguments.actor.hasPermission( "users.manage" ) ) return;
        throw(
            type    = "bxBlogger.Forbidden",
            message = "You don't have permission to change this user's profile photo."
        );
    }

    private void function validateProfilePhotoUpload( required struct upload ) {
        var mime = lCase( trim( arguments.upload.mimeType ?: "" ) );
        if ( !variables.profilePhotoMimeAllow.some( function( allowed ) {
            return allowed == mime;
        } ) ) {
            throw(
                type    = "bxBlogger.UserValidation",
                message = "Profile photo must be JPEG, PNG, or WebP."
            );
        }
        if ( val( arguments.upload.sizeBytes ?: 0 ) > variables.profilePhotoMaxBytes ) {
            throw(
                type    = "bxBlogger.UserValidation",
                message = "Profile photo exceeds the " & numberFormat( variables.profilePhotoMaxBytes / 1024 / 1024 ) & " MB upload limit."
            );
        }
        if ( !fileExists( arguments.upload.tmpPath ?: "" ) ) {
            throw(
                type    = "bxBlogger.UserValidation",
                message = "Uploaded file could not be read from the server's temp directory."
            );
        }
    }

    /**
     * Read a source image from disk, center-crop it to a square, and
     * resize the crop to `outDim × outDim`. Returns PNG bytes ready to
     * write to cbfs. Enforces the `profilePhotoMaxDim` pixel cap on
     * the source; anything larger trips bxBlogger.UserValidation.
     */
    private any function cropResizeToSquarePng( required string sourcePath, required numeric outDim ) {
        var ImageIO        = createObject( "java", "javax.imageio.ImageIO" );
        var BufferedImage  = createObject( "java", "java.awt.image.BufferedImage" );
        var RenderingHints = createObject( "java", "java.awt.RenderingHints" );
        var File           = createObject( "java", "java.io.File" );
        var BAOS           = createObject( "java", "java.io.ByteArrayOutputStream" );

        var src = ImageIO.read( File.init( arguments.sourcePath ) );
        if ( isNull( src ) ) {
            throw(
                type    = "bxBlogger.UserValidation",
                message = "Uploaded file isn't a decodable image."
            );
        }

        var srcW = src.getWidth();
        var srcH = src.getHeight();
        if ( srcW > variables.profilePhotoMaxDim || srcH > variables.profilePhotoMaxDim ) {
            throw(
                type    = "bxBlogger.UserValidation",
                message = "Profile photo must be no larger than "
                    & variables.profilePhotoMaxDim & "×" & variables.profilePhotoMaxDim
                    & " pixels; got " & srcW & "×" & srcH & "."
            );
        }

        // Center-crop to square.
        var cropSize = min( srcW, srcH );
        var cropX    = int( ( srcW - cropSize ) / 2 );
        var cropY    = int( ( srcH - cropSize ) / 2 );

        var target = BufferedImage.init(
            arguments.outDim,
            arguments.outDim,
            BufferedImage.TYPE_INT_ARGB
        );
        var g = target.createGraphics();
        try {
            g.setRenderingHint( RenderingHints.KEY_INTERPOLATION, RenderingHints.VALUE_INTERPOLATION_BICUBIC );
            g.setRenderingHint( RenderingHints.KEY_RENDERING,     RenderingHints.VALUE_RENDER_QUALITY       );
            g.setRenderingHint( RenderingHints.KEY_ANTIALIASING,  RenderingHints.VALUE_ANTIALIAS_ON         );

            // drawImage( img, dx1, dy1, dx2, dy2, sx1, sy1, sx2, sy2, observer )
            g.drawImage(
                src,
                0, 0, arguments.outDim, arguments.outDim,
                cropX, cropY, cropX + cropSize, cropY + cropSize,
                javaCast( "null", "" )
            );
        }
        finally {
            g.dispose();
        }

        var baos = BAOS.init();
        ImageIO.write( target, "png", baos );
        return baos.toByteArray();
    }

    /**
     * Public-facing URL for a user's profile photo, via the cbfs
     * `media` disk's own `url()` helper. Returns "" when no photo
     * is on file. Callers (admin views, theme templates, OG
     * composition) should ALWAYS route through this rather than
     * concatenating paths themselves — it's the only way the URL
     * stays correct when the disk provider is flipped between
     * Local and S3.
     */
    string function profilePhotoUrl( required any user ) {
        if ( !arguments.user.hasProfilePhoto() ) return "";
        return variables.cbfs.get( "media" ).url( arguments.user.getProfilePhotoPath() );
    }

    private void function deleteProfilePhotoFileSafe( required string path ) {
        if ( !len( arguments.path ) ) return;
        try {
            variables.cbfs.get( "media" ).delete( arguments.path );
        }
        catch ( any e ) {
            // Disk may have moved / S3 may be eventually consistent;
            // DB clears still succeed. Don't fail the request.
            log.warn( "UserService: could not delete profile photo at " & arguments.path & " — " & e.message );
        }
    }

    // --------------------------------------------------------------------
    // Phase 8.D.1 — GDPR export
    // --------------------------------------------------------------------

    /**
     * Bundle everything the platform holds about `user` into a
     * ZIP. Returns `{ bytes: byte[], filename: string }` — the
     * handler writes it to the response with a
     * `Content-Disposition: attachment` header.
     *
     * Contents:
     *   README.txt          — plain-text explainer
     *   profile.json        — id, email, display name, timestamps, roles
     *   posts.json          — every post authored by the user (full row,
     *                         including body_markdown / body_html)
     *   revisions.json      — every post_revision this user saved (their
     *                         edit history across all posts)
     *   audit_log.json      — every audit_log row with `user_id = X`
     *   media_manifest.json — uploaded-media listing: path + filename +
     *                         mime + size + uploaded_at. No file bytes
     *                         — the admin can fetch them out of band
     *                         (the media disk URL is in each entry)
     *
     * The spec prefers async + emailed signed URL for very large
     * datasets; Phase 8.D.1 ships the synchronous handler-returns-
     * bytes path and leaves the ExportUserDataJob as a Phase-10
     * follow-up (tracked in PLAN §B11). Typical single-user
     * exports are under a few MB of JSON so synchronous is fine
     * for the MVP surface.
     */
    /**
     * Fast data-footprint summary for the admin Privacy panel —
     * returns row counts per table that `exportData` would bundle.
     * Used by the picker to give an at-a-glance sense of how much
     * data an export will include before the admin clicks the
     * button.
     */
    struct function dataSummaryFor( required any user ) {
        var qb     = variables.wirebox.getInstance( "QueryBuilder@qb" );
        var userId = arguments.user.getId();
        return {
            "posts"      : qb.newQuery().from( "posts"          ).where( "author_id",   userId ).count(),
            "revisions"  : qb.newQuery().from( "post_revisions" ).where( "editor_id",   userId ).count(),
            "auditRows"  : qb.newQuery().from( "audit_log"      ).where( "user_id",     userId ).count(),
            "media"      : qb.newQuery().from( "media"          ).where( "uploader_id", userId ).count(),
            "notifications" : qb.newQuery().from( "notifications" ).where( "user_id",   userId ).count()
        };
    }

    struct function exportData( required any user ) {
        var qb     = variables.wirebox.getInstance( "QueryBuilder@qb" );
        var userId = arguments.user.getId();

        var profile = {
            "id"                : userId,
            "email"             : arguments.user.getEmail() ?: "",
            "display_name"      : arguments.user.getDisplayName() ?: "",
            "username"          : arguments.user.getUsername() ?: "",
            "is_active"         : arguments.user.getIsActive() ?: 0,
            "email_verified_at" : arguments.user.getEmailVerifiedAt() ?: "",
            "created_at"        : arguments.user.getCreatedAt() ?: "",
            "updated_at"        : arguments.user.getUpdatedAt() ?: "",
            "last_login_at"     : arguments.user.getLastLoginAt() ?: "",
            "roles"             : roleSlugsFor( userId )
        };

        var posts     = qb.newQuery().from( "posts" )
            .where( "author_id", userId )
            .orderBy( "id", "asc" )
            .get();
        var revisions = qb.newQuery().from( "post_revisions" )
            .where( "editor_id", userId )
            .orderBy( "id", "asc" )
            .get();
        var auditRows = qb.newQuery().from( "audit_log" )
            .where( "user_id", userId )
            .orderBy( "id", "asc" )
            .get();
        var mediaRows = qb.newQuery().from( "media" )
            .where( "uploader_id", userId )
            .select( [ "id", "disk", "path", "filename", "original_filename", "mime_type", "size_bytes", "created_at" ] )
            .orderBy( "id", "asc" )
            .get();

        var entries = {
            "README.txt"          : readmeFor( arguments.user ),
            "profile.json"        : jsonSerialize( profile )         & char( 10 ),
            "posts.json"          : jsonSerialize( posts )           & char( 10 ),
            "revisions.json"      : jsonSerialize( revisions )       & char( 10 ),
            "audit_log.json"      : jsonSerialize( auditRows )       & char( 10 ),
            "media_manifest.json" : jsonSerialize( mediaRows )       & char( 10 )
        };

        var safeEmail = reReplace( lCase( arguments.user.getEmail() ?: "user" ), "[^a-z0-9]+", "-", "all" );
        var filename  = "bx-blogger-export-" & safeEmail & "-" & dateFormat( now(), "yyyymmdd" ) & ".zip";

        return {
            "bytes"    : buildZip( entries ),
            "filename" : filename
        };
    }

    private string function readmeFor( required any user ) {
        var lines = [
            "bx-Blogger — Personal data export",
            "Generated: " & dateTimeFormat( now(), "yyyy-mm-dd HH:nn:ss" ),
            "For:       " & ( arguments.user.getEmail() ?: "" ) & " (id=" & arguments.user.getId() & ")",
            "",
            "This archive contains every piece of information the platform",
            "holds about this user account. Contents:",
            "",
            "  profile.json        Identity + timestamps + granted roles",
            "  posts.json          Posts authored by this user (full body)",
            "  revisions.json      Revision history this user has saved",
            "  audit_log.json      Admin-action audit entries for this user",
            "  media_manifest.json Uploaded media listing (paths only — the",
            "                      image bytes live on the media disk; an",
            "                      admin can retrieve them directly from",
            "                      the paths listed here if needed)",
            "",
            "This export does not include any other user's data."
        ];
        return arrayToList( lines, char( 10 ) ) & char( 10 );
    }

    private array function roleSlugsFor( required numeric userId ) {
        var rows = variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery()
            .from( "user_roles" )
            .join( "roles", "roles.id", "user_roles.role_id" )
            .where( "user_roles.user_id", arguments.userId )
            .select( "roles.slug AS slug" )
            .get();
        var out = [];
        for ( var r in rows ) out.append( r.slug );
        return out;
    }

    /**
     * Build a ZIP byte[] from `{ filename: string-contents }`
     * entries. Uses java.util.zip so we sidestep BoxLang's
     * `zip` BIF (which is unreliable from inside a WireBox-
     * managed singleton — same class of dispatch quirk that
     * burned us on `imageNew` during Phase 6.E).
     */
    private any function buildZip( required struct entries ) {
        var ZipOutputStream = createObject( "java", "java.util.zip.ZipOutputStream" );
        var ZipEntry        = createObject( "java", "java.util.zip.ZipEntry"        );
        var BAOS            = createObject( "java", "java.io.ByteArrayOutputStream" );
        var Charset         = createObject( "java", "java.nio.charset.StandardCharsets" );

        var baos = BAOS.init();
        var zos  = ZipOutputStream.init( baos );
        try {
            for ( var name in arguments.entries ) {
                var entry = ZipEntry.init( name );
                zos.putNextEntry( entry );
                var bytes = arguments.entries[ name ].getBytes( Charset.UTF_8 );
                zos.write( bytes, javaCast( "int", 0 ), javaCast( "int", arrayLen( bytes ) ) );
                zos.closeEntry();
            }
        }
        finally {
            zos.close();
        }
        return baos.toByteArray();
    }

    // --------------------------------------------------------------------
    // Phase 8.D.2 — GDPR purge (right-to-be-forgotten)
    // --------------------------------------------------------------------

    /**
     * Wipe `user` from the platform:
     *
     *   1. Reassign their posts' author_id to the sentinel
     *      "Deleted User" account (preserves post history + URLs).
     *   2. Reassign their post_revisions' editor_id to the sentinel.
     *   3. Reassign their uploaded-media uploader_id to the sentinel
     *      (media FK is RESTRICT on users.id, so we can't leave any
     *      row pointing at the user we're about to drop).
     *   4. Delete uploaded media that no surviving post references
     *      (via `featured_media_id` or `og_image_id`).
     *      Body-inline image references are NOT scanned — the
     *      media row stays reassigned to the sentinel, which is
     *      correct enough for a v1 purge (the image URL on disk
     *      still works for readers of old posts).
     *   5. Redact ip/user-agent on audit_log + login_audit rows
     *      tied to the user; keep the rows so compliance can see
     *      "admin X did Y" trails.
     *   6. Delete pivot rows (user_roles, notifications) — both
     *      CASCADE via FK but we run the explicit DELETEs anyway
     *      so the purge is observable from this method's SQL
     *      (easier to audit / trace from a log).
     *   7. Delete the users row.
     *   8. Record a `user.purge` audit entry on the purging admin,
     *      with the purged user's email captured in metadata
     *      (that email is about to vanish from the DB; capture it
     *      BEFORE the delete).
     *
     * Guard rails:
     *   - Throws `bxBlogger.UserService.CannotPurgeLastSuperAdmin`
     *     when the target is the last active super_admin.
     *   - Throws `bxBlogger.UserService.CannotPurgeSentinel` when
     *     the target IS the sentinel Deleted User. (Purging the
     *     sentinel would orphan every reassigned post.)
     */
    function purge( required any user, required numeric purgingAdminId ) {
        var qb = variables.wirebox.getInstance( "QueryBuilder@qb" );
        var targetId = arguments.user.getId();

        var sentinelId = ensureSentinelUser();
        if ( targetId == sentinelId ) {
            throw(
                type    = "bxBlogger.UserService.CannotPurgeSentinel",
                message = "Refusing to purge the sentinel 'Deleted User' account."
            );
        }
        // Self-purge guard. The "last super_admin" check below
        // handles site lock-out; this one handles the mid-request
        // session-invalidation confusion of an admin dropping
        // their own row while they're logged into it. Even when
        // peers exist, an admin should delegate the purge to
        // another admin rather than run it on themselves.
        if ( targetId == arguments.purgingAdminId ) {
            throw(
                type    = "bxBlogger.UserService.CannotPurgeSelf",
                message = "Refusing to purge your own account — ask another admin to run the purge."
            );
        }
        if ( isSuperAdmin( arguments.user ) && countActiveSuperAdmins() <= 1 ) {
            throw(
                type    = "bxBlogger.UserService.CannotPurgeLastSuperAdmin",
                message = "Refusing to purge the last active super_admin."
            );
        }

        var targetEmail = arguments.user.getEmail() ?: "";

        // Snapshot the media the target user owns BEFORE we
        // reassign. The post-reassignment alternative ("everything
        // currently owned by sentinel") would mis-scope under a
        // hypothetical concurrent purge against the same sentinel.
        var targetMediaIds = [];
        for ( var m in qb.newQuery().from( "media" )
                .select( "id" )
                .where( "uploader_id", targetId )
                .get() ) targetMediaIds.append( m.id );

        // 1. Reassign posts
        qb.newQuery().from( "posts" )
            .where( "author_id", targetId )
            .update( { "author_id" : sentinelId } );

        // 2. Reassign revisions
        qb.newQuery().from( "post_revisions" )
            .where( "editor_id", targetId )
            .update( { "editor_id" : sentinelId } );

        // 3. Reassign uploader_id on all media (media FK is
        //    RESTRICT on users; can't leave rows pointing at the
        //    user we're about to drop).
        qb.newQuery().from( "media" )
            .where( "uploader_id", targetId )
            .update( { "uploader_id" : sentinelId } );

        // 4. Delete the target's formerly-owned media rows that
        //    no surviving post (or category) references. Body-
        //    inline image references in post markdown are NOT
        //    scanned — the media row stays reassigned to the
        //    sentinel, the image on disk still works for readers.
        if ( arrayLen( targetMediaIds ) ) {
            var referenced = referencedMediaIdsFor( qb );
            var deleteQ = qb.newQuery().from( "media" )
                .whereIn( "id", targetMediaIds );
            if ( arrayLen( referenced ) ) deleteQ.whereNotIn( "id", referenced );
            deleteQ.delete();
        }

        // 5. Redact IP / user-agent in the audit surfaces but
        //    keep the rows for compliance.
        variables.wirebox.getInstance( "AuditLogService" ).redactForUser( targetId );
        qb.newQuery().from( "login_audit" )
            .where( "user_id", targetId )
            .update( {
                "ip"         : "",
                "user_agent" : ""
            } );

        // 6. Drop pivots + per-user notifications. FK cascades
        //    cover both of these, but running them explicitly
        //    makes the purge observable from this method's SQL.
        qb.newQuery().from( "user_roles"    ).where( "user_id", targetId ).delete();
        qb.newQuery().from( "notifications" ).where( "user_id", targetId ).delete();

        // 7. Drop the user row.
        qb.newQuery().from( "users" ).where( "id", targetId ).delete();

        // 8. Record the purge on the acting admin. Do this AFTER
        //    the user row is gone so the audit entry can't
        //    accidentally include `user_id = purged-user-id`
        //    (the purging admin is the actor here).
        variables.wirebox.getInstance( "AuditLogService" ).record(
            action     = "user.purge",
            userId     = arguments.purgingAdminId,
            entityType = "user",
            entityId   = targetId,
            metadata   = {
                "purgedEmail" : targetEmail
            }
        );
    }

    /**
     * Return the id of the sentinel "Deleted User" account,
     * creating it on first call. The id is memoized in
     * `settings.deleted_user_id` so subsequent boots find the
     * same sentinel without a users-table scan.
     *
     * The sentinel is inactive (never logs in), has a random
     * unverified email in the bx-blogger.local TLD, and an
     * unreachable bcrypt placeholder as password_hash.
     */
    numeric function ensureSentinelUser() {
        var settings = variables.wirebox.getInstance( "SettingService" );
        var stored   = settings.get( "deleted_user_id", 0 );
        if ( val( stored ) > 0 ) {
            // Verify the row actually exists (an operator could
            // have manually nuked it; fall through to re-create).
            var found = retrieveUserById( val( stored ) );
            if ( !isNull( found ) ) return val( stored );
        }

        var qb  = variables.wirebox.getInstance( "QueryBuilder@qb" );
        var now = dateTimeFormat( now(), "yyyy-mm-dd HH:nn:ss" );
        var email = "deleted-user-" & lCase( replace( createUUID(), "-", "", "all" ) ) & "@bx-blogger.local";
        qb.newQuery().from( "users" ).insert( {
            "email"                : email,
            // 60-char bcrypt-shaped placeholder (users.password_hash
            // is VARCHAR(60) — exact length required). Same shape
            // BaseIntegrationSpec uses for its test-user factory;
            // cbauth.canLogin() short-circuits on is_active=0 so this
            // hash is never actually verified against.
            "password_hash"        : "$2a$12$R9h/cIPz0gi.URNNX3kh2OPST9.PgBkqquzi.Ss7KIUgO2t0jWMUW",
            "display_name"         : "Deleted User",
            "username"             : "deleted-" & lCase( replace( createUUID(), "-", "", "all" ) ),
            "is_active"            : 0,
            "two_factor_enabled"   : 0,
            "must_change_password" : 0,
            "created_at"           : now,
            "updated_at"           : now
        } );
        var row = qb.newQuery().from( "users" )
            .where( "email", email )
            .first();
        var sentinelId = val( row.id ?: 0 );
        settings.set(
            key         = "deleted_user_id",
            value       = sentinelId,
            type        = "int",
            description = "Sentinel user id for GDPR purges — posts / revisions / media get reassigned here so the original user row can be dropped."
        );
        return sentinelId;
    }

    /**
     * All media ids currently referenced by any post as
     * featured_media_id or og_image_id. Used by `purge` to
     * decide which of the purged user's media can be deleted
     * outright.
     */
    private array function referencedMediaIdsFor( required any qb ) {
        var ids = {};
        var rows = arguments.qb.newQuery().from( "posts" )
            .select( [ "featured_media_id", "og_image_id" ] )
            .whereNull( "deleted_at" )
            .get();
        for ( var r in rows ) {
            if ( !isNull( r.featured_media_id ) && val( r.featured_media_id ) > 0 ) ids[ r.featured_media_id ] = true;
            if ( !isNull( r.og_image_id       ) && val( r.og_image_id       ) > 0 ) ids[ r.og_image_id       ] = true;
        }
        var cats = arguments.qb.newQuery().from( "categories" )
            .select( "og_image_id" )
            .get();
        for ( var c in cats ) {
            if ( !isNull( c.og_image_id ) && val( c.og_image_id ) > 0 ) ids[ c.og_image_id ] = true;
        }
        return structKeyArray( ids );
    }

    // --------------------------------------------------------------------

    /**
     * Shared email + displayName validation used by create + update.
     * `excludeId` prevents a user from colliding with themselves on
     * their own email during an update.
     */
    private void function validateAdminAttrs( required struct attrs, required numeric excludeId ) {
        if ( structKeyExists( arguments.attrs, "email" ) ) {
            var email = trim( lCase( arguments.attrs.email ?: "" ) );
            if ( !len( email ) || !isValid( "email", email ) ) {
                throw( type = "bxBlogger.UserValidation", message = "A valid email address is required." );
            }
            var existing = variables.wirebox.getInstance( "QueryBuilder@qb" ).newQuery()
                .from( "users" )
                .where( "email", email )
                .whereNull( "deleted_at" );
            if ( arguments.excludeId > 0 ) existing.where( "id", "!=", arguments.excludeId );
            if ( existing.exists() ) {
                throw( type = "bxBlogger.UserValidation", message = "Another account is already using that email." );
            }
        }
        if ( structKeyExists( arguments.attrs, "displayName" )
             && !len( trim( arguments.attrs.displayName ?: "" ) ) ) {
            throw( type = "bxBlogger.UserValidation", message = "Display name is required." );
        }
    }

}
