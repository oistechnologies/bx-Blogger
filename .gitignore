# Internal developer notes — planning docs, research, memories, todos
# Never ships with the application.
DEV-NOTES/

# Per-developer Claude Code state — tool permissions, scratch files,
# scheduled-task locks, etc. All of `.claude/` is user-local; nothing
# in here should ever ship.
.claude/

# Per-developer IDE settings
.vscode/
.idea/

# Environment configuration — copied from .env.example; never checked in
.env
.env.local
.env.*.local

# ForgeBox-installed dependencies — restored via `box install` (mvc layout)
lib/

# ForgeBox-installed dependencies — restored via `box install` (flat layout)
modules/
coldbox/
testbox/

# BoxLang runtime state — generated at runtime, never source-controlled
runtime/classes/
runtime/global/
runtime/lib/
runtime/logs/

# ColdBox auto-generated module config stubs (some modules drop these on install).
# NOTE: `config/cbq.bx` is NOT ignored — Phase 6.A replaced the auto-generated
# stub with a hand-authored connection + worker-pool config that must ship.
app/config/modules/
config/modules/

# Node / Vite build artifacts
node_modules/
# NOTE: `package-lock.json` is intentionally NOT ignored — it's a
# source input for the Dockerfile's theme-builder stage (`npm ci`
# fails without it on a fresh CI clone).
# Built theme CSS/JS — regenerated by `docker compose run --rm node npm run build`.
themes/*/assets/

# Uploaded media files — MediaService writes here on the local disk
# provider. Dev only; prod lands in S3/MinIO via cbfs. Keep the folder
# itself (via .gitkeep) so fresh clones have a valid upload target.
includes/public/media/*
!includes/public/media/.gitkeep

# TestBox results
tests/results/

# OS
.DS_Store
Thumbs.db

# Editor swap files
*.swp
*.swo
