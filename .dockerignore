.vscode
.idea
*.swp
*.swo

# Env files — secrets must never enter the image
.env
.env.local
.env.*.local

# Ops runbooks and local notes
*.md.local
scratch

# Docker's own
.dockerignore
Dockerfile
docker-compose*.yml
