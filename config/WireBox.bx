/**
 * bx-Blogger — WireBox Configuration
 *
 * Phase 0: defaults. Manual bindings are added in their respective phases
 * (e.g., ISearchProvider binding in Phase 3, AiAssistantService in Phase 2).
 */
class extends="coldbox.system.ioc.config.Binder" {

	function configure() {
		variables.wireBox = {
			// Register a WireBox injector on the application scope
			scopeRegistration : {
				enabled : true,
				scope   : "application",
				key     : "wireBox"
			},
			customDSL      : {},
			customScopes   : {},
			scanLocations  : [],
			stopRecursions : [],
			parentInjector : "",
			listeners      : []
		};

		// --------------------------------------------------------------
		// AI provider (Chunk 2.H)
		// --------------------------------------------------------------
		// AiAssistantService depends on an `AiProvider` alias so the
		// service layer stays provider-agnostic. The binding is chosen
		// at app boot from AI_PROVIDER:
		//   "mock"         → MockAiProvider (deterministic, no network)
		//   "openrouter" / "openai" / "anthropic" / "google"
		//                  → BxAiProvider, which forwards the same
		//                    AI_PROVIDER value to bx-ai's aiChat() so
		//                    the module picks the right service class.
		// Empty / unset   → defaults to "mock" so a fresh clone boots
		// with the editor buttons working (once AI_ENABLED=true).
		var aiProviderClass = ( getSystemSetting( "AI_PROVIDER", "mock" ) == "mock" )
			? "models.ai.MockAiProvider"
			: "models.ai.BxAiProvider";
		map( "AiProvider" ).to( aiProviderClass ).asSingleton();

		// --------------------------------------------------------------
		// AI image-gen provider (Chunk 2.I)
		// --------------------------------------------------------------
		// Separate alias from AiProvider so operators can run real text
		// AI while keeping image-gen on the mock (cost control during
		// rollout) or vice-versa. Dispatch is identical to the text
		// AI path but reads AI_IMAGE_PROVIDER instead.
		var aiImageProviderClass = ( getSystemSetting( "AI_IMAGE_PROVIDER", "mock" ) == "mock" )
			? "models.ai.MockAiImageProvider"
			: "models.ai.BxAiImageProvider";
		map( "AiImageProvider" ).to( aiImageProviderClass ).asSingleton();

		// --------------------------------------------------------------
		// Error reporter (Phase 10.F / B24)
		// --------------------------------------------------------------
		// `Main.onException` asks the `ErrorReporter` alias to handle
		// every uncaught 500. The binding is env-selected so prod can
		// switch on email alerts without touching code:
		//   "noop"  → NoopErrorReporter — log-only, safe default
		//   "email" → EmailErrorReporter — queues a SendEmailJob to
		//             `settings.notifications.email_to`, rate-limited
		//             to 10 emails per exception-fingerprint per hour
		// The interface is duck-typed — both classes expose
		// `report( exception, event?, errorReference? )`. A future
		// Sentry adapter slots in the same way.
		var errorReporterClass = lCase( getSystemSetting( "ERROR_REPORTER", "noop" ) ) == "email"
			? "models.services.errors.EmailErrorReporter"
			: "models.services.errors.NoopErrorReporter";
		map( "ErrorReporter" ).to( errorReporterClass ).asSingleton();
	}

}
