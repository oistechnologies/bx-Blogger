/**
 * bx-Blogger ŌĆö ColdBox Configuration
 *
 * The filename must be `Coldbox.bx` (capital C, lowercase "oldbox") to match
 * ColdBox's convention lookup. The class-level `variables` scope IS the
 * config object ŌĆö ColdBox reads `variables.coldbox`, `variables.settings`,
 * `variables.modules`, etc. after `configure()` runs.
 *
 * This file carries PRODUCTION defaults. Override per environment via the
 * `development()`, `staging()`, and `production()` methods at the bottom.
 */
class {

	function configure() {
		/**
		 * ----------------------------------------------------------------
		 * ColdBox Directives
		 * ----------------------------------------------------------------
		 */
		variables.coldbox = {
			// Application Setup
			appName                  : getSystemSetting( "APPNAME", "bx-Blogger" ),
			eventName                : "event",
			// Reinit
			reinitPassword           : getSystemSetting( "APP_REINIT_PASSWORD", "" ),
			reinitKey                : "fwreinit",
			handlersIndexAutoReload  : true,
			// Implicit Events
			defaultEvent             : "Main.index",
			requestStartHandler      : "Main.onRequestStart",
			requestEndHandler        : "",
			applicationStartHandler  : "Main.onAppInit",
			applicationEndHandler    : "",
			sessionStartHandler      : "",
			sessionEndHandler        : "",
			missingTemplateHandler   : "",
			// Extension Points
			applicationHelper        : "includes/helpers/ApplicationHelper.bxm",
			viewsHelper              : "",
			modulesExternalLocation  : [],
			viewsExternalLocation    : "",
			layoutsExternalLocation  : "",
			handlersExternalLocation : "",
			requestContextDecorator  : "",
			controllerDecorator      : "",
			// Error/Exception Handling
			invalidHTTPMethodHandler : "",
			exceptionHandler         : "Main.onException",
			// 3.B ŌĆö a URL that resolves via conventions to a missing
			// handler (`/about` with no Handlers/About.bx) falls
			// through to `Page.show`, which reads the routed URL as
			// the page slug and surfaces a themed 404 when nothing
			// matches in `posts WHERE post_type='page'`.
			invalidEventHandler      : "Page.show",
			customErrorTemplate      : "",
			// Application Aspects
			handlerCaching           : false,
			eventCaching             : false,
			viewCaching              : false,
			autoMapModels            : true,
			jsonPayloadToRC          : true,
			// Chunk 3.A ŌĆö `/themes` is registered as the external views +
			// layouts lookup root. Every Theme.view("home") /
			// Theme.layout("Main") call returns a slug-prefixed path like
			// "bx-blogger-fallback/views/home" which ColdBox resolves to
			// `/app/themes/bx-blogger-fallback/views/home.bxm` via
			// `expandPath( externalLocation & "/" & view )`. Leading slash
			// is required ŌĆö without it ColdBox's expandPath resolves
			// relative to whatever CWD the Renderer is running under.
			viewsExternalLocation    : "/themes",
			layoutsExternalLocation  : "/themes"
		};

		/**
		 * ----------------------------------------------------------------
		 * Custom Settings (accessed via getSetting() in handlers/services)
		 * ----------------------------------------------------------------
		 */
		variables.settings = {
			// AI feature toggles ŌĆö master off until admin enables in Settings UI
			"ai.enabled"        : false,
			"ai.image.enabled"  : false,
			// Version marker for /__health and admin UI
			"app.version"       : "0.1.0",
			"app.phase"         : "0"
		};

		/**
		 * ----------------------------------------------------------------
		 * Module Loading
		 * ----------------------------------------------------------------
		 */
		variables.modules = {
			include : [],
			exclude : []
		};

		/**
		 * --------------------------------------------------------------------------
		 * Application Logging (https://logbox.ortusbooks.com)
		 * --------------------------------------------------------------------------
		 * LOG_FORMAT controls the appender shape:
		 *
		 *   text (default, dev) ŌĆö ConsoleAppender with the stock
		 *                         human-readable layout. Easy to
		 *                         skim in `docker compose logs`.
		 *
		 *   json (prod)          ŌĆö ConsoleAppender with our custom
		 *                         JsonLineLayout: one JSON object
		 *                         per line to stdout, indexable by
		 *                         journald / Loki / fluentd / ELK
		 *                         without regex-scraping free text.
		 *
		 * Both modes write to stdout only ŌĆö no file appender. A
		 * Docker container's filesystem is ephemeral; log files
		 * there die with the container. The orchestrator's log
		 * driver is the single source of truth.
		 */
		var logFormat = getSystemSetting( "LOG_FORMAT", "text" );
		var consoleAppender = logFormat == "json"
			? {
				class  : "coldbox.system.logging.appenders.ConsoleAppender",
				layout : "models.services.logging.JsonLineLayout"
			}
			: { class : "coldbox.system.logging.appenders.ConsoleAppender" };

		variables.logBox = {
			appenders : { console : consoleAppender },
			// Root Logger
			root      : { levelmax : "INFO", appenders : "*" },
			// Implicit Level Categories
			info      : [ "coldbox.system" ]
		}

		/**
		 * ----------------------------------------------------------------
		 * Layout Settings
		 * ----------------------------------------------------------------
		 */
		variables.layoutSettings = {
			defaultLayout : "Main",
			defaultView   : ""
		};

		/**
		 * ----------------------------------------------------------------
		 * Custom Interception Points (PLAN ┬¦11 ŌĆö bxBlogger.* namespace)
		 * ----------------------------------------------------------------
		 * Declared up front so modules landing at Phases 1ŌĆō11 can hook them
		 * without the config needing changes. None are fired by Phase 0
		 * code; this is scaffolding.
		 */
		variables.interceptorSettings = {
			customInterceptionPoints : [
				// Auth
				"preLogin", "postLogin",
				"loginFailed",
				"preLogout", "postLogout",
				"preRegister", "postRegister",
				"preEmailVerify", "postEmailVerify",
				"prePasswordReset", "postPasswordReset",
				"preTwoFactorChallenge", "postTwoFactorChallenge",
				"rateLimitTriggered",
				// Posts / Pages lifecycle
				"prePostSave", "postPostSave",
				"prePostPublish", "postPostPublish",
				"prePostUnpublish", "postPostUnpublish",
				"prePostDelete", "postPostDelete",
				"postPostHardDelete",
				"prePostRestore", "postPostRestore",
				"prePostRevisionCreate", "postPostRevisionCreate",
				"prePostSubmitReview", "postPostSubmitReview",
				"prePostAutosave", "postPostAutosave",
				"prePostPreviewShare", "postPostPreviewShare",
				"preReadingTimeCompute", "postReadingTimeCompute",
				"relatedPostsFor",
				// Markdown pipeline
				"preMarkdownCompile", "postMarkdownCompile",
				"preMarkdownSanitize", "postMarkdownSanitize",
				// Comments (declared; ships Phase 11)
				"preCommentSubmit", "postCommentSubmit",
				"preCommentApprove", "postCommentApprove",
				"preCommentSpam", "postCommentSpam",
				// Media
				"preMediaUpload", "postMediaUpload",
				"preMediaDelete", "postMediaDelete",
				"preThumbnailGenerate", "postThumbnailGenerate",
				"preWebpConvert", "postWebpConvert",
				"preOgImageGenerate", "postOgImageGenerate",
				"preOembedResolve", "postOembedResolve",
				// Theming
				"preThemeSwitch", "postThemeSwitch",
				"themeAssetsBuild",
				"preThemeRender", "postThemeRender",
				// Public render
				"preRenderPost", "postRenderPost",
				"preRenderPage", "postRenderPage",
				"preRenderArchive", "postRenderArchive",
				"contentShortcode",
				// Search
				"preSearch", "postSearch",
				// SEO
				"seoMetaBuild",
				"preSitemapGenerate", "postSitemapGenerate",
				"preRssGenerate", "postRssGenerate",
				// Caching
				"preCacheStore", "postCacheStore",
				"cacheInvalidate",
				// AI authoring (Phase 2)
				"preAiRequest", "postAiResponse",
				"aiBudgetExceeded",
				"preImageGenerate", "postImageGenerate",
				"imageGenerationBudgetExceeded",
				// Admin shell extensibility
				"adminMenuBuild",
				"adminDashboardWidgets",
				"adminPostEditorPanels",
				"adminEditorToolbar",
				"notificationCreated",
				"preAdminRender", "postAdminRender",
				// Privacy / GDPR
				"preUserDataExport", "postUserDataExport",
				"preUserPurge", "postUserPurge"
			]
		};

		/**
		 * ----------------------------------------------------------------
		 * Application Interceptors
		 * ----------------------------------------------------------------
		 * A6 ŌĆö RateLimitInterceptor applies per-event budgets keyed by IP
		 * or authenticated user. Budgets below are the Phase 1 seeds per
		 * PLAN ┬¦19; Phase 2+ adds autosave, search, admin-write, etc.
		 * Exceeding a budget fires `bxBlogger.rateLimitTriggered` (B7 picks
		 * it up in Phase 7) and returns HTTP 429 to the caller.
		 */
		variables.interceptors = [
			// Patches the `backups` cbfs S3 disk endpoint at
			// disk-start so Backblaze / DO Spaces / Wasabi-style
			// endpoints (which already embed the region) don't get
			// double-regioned by s3sdk's buildUrlEndpoint(). Must
			// come before any interceptor that resolves cbfs disks
			// so the fix is in place the first time anything reads
			// a backup file.
			{ class : "interceptors.CbfsEndpointRepairInterceptor" },
			// 10.A ŌĆö resolves the real client IP on `preProcess` and
			// stamps it on `prc.clientIp` for every downstream
			// consumer (RateLimit, Security audit, BrokenLinks,
			// PostViewRecorder, etc.). Runs FIRST so everything
			// reads from a single consistent source. `prc.clientProto`
			// gets the same treatment via X-Forwarded-Proto.
			// TRUSTED_PROXIES env var gates header-trust ŌĆö attacker-
			// supplied XFF on a direct connection is ignored.
			{ class : "interceptors.TrustedProxyInterceptor" },
			// 5.A ŌĆö full-page HTML cache for anonymous GETs on public
			// routes. Registered second (after TrustedProxy) so a
			// cache hit still short-circuits RateLimit /
			// ThemeResolution ŌĆö no point doing that math on a served-
			// from-cache response.
			{ class : "interceptors.PageCacheInterceptor" },
			// 7.C ŌĆö runs BEFORE rate-limit + theme resolution. A match
			// against the `redirects` table short-circuits the request
			// as a 301/302, so there's no point paying for anything
			// downstream. Sits after PageCache because a still-live
			// cached page for an unchanged URL should win (and a
			// redirect is cheap to re-check on the next miss anyway).
			{ class : "interceptors.RedirectInterceptor" },
			{
				class      : "interceptors.RateLimitInterceptor",
				properties : {
					budgets : {
						"security.doLogin"        : { limit : 5, windowSeconds :  900, keyBy : "ip" },  // 5 / 15m
						"passwordReset.doForgot"  : { limit : 5, windowSeconds : 3600, keyBy : "ip" }   // 5 / hour
					}
				}
			},
			// Chunk 3.A ŌĆö wires `themes/` as the views+layouts external
			// location at app boot and populates `prc.theme` on every
			// request so handlers/layouts can resolve theme-scoped files.
			{ class : "interceptors.ThemeResolutionInterceptor" },
			// 6.D ŌĆö subscribes to `notificationCreated` (fired by
			// NotificationService.notify) and dispatches a SendEmailJob
			// when the caller included `"email"` in `channels[]`. Reads
			// the destination from the `notifications.email_to` setting;
			// silently logs-and-returns if the setting is blank so a
			// half-configured install doesn't throw on every write.
			{ class : "interceptors.NotificationEmailChannelInterceptor" },
			// 6.F ŌĆö listens for `postThumbnailGenerate` (fired by
			// GenerateThumbnailsJob) and dispatches a WebpConvertJob
			// for the same mediaId. Keeps the resize + webp jobs
			// decoupled; admin backfill calls MediaService
			// .dispatchWebpFor(id) directly when re-running thumbs
			// would be wasteful.
			{ class : "interceptors.WebpOnThumbnailsInterceptor" },
			// 6.H ŌĆö listens for `postRenderPost` (fired by Blog.show)
			// and dispatches a RecordPostViewJob so the view INSERT
			// + view_count bump happen off the request thread. Hashes
			// IP/UA with a daily-rotating salt; skips logged-in admin
			// traffic + common crawler UAs.
			{ class : "interceptors.PostViewRecorderInterceptor" },
			// 6.H ŌĆö listens for `postPostPublish` and fires an
			// IndexNow ping via PingSearchEnginesJob. No-ops
			// cleanly when the `seo.indexnow_key` setting or
			// `APP_URL` env var is unset.
			{ class : "interceptors.SearchEnginePingInterceptor" },
			// 7.A ŌĆö on every public render, populate `prc.seoMeta`
			// with the full SEO + OG + Twitter + JSON-LD payload.
			// Themes render it via `#seoHead( prc )#` in their
			// layout `<head>`. Detects page type by inspecting
			// what the handler stashed in prc (post / category /
			// tag / author / archive / search / 404). Admin,
			// feed, sitemap, and health events are skipped.
			{ class : "interceptors.SeoMetaInterceptor" }
		];

		/**
		 * ----------------------------------------------------------------
		 * Module Settings
		 * ----------------------------------------------------------------
		 * Populated per-module in later phases.
		 */
		variables.moduleSettings = {
			"cbwire" : {
				// Pre-Phase-6 fix 3 ŌĆö CBWIRE ships with `autoInjectAssets=true`,
				// which appends its client runtime + `wire:loading` styles to
				// every response whether or not a wire rendered. Our admin
				// layout (modules_app/admin/layouts/Main.bxm) already calls
				// `#wireStyles()#` and `#wireScripts()#` explicitly per the
				// CLAUDE.md convention, so auto-inject was producing two
				// copies of the runtime. Disabling it leaves explicit
				// placement as the single source of truth and keeps public
				// pages lean (no Livewire payload until a public wire
				// actually needs it).
				"autoInjectAssets" : false,
				// CBWIRE's built-in CSRF checker has historically been
				// fragile in this stack (token mismatch after fwreinit,
				// issues with modular wire loading). Disabled globally ŌĆö
				// trade-off: every wire action is no longer CSRF-guarded,
				// so a cross-origin POST that includes the session cookie
				// could fire any wire method. Admin wires are still behind
				// cbsecurity's auth firewall, but CSRF is a separate layer
				// we're giving up. Revisit when CBWIRE's CSRF handling
				// stabilizes.
				"csrfEnabled" : false
			},
			"cbq" : {
				// Path to the connection + worker-pool config. Resolves to
				// /config/cbq.bx.
				"configPath" : "config.cbq",
				// Register workers in-process. A dedicated `worker` compose
				// service was considered during Phase 6.A and dropped as
				// unnecessary complexity at blog scale ŌĆö the app container
				// handles both HTTP and background work. The env var stays
				// as a kill-switch so specs / one-off diagnostic runs can
				// opt out (CBQ_REGISTER_WORKERS=false) without editing this
				// file.
				"registerWorkers" : getSystemSetting( "CBQ_REGISTER_WORKERS", true ),
				// 0 turns off scheduled scaling ŌĆö worker count is static
				// (quantity set in config/cbq.bx). Revisit if a job mix
				// starves the queue under load.
				"scaleInterval" : 0,
				// Failed jobs (past maxAttempts) land in `cbq_failed_jobs`
				// so ops can replay or triage them. Table + cleanup defaults
				// come from cbq's own settings struct.
				"logFailedJobs" : true
			},
			"cbauth" : {
				// Points cbauth at our UserService which implements
				// isValidCredentials / retrieveUserByUsername / retrieveUserById.
				// Short alias works because autoMapModels=true + unique class names.
				"userServiceClass" : "UserService"
			},
			"cbfs" : {
				// Named disks per PLAN ┬¦15 ŌĆö Phase 2 ships `media` (user
				// uploads), later phases add `themeAssets`, `backups`,
				// etc. Dev stays local for fast iteration; prod points
				// the same disk id at S3/MinIO via env vars so handler
				// code keeps using `cbfs:disk:media` regardless.
				//
				// NOTE on `diskUrl`: cbfs's Local provider concatenates
				// `diskUrl + path` without inserting a separator. The
				// trailing slash here is load-bearing ŌĆö without it,
				// path `uploads/foo.png` ends up rendered as
				// `/includes/public/mediauploads/foo.png` (no slash
				// between "media" and "uploads") and 404s. Provider
				// quirk, not ours to change; the slash stays.
				"disks" : {
					"media" : {
						"provider"   : "Local",
						"properties" : {
							"path"    : getSystemSetting( "CBFS_MEDIA_DISK_PATH", expandPath( "/includes/public/media" ) ),
							"diskUrl" : "/includes/public/media/"
						}
					},
					// Phase 7.D.2 ŌĆö Java2D-rendered default OG images
					// (1200x630 PNG, keyed by {postId}-{contentVersion}.png).
					// Local-only by design: files here are a deterministic
					// function of post content, not user uploads, so
					// pointing prod at S3 would just add latency to a
					// regeneration-on-miss path. Mirrors the `media` disk's
					// trailing-slash contract for diskUrl.
					"og" : {
						"provider"   : "Local",
						"properties" : {
							"path"    : getSystemSetting( "CBFS_OG_DISK_PATH", expandPath( "/includes/public/og" ) ),
							"diskUrl" : "/includes/public/og/"
						}
					}
				}
			},
			"cbmailservices" : {
				// Applied to every outbound mail. SMTP settings flow through
				// to cfmail's `server/port/username/password` attributes.
				"defaults" : {
					"from"     : getSystemSetting( "MAIL_FROM_ADDRESS", "no-reply@bx-blogger.local" ),
					"server"   : getSystemSetting( "SMTP_HOST", "mailhog" ),
					"port"     : getSystemSetting( "SMTP_PORT", "1025" ),
					"username" : getSystemSetting( "SMTP_USERNAME", "" ),
					"password" : getSystemSetting( "SMTP_PASSWORD", "" ),
					"useTLS"   : getSystemSetting( "SMTP_ENCRYPTION", "none" ) == "tls",
					"useSSL"   : getSystemSetting( "SMTP_ENCRYPTION", "none" ) == "ssl"
				},
				"mailers" : {
					"default" : { "class" : "CFMail" }
				}
			},
			"cbsecurity" : {
				// Delegate authentication state to cbauth
				"authentication" : {
					"provider" : "authenticationService@cbauth"
				},
				// Global firewall ŌĆö protects /admin/* by redirecting anonymous
				// visitors to /login?returnTo=<original>. Phase 2 layers on
				// permission checks via handler annotations (@secured).
				"firewall" : {
					"autoLoadFirewall"             : true,
					// Event invoked when a rule blocks an unauthenticated request.
					// security.login renders our login view + captures returnTo.
					"invalidAuthenticationEvent"   : "security.login",
					"defaultAuthenticationAction"  : "redirect",
					"rules" : [
						{
							// Anything under /admin requires authentication.
							// Regex matches event.getCurrentRoutedURL() which returns
							// paths without a leading slash (e.g. "admin/", "admin/users").
							"securelist" : "^admin.*",
							"match"      : "url",
							"action"     : "redirect"
						},
						// Phase UX ŌĆö removed the standalone `^account.*` rule
						// when the account page moved under /admin/account.
						// The `^admin.*` rule above covers it.
					]
				},
				// CSRF module config (Phase 2 uses for form protection; minimal now)
				"csrf" : {},
				// Disable the built-in security headers interceptor for Phase 1 ŌĆö
				// Phase 10 (B14 NGINX + CSP) owns our security header strategy.
				// Leaving enabled=false prevents it from colliding with our
				// bespoke CSP policy later.
				"securityHeaders" : {
					"enabled" : false
				}
			}
		};

		// ----------------------------------------------------------------
		// Off-host DB backups ŌĆö register a `backups` cbfs disk pointing
		// at the operator's S3-compatible bucket. Conditional on
		// BACKUP_S3_BUCKET being set so a fresh install with no S3
		// configured doesn't error at boot trying to authenticate
		// against empty credentials.
		//
		// s3sdk wants `awsDomain` as a bare hostname, not a URL ŌĆö strip
		// the scheme if the operator pasted a full endpoint URL (our
		// BACKBLAZE-B2.md runbook tells them to). ACL is forced to
		// private because nobody should ever fetch a raw DB dump by URL.
		// ----------------------------------------------------------------
		var backupBucket = getSystemSetting( "BACKUP_S3_BUCKET", "" );
		if ( len( backupBucket ) ) {
			var backupDomain = reReplaceNoCase(
				getSystemSetting( "BACKUP_S3_ENDPOINT", "" ),
				"^https?://",
				""
			);
			variables.moduleSettings.cbfs.disks.backups = {
				"provider"   : "S3",
				"properties" : {
					"accessKey"         : getSystemSetting( "BACKUP_S3_ACCESS_KEY", "" ),
					"secretKey"         : getSystemSetting( "BACKUP_S3_SECRET_KEY", "" ),
					"awsDomain"         : len( backupDomain ) ? backupDomain : "amazonaws.com",
					"awsRegion"         : getSystemSetting( "BACKUP_S3_REGION", "us-east-1" ),
					"defaultBucketName" : backupBucket,
					"defaultACL"        : "private",
					"visibility"        : "private",
					"ssl"               : true,
					// Default to path-style URLs (`<endpoint>/<bucket>/<key>`) ŌĆö
					// the only style s3sdk's URL builder supports for non-AWS
					// domains (see `buildUrlEndpoint` in s3sdk/AmazonS3.cfc:267 ŌĆö
					// its `virtual` branch only injects the bucket when the
					// awsDomain contains `amazonaws.com`, so B2 / DO Spaces /
					// MinIO get a URL with the bucket missing entirely and the
					// request silently writes to nowhere). Operators pointed
					// directly at AWS S3 can flip BACKUP_S3_URL_STYLE=virtual.
					"urlStyle"          : getSystemSetting( "BACKUP_S3_URL_STYLE", "path" ),
					// cbfs's S3 provider reads properties.path unconditionally in
					// buildPath(). Providing an empty string keeps the job in
					// control of key prefixing (via BACKUP_S3_PREFIX) while
					// preventing the "key [PATH] was not found" struct error.
					"path"              : ""
				}
			};
		}

		// ----------------------------------------------------------------
		// User-uploaded media ŌĆö swap the `media` disk over to S3 when
		// S3_BUCKET_MEDIA is configured. Falls back to the Local default
		// registered above when the env var is empty, so dev installs
		// using the repo bind-mount keep working out of the box.
		//
		// `urlStyle=path` + `publicDomain=S3_PUBLIC_URL` covers Backblaze
		// B2 (and anything behind a Cloudflare/CDN proxy fronting B2), DO
		// Spaces, Wasabi, and a self-hosted MinIO. AWS S3 operators flip
		// S3_URL_STYLE=virtual when they want the bucket-hostname URL.
		//
		// Visibility is `public` because media is served to anonymous
		// readers on public post pages; publicDomain determines what the
		// app puts in `<img src=...>`.
		// ----------------------------------------------------------------
		var mediaBucket = getSystemSetting( "S3_BUCKET_MEDIA", "" );
		if ( len( mediaBucket ) ) {
			var mediaDomain = reReplaceNoCase(
				getSystemSetting( "S3_ENDPOINT", "" ),
				"^https?://",
				""
			);
			var mediaProps = {
				"accessKey"         : getSystemSetting( "S3_ACCESS_KEY", "" ),
				"secretKey"         : getSystemSetting( "S3_SECRET_KEY", "" ),
				"awsDomain"         : len( mediaDomain ) ? mediaDomain : "amazonaws.com",
				"awsRegion"         : getSystemSetting( "S3_REGION", "us-east-1" ),
				"defaultBucketName" : mediaBucket,
				"defaultACL"        : "public-read",
				"visibility"        : "public",
				"ssl"               : getSystemSetting( "S3_FORCE_HTTPS", true ),
				"urlStyle"          : getSystemSetting( "S3_URL_STYLE", "path" ),
				// cbfs-level prefix ŌĆö every uploaded key gets prepended
				// with this + "/", so multi-tenant hosts sharing one
				// bucket don't collide. Empty = bucket root (single-tenant).
				"path"              : trim( getSystemSetting( "S3_MEDIA_PREFIX", "" ) )
			};
			// publicDomain backs cbfs's `disk.url( path )` ŌĆö swaps the API
			// endpoint for the public-facing hostname so urlFor( media )
			// resolves to the CDN / B2-public URL instead of the signed
			// API endpoint. cbfs doesn't inject the bucket into path-
			// style public URLs on its own (its built-in default is
			// virtual-style `<bucket>.<endpoint>`), so for path-style
			// providers we append `/<bucket>` to the operator's base
			// URL when they haven't already embedded it (e.g. B2's
			// `/file/<bucket>` shape ŌĆö operators setting the full path
			// get left alone).
			var mediaPublic = reReplaceNoCase(
				getSystemSetting( "S3_PUBLIC_URL", "" ),
				"^https?://",
				""
			);
			if ( len( mediaPublic ) ) {
				if ( mediaProps.urlStyle == "path" && !( mediaPublic contains "/" ) ) {
					mediaPublic &= "/" & mediaBucket;
				}
				mediaProps.publicDomain = mediaPublic;
			}

			variables.moduleSettings.cbfs.disks.media = {
				"provider"   : "S3",
				"properties" : mediaProps
			};
		}

		/**
		 * ----------------------------------------------------------------
		 * Flash Scope Settings
		 * ----------------------------------------------------------------
		 */
		variables.flash = {
			scope        : "session",
			properties   : {},
			inflateToRC  : true,
			inflateToPRC : false,
			autoPurge    : true,
			autoSave     : true
		};

		/**
		 * ----------------------------------------------------------------
		 * Conventions
		 * ----------------------------------------------------------------
		 */
		variables.conventions = {
			handlersLocation : "handlers",
			viewsLocation    : "views",
			layoutsLocation  : "layouts",
			modelsLocation   : "models",
			eventAction      : "index"
		};
	}

	/**
	 * Development environment overrides (matched via ENVIRONMENT=development)
	 */
	function development() {
		variables.coldbox.customErrorTemplate   = "/coldbox/system/exceptions/Whoops.cfm";
		variables.coldbox.handlersIndexAutoReload = true;
		variables.coldbox.handlerCaching        = false;
		variables.coldbox.eventCaching          = false;
		variables.coldbox.viewCaching           = false;
	}

	/**
	 * Production environment overrides (matched via ENVIRONMENT=production)
	 */
	function production() {
		variables.coldbox.handlersIndexAutoReload = false;
		variables.coldbox.handlerCaching        = true;
		variables.coldbox.eventCaching          = true;
		// viewCaching still off by default; enabled per-view via setView( cache=true )
	}

}
