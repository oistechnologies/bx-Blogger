{
    "name":"bx-blogger",
    "app":{
        "cfengine":"boxlang@1",
        "engineConfigFile":"./runtime/boxlang.json"
    },
    "jvm":{
        "heapSize":"1024",
        "javaVersion":"openjdk21",
        "args":"-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=8888"
    },
    "web":{
        "host":"127.0.0.1",
        "webroot":"public",
        "http":{
            "port":8080
        },
        "rewrites":{
            "enable":true
        },
        "aliases":{
            "/coldbox/system/exceptions":"./lib/coldbox/system/exceptions/",
            "/tests":"./tests/"
        }
    },
    "scripts":{
        "onServerInitialInstall":"install bx-compat-cfml,bx-esapi"
    },
    "rc":true
}
