# EditorConfig helps maintain consistent coding styles across editors and IDEs.
# https://editorconfig.org

root = true

[*]
indent_style = tab
indent_size = 4
tab_width = 4
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,yml,yaml,md}]
indent_style = space
indent_size = 2

[*.{js,mjs,cjs,ts,jsx,tsx,scss,css}]
indent_style = space
indent_size = 2

[{Dockerfile,*.dockerfile,docker-compose*.yml}]
indent_style = space
indent_size = 2

[*.{bx,bxm,bxs,cfc,cfm,cfml}]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab
