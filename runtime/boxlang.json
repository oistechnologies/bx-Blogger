/**
 * BoxLang Runtime Configuration — bx-Blogger
 *
 * Based on the cbtemplate-boxlang default; customized for our env-var naming
 * (DB_USERNAME vs template's DB_USER) and docker-compose service hostnames.
 *
 * Substitution:
 *   ${env.VAR:default} — reads env var VAR, falls back to default
 *   ${boxlang-home}   — BoxLang home directory
 *   ${user-dir}       — process working directory (= /app in container)
 */
{
    "validTemplateExtensions": [],
    "classGenerationDirectory": "${boxlang-home}/classes",
    "debugMode": "${BOXLANG_DEBUG:false}",
    "clearClassFilesOnStartup": true,
    "classResolverCache": true,
    "trustedCache": false,
    "timezone": "",
    "locale": "",
    "whitespaceCompressionEnabled": true,
    "useHighPrecisionMath": true,
    "applicationTimeout": "0,0,0,0",
    "requestTimeout": "0,0,0,0",
    "sessionTimeout": "0,0,30,0",
    "sessionStorage": "memory",
    "maxTrackedCompletedThreads": 1000,
    "mappings": {
        "/app"                      : { "path": "${user-dir}/app",                       "external": false },
        "/public"                   : "${user-dir}/public",
        "/coldbox"                  : { "path": "${user-dir}/lib/coldbox",               "external": false },
        "/coldbox/system/exceptions": { "path": "${user-dir}/lib/coldbox/system/exceptions", "external": true },
        "/modules"                  : { "path": "${user-dir}/lib/modules",               "external": true },
        "/testbox"                  : "${user-dir}/lib/testbox",
        "/tests"                    : "${user-dir}/tests"
    },
    "modulesDirectory": [
        "${user-dir}/boxlang_modules",
        "${boxlang-home}/modules",
        "${user-dir}/runtime/modules"
    ],
    "customComponentsDirectory": [
        "${boxlang-home}/global/components",
        "${user-dir}/runtime/global/components"
    ],
    "classPaths": [
        "${boxlang-home}/global/classes",
        "${user-dir}/runtime/global/classes"
    ],
    "javaLibraryPaths": [
        "${boxlang-home}/lib",
        "${user-dir}/lib/java"
    ],
    "logging": {
        "logsDirectory": "${user-dir}/runtime/logs",
        "maxLogDays": 90,
        "maxFileSize": "100MB",
        "totalCapSize": "5GB",
        "rootLevel": "WARN",
        "defaultEncoder": "text",
        "statusPrinterOnLoad": false,
        "loggers": {
            "runtime":     { "level": "INFO", "appender": "file", "encoder": "text", "additive": false },
            "async":       { "level": "INFO", "appender": "file", "encoder": "text", "additive": false },
            "cache":       { "level": "WARN", "appender": "file", "encoder": "text", "additive": false },
            "datasource":  { "level": "WARN", "appender": "file", "encoder": "text", "additive": false },
            "modules":     { "level": "INFO", "appender": "file", "encoder": "text", "additive": false },
            "application": { "level": "WARN", "appender": "file", "encoder": "text", "additive": false },
            "scheduler":   { "level": "INFO", "appender": "file", "encoder": "text", "additive": false }
        }
    },
    "experimental": {
        "compiler": "asm",
        "ASTCapture": false
    },
    "executors": {
        "io-tasks":        { "type": "virtual",   "description": "Unlimited IO bound tasks using Java Virtual Threads" },
        "cpu-tasks":       { "type": "scheduled", "threads": 20, "description": "CPU bound tasks using a fixed thread pool" },
        "scheduled-tasks": { "type": "scheduled", "threads": 20, "description": "Scheduled tasks using a fixed thread pool" }
    },
    "scheduler": {
        "executor": "scheduled-tasks",
        "cacheName": "default",
        "schedulers": [],
        "tasks": {}
    },
    "defaultDatasource": "",
    "datasources": {
        "coldbox": {
            "connectionLimit"  : "100",
            "connectionTimeout": "1",
            "custom"           : "useUnicode=true&characterEncoding=UTF8&serverTimezone=UTC&useLegacyDatetimeCode=true&autoReconnect=true&useSSL=false&allowPublicKeyRetrieval=true",
            "database"         : "${DB_DATABASE}",
            "dbdriver"         : "${DB_DRIVER:MySQL}",
            "dsn"              : "jdbc:mysql://{host}:{port}/{database}",
            "host"             : "${DB_HOST:mysql}",
            "password"         : "${DB_PASSWORD}",
            "port"             : "${DB_PORT:3306}",
            "username"         : "${DB_USERNAME:bx_blogger}"
        }
    },
    "defaultRemoteMethodReturnFormat": "json",
    "caches": {
        "default": {
            "provider": "BoxCacheProvider",
            "properties": {
                "evictCount"                    : 1,
                "evictionPolicy"                : "LRU",
                "freeMemoryPercentageThreshold" : 0,
                "maxObjects"                    : 1000,
                "defaultLastAccessTimeout"      : 1800,
                "defaultTimeout"                : 3600,
                "objectStore"                   : "ConcurrentStore",
                "reapFrequency"                 : 120,
                "resetTimeoutOnAccess"          : false,
                "useLastAccessTimeouts"         : true
            }
        },
        "bxSessions": {
            "provider": "BoxCacheProvider",
            "properties": {
                "evictCount"                    : 1,
                "evictionPolicy"                : "LRU",
                "maxObjects"                    : 100000,
                "defaultTimeout"                : 3600,
                "objectStore"                   : "ConcurrentStore",
                "freeMemoryPercentageThreshold" : 0,
                "reapFrequency"                 : 120,
                "resetTimeoutOnAccess"          : true,
                "useLastAccessTimeouts"         : false
            }
        },
        "bxRegex": {
            "provider": "BoxCacheProvider",
            "properties": {
                "evictCount"                    : 1,
                "evictionPolicy"                : "LRU",
                "freeMemoryPercentageThreshold" : 0,
                "maxObjects"                    : 500,
                "defaultLastAccessTimeout"      : 1800,
                "defaultTimeout"                : 3600,
                "objectStore"                   : "ConcurrentSoftReferenceStore",
                "reapFrequency"                 : 120,
                "resetTimeoutOnAccess"          : false,
                "useLastAccessTimeouts"         : true
            }
        }
    },
    "security": {
        "disallowedImports": [],
        "disallowedBifs": [],
        "disallowedComponents": [],
        "populateServerSystemScope": true,
        "allowedFileOperationExtensions": [],
        "disallowedFileOperationExtensions": []
    },
    "modules": {}
}
