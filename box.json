{
    "name":"bx-Blogger",
    "version":"0.1.0",
    "slug":"bx-blogger",
    "author":"Michael Rigsby",
    "location":"",
    "type":"mvc",
    "language":"boxlang",
    "private":true,
    "shortDescription":"BoxLang + ColdBox 8 CMS with swappable themes, markdown authoring, and AI authoring assistance.",
    "ignore":[
        ".github/ISSUE_TEMPLATE",
        ".github/CONTRIBUTING.md",
        ".github/FUNDING.YML",
        ".github/PULL_REQUEST_TEMPLATE.md",
        "DEV-NOTES/",
        "tests/results/",
        "node_modules/"
    ],
    "dependencies":{
        "coldbox":"^8.0.0",
        "cbauth":"^7.0.0",
        "cbsecurity":"^3.7.0",
        "cbmailservices":"^2.9.0+3",
        "cbvalidation":"^4.8.0+30",
        "qb":"^13.1.0",
        "quick":"^12.0.12",
        "cfmigrations":"^5.1.1",
        "cbfs":"^1.1.4+4",
        "cbwire":"^5.0.3",
        "cbcsrf":"^3.2.0+1",
        "cbantisamy":"^2.2.0+2",
        "cbpaginator":"^2.8.3",
        "cbi18n":"^3.5.0+3",
        "cbfeeds":"^2.0.0+2",
        "cbmessagebox":"^4.1.0+1",
        "mementifier":"^3.7.0+7",
        "cbjavaloader":"^2.5.0+4",
        "hyper":"^8.2.0",
        "cbstorages":"^3.5.0+5",
        "BCrypt":"^3.2.0+1",
        "cbq":"^5.0.7"
    },
    "devDependencies":{
        "testbox":"*",
        "route-visualizer":"*",
        "commandbox-boxlang":"*",
        "commandbox-cfformat":"*",
        "cbdebugger":"^4.4.0+6"
    },
    "installPaths":{
        "coldbox":"coldbox/",
        "testbox":"testbox/",
        "cbsecurity":"modules/cbsecurity/",
        "cbq":"modules/cbq/"
    },
    "scripts":{
        "format":"cfformat run config/,handlers/,interceptors/,models/,modules_app/,tests/specs/,*.bx ./.cfformat.json --overwrite",
        "format:check":"cfformat check config/,handlers/,interceptors/,models/,modules_app/,tests/specs/,*.bx ./.cfformat.json",
        "format:watch":"cfformat watch path='config/,handlers/,interceptors/,models/,modules_app/,tests/specs/,*.bx' settingsPath='.cfformat.json'",
        "docker:build":"!docker compose build",
        "docker:up":"!docker compose up -d",
        "docker:down":"!docker compose down",
        "docker:logs":"!docker compose logs -f app",
        "docker:bash":"!docker compose exec app bash"
    },
    "testbox":{
        "runner":"/tests/runner.bxm"
    },
    "cfmigrations":{
        "defaultGrammar":"MySQLGrammar@qb",
        "migrationsDirectory":"resources/database/migrations",
        "connectionInfo":{
            "class":"com.mysql.cj.jdbc.Driver",
            "connectionString":"jdbc:mysql://mysql:3306/bx_blogger?useUnicode=true&characterEncoding=UTF-8&serverTimezone=UTC&useLegacyDatetimeCode=true&allowPublicKeyRetrieval=true&useSSL=false",
            "username":"${DB_USERNAME}",
            "password":"${DB_PASSWORD}"
        }
    }
}
