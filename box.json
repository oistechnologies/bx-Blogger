{
    "name":"bx-Blogger",
    "version":"0.1.0",
    "slug":"bx-blogger",
    "author":"Michael Rigsby",
    "location":"",
    "type":"mvc",
    "language":"boxlang",
    "private":true,
    "shortDescription":"BoxLang + ColdBox 8 CMS with swappable themes, markdown authoring, and AI authoring assistance.",
    "ignore":[
        ".github/ISSUE_TEMPLATE",
        ".github/CONTRIBUTING.md",
        ".github/FUNDING.YML",
        ".github/PULL_REQUEST_TEMPLATE.md",
        "DEV-NOTES/",
        "tests/results/",
        "node_modules/"
    ],
    "dependencies":{
        "coldbox":"^8.0.0",
        "cbauth":"^7.0.0",
        "cbvalidation":"^4.8.0+30",
        "qb":"^13.1.0",
        "quick":"^12.0.12",
        "cfmigrations":"^5.1.1",
        "cbfs":"^1.1.4+4",
        "cbwire":"^5.0.3",
        "cbcsrf":"^3.2.0+1",
        "cbantisamy":"^2.2.0+2",
        "cbpaginator":"^2.8.3",
        "cbi18n":"^3.5.0+3",
        "cbfeeds":"^2.0.0+2",
        "cbmessagebox":"^4.1.0+1",
        "mementifier":"^3.7.0+7",
        "cbjavaloader":"^2.5.0+4",
        "hyper":"^8.2.0",
        "cbstorages":"^3.5.0+5",
        "BCrypt":"^3.2.0+1"
    },
    "devDependencies":{
        "testbox":"*",
        "route-visualizer":"*",
        "commandbox-boxlang":"*",
        "commandbox-cfformat":"*",
        "cbdebugger":"^4.4.0+6"
    },
    "installPathConventions":{
        "modules":"lib/modules"
    },
    "installPaths":{
        "coldbox":"lib/coldbox/",
        "testbox":"lib/testbox/",
        "route-visualizer":"lib/modules/route-visualizer/",
        "cbauth":"lib/modules/cbauth/",
        "cbvalidation":"lib/modules/cbvalidation/",
        "qb":"lib/modules/qb/",
        "quick":"lib/modules/quick/",
        "cfmigrations":"lib/modules/cfmigrations/",
        "cbfs":"lib/modules/cbfs/",
        "cbwire":"lib/modules/cbwire/",
        "cbdebugger":"lib/modules/cbdebugger/",
        "cbcsrf":"lib/modules/cbcsrf/",
        "cbantisamy":"lib/modules/cbantisamy/",
        "cbpaginator":"lib/modules/cbpaginator/",
        "cbi18n":"lib/modules/cbi18n/",
        "cbfeeds":"lib/modules/cbfeeds/",
        "cbmessagebox":"lib/modules/cbmessagebox/",
        "mementifier":"lib/modules/mementifier/",
        "cbjavaloader":"lib/modules/cbjavaloader/",
        "hyper":"lib/modules/hyper/",
        "cbstorages":"lib/modules/cbstorages/",
        "BCrypt":"lib/modules/BCrypt/"
    },
    "scripts":{
        "format":"cfformat run app/,tests/specs/,*.bx --overwrite --verbose",
        "format:check":"cfformat check app/,tests/specs/,*.bx ./.cfformat.json --verbose",
        "format:watch":"cfformat watch path='app/,tests/specs/,*.bx' settingsPath='.cfformat.json'",
        "docker:build":"!docker build --no-cache -t my-coldbox-app -f ./docker/Dockerfile ./",
        "docker:run":"!docker run -it -p 8080:8080 my-coldbox-app",
        "docker:bash":"!docker run -it my-coldbox-app /bin/bash",
        "docker:stack":"!docker compose -f docker/docker-compose.yaml ${1}"
    },
    "testbox":{
        "runner":"/tests/runner.bxm"
    }
}
