<bx:output>
<header class="mb-4 pb-3 border-bottom">
    <p class="text-secondary mb-1 text-uppercase small">Author</p>
    <h1 class="h3 mb-1">#encodeForHTML( prc.author.getDisplayName() ?: "Author" )#</h1>
    <bx:if len( prc.author.getBio() ?: "" )>
        <p class="text-secondary mb-0">#encodeForHTML( prc.author.getBio() )#</p>
    </bx:if>
</header>

<bx:if ( prc.posts ?: [] ).len()>
    <section class="row g-4 mb-4">
        <bx:loop array="#prc.posts#" item="post">
            <div class="col-md-6 col-lg-4">
                #view( view = "bx-blogger-default/partials/post-card", args = { "post" : post } )#
            </div>
        </bx:loop>
    </section>
    <bx:if structKeyExists( prc, "pagination" )>
        #view( view = "bx-blogger-default/partials/pagination" )#
    </bx:if>
<bx:else>
    <p class="text-secondary">No posts by this author yet.</p>
</bx:if>
</bx:output>
