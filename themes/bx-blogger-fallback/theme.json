{
    "$schema": "/schemas/theme.schema.json",
    "name": "bx-Blogger Fallback",
    "slug": "bx-blogger-fallback",
    "version": "1.0.0",
    "author": "bx-Blogger Team",
    "description": "Vanilla Bootstrap 5 fallback theme. Always installed; cannot be uninstalled. Activated automatically when the configured active theme can't be resolved. Uses Bootstrap 5 from CDN — no build step, no asset folder.",
    "minBxblogerVersion": "0.1.0",
    "bootstrap": "5.3",
    "supports": [ "dark-mode" ],
    "syntaxHighlighting": true,
    "menus": {
        "header": "Header Navigation",
        "footer": "Footer Navigation"
    },
    "templates": {
        "post": [ "default" ],
        "page": [ "default" ]
    },
    "thumbnails": [
        { "name": "thumb",  "width": 150,  "height": 150, "crop": true  },
        { "name": "medium", "width": 1024, "crop": false }
    ],
    "options": [
        { "key": "logo_image",                  "type": "image",    "default": 0,         "label": "Top-bar Logo (rendered to the left of the site title; leave unset for no logo)" },
        { "key": "site_title",                  "type": "text",     "default": "",        "label": "Site Title (top bar — leave blank to use the site-wide name from System Settings)" },
        { "key": "title_color_light",           "type": "color",    "default": "#212529", "label": "Top-bar Title Color (Light Mode)" },
        { "key": "title_color_dark",            "type": "color",    "default": "#f8f9fa", "label": "Top-bar Title Color (Dark Mode)" },
        { "key": "show_blog_categories_in_menu", "type": "bool",    "default": true,      "label": "Show Categories link in main menu (under Blog)" },
        { "key": "show_blog_tags_in_menu",      "type": "bool",     "default": true,      "label": "Show Tags link in main menu (under Blog)" },
        { "key": "show_default_footer_brand",   "type": "bool",     "default": true,      "label": "Show bx-Blogger logo + copyright in footer (left side)" },
        { "key": "custom_footer_text",          "type": "textarea", "default": "",        "label": "Custom Footer Text (shown in place of the bx-Blogger logo + copyright when the option above is OFF)" },
        { "key": "show_authors_in_footer",      "type": "bool",     "default": true,      "label": "Show Authors link in footer (before the RSS link)" },
        { "key": "show_footer_rss",             "type": "bool",     "default": true,      "label": "Show RSS link in footer" }
    ]
}
