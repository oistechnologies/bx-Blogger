<bx:output>
<bx:if structKeyExists( prc, "page" ) && !isNull( prc.page )>
    <article class="mx-auto page-article" style="max-width: 46rem;">
        <header class="mb-4 text-center">
            <h1 class="display-5 mb-0 fw-semibold">#encodeForHTML( prc.page.getTitle() )#</h1>
        </header>
        <div class="page-body">
            #( prc.page.getBodyHtml() ?: "" )#
        </div>
    </article>
<bx:else>
    <p class="text-secondary">Page unavailable.</p>
</bx:if>
</bx:output>
